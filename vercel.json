{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/book",
      "destination": "https://calendly.com/legacy-financial/consultation",
      "statusCode": 302
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/vercel/flags",
      "destination": "/api/vercel-flags"
    }
  ]
}
