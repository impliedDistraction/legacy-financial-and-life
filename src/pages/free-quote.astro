---
import Base from '../layouts/Base.astro';
import { site } from '../content/site';
import '../styles/tailwind.css';

const licensedStates = 'Ohio, Georgia, Oklahoma, South Carolina, Mississippi, Michigan, Texas, Utah, Alabama, and Louisiana';
---

<Base
  title="Free Life Insurance Quote — Legacy Financial & Life"
  description="Get a free, no-obligation life insurance quote. Coverage for ages 0–85, no medical exams in most cases. Whole life, IUL, and final expense options."
>
  <!-- Minimal header — no nav links to keep conversion focus -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-200">
    <div class="mx-auto max-w-6xl flex items-center justify-between gap-4 px-4 py-3">
      <div class="flex min-w-0 items-center gap-3">
        <a href="/" class="flex h-10 w-10 flex-shrink-0 items-center justify-center" aria-label="Legacy Financial & Life home">
          <img src={site.branding.logo} alt={site.branding.logoAlt} class="h-10 w-10 object-contain" width="40" height="40" />
        </a>
        <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center overflow-hidden rounded-sm">
          <img src="/images/fb-crest-logo.jpeg" alt="Lifetime Safeguard logo" class="h-10 w-10 object-contain scale-[1.28] -translate-y-0.5" width="40" height="40" />
        </div>
      </div>
      <span class="text-sm font-medium text-brand-600">Free Quote — No Obligation</span>
    </div>
  </header>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-brand-900 text-white py-20 sm:py-28">
    <div class="absolute inset-0 opacity-40" aria-hidden="true">
      <div class="absolute left-[-6rem] top-[-4rem] h-56 w-56 rounded-full bg-brand-500/20 blur-3xl"></div>
      <div class="absolute bottom-[-5rem] right-[-3rem] h-64 w-64 rounded-full bg-cyan-400/10 blur-3xl"></div>
      <div class="absolute inset-x-0 top-0 h-px bg-white/10"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4">
      <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.15fr)_22rem] lg:gap-14">
        <div class="max-w-3xl">
          <p class="inline-flex items-center rounded-full border border-white/15 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-200">
            Straightforward coverage guidance
          </p>

          <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
            Life Insurance That Fits Your Family, Budget, and Timeline
          </h1>

          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl">
            Request a quote, see what your options look like, and decide from a place of clarity instead of pressure. We keep the process simple and explain what matters.
          </p>

          <div class="mt-9 flex flex-col gap-4 sm:flex-row sm:items-center">
            <a
              href="#quote-form"
              data-quote-cta="hero-primary"
              class="inline-flex items-center justify-center rounded-lg bg-brand-600 px-8 py-4 text-lg font-semibold text-white shadow-lg shadow-brand-700/30 transition-colors hover:bg-brand-500"
            >
              Get Your Free Quote
            </a>
            <p class="text-sm text-slate-300">No obligation. No pushy follow-up. Just clear options.</p>
          </div>

          <div class="mt-10 grid gap-3 text-sm sm:grid-cols-3">
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 backdrop-blur-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Experience</p>
              <p class="mt-2 text-base font-semibold text-white">20+ years of combined experience</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 backdrop-blur-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Track Record</p>
              <p class="mt-2 text-base font-semibold text-white">1,000+ policies managed</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 backdrop-blur-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Focus</p>
              <p class="mt-2 text-base font-semibold text-white">Licensed in 10 states</p>
            </div>
          </div>
        </div>

        <aside class="rounded-3xl border border-white/10 bg-white/[0.08] p-6 shadow-2xl shadow-slate-950/30 backdrop-blur-sm">
          <div class="flex items-center gap-3">
            <img src="/images/quote-icons/shield-check.svg" alt="" class="h-12 w-12" width="48" height="48" />
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-300">What to Expect</p>
              <p class="mt-1 text-lg font-semibold text-white">A short, clear next step</p>
            </div>
          </div>

          <ol class="mt-6 space-y-4 text-sm text-slate-300">
            <li class="flex gap-3">
              <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-white/10 font-semibold text-white">1</span>
              <div>
                <p class="font-semibold text-white">Fill out one short form</p>
                <p class="mt-1 leading-relaxed text-slate-400">Basic details help narrow the coverage that actually fits.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-white/10 font-semibold text-white">2</span>
              <div>
                <p class="font-semibold text-white">Review your options</p>
                <p class="mt-1 leading-relaxed text-slate-400">Whole life, IUL, and final expense are compared in plain language.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-white/10 font-semibold text-white">3</span>
              <div>
                <p class="font-semibold text-white">Move forward only if it makes sense</p>
                <p class="mt-1 leading-relaxed text-slate-400">You decide on timing after you understand the tradeoffs.</p>
              </div>
            </li>
          </ol>

          <div class="mt-6 rounded-2xl border border-brand-400/20 bg-brand-400/10 px-4 py-4 text-sm text-slate-200">
            Most people can get started without a medical exam, and the form typically takes about two minutes.
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Coverage Made Simple -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <div class="flex items-center gap-3 mb-6">
            <img src="/images/quote-icons/shield-check.svg" alt="" class="h-12 w-12" width="48" height="48" />
            <h2 class="text-3xl font-bold text-slate-900">Here's What We Offer</h2>
          </div>
          <ul class="space-y-4 text-slate-700 text-lg">
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-6 h-6 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </span>
              Ages 0–85 eligible
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-6 h-6 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </span>
              No medical exams in most cases
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-6 h-6 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </span>
              Simple application — most people finish in minutes
            </li>
          </ul>

          <h3 class="mt-8 font-semibold text-slate-900 text-lg">Options include:</h3>
          <div class="mt-4 grid sm:grid-cols-3 gap-4">
            <div class="rounded-xl border border-slate-200 p-4 text-center hover:border-brand-300 hover-lift transition-colors">
              <img src="/images/quote-icons/whole-life.svg" alt="" class="mx-auto h-14 w-14" width="56" height="56" />
              <p class="mt-2 font-medium text-slate-900">Whole Life Insurance</p>
            </div>
            <div class="rounded-xl border border-slate-200 p-4 text-center hover:border-brand-300 hover-lift transition-colors">
              <img src="/images/quote-icons/indexed-life.svg" alt="" class="mx-auto h-14 w-14" width="56" height="56" />
              <p class="mt-2 font-medium text-slate-900">Indexed Universal Life</p>
            </div>
            <div class="rounded-xl border border-slate-200 p-4 text-center hover:border-brand-300 hover-lift transition-colors">
              <img src="/images/quote-icons/final-expense.svg" alt="" class="mx-auto h-14 w-14" width="56" height="56" />
              <p class="mt-2 font-medium text-slate-900">Final Expense &amp; Burial</p>
            </div>
          </div>
        </div>

        <!-- Build More Than Protection -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <img src="/images/quote-icons/strategy.svg" alt="" class="h-12 w-12" width="48" height="48" />
            <h2 class="text-3xl font-bold text-slate-900">It's Not Just a Policy</h2>
          </div>
          <p class="text-slate-600 mb-6 text-lg">The right coverage can do more than you think:</p>
          <ul class="space-y-4">
            <li class="flex items-start gap-4 bg-brand-50 rounded-lg p-4">
              <img src="/images/quote-icons/legacy-building.svg" alt="" class="h-12 w-12 flex-shrink-0" width="48" height="48" />
              <div>
                <p class="font-semibold text-slate-900">Leave Something Behind</p>
                <p class="text-sm text-slate-600">Build wealth your kids and grandkids actually benefit from</p>
              </div>
            </li>
            <li class="flex items-start gap-4 bg-brand-50 rounded-lg p-4">
              <img src="/images/quote-icons/safe-growth.svg" alt="" class="h-12 w-12 flex-shrink-0" width="48" height="48" />
              <div>
                <p class="font-semibold text-slate-900">Steady Growth You Can Count On</p>
                <p class="text-sm text-slate-600">Safe money strategies that don't keep you up at night</p>
              </div>
            </li>
            <li class="flex items-start gap-4 bg-brand-50 rounded-lg p-4">
              <img src="/images/quote-icons/retirement.svg" alt="" class="h-12 w-12 flex-shrink-0" width="48" height="48" />
              <div>
                <p class="font-semibold text-slate-900">Retire on Your Terms</p>
                <p class="text-sm text-slate-600">Tax-smart strategies so you actually enjoy the years you've earned</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Carriers / Trust Banner -->
  <section class="bg-slate-50 py-12 border-y border-slate-200">
    <div class="mx-auto max-w-5xl px-4 text-center">
      <p class="text-sm font-medium text-slate-500 uppercase tracking-wider mb-6">
        We work with America's top-rated carriers
      </p>
      <img
        src="/images/fb-carriers.jpg"
        alt="Insurance carrier partners including Mutual of Omaha, Foresters Financial, CVS Health, Americo, Transamerica, Aflac, and many more"
        class="mx-auto max-w-full rounded-lg"
        width="900"
        height="500"
        loading="lazy"
      />
    </div>
  </section>

  <!-- Quote Form -->
  <section id="quote-form" class="bg-white py-16 sm:py-20 scroll-mt-20">
    <div class="mx-auto max-w-2xl px-4">
      <div class="text-center mb-10">
        <img src="/images/quote-icons/contact.svg" alt="" class="mx-auto h-16 w-16" width="64" height="64" />
        <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-slate-900">
          Let's Find the Right Fit
        </h2>
        <p class="mt-3 text-lg text-slate-600">
          Fill this out and we'll get back to you with a free, no-obligation quote — usually the same day.
        </p>
        <div class="mt-4 flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-sm text-slate-500">
          <span class="flex items-center gap-1"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Takes 2 minutes</span>
          <span class="flex items-center gap-1"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>No obligation</span>
          <span class="flex items-center gap-1"><svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>Same-day response</span>
        </div>
        <p class="mt-4 text-sm text-slate-500">
          Licensed in {licensedStates}.
        </p>
      </div>

      <form
        method="POST"
        action="/api/fb-lead"
        class="grid gap-5 rounded-2xl border border-slate-200 p-6 sm:p-8 shadow-lg"
      >
        <!-- About you -->
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">About You</p>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Full Name <span class="text-red-500">*</span></span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            placeholder="Your full name"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Email Address <span class="text-red-500">*</span></span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Phone Number <span class="text-red-500">*</span></span>
          <input
            type="tel"
            name="phone"
            required
            autocomplete="tel"
            placeholder="(555) 123-4567"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Date of Birth <span class="text-red-500">*</span></span>
          <div class="grid grid-cols-3 gap-3">
            <label class="grid gap-1">
              <span class="sr-only">Birth month</span>
              <select
                name="dobMonth"
                required
                autocomplete="bday-month"
                aria-label="Birth month"
                class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
              >
                <option value="">Month</option>
                <option value="01">Jan</option>
                <option value="02">Feb</option>
                <option value="03">Mar</option>
                <option value="04">Apr</option>
                <option value="05">May</option>
                <option value="06">Jun</option>
                <option value="07">Jul</option>
                <option value="08">Aug</option>
                <option value="09">Sep</option>
                <option value="10">Oct</option>
                <option value="11">Nov</option>
                <option value="12">Dec</option>
              </select>
            </label>
            <label class="grid gap-1">
              <span class="sr-only">Birth day</span>
              <input
                type="text"
                name="dobDay"
                required
                autocomplete="bday-day"
                inputmode="numeric"
                maxlength="2"
                pattern="[0-9]{1,2}"
                aria-label="Birth day"
                placeholder="Day"
                class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
              />
            </label>
            <label class="grid gap-1">
              <span class="sr-only">Birth year</span>
              <input
                type="text"
                name="dobYear"
                required
                autocomplete="bday-year"
                inputmode="numeric"
                maxlength="4"
                pattern="[0-9]{4}"
                aria-label="Birth year"
                placeholder="Year"
                class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
              />
            </label>
          </div>
          <p class="text-sm text-slate-500">Enter month, day, and 4-digit birth year.</p>
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Height <span class="text-red-500">*</span></span>
          <div class="grid grid-cols-2 gap-3 sm:max-w-sm">
            <label class="grid gap-1">
              <span class="sr-only">Height in feet</span>
              <select
                name="heightFeet"
                required
                aria-label="Height in feet"
                class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
              >
                <option value="">Feet</option>
                <option value="4">4 ft</option>
                <option value="5">5 ft</option>
                <option value="6">6 ft</option>
                <option value="7">7 ft</option>
              </select>
            </label>
            <label class="grid gap-1">
              <span class="sr-only">Height in inches</span>
              <select
                name="heightInches"
                required
                aria-label="Height in inches"
                class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
              >
                <option value="">Inches</option>
                <option value="0">0 in</option>
                <option value="1">1 in</option>
                <option value="2">2 in</option>
                <option value="3">3 in</option>
                <option value="4">4 in</option>
                <option value="5">5 in</option>
                <option value="6">6 in</option>
                <option value="7">7 in</option>
                <option value="8">8 in</option>
                <option value="9">9 in</option>
                <option value="10">10 in</option>
                <option value="11">11 in</option>
              </select>
            </label>
          </div>
          <p class="text-sm text-slate-500">Select your height in feet and inches.</p>
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Weight (lbs) <span class="text-red-500">*</span></span>
          <input
            type="text"
            name="weight"
            required
            inputmode="numeric"
            maxlength="3"
            pattern="[0-9]{2,3}"
            placeholder="Weight in pounds"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
          <p class="text-sm text-slate-500">Enter your current weight in pounds.</p>
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Do you currently use tobacco or nicotine products? <span class="text-red-500">*</span></span>
          <select
            name="tobaccoUse"
            required
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
          >
            <option value="">Select an option</option>
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </label>

        <!-- Your coverage -->
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mt-2 pt-4 border-t border-slate-100">Your Coverage</p>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Beneficiary Name <span class="text-red-500">*</span></span>
          <input
            type="text"
            name="beneficiary"
            required
            autocomplete="off"
            placeholder="Full beneficiary name"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
          <p class="text-sm text-slate-500">Enter the full name of the person you want listed as beneficiary.</p>
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">State <span class="text-red-500">*</span></span>
          <input
            type="text"
            name="state"
            required
            autocomplete="address-level1"
            placeholder="State you live in"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">I'm interested in… <span class="text-red-500">*</span></span>
          <select
            name="interest"
            required
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
          >
            <option value="">Select an option</option>
            <option value="whole-life">Whole Life Insurance</option>
            <option value="final-expense">Final Expense / Burial Coverage</option>
            <option value="wealth">Generational Wealth Strategies</option>
            <option value="not-sure">Not sure — help me decide</option>
          </select>
        </label>

        <button
          type="submit"
          class="mt-2 rounded-lg bg-brand-600 hover:bg-brand-700 active:bg-brand-800 text-white px-6 py-4 font-semibold text-lg transition-all shadow-md hover:shadow-lg"
        >
          Get My Free Quote
        </button>

        <!-- Consent Notice -->
        <div class="flex items-start gap-3 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-xs leading-relaxed text-slate-600">
          <img src="/images/quote-icons/notice.svg" alt="" class="mt-0.5 h-8 w-8 flex-shrink-0" width="32" height="32" />
          <p>
            <strong class="text-slate-900">Consent Notice:</strong> By completing and submitting this form, you agree to be contacted by a licensed insurance professional via phone, text message, and email regarding your options. See our <a href="/privacy" class="underline text-brand-600 hover:text-brand-700">Privacy Policy</a>.
          </p>
        </div>

        <p class="text-xs leading-relaxed text-slate-500">
          Licensed in {licensedStates}. Policies and product availability vary by carrier and state.
        </p>
      </form>
    </div>
  </section>

  <!-- Closer -->
  <section class="bg-gradient-to-br from-brand-600 to-brand-800 text-white py-14">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="text-2xl sm:text-3xl font-bold">
        You've been thinking about this. Let's make it easy.
      </p>
      <p class="mt-4 text-brand-200">
        Life Insurance · Medicare · Estate Planning · Retirement Strategies
      </p>
      <a
        href="#quote-form"
        data-quote-cta="closer-primary"
        class="mt-8 inline-block rounded-lg bg-white text-brand-700 hover:bg-brand-50 px-8 py-4 font-semibold text-lg transition-colors"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Minimal Footer -->
  <footer class="bg-slate-900 text-slate-400 py-8">
    <div class="mx-auto max-w-md px-4 text-center text-xs leading-relaxed space-y-3">
      <p>Licensed in {licensedStates}. Policies and features vary by carrier and state.</p>
      <p><a href="/privacy" class="underline hover:text-white transition-colors">Privacy Policy</a></p>
    </div>
  </footer>
</Base>

<script>
  type VercelAnalyticsWindow = Window & {
    va?: {
      track: (eventName: string, properties?: Record<string, string>) => void;
    };
  };

  // Simple client-side loading state for the form
  const form = document.querySelector('#quote-form form') as HTMLFormElement | null;
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const emailInput = form?.querySelector('input[name="email"]') as HTMLInputElement | null;
  const analyticsWindow = window as VercelAnalyticsWindow;

  const normalizeEmailAddress = (value: string): string => {
    const trimmed = value.trim();
    const atIndex = trimmed.lastIndexOf('@');

    if (atIndex === -1) {
      return trimmed;
    }

    const localPart = trimmed.slice(0, atIndex);
    const domain = trimmed.slice(atIndex + 1);
    const normalizedDomain = domain.toLowerCase().replace(/\.comn$/i, '.com');

    return `${localPart}@${normalizedDomain}`;
  };

  document.querySelectorAll('[data-quote-cta]').forEach((element) => {
    element.addEventListener('click', () => {
      analyticsWindow.va?.track('quote_cta_click', {
        location: element.getAttribute('data-quote-cta') ?? 'unknown',
      });
    });
  });

  if (emailInput) {
    const normalizeEmailField = () => {
      const normalizedEmail = normalizeEmailAddress(emailInput.value);
      if (normalizedEmail !== emailInput.value.trim()) {
        emailInput.value = normalizedEmail;
      }
    };

    emailInput.addEventListener('blur', normalizeEmailField);
    emailInput.addEventListener('change', normalizeEmailField);
  }

  if (form && btn) {
    form.addEventListener('submit', () => {
      if (emailInput) {
        emailInput.value = normalizeEmailAddress(emailInput.value);
      }

      const interest = (form.querySelector('select[name="interest"]') as HTMLSelectElement | null)?.value ?? 'unknown';
      sessionStorage.setItem('quote_interest', interest);
      sessionStorage.removeItem('quote_success_tracked');

      analyticsWindow.va?.track('quote_form_submit_attempt', {
        interest,
      });

      btn.disabled = true;
      btn.textContent = 'Sending…';
      btn.classList.add('opacity-70', 'cursor-wait');
    });
  }
</script>
