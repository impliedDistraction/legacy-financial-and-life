---
import Base from '../layouts/Base.astro';
import { site } from '../content/site';
import '../styles/tailwind.css';
---

<Base
  title="Free Life Insurance Quote — Legacy Financial & Life"
  description="Get a free, no-obligation life insurance quote. Coverage for ages 0–85, no medical exams in most cases. Term, whole life, and final expense options."
>
  <!-- Minimal header — no nav links to keep conversion focus -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-200">
    <div class="mx-auto max-w-6xl flex items-center justify-between px-4 py-3">
      <a href="/" class="flex items-center gap-2" aria-label="Legacy Financial & Life home">
        <img src="/images/fb-crest-logo.png" alt={site.branding.logoAlt} class="h-10 w-auto" width="40" height="40" />
        <span class="font-bold text-lg text-slate-900 hidden sm:inline">Legacy Financial & Life</span>
      </a>
      <a
        href={`tel:${site.phone}`}
        class="text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors"
      >
        {site.phone}
      </a>
    </div>
  </header>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 via-slate-800 to-brand-900 text-white py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight">
          Protect Your Family.<br />Secure Your Future.
        </h1>
        <p class="mt-6 text-lg text-slate-300 leading-relaxed max-w-xl">
          You're just a few steps away from exploring affordable life insurance options designed to fit your needs and your budget.
        </p>
        <p class="mt-4 text-slate-400 leading-relaxed max-w-xl">
          Whether you're planning for today or building for tomorrow, we're here to help you find the right coverage with no pressure and no hassle.
        </p>
        <a
          href="#quote-form"
          class="mt-8 inline-block rounded-lg bg-brand-600 hover:bg-brand-500 text-white px-8 py-4 font-semibold text-lg transition-colors"
        >
          Get Your Free Quote &darr;
        </a>
      </div>
      <div class="flex justify-center">
        <img
          src="/images/fb-crest-logo.png"
          alt="Legacy Financial & Life crest"
          class="w-64 sm:w-80 drop-shadow-2xl"
          width="320"
          height="400"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Coverage Made Simple -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <div class="flex items-center gap-3 mb-6">
            <span class="text-3xl">✅</span>
            <h2 class="text-3xl font-bold text-slate-900">Coverage Made Simple</h2>
          </div>
          <ul class="space-y-4 text-slate-700 text-lg">
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-6 h-6 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </span>
              Ages 0–85 eligible
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-6 h-6 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </span>
              No medical exams required (in most cases)
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-6 h-6 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </span>
              Quick &amp; easy application process
            </li>
          </ul>

          <h3 class="mt-8 font-semibold text-slate-900 text-lg">Options include:</h3>
          <div class="mt-4 grid sm:grid-cols-3 gap-4">
            <div class="rounded-xl border border-slate-200 p-4 text-center hover:border-brand-300 transition-colors">
              <span class="text-2xl">🛡️</span>
              <p class="mt-2 font-medium text-slate-900">Term Life Insurance</p>
            </div>
            <div class="rounded-xl border border-slate-200 p-4 text-center hover:border-brand-300 transition-colors">
              <span class="text-2xl">💰</span>
              <p class="mt-2 font-medium text-slate-900">Whole Life Insurance</p>
            </div>
            <div class="rounded-xl border border-slate-200 p-4 text-center hover:border-brand-300 transition-colors">
              <span class="text-2xl">🤝</span>
              <p class="mt-2 font-medium text-slate-900">Final Expense &amp; Burial</p>
            </div>
          </div>
        </div>

        <!-- Build More Than Protection -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <span class="text-3xl">💡</span>
            <h2 class="text-3xl font-bold text-slate-900">Build More Than Protection</h2>
          </div>
          <p class="text-slate-600 mb-6 text-lg">Our solutions can also help you:</p>
          <ul class="space-y-4">
            <li class="flex items-start gap-4 bg-brand-50 rounded-lg p-4">
              <span class="text-2xl">🏛️</span>
              <div>
                <p class="font-semibold text-slate-900">Create Generational Wealth</p>
                <p class="text-sm text-slate-600">Build a financial legacy that lasts for generations</p>
              </div>
            </li>
            <li class="flex items-start gap-4 bg-brand-50 rounded-lg p-4">
              <span class="text-2xl">🔒</span>
              <div>
                <p class="font-semibold text-slate-900">Access Safe Money Strategies</p>
                <p class="text-sm text-slate-600">Protect your assets with proven approaches</p>
              </div>
            </li>
            <li class="flex items-start gap-4 bg-brand-50 rounded-lg p-4">
              <span class="text-2xl">📈</span>
              <div>
                <p class="font-semibold text-slate-900">Plan for Retirement with Confidence</p>
                <p class="text-sm text-slate-600">Tax-advantaged strategies for your future</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Carriers / Trust Banner -->
  <section class="bg-slate-50 py-12 border-y border-slate-200">
    <div class="mx-auto max-w-5xl px-4 text-center">
      <p class="text-sm font-medium text-slate-500 uppercase tracking-wider mb-6">
        We work with America's top-rated carriers
      </p>
      <img
        src="/images/fb-carriers.png"
        alt="Insurance carrier partners including Mutual of Omaha, Foresters Financial, CVS Health, Americo, Transamerica, Aflac, and many more"
        class="mx-auto max-w-full rounded-lg"
        width="900"
        height="500"
        loading="lazy"
      />
    </div>
  </section>

  <!-- Quote Form -->
  <section id="quote-form" class="bg-white py-16 sm:py-20 scroll-mt-20">
    <div class="mx-auto max-w-2xl px-4">
      <div class="text-center mb-10">
        <span class="text-4xl">📩</span>
        <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-slate-900">
          Get Your FREE, No-Obligation Quote
        </h2>
        <p class="mt-3 text-lg text-slate-600">
          Fill out the form below to get started. It's fast, easy, and completely no pressure.
        </p>
      </div>

      <form
        method="POST"
        action="/api/fb-lead"
        class="grid gap-5 rounded-2xl border border-slate-200 p-6 sm:p-8 shadow-lg"
      >
        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Full Name <span class="text-red-500">*</span></span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            placeholder="Your full name"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Email Address <span class="text-red-500">*</span></span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Phone Number</span>
          <input
            type="tel"
            name="phone"
            autocomplete="tel"
            placeholder="(555) 123-4567"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Age Range</span>
          <select
            name="age"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
          >
            <option value="">Select age range</option>
            <option value="0-17">0–17</option>
            <option value="18-30">18–30</option>
            <option value="31-45">31–45</option>
            <option value="46-55">46–55</option>
            <option value="56-65">56–65</option>
            <option value="66-75">66–75</option>
            <option value="76-85">76–85</option>
          </select>
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">I'm interested in…</span>
          <select
            name="interest"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none bg-white"
          >
            <option value="">Select an option</option>
            <option value="term-life">Term Life Insurance</option>
            <option value="whole-life">Whole Life Insurance</option>
            <option value="final-expense">Final Expense / Burial Coverage</option>
            <option value="retirement">Retirement Planning</option>
            <option value="wealth">Generational Wealth Strategies</option>
            <option value="not-sure">Not sure — help me decide</option>
          </select>
        </label>

        <button
          type="submit"
          class="mt-2 rounded-lg bg-brand-600 hover:bg-brand-700 active:bg-brand-800 text-white px-6 py-4 font-semibold text-lg transition-colors"
        >
          Get My Free Quote
        </button>

        <!-- Consent Notice -->
        <p class="text-xs text-slate-500 leading-relaxed">
          ⚠️ <strong>Consent Notice:</strong> By completing and submitting this form, you agree to be contacted by a licensed insurance professional via phone, text message, and email regarding your options.
        </p>
      </form>
    </div>
  </section>

  <!-- Closer -->
  <section class="bg-gradient-to-br from-brand-600 to-brand-800 text-white py-14">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="text-2xl sm:text-3xl font-bold">
        👉 Take the first step toward peace of mind today.
      </p>
      <p class="mt-4 text-brand-200">
        Tim Byrd · Legacy Financial & Life<br />
        Life, Medicare, Estate Planning, Wealth and Retirement Strategist
      </p>
      <a
        href="#quote-form"
        class="mt-8 inline-block rounded-lg bg-white text-brand-700 hover:bg-brand-50 px-8 py-4 font-semibold text-lg transition-colors"
      >
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Minimal Footer -->
  <footer class="bg-slate-900 text-slate-400 py-8">
    <div class="mx-auto max-w-6xl px-4 text-center text-sm space-y-2">
      <p>&copy; {new Date().getFullYear()} Legacy Financial & Life. All rights reserved.</p>
      <p>{site.footerNote}</p>
      <p>
        <a href={`tel:${site.phone}`} class="hover:text-white transition-colors">{site.phone}</a>
        &nbsp;·&nbsp;
        <a href={`mailto:${site.email}`} class="hover:text-white transition-colors">{site.email}</a>
      </p>
    </div>
  </footer>
</Base>

<script>
  // Simple client-side loading state for the form
  const form = document.querySelector('#quote-form form') as HTMLFormElement | null;
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  if (form && btn) {
    form.addEventListener('submit', () => {
      btn.disabled = true;
      btn.textContent = 'Sending…';
      btn.classList.add('opacity-70', 'cursor-wait');
    });
  }
</script>
