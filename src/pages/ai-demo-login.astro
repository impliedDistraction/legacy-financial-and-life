---
/**
 * /ai-demo-login — email‑only magic‑link login for the AI demo page.
 */
export const prerender = false;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>AI Demo Login — Legacy Financial & Life</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0}
    body{font-family:system-ui,-apple-system,sans-serif;background:#f8fafc;color:#1e293b;display:flex;align-items:center;justify-content:center;min-height:100dvh;padding:1rem}
    .card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:2rem;max-width:400px;width:100%;box-shadow:0 1px 3px rgba(0,0,0,.06)}
    h1{font-size:1.25rem;font-weight:700;margin-bottom:.5rem}
    p{font-size:.875rem;color:#475569;line-height:1.5;margin-bottom:1.5rem}
    .badge{display:inline-block;font-size:.6875rem;background:#fef3c7;color:#92400e;padding:.125rem .5rem;border-radius:9999px;font-weight:600;margin-bottom:1rem}
    label{display:block;font-size:.8125rem;font-weight:600;color:#334155;margin-bottom:.375rem}
    input[type="email"]{width:100%;padding:.625rem .75rem;border:1px solid #cbd5e1;border-radius:8px;font-size:.9375rem;outline:none;transition:border .15s}
    input[type="email"]:focus{border-color:#1a62db;box-shadow:0 0 0 3px rgba(26,98,219,.15)}
    button{width:100%;margin-top:1rem;padding:.625rem;background:#1a62db;color:#fff;border:none;border-radius:8px;font-size:.9375rem;font-weight:600;cursor:pointer;transition:background .15s}
    button:hover{background:#1550b8}
    button:disabled{opacity:.6;cursor:not-allowed}
    .msg{margin-top:1rem;padding:.75rem;border-radius:8px;font-size:.8125rem;line-height:1.4}
    .msg-ok{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0}
    .msg-err{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .back{display:inline-block;margin-top:1rem;font-size:.8125rem;color:#64748b;text-decoration:none}
    .back:hover{color:#1a62db}
  </style>
</head>
<body>
  <div class="card">
    <span class="badge">PREVIEW</span>
    <h1>AI Services Demo</h1>
    <p>Enter your team email to receive a login link. This is an internal preview — only pre‑approved email addresses are accepted.</p>

    <form id="login-form">
      <label for="email">Email address</label>
      <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@legacyf-l.com" />
      <button type="submit" id="submit-btn">Send Login Link</button>
    </form>

    <div id="message" class="msg" style="display:none"></div>
    <a href="/" class="back">&larr; Back to site</a>
  </div>

  <script is:inline>
    const form = document.getElementById('login-form');
    const btn = document.getElementById('submit-btn');
    const msg = document.getElementById('message');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Sending…';
      msg.style.display = 'none';

      const email = form.email.value.trim();
      const params = new URLSearchParams(window.location.search);
      const redirect = params.get('redirect') || null;
      try {
        const res = await fetch('/api/ai-demo-auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, redirect }),
        });
        if (res.ok) {
          msg.className = 'msg msg-ok';
          msg.textContent = 'If that email is on the approved list, a login link has been sent. Check your inbox.';
        } else {
          throw new Error('Request failed');
        }
      } catch {
        msg.className = 'msg msg-err';
        msg.textContent = 'Something went wrong. Please try again.';
      }
      msg.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Send Login Link';
    });
  </script>
</body>
</html>
