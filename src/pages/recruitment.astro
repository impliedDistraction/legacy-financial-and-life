---
/**
 * /recruitment — Agent recruitment campaign dashboard.
 *
 * Allows Tim to:
 * 1. Upload a CSV of potential recruits
 * 2. Run AI processing to generate personalized outreach
 * 3. Review/edit/approve generated emails & call scripts
 * 4. Send emails and track outcomes
 *
 * Protected by the same magic-link auth as /ai-demo.
 */
import Base from '../layouts/Base.astro';
import '../styles/tailwind.css';
import { verifySessionCookie } from '../lib/ai-demo-auth';

export const prerender = false;

const session = await verifySessionCookie(Astro.request.headers.get('cookie'));
if (!session) {
  return Astro.redirect('/ai-demo-login?redirect=/recruitment', 302);
}
---
<Base title="Recruitment — Legacy Financial & Life" description="AI-powered agent recruitment campaigns">

<div class="bg-gray-50 min-h-screen">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-30">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <div>
          <h1 class="text-sm font-bold text-gray-900">Agent Recruitment</h1>
          <p class="text-xs text-gray-500">Legacy Financial & Life</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span id="status-indicator" class="flex items-center gap-1.5 text-xs text-gray-500">
          <span id="status-dot" class="w-2 h-2 bg-gray-300 rounded-full inline-block"></span>
          <span id="status-text">Ready</span>
        </span>
        <a href="/ai-demo" class="text-xs text-brand-600 hover:text-brand-700 font-medium">← AI Demo</a>
      </div>
    </div>
  </header>

  <!-- Stats Bar -->
  <section class="max-w-7xl mx-auto px-4 pt-6 pb-2">
    <div class="grid grid-cols-3 sm:grid-cols-7 gap-3">
      <div class="bg-white rounded-lg border border-gray-200 p-3 text-center">
        <div class="text-2xl font-bold text-gray-900" id="stat-total">0</div>
        <div class="text-xs text-gray-500">Total</div>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-3 text-center cursor-pointer hover:border-amber-300 transition-colors" data-stat-tab="review" data-stat-filter="pending">
        <div class="text-2xl font-bold text-amber-600" id="stat-pending">0</div>
        <div class="text-xs text-gray-500">Pending</div>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-3 text-center cursor-pointer hover:border-blue-300 transition-colors" data-stat-tab="review" data-stat-filter="drafted">
        <div class="text-2xl font-bold text-blue-600" id="stat-drafted">0</div>
        <div class="text-xs text-gray-500">Drafted</div>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-3 text-center cursor-pointer hover:border-indigo-300 transition-colors" data-stat-tab="review" data-stat-filter="reviewed">
        <div class="text-2xl font-bold text-indigo-600" id="stat-reviewed">0</div>
        <div class="text-xs text-gray-500">Reviewed</div>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-3 text-center cursor-pointer hover:border-emerald-300 transition-colors" data-stat-tab="review" data-stat-filter="approved">
        <div class="text-2xl font-bold text-emerald-600" id="stat-approved">0</div>
        <div class="text-xs text-gray-500">Approved</div>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-3 text-center cursor-pointer hover:border-green-300 transition-colors" data-stat-tab="sent" data-stat-filter="sent">
        <div class="text-2xl font-bold text-green-600" id="stat-sent">0</div>
        <div class="text-xs text-gray-500">Sent</div>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-3 text-center cursor-pointer hover:border-purple-300 transition-colors" data-stat-tab="sent" data-stat-filter="converted">
        <div class="text-2xl font-bold text-purple-600" id="stat-converted">0</div>
        <div class="text-xs text-gray-500">Converted</div>
      </div>
    </div>
  </section>

  <!-- AI Status Badge -->
  <div class="max-w-7xl mx-auto px-4">
    <div id="ai-busy-badge" class="hidden inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-50 border border-amber-200 rounded-full text-xs font-medium text-amber-700 animate-pulse">
      🤖 AI working...
    </div>
  </div>

  <!-- Tab Navigation -->
  <div class="max-w-7xl mx-auto px-4 pt-4">
    <div class="flex gap-1 bg-gray-100 rounded-lg p-1 w-fit" id="tab-nav">
      <button class="tab-btn active px-4 py-2 text-sm font-medium rounded-md transition-colors" data-tab="campaigns">
        🎯 Leads
      </button>
      <button class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors" data-tab="review">
        ✅ Review & Approve
      </button>
      <button class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors" data-tab="sent">
        📧 Sent & Tracking
      </button>
      <button class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors" data-tab="preview">
        🧪 Preview & Test
      </button>
      <button class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors" data-tab="pipeline">
        ⚙️ Pipeline
      </button>
    </div>
  </div>

  <!-- Tab Content -->
  <div class="max-w-7xl mx-auto px-4 py-4">

    <!-- ═══════════════ LEADS TAB ═══════════════ -->
    <div id="tab-campaigns" class="tab-panel">
      <div class="space-y-6">

        <!-- ── Pool Overview ── -->
        <div class="bg-white rounded-xl border border-gray-200 p-5">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-semibold text-gray-900">Agent Pool</h2>
              <p class="text-xs text-gray-500 mt-0.5">Leads from all sources flow into this pool. AI agents research, draft, review, and send outreach automatically.</p>
            </div>
          </div>
          <!-- Pipeline Flow Visual -->
          <div class="flex items-center gap-0 overflow-x-auto pb-2" id="pool-pipeline">
            <div class="flex flex-col items-center min-w-[80px]">
              <div class="text-2xl font-bold text-gray-900" id="pool-total">—</div>
              <div class="text-[10px] text-gray-400 uppercase tracking-wider">In Pool</div>
            </div>
            <div class="text-gray-300 text-lg px-1">→</div>
            <div class="flex flex-col items-center min-w-[80px]">
              <div class="text-2xl font-bold text-amber-600" id="pool-pending">—</div>
              <div class="text-[10px] text-gray-400 uppercase tracking-wider">Pending</div>
            </div>
            <div class="text-gray-300 text-lg px-1">→</div>
            <div class="flex flex-col items-center min-w-[80px]">
              <div class="text-2xl font-bold text-blue-600" id="pool-drafted">—</div>
              <div class="text-[10px] text-gray-400 uppercase tracking-wider">Drafted</div>
            </div>
            <div class="text-gray-300 text-lg px-1">→</div>
            <div class="flex flex-col items-center min-w-[80px]">
              <div class="text-2xl font-bold text-indigo-600" id="pool-reviewed">—</div>
              <div class="text-[10px] text-gray-400 uppercase tracking-wider">Reviewed</div>
            </div>
            <div class="text-gray-300 text-lg px-1">→</div>
            <div class="flex flex-col items-center min-w-[80px]">
              <div class="text-2xl font-bold text-emerald-600" id="pool-approved">—</div>
              <div class="text-[10px] text-gray-400 uppercase tracking-wider">Approved</div>
            </div>
            <div class="text-gray-300 text-lg px-1">→</div>
            <div class="flex flex-col items-center min-w-[80px]">
              <div class="text-2xl font-bold text-green-600" id="pool-sent">—</div>
              <div class="text-[10px] text-gray-400 uppercase tracking-wider">Sent</div>
            </div>
            <div class="text-gray-300 text-lg px-1">→</div>
            <div class="flex flex-col items-center min-w-[80px]">
              <div class="text-2xl font-bold text-purple-600" id="pool-converted">—</div>
              <div class="text-[10px] text-gray-400 uppercase tracking-wider">Converted</div>
            </div>
            <div class="text-gray-300 text-lg px-2">|</div>
            <div class="flex flex-col items-center min-w-[80px]">
              <div class="text-2xl font-bold text-red-500" id="pool-rejected">—</div>
              <div class="text-[10px] text-gray-400 uppercase tracking-wider">Rejected</div>
            </div>
          </div>
          <!-- Source breakdown -->
          <div class="flex gap-4 mt-3 pt-3 border-t border-gray-100 text-xs text-gray-500" id="pool-sources">
            <span>🔍 Prophog: <strong id="pool-src-prophog">—</strong></span>
            <span>📤 CSV: <strong id="pool-src-csv">—</strong></span>
            <span>🌐 Landing Page: <strong id="pool-src-landing">—</strong></span>
          </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-6">
          <!-- ── Outreach Campaigns ── -->
          <div class="lg:col-span-2 space-y-4">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold text-gray-900">Outreach Campaigns</h2>
              <button id="new-campaign-btn" class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">+ New Campaign</button>
            </div>
            <div id="campaign-list" class="space-y-3">
              <div class="text-sm text-gray-500 text-center py-8">Loading...</div>
            </div>
          </div>

          <!-- ── Sidebar: Lead Sources + Upload + Live Feed ── -->
          <div class="space-y-4">

            <!-- New Campaign Form -->
            <div id="campaign-form" class="bg-white rounded-xl border border-gray-200 p-5 hidden">
              <h3 class="text-sm font-semibold text-gray-900 mb-4">Launch Outreach Campaign</h3>
              <div class="space-y-3">
                <div>
                  <label class="block text-xs font-medium text-gray-600 mb-1">Campaign Name</label>
                  <input type="text" id="cmp-name" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="e.g., May GA Outreach" />
                </div>
                <div>
                  <label class="block text-xs font-medium text-gray-600 mb-1">Lead Source</label>
                  <select id="cmp-source" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white">
                    <option value="prophog" selected>🔍 Prophog (auto-search)</option>
                    <option value="csv">📤 CSV Import</option>
                    <option value="pool">🎯 Existing Pool (all sources)</option>
                  </select>
                  <p class="text-xs text-gray-400 mt-0.5">Prophog auto-searches for new agents. CSV uses agents you've uploaded. Pool targets all available agents.</p>
                </div>
                <div>
                  <label class="block text-xs font-medium text-gray-600 mb-1">Target State</label>
                  <select id="cmp-state" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white">
                    <option value="Florida" selected>Florida (FL)</option>
                    <option value="Georgia">Georgia (GA)</option>
                    <option value="Ohio">Ohio (OH)</option>
                    <option value="Oklahoma">Oklahoma (OK)</option>
                    <option value="South Carolina">South Carolina (SC)</option>
                    <option value="Mississippi">Mississippi (MS)</option>
                    <option value="Michigan">Michigan (MI)</option>
                    <option value="Texas">Texas (TX)</option>
                    <option value="Utah">Utah (UT)</option>
                    <option value="Alabama">Alabama (AL)</option>
                    <option value="Louisiana">Louisiana (LA)</option>
                    <option value="Tennessee">Tennessee (TN)</option>
                  </select>
                </div>
                <!-- Prophog Search Filters -->
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">License Effective From</label>
                    <input type="date" id="cmp-lic-from" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">License Effective To</label>
                    <input type="date" id="cmp-lic-to" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                  </div>
                </div>
                <label class="flex items-center gap-3 py-1 cursor-pointer">
                  <input type="checkbox" id="cmp-new-agents" class="w-4 h-4 text-brand-600 border-gray-300 rounded focus:ring-brand-500" />
                  <div>
                    <span class="text-sm font-medium text-gray-800">New Agents Only</span>
                    <p class="text-xs text-gray-500">Target recently licensed agents (best response rates)</p>
                  </div>
                </label>
                <div>
                  <label class="block text-xs font-medium text-gray-600 mb-1">Outreach Goal</label>
                  <input type="number" id="cmp-budget" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" value="200" min="10" max="10000" />
                  <p class="text-xs text-gray-400 mt-0.5">How many agents to find and outreach to</p>
                </div>
                <!-- Email Sign-off -->
                <div>
                  <label class="block text-xs font-medium text-gray-600 mb-1">Email Sign-off</label>
                  <select id="cmp-signoff" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white">
                    <option value="Legacy Financial Recruiting Team" selected>Legacy Financial Recruiting Team</option>
                    <option value="Legacy Financial & Life">Legacy Financial & Life</option>
                    <option value="The Legacy Financial Team">The Legacy Financial Team</option>
                    <option value="Legacy Financial AI Recruiting">Legacy Financial AI Recruiting</option>
                  </select>
                </div>
                <!-- Reply-to Email -->
                <div>
                  <label class="block text-xs font-medium text-gray-600 mb-1">Reply-to Email</label>
                  <input type="email" id="cmp-reply-to" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="recruiting@legacyfinancial.app" />
                  <p class="text-xs text-gray-400 mt-0.5">Where replies go. Leave blank for default.</p>
                </div>
                <!-- Auto-relaunch toggle -->
                <label class="flex items-center gap-3 py-2 cursor-pointer">
                  <input type="checkbox" id="cmp-relaunch" class="w-4 h-4 text-brand-600 border-gray-300 rounded focus:ring-brand-500" />
                  <div>
                    <span class="text-sm font-medium text-gray-800">Continuous</span>
                    <p class="text-xs text-gray-500">Auto-relaunch when goal reached. Runs until stopped.</p>
                  </div>
                </label>
                <!-- Advanced (hidden by default) -->
                <details class="border-t border-gray-100 pt-2">
                  <summary class="text-xs text-gray-400 cursor-pointer hover:text-gray-600">Advanced options</summary>
                  <div class="mt-2 space-y-3">
                    <div class="grid grid-cols-2 gap-3">
                      <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Pages per Run</label>
                        <input type="number" id="cmp-pages" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" value="20" min="1" max="50" />
                      </div>
                      <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Run Every (min)</label>
                        <input type="number" id="cmp-interval" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" value="60" min="1" max="1440" />
                      </div>
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">Schedule Jitter (min)</label>
                      <input type="number" id="cmp-jitter" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" value="15" min="0" max="30" />
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">Notes</label>
                      <textarea id="cmp-notes" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" rows="2" placeholder="Internal notes..."></textarea>
                    </div>
                  </div>
                </details>
                <!-- Hidden fields for backward compat -->
                <input type="hidden" id="cmp-review" value="true" />
                <button id="cmp-submit" class="w-full bg-brand-600 hover:bg-brand-700 text-white font-medium py-2.5 rounded-lg text-sm transition-colors mt-2">Launch Campaign</button>
                <button id="cmp-preview-btn" type="button" class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 rounded-lg text-sm transition-colors mt-1">
                  👁️ Preview Sample Email
                </button>
                <div id="cmp-preview-output" class="hidden mt-3 border border-gray-200 rounded-lg overflow-hidden bg-gray-50">
                  <div class="px-3 py-2 bg-gray-100 border-b border-gray-200 text-xs font-medium text-gray-500">Sample Email Preview</div>
                  <div id="cmp-preview-content" class="p-3 text-xs text-gray-700 space-y-2"></div>
                </div>
              </div>
            </div>

            <!-- Quick CSV Upload -->
            <div class="bg-white rounded-xl border border-gray-200 p-5">
              <h3 class="text-sm font-semibold text-gray-900 mb-2">Import Leads</h3>
              <p class="text-xs text-gray-500 mb-3">Upload a CSV to add agents directly into the pool.</p>
              <button id="leads-upload-btn" class="w-full border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-brand-400 transition-colors cursor-pointer">
                <div class="text-sm text-gray-600">📤 <span class="text-brand-600 font-medium">Browse CSV</span> or drag & drop</div>
                <div class="text-xs text-gray-400 mt-1">Supported: .csv up to 500 rows</div>
              </button>
              <input type="file" accept=".csv,.txt" id="leads-csv-input" class="hidden" />
            </div>

            <!-- Live Feed -->
            <div class="bg-white rounded-xl border border-gray-200 p-5">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Recent Activity</h3>
              <div id="live-feed" class="space-y-1 max-h-96 overflow-y-auto">
                <div class="text-xs text-gray-400 text-center py-4">Loading...</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════ UPLOAD TAB (hidden, accessed via Leads) ═══════════════ -->
    <div id="tab-upload" class="tab-panel hidden">
      <div class="grid lg:grid-cols-3 gap-4">
        <div class="lg:col-span-2 space-y-4">
          <!-- CSV Upload -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-1">Upload Recruit List</h2>
            <p class="text-sm text-gray-500 mb-4">Upload a CSV file with your prospect list. We'll process each one with AI-generated personalized outreach.</p>

            <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-brand-400 transition-colors" id="drop-zone">
              <input type="file" accept=".csv,.txt" id="csv-input" class="hidden" />
              <svg class="w-10 h-10 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
              <p class="text-sm text-gray-600 mb-1">Drop CSV here or <button class="text-brand-600 font-medium hover:underline" id="browse-btn">browse</button></p>
              <p class="text-xs text-gray-400">Supports: .csv files up to 500 rows</p>
            </div>

            <!-- Preview -->
            <div id="csv-preview" class="hidden mt-4">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-sm font-medium text-gray-700">Preview (<span id="preview-count">0</span> prospects)</h3>
                <button class="text-xs text-red-500 hover:text-red-700" id="clear-csv-btn">Clear</button>
              </div>
              <div class="overflow-x-auto max-h-60 border border-gray-200 rounded-lg">
                <table class="w-full text-xs" id="preview-table">
                  <thead class="bg-gray-50 sticky top-0"><tr id="preview-header"></tr></thead>
                  <tbody id="preview-body"></tbody>
                </table>
              </div>
            </div>

            <!-- Campaign Name + Column Mapping -->
            <div id="upload-controls" class="hidden mt-4 space-y-3">
              <div>
                <label class="text-sm font-medium text-gray-700">Campaign Name</label>
                <input type="text" id="campaign-name" class="mt-1 w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500" placeholder="e.g., May 2026 Georgia Agents" />
              </div>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2" id="column-mapping">
                <!-- Populated dynamically -->
              </div>
              <button id="upload-btn" class="w-full bg-brand-600 hover:bg-brand-700 text-white font-medium py-2.5 rounded-lg transition-colors">
                Upload Campaign
              </button>
            </div>
          </div>

          <!-- Processing Status (for batch operations) -->
          <div id="processing-status" class="hidden bg-white rounded-xl border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-sm font-semibold text-gray-900">Processing</h3>
              <span class="text-xs text-gray-500" id="process-progress">0/0</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2 mb-2">
              <div class="bg-brand-600 h-2 rounded-full transition-all duration-300" id="process-bar" style="width: 0%"></div>
            </div>
            <p class="text-xs text-gray-500" id="process-status-text">Waiting...</p>
          </div>
        </div>

        <!-- Sidebar Instructions -->
        <div class="space-y-4">
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">CSV Format</h3>
            <p class="text-xs text-gray-600 mb-3">Your CSV should include some or all of these columns:</p>
            <ul class="text-xs text-gray-600 space-y-1.5">
              <li class="flex gap-2"><span class="text-brand-600 font-mono">name</span> <span class="text-gray-400">— Full name (required)</span></li>
              <li class="flex gap-2"><span class="text-brand-600 font-mono">email</span> <span class="text-gray-400">— Email address</span></li>
              <li class="flex gap-2"><span class="text-brand-600 font-mono">phone</span> <span class="text-gray-400">— Phone number</span></li>
              <li class="flex gap-2"><span class="text-brand-600 font-mono">state</span> <span class="text-gray-400">— State abbreviation</span></li>
              <li class="flex gap-2"><span class="text-brand-600 font-mono">city</span> <span class="text-gray-400">— City</span></li>
              <li class="flex gap-2"><span class="text-brand-600 font-mono">experience</span> <span class="text-gray-400">— Experience level</span></li>
              <li class="flex gap-2"><span class="text-brand-600 font-mono">agency</span> <span class="text-gray-400">— Current agency</span></li>
              <li class="flex gap-2"><span class="text-brand-600 font-mono">notes</span> <span class="text-gray-400">— Any notes</span></li>
