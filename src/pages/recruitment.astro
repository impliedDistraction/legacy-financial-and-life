                    if (rep.signals?.newsMedia) badges.push('📰 News');
                    if (rep.signals?.industryRecognition) badges.push('🏅 Industry');
                    const ev = (rep.evidence || []).map((e: any) =>
                      `<div class="pl-3 border-l-2 border-purple-200 text-gray-500 italic">"${escapeHtml(e.snippet)}" <span class="text-gray-400 not-italic">— ${escapeHtml(e.source)}</span></div>`
                    ).join('');
                    return `<div><span class="font-medium">Reputation:</span> <span class="px-2 py-0.5 rounded-full text-xs font-medium ${repColor}">${rep.tier.replace(/_/g, ' ')}</span> ${badges.map(b => `<span class="inline-block bg-white border border-gray-200 px-1.5 py-0.5 rounded text-xs">${b}</span>`).join(' ')}</div>${ev}`;
                  })()}
                  ${(() => {
                    const tone = wp.toneProfile;
                    if (!tone) return '';
                    const toneColors: Record<string, string> = {
                      supportive: 'bg-green-100 text-green-700',
                      professional: 'bg-blue-100 text-blue-700',
                      relatable: 'bg-amber-100 text-amber-700',
                      salesy: 'bg-orange-100 text-orange-700',
                      confrontational: 'bg-red-100 text-red-700',
                    };
                    const toneIcons: Record<string, string> = {
                      supportive: '💛',
                      professional: '🎯',
                      relatable: '🤝',
                      salesy: '📣',
                      confrontational: '⚡',
                    };
                    const color = toneColors[tone.primary] || 'bg-gray-100 text-gray-600';
                    const icon = toneIcons[tone.primary] || '💬';
                    const dims = Object.entries(tone.dimensions || {})
                      .sort((a: any, b: any) => b[1] - a[1])
                      .map(([dim, count]: [string, any]) => {
                        const dIcon = toneIcons[dim] || '·';
                        return `<span class="inline-block bg-white border border-gray-200 px-1.5 py-0.5 rounded text-xs">${dIcon} ${dim} (${count})</span>`;
                      }).join(' ');
                    const ev = (tone.evidence || []).slice(0, 3).map((e: any) =>
                      `<div class="pl-3 border-l-2 border-indigo-200 text-gray-500 italic">"${escapeHtml(e.excerpt)}"</div>`
                    ).join('');
                    return `<div class="mt-1 pt-1 border-t border-purple-200"><span class="font-medium">Online Tone:</span> <span class="px-2 py-0.5 rounded-full text-xs font-medium ${color}">${icon} ${escapeHtml(tone.summary)}</span></div><div class="flex flex-wrap gap-1">${dims}</div>${ev}<div class="text-[10px] text-gray-400">${tone.snippetsAnalyzed} public snippet${tone.snippetsAnalyzed === 1 ? '' : 's'} analyzed — informational only, not used in scoring</div>`;
                  })()}
                </div>
                <div class="mt-1.5 flex items-center gap-1.5 text-[10px] text-indigo-400">
                  <span>✨</span>
                  <span>Expanded Research — 8-search agent profile included free.</span>
                  <span class="text-indigo-300">Add research credits at workingorder.app</span>
                </div>
              </details>`;
              })() : ''}
            </div>
          </div>

          ${p.email_body ? `
          <details class="mt-3">
            <summary class="text-xs font-medium text-brand-600 cursor-pointer">View Email Draft</summary>
            <div class="mt-2 bg-gray-50 rounded-lg p-3">
              <div class="text-xs text-gray-500 mb-1">Subject: <span class="font-medium text-gray-700">${escapeHtml(p.email_subject || '')}</span></div>
              <textarea class="w-full text-xs text-gray-700 bg-white border border-gray-200 rounded p-2 min-h-[80px] email-edit" data-id="${p.id}">${escapeHtml(p.email_body || '')}</textarea>
            </div>
          </details>` : ''}

          ${p.call_opener ? `
          <details class="mt-2">
            <summary class="text-xs font-medium text-brand-600 cursor-pointer">View Call Script</summary>
            <div class="mt-2 bg-gray-50 rounded-lg p-3 text-xs text-gray-700 whitespace-pre-wrap">${escapeHtml(p.call_opener)}</div>
            ${p.call_voicemail ? `<div class="mt-1 text-xs text-gray-500"><strong>Voicemail:</strong> ${escapeHtml(p.call_voicemail)}</div>` : ''}
          </details>` : ''}

          <!-- Actions per status -->
          <div class="flex gap-2 mt-3 flex-wrap">
            ${status === 'pending' ? `
              <button class="action-btn generate-btn bg-brand-600 hover:bg-brand-700 text-white text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">⚡ Generate Outreach</button>
              <button class="action-btn reject-open-btn bg-red-100 hover:bg-red-200 text-red-700 text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">✗ Reject</button>
              <button class="action-btn delete-btn bg-gray-100 hover:bg-red-100 text-gray-500 hover:text-red-600 text-xs px-2 py-1.5 rounded-lg" data-id="${p.id}" title="Permanently delete">🗑️</button>
            ` : ''}
            ${status === 'drafted' ? `
              <span class="text-xs text-gray-400 italic">⏳ Awaiting QA review (automated)</span>
              <button class="action-btn reject-open-btn bg-red-100 hover:bg-red-200 text-red-700 text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">✗ Reject</button>
              <button class="action-btn delete-btn bg-gray-100 hover:bg-red-100 text-gray-500 hover:text-red-600 text-xs px-2 py-1.5 rounded-lg" data-id="${p.id}" title="Permanently delete">🗑️</button>
            ` : ''}
            ${status === 'reviewed' ? `
              <button class="action-btn approve-btn bg-green-600 hover:bg-green-700 text-white text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">✓ Approve</button>
              <button class="action-btn reject-open-btn bg-red-100 hover:bg-red-200 text-red-700 text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">✗ Reject</button>
              ${p.email ? `<button class="action-btn send-btn bg-blue-600 hover:bg-blue-700 text-white text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">📧 Approve & Send</button>` : ''}
              <button class="action-btn delete-btn bg-gray-100 hover:bg-red-100 text-gray-500 hover:text-red-600 text-xs px-2 py-1.5 rounded-lg" data-id="${p.id}" title="Permanently delete">🗑️</button>
            ` : ''}
            ${status === 'approved' ? `
              ${p.email ? `<button class="action-btn send-btn bg-blue-600 hover:bg-blue-700 text-white text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">📧 Send Email</button>` : ''}
              <button class="action-btn call-btn bg-amber-100 hover:bg-amber-200 text-amber-800 text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">📞 Mark Called</button>
              <button class="action-btn delete-btn bg-gray-100 hover:bg-red-100 text-gray-500 hover:text-red-600 text-xs px-2 py-1.5 rounded-lg" data-id="${p.id}" title="Permanently delete">🗑️</button>
            ` : ''}
            ${status === 'rejected' ? `
              <span class="text-xs text-gray-400 italic">${p.qa_rejection_reason ? 'QA: ' + escapeHtml(p.qa_rejection_reason) : (p.properties?.rejection_reason) ? 'Reason: ' + escapeHtml(p.properties.rejection_reason) : 'No reason given'}</span>
              <button class="action-btn delete-btn bg-gray-100 hover:bg-red-100 text-gray-500 hover:text-red-600 text-xs px-2 py-1.5 rounded-lg ml-auto" data-id="${p.id}" title="Permanently delete">🗑️ Delete forever</button>
            ` : ''}
          </div>
          <!-- Reject reason inline (hidden by default) -->
          <div class="reject-reason-row hidden mt-2 flex items-center gap-2" data-id="${p.id}">
            <input type="text" class="reject-reason-input flex-1 text-xs border border-gray-300 rounded-lg px-2 py-1.5" placeholder="Reason (optional): wrong state, not a fit, etc." data-id="${p.id}" />
            <button class="reject-confirm-btn bg-red-600 hover:bg-red-700 text-white text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">Confirm Reject</button>
            <button class="reject-cancel-btn text-xs text-gray-400 hover:text-gray-600" data-id="${p.id}">Cancel</button>
          </div>
        </div>`;
    }).join('');

    // Wire action buttons
    reviewList.querySelectorAll('.generate-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = getAttr(btn, 'data-id');
        (btn as HTMLButtonElement).disabled = true;
        (btn as HTMLButtonElement).textContent = '⏳ Generating...';
        activeGenerations++;
        updateGenerationStatus();
        try {
          const res = await fetch('/api/recruitment-process', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prospectIds: [id] }),
          });
          if (!res.ok && res.status === 504) {
            showToast('Generation timed out — try again (model needs warmup)', 'error');
            (btn as HTMLButtonElement).disabled = false;
            (btn as HTMLButtonElement).textContent = '⚡ Generate Outreach';
            return;
          }
          const data = await res.json();
          if (data.processed > 0) {
            hideAiErrorBanner();
            showToast('Outreach generated');
            loadReviewList();
          } else {
            const reason = data.failReason || 'Generation failed — try again';
            if (isAiUnavailableError(reason)) {
              showAiErrorBanner(reason);
            }
            showToast(reason, 'error');
            (btn as HTMLButtonElement).disabled = false;
            (btn as HTMLButtonElement).textContent = '⚡ Generate Outreach';
          }
          refreshStats();
        } catch {
          showAiErrorBanner('Network error: could not reach server');
          showToast('Generation failed — AI service unreachable', 'error');
          (btn as HTMLButtonElement).disabled = false;
          (btn as HTMLButtonElement).textContent = '⚡ Generate Outreach';
        } finally {
          activeGenerations--;
          updateGenerationStatus();
        }
      });
    });
    reviewList.querySelectorAll('.approve-btn').forEach(btn => {
      btn.addEventListener('click', () => doAction(getAttr(btn, 'data-id'), 'approve'));
    });
    reviewList.querySelectorAll('.reject-open-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = getAttr(btn, 'data-id');
        const row = reviewList.querySelector(`.reject-reason-row[data-id="${id}"]`);
        row?.classList.remove('hidden');
        (btn as HTMLButtonElement).classList.add('hidden');
      });
    });
    reviewList.querySelectorAll('.reject-confirm-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = getAttr(btn, 'data-id');
        const input = reviewList.querySelector(`.reject-reason-input[data-id="${id}"]`) as HTMLInputElement;
        const reason = input?.value.trim() || '';
        await doAction(id, 'reject', undefined, reason);
        showToast('Prospect rejected');
        loadReviewList();
        refreshStats();
      });
    });
    reviewList.querySelectorAll('.reject-cancel-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = getAttr(btn, 'data-id');
        const row = reviewList.querySelector(`.reject-reason-row[data-id="${id}"]`);
        row?.classList.add('hidden');
        // Re-show the reject button
        const openBtn = reviewList.querySelector(`.reject-open-btn[data-id="${id}"]`);
        openBtn?.classList.remove('hidden');
      });
    });
    reviewList.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = getAttr(btn, 'data-id');
        if (!confirm('Permanently delete this prospect? This cannot be undone.')) return;
        await doAction(id, 'delete');
        showToast('Prospect permanently deleted');
        loadReviewList();
        refreshStats();
      });
    });
    reviewList.querySelectorAll('.send-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = getAttr(btn, 'data-id');
        const emailArea = document.querySelector(`.email-edit[data-id="${id}"]`) as HTMLTextAreaElement | null;
        await doAction(id, 'approve', emailArea?.value);
        await doAction(id, 'send_email', emailArea?.value);
      });
    });
    reviewList.querySelectorAll('.call-btn').forEach(btn => {
      btn.addEventListener('click', () => doAction(getAttr(btn, 'data-id'), 'mark_called'));
    });
  }

  approveAllBtn.addEventListener('click', async () => {
    const cards = reviewList.querySelectorAll('.prospect-card');
    for (const card of cards) {
      const id = (card as HTMLElement).dataset.id;
      if (id) await doAction(id, 'approve');
    }
    loadReviewList();
    refreshStats();
  });

  async function doAction(id: string, action: string, editedEmailBody?: string, reason?: string) {
    try {
      await fetch('/api/recruitment-action', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, action, editedEmailBody, reason }),
      });
      // Remove the card from view
      const card = reviewList.querySelector(`[data-id="${id}"]`);
      card?.remove();
      refreshStats();
    } catch {
      showToast('Action failed', 'error');
    }
  }

  // ═══════════════════════════════════════════
  // SENT / CRM TRACKING
  // ═══════════════════════════════════════════
  const sentList = document.getElementById('sent-list')!;
  const sentFilter = document.getElementById('sent-filter') as HTMLSelectElement;
  const sentSearch = document.getElementById('sent-search') as HTMLInputElement;
  const sentSort = document.getElementById('sent-sort') as HTMLSelectElement;
  const sentLoadMore = document.getElementById('sent-load-more') as HTMLButtonElement;
  let sentOffset = 0;
  const SENT_PAGE = 30;
  let sentProspects: any[] = [];

  sentFilter.addEventListener('change', () => { sentOffset = 0; sentProspects = []; loadSentList(); });
  sentSort.addEventListener('change', () => { sentOffset = 0; sentProspects = []; loadSentList(); });
  let sentSearchTimer: ReturnType<typeof setTimeout>;
  sentSearch.addEventListener('input', () => {
    clearTimeout(sentSearchTimer);
    sentSearchTimer = setTimeout(() => { sentOffset = 0; sentProspects = []; loadSentList(); }, 300);
  });
  sentLoadMore.addEventListener('click', () => { sentOffset += SENT_PAGE; loadSentList(true); });

  async function loadSentList(append = false) {
    const status = sentFilter.value;
    const search = sentSearch.value.trim();
    const sort = sentSort.value;

    // Build query params
    let statusFilter = `status=${status}`;
    if (status === 'all_active') {
      statusFilter = 'status=in.(sent,approved,converted)';
    }
    let orderBy = 'sent_at.desc.nullslast,created_at.desc';
    if (sort === 'name') orderBy = 'name.asc';
    else if (sort === 'score') orderBy = 'fit_score.desc.nullslast';
    else if (sort === 'interaction') orderBy = 'last_interaction_at.desc.nullslast,sent_at.desc.nullslast';

    try {
      let url = `/api/recruitment-upload?${statusFilter}&limit=${SENT_PAGE}&offset=${sentOffset}&order=${orderBy}`;
      if (search) url += `&search=${encodeURIComponent(search)}`;
      const res = await fetch(url);
      const data = await res.json();
      const prospects = data.prospects || [];

      if (append) {
        sentProspects = [...sentProspects, ...prospects];
      } else {
        sentProspects = prospects;
      }

      const count = data.total || sentProspects.length;
      document.getElementById('sent-count')!.textContent = count > 0 ? `${count} total` : '';
      sentLoadMore.classList.toggle('hidden', prospects.length < SENT_PAGE);

      if (sentProspects.length === 0) {
        sentList.innerHTML = '<div class="bg-white rounded-xl border border-gray-200 p-8 text-center text-gray-400"><p class="text-sm">No outreach in this category yet.</p></div>';
        return;
      }

      renderSentCards(sentProspects);
      loadTrackingStats();
    } catch {
      sentList.innerHTML = '<div class="text-center text-red-500 text-sm py-4">Failed to load</div>';
    }
  }

  function renderSentCards(prospects: any[]) {
    sentList.innerHTML = prospects.map((p: any) => {
      const scoreColor = (p.fit_score || 0) >= 7 ? 'green' : (p.fit_score || 0) >= 4 ? 'amber' : 'red';
      const stateMatch = ['GA','OH','OK','SC','MS','MI','TX','UT','AL','LA'].includes(p.state?.toUpperCase());
      const props = p.properties || {};

      // Interaction indicators
      const indicators: string[] = [];
      if (p.sent_at) indicators.push(`<span class="text-blue-600" title="Sent ${new Date(p.sent_at).toLocaleDateString()}">📧</span>`);
      if (props.email_opened_at || p.email_opened_at) indicators.push(`<span class="text-green-600" title="Opened">👁️</span>`);
      if (props.email_clicked_at || p.email_clicked_at) indicators.push(`<span class="text-purple-600" title="Clicked">🔗</span>`);
      if (p.replied_at || props.replied_at) indicators.push(`<span class="text-indigo-600" title="Replied">💬</span>`);
      if (p.status === 'converted') indicators.push(`<span class="text-emerald-600" title="Converted">🎉</span>`);
      if (p.status === 'bounced' || props.bounced_at) indicators.push(`<span class="text-red-500" title="Bounced">⚠️</span>`);
      if (props.call_made_at) indicators.push(`<span class="text-amber-600" title="Called: ${escapeHtml(props.call_outcome || '')}">📞</span>`);

      // Stage badge
      const stage = p.interaction_stage || (p.status === 'sent' ? 'outreach_sent' : p.status);
      const stageLabels: Record<string, { label: string; color: string }> = {
        new: { label: 'New', color: 'gray' },
        outreach_sent: { label: 'Outreach Sent', color: 'blue' },
        opened: { label: 'Opened', color: 'green' },
        engaged: { label: 'Engaged', color: 'purple' },
        replied: { label: 'Replied', color: 'indigo' },
        scheduled: { label: 'Call Scheduled', color: 'amber' },
        converted: { label: 'Converted', color: 'emerald' },
        approved: { label: 'Approved', color: 'sky' },
        sent: { label: 'Sent', color: 'blue' },
        bounced: { label: 'Bounced', color: 'red' },
      };
      const stageInfo = stageLabels[stage] || { label: stage, color: 'gray' };

      return `
        <div class="bg-white rounded-xl border border-gray-200 p-4 hover:border-brand-200 transition-colors">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <h3 class="font-semibold text-gray-900 text-sm">${escapeHtml(p.name)}</h3>
                ${p.fit_score ? `<span class="text-xs font-bold text-${scoreColor}-600">${p.fit_score}/10</span>` : ''}
                <span class="text-xs bg-${stageInfo.color}-100 text-${stageInfo.color}-700 px-1.5 py-0.5 rounded font-medium">${stageInfo.label}</span>
                ${stateMatch ? '<span class="text-xs bg-green-50 text-green-600 px-1.5 py-0.5 rounded">Licensed</span>' : ''}
                ${p.research_score != null ? `<span class="text-xs ${p.research_score >= 7 ? 'bg-green-50 text-green-600' : p.research_score >= 4 ? 'bg-amber-50 text-amber-600' : 'bg-gray-50 text-gray-500'} px-1.5 py-0.5 rounded">🔍 ${p.research_score}</span>` : ''}
              </div>
              <div class="flex flex-wrap gap-x-4 gap-y-0.5 text-xs text-gray-500">
                ${p.email ? `<span class="text-brand-700 font-medium">✉️ ${escapeHtml(p.email)}</span>${p.web_presence?.carrierEmail ? ' <span class="text-red-500 text-[10px]" title="Carrier-owned domain — needs personal email">⚠️ carrier</span>' : ''}` : '<span class="text-amber-500 font-medium">📞 Phone Only</span>'}
                ${p.state ? `<span>📍 ${escapeHtml(p.state)}${p.city ? ', ' + escapeHtml(p.city) : ''}</span>` : ''}
                ${p.phone ? `<span>📞 ${escapeHtml(p.phone)}</span>` : ''}
              </div>
              ${p.fit_reason ? `<p class="text-xs text-gray-500 mt-1 italic">${escapeHtml(p.fit_reason)}</p>` : ''}
            </div>
            <div class="text-right flex-shrink-0">
              <div class="flex gap-1 justify-end mb-1">${indicators.join('')}</div>
              ${p.sent_at ? `<p class="text-xs text-gray-400">Sent ${new Date(p.sent_at).toLocaleDateString()}</p>` : ''}
              ${p.follow_up_count ? `<p class="text-xs text-gray-400">${p.follow_up_count} follow-up${p.follow_up_count > 1 ? 's' : ''}</p>` : ''}
            </div>
          </div>

          <!-- Interaction Timeline -->
          <details class="mt-3">
            <summary class="text-xs font-medium text-brand-600 cursor-pointer">Timeline & Details</summary>
            <div class="mt-2 space-y-2">
              <!-- Timeline -->
              <div class="bg-gray-50 rounded-lg p-3">
                <div class="space-y-1.5 text-xs">
                  ${p.created_at ? `<div class="flex gap-2"><span class="text-gray-400 w-24 flex-shrink-0">${new Date(p.created_at).toLocaleDateString()}</span><span class="text-gray-600">📋 Added to pipeline</span></div>` : ''}
                  ${p.processed_at ? `<div class="flex gap-2"><span class="text-gray-400 w-24 flex-shrink-0">${new Date(p.processed_at).toLocaleDateString()}</span><span class="text-gray-600">🤖 AI outreach generated</span></div>` : ''}
                  ${p.approved_at ? `<div class="flex gap-2"><span class="text-gray-400 w-24 flex-shrink-0">${new Date(p.approved_at).toLocaleDateString()}</span><span class="text-gray-600">✅ Approved${props.auto_approved ? ' (auto)' : ''}</span></div>` : ''}
                  ${p.sent_at ? `<div class="flex gap-2"><span class="text-gray-400 w-24 flex-shrink-0">${new Date(p.sent_at).toLocaleDateString()}</span><span class="text-gray-600">📧 Email sent</span></div>` : ''}
                  ${(props.email_opened_at || p.email_opened_at) ? `<div class="flex gap-2"><span class="text-gray-400 w-24 flex-shrink-0">${new Date(props.email_opened_at || p.email_opened_at).toLocaleDateString()}</span><span class="text-green-600">👁️ Email opened</span></div>` : ''}
                  ${(props.email_clicked_at || p.email_clicked_at) ? `<div class="flex gap-2"><span class="text-gray-400 w-24 flex-shrink-0">${new Date(props.email_clicked_at || p.email_clicked_at).toLocaleDateString()}</span><span class="text-purple-600">🔗 Link clicked</span></div>` : ''}
                  ${(p.replied_at || props.replied_at) ? `<div class="flex gap-2"><span class="text-gray-400 w-24 flex-shrink-0">${new Date(p.replied_at || props.replied_at).toLocaleDateString()}</span><span class="text-indigo-600">💬 Replied</span></div>` : ''}
                  ${props.call_made_at ? `<div class="flex gap-2"><span class="text-gray-400 w-24 flex-shrink-0">${new Date(props.call_made_at).toLocaleDateString()}</span><span class="text-amber-600">📞 Call: ${escapeHtml(props.call_outcome || 'unknown')}</span></div>` : ''}
                </div>
              </div>

              <!-- Email Content -->
              ${p.email_body ? `
              <div class="bg-gray-50 rounded-lg p-3">
                <p class="text-xs font-medium text-gray-500 mb-1">Subject: ${escapeHtml(p.email_subject || '')}</p>
                <p class="text-xs text-gray-600 whitespace-pre-wrap max-h-32 overflow-y-auto">${escapeHtml(p.email_body)}</p>
              </div>` : ''}

              <!-- Actions -->
              <div class="flex gap-2 flex-wrap">
                ${p.status === 'approved' && p.email ? `<button class="action-btn send-btn bg-blue-600 hover:bg-blue-700 text-white text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">📧 Send Email</button>` : ''}
                ${p.status === 'sent' ? `<button class="action-btn call-btn bg-amber-100 hover:bg-amber-200 text-amber-800 text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">📞 Mark Called</button>` : ''}
                ${p.status === 'sent' || p.status === 'approved' ? `<button class="action-btn convert-btn bg-emerald-600 hover:bg-emerald-700 text-white text-xs px-3 py-1.5 rounded-lg" data-id="${p.id}">🎉 Mark Converted</button>` : ''}
              </div>
            </div>
          </details>
        </div>`;
    }).join('');

    // Bind action buttons
    sentList.querySelectorAll('.send-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id;
        if (!confirm('Send email to this prospect?')) return;
        try {
          const res = await fetch('/api/recruitment-action', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, action: 'send_email' }),
          });
          const data = await res.json();
          if (data.error) { showToast(data.error, 'error'); return; }
          showToast('Email sent!', 'success');
          sentOffset = 0; sentProspects = []; loadSentList();
        } catch { showToast('Send failed', 'error'); }
      });
    });

    sentList.querySelectorAll('.call-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id;
        const outcome = prompt('Call outcome (no_answer, spoke, scheduled, voicemail):');
        if (!outcome) return;
        try {
          const res = await fetch('/api/recruitment-action', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, action: 'mark_called', callOutcome: outcome }),
          });
          const data = await res.json();
          if (data.error) { showToast(data.error, 'error'); return; }
          showToast('Call logged', 'success');
          sentOffset = 0; sentProspects = []; loadSentList();
        } catch { showToast('Failed', 'error'); }
      });
    });

    sentList.querySelectorAll('.convert-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id;
        try {
          const res = await fetch('/api/recruitment-action', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, action: 'approve' }),
          });
          // Then update status to converted
          await fetch('/api/recruitment-action', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, action: 'mark_called', callOutcome: 'scheduled' }),
          });
          showToast('Marked as converted!', 'success');
          sentOffset = 0; sentProspects = []; loadSentList();
        } catch { showToast('Failed', 'error'); }
      });
    });
  }

  async function loadTrackingStats() {
    try {
      const [sentRes, convertedRes] = await Promise.all([
        fetch('/api/recruitment-upload?status=sent&limit=1'),
        fetch('/api/recruitment-upload?status=converted&limit=1'),
      ]);
      const sentData = await sentRes.json();
      const convertedData = await convertedRes.json();
      document.getElementById('stat-track-sent')!.textContent = String(sentData.total || 0);
      document.getElementById('stat-track-converted')!.textContent = String(convertedData.total || 0);
      // Opened/replied/bounced would need server-side counts — show '-' until available
    } catch { /* silent */ }
  }

  // ═══════════════════════════════════════════
  // STATS
  // ═══════════════════════════════════════════
  async function refreshStats() {
    try {
      const statuses = ['pending', 'drafted', 'reviewed', 'approved', 'sent', 'converted', 'held', 'rejected'];
      const counts: Record<string, number> = {};
      let total = 0;

      for (const s of statuses) {
        const res = await fetch(`/api/recruitment-upload?status=${s}&limit=1`);
        const data = await res.json();
        counts[s] = data.total || 0;
        total += counts[s];
      }

      document.getElementById('stat-total')!.textContent = String(total);
      document.getElementById('stat-pending')!.textContent = String(counts['pending'] || 0);
      document.getElementById('stat-drafted')!.textContent = String(counts['drafted'] || 0);
      document.getElementById('stat-reviewed')!.textContent = String(counts['reviewed'] || 0);
      document.getElementById('stat-approved')!.textContent = String(counts['approved'] || 0);
      document.getElementById('stat-sent')!.textContent = String(counts['sent'] || 0);
      document.getElementById('stat-converted')!.textContent = String(counts['converted'] || 0);
    } catch { /* silent */ }
  }

  // ═══════════════════════════════════════════
  // UTILITIES
  // ═══════════════════════════════════════════
  function escapeHtml(text: string): string {
    const el = document.createElement('span');
    el.textContent = text;
    return el.innerHTML;
  }



  function getAttr(el: Element, attr: string): string {
    return el.getAttribute(attr) || '';
  }

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const toast = document.createElement('div');
    toast.className = `fixed bottom-4 right-4 max-w-md px-4 py-2 rounded-lg text-sm font-medium z-50 shadow-lg transition-opacity ${
      type === 'error' ? 'bg-red-600 text-white' : 'bg-green-600 text-white'
    }`;
    toast.textContent = message;
    document.body.appendChild(toast);
    const duration = type === 'error' ? 8000 : 3000;
    setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, duration);
  }

  // ═══════════════════════════════════════════
  // PREVIEW & TEST
  // ═══════════════════════════════════════════
  const previewAgentSelect = document.getElementById('preview-agent-select') as HTMLSelectElement;
  const previewGenerateBtn = document.getElementById('preview-generate-btn') as HTMLButtonElement;
  const previewRefreshBtn = document.getElementById('preview-refresh-btn') as HTMLButtonElement;
  const previewAgentCard = document.getElementById('preview-agent-card')!;
  const testGenerateBtn = document.getElementById('test-generate-btn') as HTMLButtonElement;
  const testOutput = document.getElementById('test-output')!;
  const testMeta = document.getElementById('test-meta')!;
  const testMetaContent = document.getElementById('test-meta-content')!;
  const testFeedbackSection = document.getElementById('test-feedback-section')!;
  const testFeedbackText = document.getElementById('test-feedback-text') as HTMLTextAreaElement;
  const testFeedbackSubmit = document.getElementById('test-feedback-submit') as HTMLButtonElement;

  let previewAgents: any[] = [];

  async function loadPreviewAgents() {
    try {
      const res = await fetch('/api/recruitment-upload?status=pending&limit=100');
      const data = await res.json();
      previewAgents = data.prospects || [];
      previewAgentSelect.innerHTML = previewAgents.length === 0
        ? '<option value="">No pending agents found</option>'
        : `<option value="">Select an agent (${previewAgents.length} pending)...</option>` +
          previewAgents.map((p: any, i: number) => {
            const score = p.research_score != null ? ` [🔍${p.research_score}]` : '';
            return `<option value="${i}">${escapeHtml(p.name)} — ${escapeHtml(p.state || '?')}, ${escapeHtml(p.city || '?')}${score}</option>`;
          }).join('');
      previewGenerateBtn.disabled = true;
    } catch {
      previewAgentSelect.innerHTML = '<option value="">Failed to load agents</option>';
    }
  }

  previewAgentSelect.addEventListener('change', () => {
    const idx = previewAgentSelect.value;
    if (idx === '') {
      previewAgentCard.classList.add('hidden');
      previewGenerateBtn.disabled = true;
      return;
    }
    const agent = previewAgents[parseInt(idx)];
    previewGenerateBtn.disabled = false;
    previewAgentCard.classList.remove('hidden');

    document.getElementById('preview-agent-name')!.textContent = agent.name;
    const scoreEl = document.getElementById('preview-agent-score')!;
    if (agent.research_score != null) {
      const color = agent.research_score >= 7 ? 'green' : agent.research_score >= 4 ? 'amber' : 'gray';
      scoreEl.textContent = `🔍 ${agent.research_score}/10`;
      scoreEl.className = `text-xs font-bold px-1.5 py-0.5 rounded bg-${color}-100 text-${color}-700`;
    } else {
      scoreEl.textContent = agent.research_status === 'unscored' ? '⏳ Unscored' : '';
      scoreEl.className = 'text-xs text-gray-400';
    }

    const details: string[] = [];
    if (agent.state) details.push(`📍 ${escapeHtml(agent.state)}${agent.city ? ', ' + escapeHtml(agent.city) : ''}`);
    if (agent.email) details.push(`✉️ ${escapeHtml(agent.email)}`);
    if (agent.phone) details.push(`📞 ${escapeHtml(agent.phone)}`);
    if (agent.experience_level && agent.experience_level !== 'unknown') details.push(`⭐ ${escapeHtml(agent.experience_level)}`);
    if (agent.current_agency) details.push(`🏢 ${escapeHtml(agent.current_agency)}`);
    if (agent.notes) details.push(`📝 ${escapeHtml(agent.notes)}`);
    document.getElementById('preview-agent-details')!.innerHTML = details.map(d => `<div>${d}</div>`).join('');

    // Research findings
    const researchSection = document.getElementById('preview-agent-research')!;
    const researchContent = document.getElementById('preview-agent-research-content')!;
    if (agent.web_presence && Object.keys(agent.web_presence).length > 0) {
      researchSection.classList.remove('hidden');
      const wp = agent.web_presence;
      const findings: string[] = [];
      if (wp.summary) findings.push(`<div class="text-gray-700">${escapeHtml(wp.summary)}</div>`);
      if (wp.linkedin) findings.push(`<div>🔗 LinkedIn: <a href="${escapeHtml(wp.linkedin)}" target="_blank" class="text-brand-600 hover:underline">${escapeHtml(wp.linkedin)}</a></div>`);
      if (wp.websites?.length) findings.push(`<div>🌐 ${wp.websites.map((u: string) => `<a href="${escapeHtml(u)}" target="_blank" class="text-brand-600 hover:underline">${escapeHtml(u)}</a>`).join(', ')}</div>`);
      if (wp.signals?.length) findings.push(`<div>📊 Signals: ${wp.signals.map((s: string) => `<span class="inline-block bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded text-xs mr-1">${escapeHtml(s)}</span>`).join('')}</div>`);
      if (wp.notes) findings.push(`<div class="italic text-gray-500">${escapeHtml(wp.notes)}</div>`);
      researchContent.innerHTML = findings.join('') || '<div class="text-gray-400 italic">No details available</div>';
    } else {
      researchSection.classList.add('hidden');
    }
  });

  previewGenerateBtn.addEventListener('click', async () => {
    const idx = previewAgentSelect.value;
    if (idx === '') return;
    const agent = previewAgents[parseInt(idx)];

    const prospect = {
      name: agent.name,
      state: agent.state,
      city: agent.city,
      experience_level: agent.experience_level,
      email: agent.email,
      phone: agent.phone,
      current_agency: agent.current_agency,
      notes: agent.notes,
      web_presence: agent.web_presence,
      research_score: agent.research_score,
    };

    previewGenerateBtn.disabled = true;
    previewGenerateBtn.textContent = '⚙️ Generating...';
    activeGenerations++;
    updateGenerationStatus();
    testOutput.innerHTML = `
      <div class="text-center py-8">
        <div class="animate-pulse text-brand-600 mb-2">
          <svg class="w-8 h-8 mx-auto animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </div>
        <p class="text-sm text-gray-600">AI is generating personalized outreach for ${escapeHtml(agent.name)}...</p>
        <p class="text-xs text-gray-400 mt-1">This takes 20-60 seconds (full inference)</p>
      </div>`;

    try {
      const feedback = loadFeedback();
      const signOff = (document.getElementById('cmp-signoff') as HTMLSelectElement)?.value || 'Legacy Financial Recruiting Team';
      const res = await fetch('/api/recruitment-preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prospect, feedback, signOff }),
      });
      if (!res.ok && res.status === 504) {
        showAiErrorBanner('Generation timed out');
        testOutput.innerHTML = `<div class="text-center py-8 text-amber-600"><p class="text-sm">⏱️ Timed out. Try again.</p></div>`;
        return;
      }
      const data = await res.json();
      if (data.error) {
        if (isAiUnavailableError(data.error)) showAiErrorBanner(data.error);
        testOutput.innerHTML = `<div class="text-center py-8 text-red-500"><p class="text-sm">${escapeHtml(data.error)}</p></div>`;
        return;
      }
      hideAiErrorBanner();
      renderPreviewOutput(data, prospect);
      testFeedbackSection.classList.remove('hidden');
      testMeta.classList.remove('hidden');
      renderMeta(data, prospect);
    } catch {
      showAiErrorBanner('Network error');
      testOutput.innerHTML = `<div class="text-center py-8 text-red-500"><p class="text-sm">Generation failed.</p></div>`;
    } finally {
      activeGenerations--;
      updateGenerationStatus();
      previewGenerateBtn.disabled = false;
      previewGenerateBtn.textContent = '🧪 Generate Preview';
    }
  });

  previewRefreshBtn.addEventListener('click', loadPreviewAgents);

  // Load preview agents when tab opens
  document.querySelector('[data-tab="preview"]')?.addEventListener('click', () => {
    if (previewAgents.length === 0) loadPreviewAgents();
  });

  // Stored feedback adjustments
  const FEEDBACK_KEY = 'legacy_recruitment_feedback';
  function loadFeedback(): string[] {
    try { return JSON.parse(localStorage.getItem(FEEDBACK_KEY) || '[]'); }
    catch { return []; }
  }
  function saveFeedback(items: string[]) {
    localStorage.setItem(FEEDBACK_KEY, JSON.stringify(items));
  }


  testGenerateBtn.addEventListener('click', () => generateSyntheticPreview());

  async function generateSyntheticPreview() {
    const prospect = {
      name: (document.getElementById('test-name') as HTMLInputElement).value.trim(),
      state: (document.getElementById('test-state') as HTMLInputElement).value.trim(),
      city: (document.getElementById('test-city') as HTMLInputElement).value.trim(),
      experience_level: (document.getElementById('test-experience') as HTMLSelectElement).value,
      email: (document.getElementById('test-email') as HTMLInputElement).value.trim(),
      phone: (document.getElementById('test-phone') as HTMLInputElement).value.trim(),
      current_agency: (document.getElementById('test-agency') as HTMLInputElement).value.trim(),
      notes: (document.getElementById('test-notes') as HTMLTextAreaElement).value.trim(),
    };

    if (!prospect.name) { showToast('Name is required', 'error'); return; }

    testGenerateBtn.disabled = true;
    testGenerateBtn.textContent = '⚙️ Generating...';
    activeGenerations++;
    updateGenerationStatus();
    testOutput.innerHTML = `
      <div class="text-center py-8">
        <div class="animate-pulse text-brand-600 mb-2">
          <svg class="w-8 h-8 mx-auto animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </div>
        <p class="text-sm text-gray-600">AI is generating personalized outreach...</p>
        <p class="text-xs text-gray-400 mt-1">This takes 20-60 seconds (full inference)</p>
      </div>`;

    try {
      const feedback = loadFeedback();
      const signOff = (document.getElementById('cmp-signoff') as HTMLSelectElement)?.value || 'Legacy Financial Recruiting Team';
      const res = await fetch('/api/recruitment-preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prospect, feedback, signOff }),
      });

      if (!res.ok && res.status === 504) {
        showAiErrorBanner('Generation timed out — the model is too slow for the server time limit');
        testOutput.innerHTML = `<div class="text-center py-8 text-amber-600"><p class="text-sm">⏱️ Generation timed out (the model took too long).</p><p class="text-xs text-gray-400 mt-1">The AI is working but too slowly for the server time limit. Try again — it may succeed on retry when the model is warmed up.</p></div>`;
        return;
      }

      const data = await res.json();

      if (data.error) {
        if (isAiUnavailableError(data.error)) {
          showAiErrorBanner(data.error);
        }
        const rawHint = data.raw ? `<details class="mt-2 text-left"><summary class="cursor-pointer text-xs text-gray-400">Show raw AI output</summary><pre class="mt-1 text-xs bg-gray-100 p-2 rounded overflow-x-auto max-h-40 whitespace-pre-wrap">${escapeHtml(data.raw)}</pre></details>` : '';
        testOutput.innerHTML = `<div class="text-center py-8 text-red-500"><p class="text-sm">${escapeHtml(data.error)}</p>${rawHint}</div>`;
        return;
      }

      hideAiErrorBanner();
      renderPreviewOutput(data, prospect);
      testFeedbackSection.classList.remove('hidden');
      testMeta.classList.remove('hidden');
      renderMeta(data, prospect);
    } catch {
      showAiErrorBanner('Network error: could not reach server');
      testOutput.innerHTML = `<div class="text-center py-8 text-red-500"><p class="text-sm">Generation failed. The AI service appears to be offline.</p></div>`;
    } finally {
      activeGenerations--;
      updateGenerationStatus();
      testGenerateBtn.disabled = false;
      testGenerateBtn.textContent = '🧪 Generate Preview';
    }
  }

