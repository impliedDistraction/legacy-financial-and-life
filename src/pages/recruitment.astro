  // ═══════════════════════════════════════════
  // CSV PARSING
  // ═══════════════════════════════════════════
  const dropZone = document.getElementById('drop-zone')!;
  const csvInput = document.getElementById('csv-input') as HTMLInputElement;
  const browseBtn = document.getElementById('browse-btn')!;
  const csvPreview = document.getElementById('csv-preview')!;
  const previewCount = document.getElementById('preview-count')!;
  const previewHeader = document.getElementById('preview-header')!;
  const previewBody = document.getElementById('preview-body')!;
  const uploadControls = document.getElementById('upload-controls')!;
  const clearCsvBtn = document.getElementById('clear-csv-btn')!;

  browseBtn.addEventListener('click', () => csvInput.click());
  dropZone.addEventListener('click', () => csvInput.click());

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-brand-400', 'bg-brand-50');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-brand-400', 'bg-brand-50');
  });
  dropZone.addEventListener('drop', (e) => {
