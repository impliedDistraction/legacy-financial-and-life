  // ═══════════════════════════════════════════
  // CAMPAIGNS MANAGEMENT
  // ═══════════════════════════════════════════
  let campaignsCache: any[] = [];

  async function loadCampaigns() {
    const list = document.getElementById('campaign-list');
    if (!list) return;
    try {
      const res = await fetch('/api/recruitment-campaigns');
      const data = await res.json();
      campaignsCache = data.campaigns || [];
      renderCampaigns();
      loadLiveFeed();
      refreshPoolStats();
    } catch (err) {
      list.innerHTML = '<div class="text-sm text-red-500 text-center py-4">Failed to load searches</div>';
    }
  }

  function renderCampaigns() {
    const list = document.getElementById('campaign-list');
    if (!list) return;
    if (campaignsCache.length === 0) {
      list.innerHTML = '<div class="text-sm text-gray-500 text-center py-8">No campaigns yet. Click "+ New Campaign" to start finding and reaching agents.</div>';
      return;
    }

    const activeCampaigns = campaignsCache.filter(c => c.status === 'active' || c.status === 'paused');
    const pastCampaigns = campaignsCache.filter(c => c.status === 'completed');

    function renderCard(c: any, isPast: boolean) {
      const statusColor = c.status === 'active' ? 'green' : c.status === 'paused' ? 'amber' : 'gray';
      const counts = c.prospect_counts || {};
      const totalFound = Object.values(counts).reduce((a: number, b: any) => a + (b || 0), 0);
      const totalSent = (counts.sent || 0) + (counts.converted || 0) + (counts.bounced || 0);
      const goal = c.credit_budget || 100;
      const progressPct = goal > 0 ? Math.round((totalSent / goal) * 100) : 0;
      const lastRun = c.last_run_at ? new Date(c.last_run_at).toLocaleString() : 'Never';
      const nextRun = c.next_run_at ? new Date(c.next_run_at).toLocaleString() : 'Queued';
      const relaunchBadge = c.auto_relaunch
        ? '<span class="text-xs bg-purple-50 text-purple-600 px-1.5 py-0.5 rounded">Continuous</span>'
        : '';

      const actionButtons = isPast ? '' : `
              <button class="text-xs text-brand-600 hover:text-brand-800 font-medium" data-campaign-action="${c.status === 'active' ? 'pause' : 'resume'}" data-campaign-id="${c.id}" title="${c.status === 'active' ? 'Pause' : 'Resume'}">${c.status === 'active' ? '⏸' : '▶'}</button>
              <button class="text-xs text-red-500 hover:text-red-700 font-medium" data-campaign-action="stop" data-campaign-id="${c.id}" title="Stop campaign">⏹</button>`;

      return `
        <div class="bg-white rounded-xl border border-gray-200 p-4 ${isPast ? 'opacity-75' : 'hover:border-brand-300'} transition-colors">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h3 class="font-semibold text-gray-900">${escapeHtml(c.name)}</h3>
              <p class="text-xs text-gray-500 mt-0.5">🔍 Prophog · ${escapeHtml(c.search_state)}${c.search_filters?.onlyNewAgents ? ' · 🆕 New Agents' : ''}${c.search_filters?.licenseEffectiveFrom ? ' · 📅 ' + escapeHtml(c.search_filters.licenseEffectiveFrom) : ''}</p>
            </div>
            <div class="flex items-center gap-2">
              ${relaunchBadge}
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-${statusColor}-100 text-${statusColor}-700">${c.status}</span>
              ${actionButtons}
            </div>
          </div>
          <!-- Outreach Progress -->
          <div class="mb-3">
            <div class="flex items-center justify-between text-xs mb-1">
              <span class="text-gray-600 font-medium">${totalSent} / ${goal} outreaches sent</span>
              <span class="text-gray-400">${progressPct}%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="${progressPct >= 90 ? 'bg-green-500' : progressPct >= 50 ? 'bg-brand-600' : 'bg-blue-500'} h-2 rounded-full transition-all" style="width: ${Math.min(100, progressPct)}%"></div>
            </div>
          </div>
          <!-- Pipeline mini-stats -->
          <div class="grid grid-cols-5 gap-1 text-center mb-3">
            <div><div class="text-sm font-bold text-gray-900">${totalFound}</div><div class="text-[10px] text-gray-400">Found</div></div>
            <div><div class="text-sm font-bold text-amber-600">${counts.pending || 0}</div><div class="text-[10px] text-gray-400">Pending</div></div>
            <div><div class="text-sm font-bold text-blue-600">${(counts.drafted || 0) + (counts.reviewed || 0)}</div><div class="text-[10px] text-gray-400">Pipeline</div></div>
            <div><div class="text-sm font-bold text-emerald-600">${counts.approved || 0}</div><div class="text-[10px] text-gray-400">Ready</div></div>
            <div><div class="text-sm font-bold text-green-600">${totalSent}</div><div class="text-[10px] text-gray-400">Sent</div></div>
          </div>
          <div class="flex items-center justify-between text-xs text-gray-400">
            <span>Last: ${lastRun}</span>
            ${isPast ? `<span>Ended: ${c.updated_at ? new Date(c.updated_at).toLocaleString() : '—'}</span>` : `<span>Next: ${nextRun}</span>`}
          </div>
        </div>`;
    }

    let html = '';
    if (activeCampaigns.length > 0) {
      html += activeCampaigns.map(c => renderCard(c, false)).join('');
    } else {
      html += '<div class="text-sm text-gray-500 text-center py-4">No active campaigns. Launch one to start finding and reaching agents.</div>';
    }

    if (pastCampaigns.length > 0) {
      html += `<div class="mt-6 mb-3"><h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Past Campaigns</h3></div>`;
      html += pastCampaigns.map(c => renderCard(c, true)).join('');
    }

    list.innerHTML = html;

    // Wire action buttons
    list.querySelectorAll('[data-campaign-action]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const el = e.currentTarget as HTMLElement;
        const action = el.dataset.campaignAction;
        const id = el.dataset.campaignId;
        if (action === 'stop' && !confirm('Stop this campaign? It will be moved to Past Campaigns.')) return;
        try {
          await fetch('/api/recruitment-campaigns', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action, id }),
          });
          loadCampaigns();
        } catch (err) {
          console.error('Campaign action failed:', err);
        }
      });
    });
  }

  async function loadLiveFeed() {
    const feed = document.getElementById('live-feed');
    if (!feed) return;
    try {
      const res = await fetch('/api/recruitment-upload?limit=20');
      if (!res.ok) throw new Error(`${res.status}`);
      const data = await res.json();
      const prospects = data.prospects || [];
      if (prospects.length === 0) {
        feed.innerHTML = '<div class="text-xs text-gray-400 text-center py-4">No leads yet</div>';
        return;
      }
      feed.innerHTML = prospects.map((p: any) => {
        const scoreEmoji = p.research_score >= 7 ? '🌟' : p.research_score >= 4 ? '✅' : p.research_status === 'unscored' ? '⏳' : '📋';
        const scoreText = p.research_score != null ? `${p.research_score}/10` : 'unscored';
        const time = new Date(p.created_at).toLocaleString(undefined, { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
        return `
          <div class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 text-xs">
            <span class="text-base">${scoreEmoji}</span>
            <div class="flex-1 min-w-0">
              <div class="font-medium text-gray-900 truncate">${escapeHtml(p.name)}</div>
              <div class="text-gray-500">${escapeHtml(p.city || '')}${p.city && p.state ? ', ' : ''}${escapeHtml(p.state || '')} · ${scoreText}</div>
            </div>
            <div class="text-gray-400 whitespace-nowrap">${time}</div>
          </div>`;
      }).join('');
    } catch {
      feed.innerHTML = '<div class="text-xs text-red-400 text-center py-4">Failed to load</div>';
    }
  }

  // ═══════════════════════════════════════════
  // POOL STATS
  // ═══════════════════════════════════════════
  async function refreshPoolStats() {
    try {
      const statuses = ['pending', 'drafted', 'reviewed', 'approved', 'held', 'sent', 'converted', 'rejected'];
      const sources = ['prophog_scrape', 'csv_import', 'landing_page'];
      const fetches = [
        ...statuses.map(s => fetch(`/api/recruitment-upload?status=${s}&limit=1`).then(r => r.json()).then(d => ({ key: s, count: d.total || 0 }))),
        ...sources.map(s => fetch(`/api/recruitment-upload?limit=1&source=${s}`).then(r => r.json()).then(d => ({ key: `src-${s}`, count: d.total || 0 }))),
      ];
      const results = await Promise.all(fetches);
      const counts: Record<string, number> = {};
      let total = 0;
      for (const r of results) {
        counts[r.key] = r.count;
        if (!r.key.startsWith('src-')) total += r.count;
      }
      const setEl = (id: string, val: number) => {
        const el = document.getElementById(id);
        if (el) el.textContent = String(val);
      };
      setEl('pool-total', total);
      setEl('pool-pending', counts['pending'] || 0);
      setEl('pool-drafted', counts['drafted'] || 0);
      setEl('pool-reviewed', counts['reviewed'] || 0);
      setEl('pool-approved', counts['approved'] || 0);
      setEl('pool-sent', counts['sent'] || 0);
      setEl('pool-converted', counts['converted'] || 0);
      setEl('pool-rejected', counts['rejected'] || 0);
      setEl('pool-src-prophog', counts['src-prophog_scrape'] || 0);
      setEl('pool-src-csv', counts['src-csv_import'] || 0);
      setEl('pool-src-landing', counts['src-landing_page'] || 0);
    } catch { /* silent */ }
  }

