                    return `<a href="${escapeHtml(s.url)}" target="_blank" rel="noopener" title="${tooltip}" class="inline-flex items-center gap-1 ${borderColor} border ${textColor} hover:opacity-80 px-2 py-0.5 rounded-full transition-colors">${icon} ${label}${confidence}</a>`;
