    if (file) handleFile(file);
  });

  csvInput.addEventListener('change', () => {
    if (csvInput.files?.[0]) handleFile(csvInput.files[0]);
  });

  clearCsvBtn.addEventListener('click', () => {
    csvData = [];
    csvHeaders = [];
    csvPreview.classList.add('hidden');
    uploadControls.classList.add('hidden');
    dropZone.classList.remove('hidden');
  });

  function handleFile(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const text = e.target?.result as string;
      parseCSV(text);
    };
    reader.readAsText(file);
  }

  function parseCSV(text: string) {
    const lines = text.split(/\r?\n/).filter(l => l.trim());
    if (lines.length < 2) return;

    // Detect delimiter
    const firstLine = lines[0];
    const delimiter = firstLine.includes('\t') ? '\t' : ',';

    csvHeaders = parseLine(firstLine, delimiter);
    csvData = [];

    for (let i = 1; i < lines.length && csvData.length < 500; i++) {
      const values = parseLine(lines[i], delimiter);
      const row: Record<string, string> = {};
      csvHeaders.forEach((h, idx) => { row[h] = values[idx] || ''; });
      if (Object.values(row).some(v => v.trim())) csvData.push(row);
    }

    renderPreview();
  }

  function parseLine(line: string, delimiter: string): string[] {
    const result: string[] = [];
    let current = '';
    let inQuotes = false;
    for (const char of line) {
      if (char === '"') { inQuotes = !inQuotes; continue; }
      if (char === delimiter && !inQuotes) { result.push(current.trim()); current = ''; continue; }
      current += char;
    }
    result.push(current.trim());
    return result;
  }

  function renderPreview() {
    previewCount.textContent = String(csvData.length);
    previewHeader.innerHTML = csvHeaders.map(h => `<th class="px-2 py-1.5 text-left font-medium text-gray-600 border-b">${escapeHtml(h)}</th>`).join('');
    previewBody.innerHTML = csvData.slice(0, 10).map(row =>
      `<tr class="border-b border-gray-100">${csvHeaders.map(h => `<td class="px-2 py-1.5 text-gray-700 whitespace-nowrap max-w-[150px] truncate">${escapeHtml(row[h] || '')}</td>`).join('')}</tr>`
    ).join('');
    if (csvData.length > 10) {
      previewBody.innerHTML += `<tr><td colspan="${csvHeaders.length}" class="px-2 py-2 text-gray-400 text-center">...and ${csvData.length - 10} more</td></tr>`;
    }

    dropZone.classList.add('hidden');
    csvPreview.classList.remove('hidden');
    uploadControls.classList.remove('hidden');
    renderColumnMapping();
  }

  function renderColumnMapping() {
    const mapEl = document.getElementById('column-mapping')!;
    const knownFields = ['name', 'email', 'phone', 'state', 'city', 'experience', 'agency', 'notes'];
    const normalizedHeaders = csvHeaders.map(h => h.toLowerCase().replace(/[^a-z0-9]/g, ''));

    // Auto-detect mapping
    columnMap = {};
    knownFields.forEach(field => {
      const idx = normalizedHeaders.findIndex(h =>
        h === field || h.includes(field) ||
        (field === 'name' && (h.includes('first') || h.includes('full') || h === 'name')) ||
        (field === 'phone' && (h.includes('phone') || h.includes('cell') || h.includes('mobile'))) ||
        (field === 'agency' && (h.includes('agency') || h.includes('company') || h.includes('employer'))) ||
        (field === 'experience' && (h.includes('exp') || h.includes('years') || h.includes('level')))
      );
      if (idx !== -1) columnMap[field] = csvHeaders[idx];
    });

    mapEl.innerHTML = knownFields.map(field => `
      <div>
        <label class="text-xs font-medium text-gray-600 capitalize">${field}</label>
        <select class="field-map w-full mt-0.5 text-xs border border-gray-300 rounded px-2 py-1" data-field="${field}">
          <option value="">— skip —</option>
          ${csvHeaders.map(h => `<option value="${escapeHtml(h)}" ${columnMap[field] === h ? 'selected' : ''}>${escapeHtml(h)}</option>`).join('')}
        </select>
      </div>
    `).join('');

    mapEl.querySelectorAll('.field-map').forEach(sel => {
      sel.addEventListener('change', () => {
        const field = (sel as HTMLSelectElement).dataset.field!;
        const value = (sel as HTMLSelectElement).value;
        if (value) columnMap[field] = value;
        else delete columnMap[field];
      });
    });
  }

  // ═══════════════════════════════════════════
  // UPLOAD
  // ═══════════════════════════════════════════
  const uploadBtn = document.getElementById('upload-btn') as HTMLButtonElement;
  const campaignNameInput = document.getElementById('campaign-name') as HTMLInputElement;

  uploadBtn.addEventListener('click', async () => {
    if (csvData.length === 0) return;
    uploadBtn.disabled = true;
    uploadBtn.textContent = 'Uploading...';

    // Map CSV data to normalized prospect format
    const prospects = csvData.map(row => ({
      name: row[columnMap['name']] || Object.values(row)[0] || 'Unknown',
      email: row[columnMap['email']] || null,
      phone: row[columnMap['phone']] || null,
      state: row[columnMap['state']] || null,
      city: row[columnMap['city']] || null,
      experience_level: row[columnMap['experience']] || null,
      current_agency: row[columnMap['agency']] || null,
      notes: row[columnMap['notes']] || null,
    }));

    try {
      const res = await fetch('/api/recruitment-upload', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          prospects,
          campaignName: campaignNameInput.value.trim() || `Upload ${new Date().toLocaleDateString()}`,
        }),
      });

      const data = await res.json();
      if (data.success) {
        showToast(`✓ Uploaded ${data.uploaded} prospects to "${data.campaignName}"`);
        // Switch to Review tab showing pending prospects
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        const reviewBtn = document.querySelector('[data-tab="review"]');
        reviewBtn?.classList.add('active');
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
        document.getElementById('tab-review')?.classList.remove('hidden');
        reviewFilter.value = 'pending';
        currentOffset = 0;
        loadReviewList();
        refreshStats();
      } else {
        showToast(`Error: ${data.error}`, 'error');
      }
    } catch {
      showToast('Upload failed. Check connection.', 'error');
    } finally {
      uploadBtn.disabled = false;
      uploadBtn.textContent = 'Upload Campaign';
    }
  });

  // ═══════════════════════════════════════════
  // PROCESSING (batch, sequential)
  // ═══════════════════════════════════════════
  const processingStatus = document.getElementById('processing-status')!;
  const processBar = document.getElementById('process-bar')!;
  const processProgress = document.getElementById('process-progress')!;
  const processStatusText = document.getElementById('process-status-text')!;

  async function startProcessing(_campaignId: string, total: number) {
    processingStatus.classList.remove('hidden');
    let processed = 0;

    while (processed < total) {
      processStatusText.textContent = `Processing batch ${Math.floor(processed / 5) + 1}...`;
      processProgress.textContent = `${processed}/${total}`;
      processBar.style.width = `${(processed / total) * 100}%`;

      try {
        const res = await fetch('/api/recruitment-process', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ limit: 5 }),
        });
        if (!res.ok && res.status === 504) {
          processStatusText.textContent = 'Generation timed out — model too slow. Retrying...';
          continue;
        }
        const data = await res.json();
        processed += data.processed || 0;
        if ((data.processed || 0) === 0) break; // No more pending
      } catch {
        processStatusText.textContent = 'Processing error — will retry...';
        break;
      }
    }

    processProgress.textContent = `${processed}/${total}`;
    processBar.style.width = '100%';
    processStatusText.textContent = `Done! ${processed} prospects processed.`;
    refreshStats();
  }

  // ═══════════════════════════════════════════
  // REVIEW LIST
  // ═══════════════════════════════════════════
  const reviewList = document.getElementById('review-list')!;
  const reviewFilter = document.getElementById('review-filter') as HTMLSelectElement;
  const processBatchBtn = document.getElementById('process-batch-btn') as HTMLButtonElement;
  const approveAllBtn = document.getElementById('approve-all-btn') as HTMLButtonElement;
  const loadMoreBtn = document.getElementById('load-more-btn') as HTMLButtonElement;

  reviewFilter.addEventListener('change', () => { currentOffset = 0; loadReviewList(); });

  // Wire stage pill buttons to the hidden select
  const stageBtns = document.querySelectorAll('.review-stage-btn') as NodeListOf<HTMLButtonElement>;
  function updateStageBtnStyles() {
    const active = reviewFilter.value;
    stageBtns.forEach(btn => {
      const stage = btn.getAttribute('data-stage');
      if (stage === active) {
        btn.classList.add('border-brand-500', 'bg-brand-50', 'text-brand-700');
        btn.classList.remove('border-gray-200', 'bg-white', 'text-gray-600', 'hover:bg-gray-50');
      } else {
        btn.classList.remove('border-brand-500', 'bg-brand-50', 'text-brand-700');
        btn.classList.add('border-gray-200', 'bg-white', 'text-gray-600', 'hover:bg-gray-50');
      }
    });
  }
  stageBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const stage = btn.getAttribute('data-stage') || 'pending';
      reviewFilter.value = stage;
      currentOffset = 0;
      updateStageBtnStyles();
      loadReviewList();
    });
  });

  // Refresh pipeline stage counts
  async function refreshReviewStageCounts() {
    const stages = ['pending', 'drafted', 'reviewed', 'approved', 'held', 'rejected'];
    await Promise.all(stages.map(async (s) => {
      try {
        const res = await fetch(`/api/recruitment-upload?status=${s}&limit=0`);
        const data = await res.json();
        const el = document.querySelector(`.review-stage-count[data-count="${s}"]`);
        if (el) el.textContent = String(data.total || 0);
      } catch { /* silent */ }
    }));
  }

  processBatchBtn.addEventListener('click', async () => {
    processBatchBtn.disabled = true;
    processBatchBtn.textContent = '⚡ Generating...';
    activeGenerations++;
    updateGenerationStatus();
    try {
      const res = await fetch('/api/recruitment-process', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ limit: 1 }),
      });
      if (!res.ok && res.status === 504) {
        showAiErrorBanner('Generation timed out — the model is too slow for the server time limit');
        showToast('Generation timed out — try again (model may be warmed up now)', 'error');
        loadReviewList();
        refreshStats();
        return;
      }
      const data = await res.json();
      if (data.error) {
        if (isAiUnavailableError(data.error)) {
          showAiErrorBanner(data.error);
        }
        showToast(`Error: ${data.error}`, 'error');
      } else if (data.processed > 0) {
        hideAiErrorBanner();
        showToast(`Generated outreach for ${data.processed} prospect`);
      } else if (data.failed > 0) {
        const reason = data.failReason || 'unknown error';
        if (isAiUnavailableError(reason)) {
          showAiErrorBanner(reason);
        }
        showToast(`AI failed: ${reason}. Try again.`, 'error');
      } else {
        showToast('No pending prospects to process');
      }
      loadReviewList();
      refreshStats();
    } catch {
      showAiErrorBanner('Network error: could not reach server');
      showToast('Processing failed — check connection', 'error');
    } finally {
      activeGenerations--;
      updateGenerationStatus();
      processBatchBtn.disabled = false;
      processBatchBtn.textContent = '⚡ Generate Next';
    }
  });

  async function loadReviewList() {
    const status = reviewFilter.value;
    // Show/hide contextual buttons
    approveAllBtn.classList.toggle('hidden', status !== 'reviewed');
    processBatchBtn.classList.toggle('hidden', status !== 'pending');
    updateStageBtnStyles();
    try {
      const res = await fetch(`/api/recruitment-upload?status=${status}&limit=${PAGE_SIZE}&offset=${currentOffset}`);
      const data = await res.json();
      const count = data.total || data.prospects?.length || 0;
      document.getElementById('review-count')!.textContent = count > 0 ? `${count} total` : '';
      renderReviewCards(data.prospects || [], status);
      loadMoreBtn.classList.toggle('hidden', (data.prospects?.length || 0) < PAGE_SIZE);
    } catch {
      reviewList.innerHTML = '<div class="text-center text-red-500 text-sm py-4">Failed to load prospects</div>';
    }
    // Refresh stage counts in background
    refreshReviewStageCounts();
  }

  loadMoreBtn.addEventListener('click', () => { currentOffset += PAGE_SIZE; loadReviewList(); });

  function renderReviewCards(prospects: any[], status: string) {
    if (prospects.length === 0) {
      const msg = status === 'pending' ? 'No pending prospects. Upload a CSV to add agents.' : `No prospects with status "${status}"`;
      reviewList.innerHTML = `<div class="bg-white rounded-xl border border-gray-200 p-8 text-center text-gray-400"><p class="text-sm">${msg}</p></div>`;
      return;
    }

    reviewList.innerHTML = prospects.map(p => {
      const scoreColor = (p.fit_score || 0) >= 7 ? 'green' : (p.fit_score || 0) >= 4 ? 'amber' : 'red';
      const stateMatch = ['GA','OH','OK','SC','MS','MI','TX','UT','AL','LA'].includes(p.state?.toUpperCase());

      return `
        <div class="bg-white rounded-xl border border-gray-200 p-4 prospect-card" data-id="${p.id}">
          <div class="flex items-start justify-between gap-3">
