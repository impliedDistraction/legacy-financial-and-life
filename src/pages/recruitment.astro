            <span class="text-xs text-gray-400">To:</span>
            <span class="text-xs font-medium">${escapeHtml(prospect.name)} &lt;${escapeHtml(prospect.email || 'no email')}&gt;</span>
          </div>
          <div class="bg-gray-50 px-4 py-2 border-b border-gray-200 flex items-center gap-2">
            <span class="text-xs text-gray-400">Reply-To:</span>
            <span class="text-xs text-gray-600">tim@legacyf-l.com</span>
          </div>
          <div class="bg-gray-50 px-4 py-2 border-b border-gray-200 flex items-center gap-2">
            <span class="text-xs text-gray-400">Subject:</span>
            <span class="text-xs font-bold text-gray-800">${escapeHtml(data.email?.subject || '(no subject)')}</span>
          </div>
          <div class="px-4 py-3 text-sm text-gray-700 whitespace-pre-wrap leading-relaxed">${escapeHtml(data.email?.body || '(no body)')}</div>
        </div>

        <!-- Send status -->
        <div class="bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
          <p class="text-xs text-amber-800 font-medium">🔒 Sending is locked — client review in progress</p>
          <p class="text-xs text-amber-600 mt-0.5">${hasEmail ? 'This email will NOT be sent until content is approved.' : 'No email address on file — outreach will be phone-only.'}</p>
        </div>

        <!-- Call Script Preview -->
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <div class="bg-amber-50 px-4 py-2 border-b border-gray-200 flex items-center justify-between">
            <span class="text-xs font-semibold text-amber-800">📞 Call Script (30-second opener)</span>
            <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">AI-Generated Draft</span>
          </div>
          <div class="px-4 py-3 text-sm text-gray-700 whitespace-pre-wrap">${escapeHtml(data.callScript?.opener || '(no script)')}</div>
          ${data.callScript?.voicemail ? `
          <div class="bg-gray-50 px-4 py-2 border-t border-gray-200">
            <span class="text-xs font-semibold text-gray-500">📱 Voicemail</span>
          </div>
          <div class="px-4 py-3 text-xs text-gray-600 whitespace-pre-wrap">${escapeHtml(data.callScript.voicemail)}</div>` : ''}
          <div class="bg-blue-50 px-4 py-2 border-t border-gray-200">
            <p class="text-xs text-blue-700">ℹ️ Client's custom call script will replace this AI draft once provided. Phone agent will follow the approved script.</p>
