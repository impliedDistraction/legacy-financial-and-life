<script>
  // ═══════════════════════════════════════════
  // STATE
  // ═══════════════════════════════════════════
  let csvData: Record<string, string>[] = [];
  let csvHeaders: string[] = [];
  let columnMap: Record<string, string> = {};
  let currentOffset = 0;
  const PAGE_SIZE = 20;
  let activeGenerations = 0;
  let lastAiError: string | null = null;

  function updateGenerationStatus() {
    const badge = document.getElementById('ai-busy-badge');
    if (!badge) return;
    if (activeGenerations > 0) {
      badge.textContent = `🤖 AI working (${activeGenerations} in queue)`;
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  }

  function isAiUnavailableError(msg: string): boolean {
    const lower = msg.toLowerCase();
    return lower.includes('system memory') ||
           lower.includes('connection refused') ||
           lower.includes('network error') ||
           lower.includes('econnrefused') ||
           lower.includes('model requires more') ||
           lower.includes('ollama returned 5') ||
           lower.includes('fetch failed') ||
           lower.includes('model not found') ||
           lower.includes('timed out');
  }

  function showAiErrorBanner(reason: string) {
    const banner = document.getElementById('ai-error-banner');
    const detail = document.getElementById('ai-error-detail');
    if (!banner || !detail) return;
    lastAiError = reason;
    // Make the reason user-friendly
    let friendly = 'The AI model is not responding. Generation buttons will not work until the service is back online.';
    if (reason.includes('timed out') || reason.includes('too slow')) {
      friendly = 'The AI model is responding but too slowly for the server time limit. Try again — the model may be faster once warmed up.';
    } else if (reason.includes('system memory') || reason.includes('memory')) {
      friendly = 'The AI model requires more memory than is currently available on the server. Try restarting the AI server or freeing resources.';
    } else if (reason.includes('connection refused') || reason.includes('ECONNREFUSED') || reason.includes('fetch failed')) {
      friendly = 'Cannot connect to the AI server. Make sure OpenClaw/Ollama is running.';
    } else if (reason.includes('model not found')) {
      friendly = 'The AI model is not loaded. Make sure the model is pulled on the Ollama server.';
    }
    detail.textContent = friendly;
    banner.classList.remove('hidden');
  }

