    const scoreColor = (data.fitScore || 0) >= 7 ? 'green' : (data.fitScore || 0) >= 4 ? 'amber' : 'red';
    const isTestDomain = prospect.email?.endsWith('@test.legacy');
    const hasEmail = prospect.email && !isTestDomain;

    testOutput.innerHTML = `
      <div class="space-y-4">
        <!-- Header -->
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-lg font-bold text-${scoreColor}-600">${data.fitScore || '?'}/10</span>
            <span class="text-xs text-gray-500">Fit Score</span>
          </div>
          ${isTestDomain ? '<span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full font-medium">🧪 TEST MODE</span>' : ''}
        </div>
        ${data.fitReason ? `<p class="text-xs text-gray-600 italic">${escapeHtml(data.fitReason)}</p>` : ''}
        ${data.personalNotes ? `<p class="text-xs text-blue-600 bg-blue-50 p-2 rounded">💡 <strong>Note to Tim:</strong> ${escapeHtml(data.personalNotes)}</p>` : ''}

