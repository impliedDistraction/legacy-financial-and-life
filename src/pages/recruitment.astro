                    const desigs = (cred.designations || []).map((d: any) => `<span class="inline-block bg-white border border-blue-200 text-blue-700 px-1.5 py-0.5 rounded text-xs font-medium" title="${escapeHtml(d.label)}">${escapeHtml(d.code)}</span>`).join(' ');
