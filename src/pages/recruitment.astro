  function renderMeta(data: any, prospect: any) {
    const isLicensedState = ['GA','OH','OK','SC','MS','MI','TX','UT','AL','LA'].includes(prospect.state?.toUpperCase());
    testMetaContent.innerHTML = `
      <div class="grid grid-cols-2 gap-x-4 gap-y-1">
        <span class="text-gray-500">Test domain:</span><span class="${prospect.email?.endsWith('@test.legacy') ? 'text-purple-600 font-medium' : 'text-gray-700'}">${prospect.email?.endsWith('@test.legacy') ? 'Yes (no send)' : 'Live email!'}</span>
        <span class="text-gray-500">Licensed state:</span><span class="${isLicensedState ? 'text-green-600' : 'text-gray-700'}">${isLicensedState ? '✓ Yes' : '✗ No'}</span>
        <span class="text-gray-500">Fit score:</span><span>${data.fitScore || '?'}/10</span>
        <span class="text-gray-500">Active feedback:</span><span>${loadFeedback().length} adjustment${loadFeedback().length !== 1 ? 's' : ''}</span>
      </div>
      <div class="mt-2 pt-2 border-t border-gray-200">
        <p class="text-gray-500 mb-1">Prompt adjustments active:</p>
        ${loadFeedback().length > 0 ? `<ul class="list-disc list-inside text-gray-700">${loadFeedback().map(f => `<li>${escapeHtml(f)}</li>`).join('')}</ul>` : '<p class="text-gray-400 italic">None yet — use feedback below to adjust</p>'}
      </div>`;
  }

  // Feedback chips
  document.querySelectorAll('.feedback-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      chip.classList.toggle('bg-brand-100');
      chip.classList.toggle('border-brand-400');
      chip.classList.toggle('text-brand-700');
    });
  });

  testFeedbackSubmit.addEventListener('click', async () => {
    const chips = Array.from(document.querySelectorAll('.feedback-chip.bg-brand-100'))
      .map(el => (el as HTMLElement).dataset.feedback!)
      .filter(Boolean);
    const freetext = testFeedbackText.value.trim();

    const feedbackItems: string[] = [];
    if (chips.includes('more-personal')) feedbackItems.push('Make emails more personal and specific to the prospect');
    if (chips.includes('shorter')) feedbackItems.push('Keep emails under 150 words');
    if (chips.includes('more-direct')) feedbackItems.push('Include a stronger, more direct call-to-action');
    if (chips.includes('less-formal')) feedbackItems.push('Use a more casual, conversational tone');
    if (chips.includes('mention-ai')) feedbackItems.push('Always mention the AI-powered tools and technology stack');
    if (chips.includes('mention-training')) feedbackItems.push('Emphasize weekly training sessions and mentorship');
    if (freetext) feedbackItems.push(freetext);

    if (feedbackItems.length === 0) { showToast('Select or type feedback first', 'error'); return; }

    // Merge with existing feedback (dedupe)
    const existing = loadFeedback();
    const merged = [...new Set([...existing, ...feedbackItems])];
    saveFeedback(merged);

    showToast(`Saved ${feedbackItems.length} feedback adjustment${feedbackItems.length > 1 ? 's' : ''}. Regenerating...`);

    // Clear chip selections
    document.querySelectorAll('.feedback-chip.bg-brand-100').forEach(el => {
      el.classList.remove('bg-brand-100', 'border-brand-400', 'text-brand-700');
    });
    testFeedbackText.value = '';

    // Regenerate with new feedback — use real agent if selected, otherwise synthetic
    if (previewAgentSelect.value) {
      previewGenerateBtn.click();
    } else {
      await generateSyntheticPreview();
    }
  });

  // Initial load
  refreshStats();

  // Clickable stats → navigate to relevant tab + filter
  document.querySelectorAll('[data-stat-tab]').forEach(el => {
    el.addEventListener('click', () => {
      const tab = (el as HTMLElement).dataset.statTab!;
      const filter = (el as HTMLElement).dataset.statFilter!;
      // Switch tab
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelector(`[data-tab="${tab}"]`)?.classList.add('active');
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
      // Set filter and load
      if (tab === 'review') {
        reviewFilter.value = filter;
        currentOffset = 0;
        loadReviewList();
      } else if (tab === 'sent') {
        sentFilter.value = filter;
        loadSentList();
      }
    });
  });

  // Auto-switch to Review tab if there are pending/drafted prospects
  (async () => {
    try {
      const res = await fetch('/api/recruitment-upload?status=pending&limit=1');
      const data = await res.json();
      if ((data.total || 0) > 0) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelector('[data-tab="review"]')?.classList.add('active');
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
        document.getElementById('tab-review')?.classList.remove('hidden');
        loadReviewList();
      }
    } catch { /* ignore — stays on upload tab */ }
  })();

  // ═══════════════════════════════════════════
  // PIPELINE TAB
  // ═══════════════════════════════════════════

  async function loadPipelineStatus() {
    const statsEl = document.getElementById('pipeline-stats');
    const listEl = document.getElementById('ready-to-send-list');
    if (!statsEl) return;

    try {
      // Fetch counts for each status
      const statuses = ['pending', 'drafted', 'reviewed', 'approved', 'sent', 'rejected'];
      const counts: Record<string, number> = {};

      await Promise.all(statuses.map(async (s) => {
        const res = await fetch(`/api/recruitment-upload?status=${s}&limit=0`);
        const data = await res.json();
        counts[s] = data.total || 0;
      }));

      const stages = [
        { key: 'pending', label: '⏳ Pending (need outreach)', color: 'text-gray-600' },
        { key: 'drafted', label: '📝 Drafted (awaiting QA)', color: 'text-blue-600' },
        { key: 'reviewed', label: '✅ Reviewed (QA passed)', color: 'text-green-600' },
        { key: 'approved', label: '👍 Approved (ready to send)', color: 'text-emerald-600' },
        { key: 'sent', label: '📧 Sent', color: 'text-purple-600' },
        { key: 'rejected', label: '❌ Rejected', color: 'text-red-600' },
      ];

      statsEl.innerHTML = stages.map(s => `
        <div class="flex items-center justify-between py-1 border-b border-gray-100 last:border-0">
          <span class="text-sm ${s.color}">${s.label}</span>
          <span class="text-sm font-semibold ${s.color}">${counts[s.key] || 0}</span>
        </div>
      `).join('') + `
        <div class="pt-2 text-xs text-gray-400">
          Flow: Pending → Drafted → [QA] → Reviewed → Approved → Sent<br>
          Cron loop: every 90s • Outreach: 3/loop • QA: 50/loop • Review: 20/loop
        </div>
      `;
    } catch (err) {
      statsEl.innerHTML = `<div class="text-sm text-red-500">Failed to load: ${err}</div>`;
    }

    // Load ready-to-send prospects
    if (listEl) {
      try {
        const res = await fetch('/api/recruitment-upload?status=reviewed&limit=20&sort=recent');
        const data = await res.json();
        const prospects = data.prospects || [];

        if (prospects.length === 0) {
          listEl.innerHTML = '<div class="text-sm text-gray-400">No prospects ready to send yet. The pipeline is working on it.</div>';
        } else {
          listEl.innerHTML = prospects.map((p: any) => `
            <div class="border border-gray-100 rounded-lg p-3 hover:border-brand-200 transition-colors">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-medium text-gray-900">${p.name || 'Unknown'}</span>
                <span class="text-xs px-1.5 py-0.5 rounded ${p.fit_score >= 7 ? 'bg-green-100 text-green-700' : p.fit_score >= 5 ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600'}">${p.fit_score || '?'}/10</span>
              </div>
              <div class="text-xs text-gray-500">${p.state || ''} ${p.city ? '• ' + p.city : ''} ${p.email ? '• ' + p.email : ''}</div>
              ${p.email_subject ? `<div class="mt-2 text-xs text-gray-700 bg-gray-50 rounded p-2"><strong>Subject:</strong> ${p.email_subject}</div>` : ''}
              ${p.email_body ? `<details class="mt-1"><summary class="text-xs text-brand-600 cursor-pointer">Preview email body</summary><pre class="mt-1 text-xs text-gray-600 whitespace-pre-wrap bg-gray-50 rounded p-2 max-h-40 overflow-y-auto">${p.email_body}</pre></details>` : ''}
              <div class="mt-2 flex gap-2">
                <button class="pipeline-send-btn text-xs bg-brand-600 hover:bg-brand-700 text-white px-2 py-1 rounded" data-id="${p.id}" ${!p.email ? 'disabled title="No email"' : ''}>
                  📧 Approve & Queue Send
                </button>
                <button class="pipeline-reject-btn text-xs bg-red-50 hover:bg-red-100 text-red-700 px-2 py-1 rounded" data-id="${p.id}">
                  ✕ Reject
                </button>
              </div>
            </div>
          `).join('');

          // Wire buttons
          listEl.querySelectorAll('.pipeline-send-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
              const id = (btn as HTMLElement).dataset.id;
              (btn as HTMLButtonElement).disabled = true;
              (btn as HTMLButtonElement).textContent = '...';
              await fetch('/api/recruitment-action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, action: 'approve' }),
              });
              loadPipelineStatus();
            });
          });
          listEl.querySelectorAll('.pipeline-reject-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
              const id = (btn as HTMLElement).dataset.id;
              (btn as HTMLButtonElement).disabled = true;
              await fetch('/api/recruitment-action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, action: 'reject', reason: 'Rejected from pipeline tab' }),
              });
              loadPipelineStatus();
            });
          });
        }
      } catch {
        listEl.innerHTML = '<div class="text-sm text-red-500">Failed to load</div>';
      }
    }
  }

  // Pipeline manual triggers
  document.getElementById('pipeline-run-outreach')?.addEventListener('click', async function() {
    const btn = this as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Running...';
    try {
      const limit = (document.getElementById('pipeline-outreach-limit') as HTMLSelectElement)?.value || '3';
      const res = await fetch('/api/recruitment-pipeline', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'outreach', limit: parseInt(limit) }),
      });
      const data = await res.json();
      btn.textContent = `✅ ${data.processed || 0} done`;
      setTimeout(() => { btn.textContent = '▶ Run Outreach Now'; btn.disabled = false; }, 3000);
      loadPipelineStatus();
    } catch {
      btn.textContent = '❌ Failed';
      setTimeout(() => { btn.textContent = '▶ Run Outreach Now'; btn.disabled = false; }, 3000);
    }
  });

  document.getElementById('pipeline-run-review')?.addEventListener('click', async function() {
    const btn = this as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Running...';
    try {
      const res = await fetch('/api/recruitment-pipeline', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'review' }),
      });
      const data = await res.json();
      btn.textContent = `✅ ${data.reviewed || 0} reviewed`;
      setTimeout(() => { btn.textContent = '▶ Run Review Now'; btn.disabled = false; }, 3000);
      loadPipelineStatus();
    } catch {
      btn.textContent = '❌ Failed';
      setTimeout(() => { btn.textContent = '▶ Run Review Now'; btn.disabled = false; }, 3000);
    }
  });

  document.getElementById('pipeline-run-research')?.addEventListener('click', async function() {
    const btn = this as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Running...';
    try {
      const res = await fetch('/api/recruitment-pipeline', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'research' }),
      });
      const data = await res.json();
      btn.textContent = `✅ ${data.processed || 0} scored`;
      setTimeout(() => { btn.textContent = '▶ Run Research Now'; btn.disabled = false; }, 3000);
      loadPipelineStatus();
    } catch {
      btn.textContent = '❌ Failed';
      setTimeout(() => { btn.textContent = '▶ Run Research Now'; btn.disabled = false; }, 3000);
    }
  });

  document.getElementById('pipeline-refresh-btn')?.addEventListener('click', loadPipelineStatus);
</script>

</Base>
