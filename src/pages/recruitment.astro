              <div class="flex items-center gap-2 mb-1">
                <h3 class="font-semibold text-gray-900 text-sm">${escapeHtml(p.name)}</h3>
                ${p.fit_score ? `<span class="text-xs font-bold text-${scoreColor}-600">${p.fit_score}/10</span>` : ''}
                ${stateMatch ? '<span class="text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded">Licensed State</span>' : ''}
