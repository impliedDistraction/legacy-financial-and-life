---
/**
 * /voice/editor — Visual Dialog Tree Editor
 *
 * Drag-and-drop node editor for designing AI call scripts.
 * Features:
 * - Visual node graph with connections
 * - Edit node speak text, edges, slot extraction
 * - Conversational mode settings per node
 * - Back-on-track behavior configuration
 * - Preview TTS audio per node
 * - Save/load trees from Supabase
 * - Compliance guardrails (AI disclosure, opt-out, no false claims)
 * - Live call position overlay (which node is active)
 *
 * Auth: same magic-link as /recruitment.
 */
import Base from '../../layouts/Base.astro';
import '../../styles/tailwind.css';
import { verifySessionCookie } from '../../lib/ai-demo-auth';

export const prerender = false;

const session = await verifySessionCookie(Astro.request.headers.get('cookie'));
if (!session) {
  return Astro.redirect('/ai-demo-login?redirect=/voice/editor', 302);
}

const userEmail = session.email;
---
<Base title="Dialog Tree Editor — Legacy Financial & Life" description="Visual editor for AI call scripts">

<div class="bg-gray-900 min-h-screen text-gray-100" id="editor-app" data-email={userEmail}>
  <!-- Top Toolbar -->
  <header class="bg-gray-800 border-b border-gray-700 sticky top-0 z-50">
    <div class="max-w-full mx-auto px-4 py-2 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/voice" class="text-xs text-gray-400 hover:text-white">← Voice Dashboard</a>
        <div class="h-4 w-px bg-gray-600"></div>
        <div class="flex items-center gap-2">
          <select id="tree-selector" class="bg-gray-700 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200 focus:ring-brand-500 focus:border-brand-500">
            <option value="">Loading trees...</option>
          </select>
          <button id="btn-new-tree" class="px-2 py-1 bg-gray-700 border border-gray-600 rounded text-xs text-gray-300 hover:bg-gray-600">+ New</button>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span id="save-status" class="text-xs text-gray-500">No changes</span>
        <button id="btn-new" class="px-3 py-1 bg-gray-600 text-white text-xs font-medium rounded hover:bg-gray-500" title="Start a new tree (clears current)">New</button>
        <button id="btn-save" class="px-3 py-1 bg-brand-600 text-white text-xs font-medium rounded hover:bg-brand-700 disabled:opacity-50">Save</button>
        <button id="btn-save-as" class="px-3 py-1 bg-brand-700 text-white text-xs font-medium rounded hover:bg-brand-600" title="Save as a new copy">Save As</button>
        <button id="btn-run-tests" class="px-3 py-1 bg-amber-600 text-white text-xs font-medium rounded hover:bg-amber-700" title="Run synthetic prospect tests before deploying">🧪 Test</button>
        <button id="btn-experiments" class="px-3 py-1 bg-indigo-600 text-white text-xs font-medium rounded hover:bg-indigo-700" title="View A/B experiment results">🧬 Experiments</button>
        <button id="btn-deploy" class="px-3 py-1 bg-green-600 text-white text-xs font-medium rounded hover:bg-green-700">Deploy</button>
        <button id="btn-render-tts" class="px-3 py-1 bg-purple-600 text-white text-xs font-medium rounded hover:bg-purple-700" title="Pre-render TTS audio for all nodes">🔊 Render</button>
        <div class="h-4 w-px bg-gray-600"></div>
        <button id="btn-help" class="w-6 h-6 flex items-center justify-center bg-gray-700 border border-gray-600 rounded-full text-xs text-gray-300 hover:bg-gray-600 hover:text-white" title="Show tutorial">?</button>
      </div>
    </div>
  </header>

  <div class="flex h-[calc(100vh-44px)]">
    <!-- Left Panel: Tabbed (Nodes / Trees) -->
    <aside class="w-64 bg-gray-800 border-r border-gray-700 overflow-y-auto flex-shrink-0 flex flex-col">
      <!-- Tab Headers -->
      <div class="flex border-b border-gray-700 flex-shrink-0">
        <button id="tab-nodes" class="flex-1 px-3 py-2 text-xs font-semibold text-brand-300 border-b-2 border-brand-400 bg-gray-800" data-tab="nodes">Nodes</button>
        <button id="tab-trees" class="flex-1 px-3 py-2 text-xs font-semibold text-gray-500 border-b-2 border-transparent hover:text-gray-300" data-tab="trees">Trees</button>
      </div>

      <!-- Nodes Tab -->
      <div id="panel-nodes" class="flex-1 overflow-y-auto">
        <div class="p-3">
          <div id="node-list" class="space-y-1"></div>
          <button id="btn-add-node" class="mt-3 w-full px-3 py-2 border border-dashed border-gray-600 rounded-lg text-xs text-gray-400 hover:border-gray-400 hover:text-gray-200 transition-colors">
            + Add Node
          </button>
          <div class="flex gap-1 mt-1">
            <button id="btn-add-group" class="flex-1 px-2 py-1.5 border border-dashed border-purple-700 rounded text-[10px] text-purple-400 hover:border-purple-500 hover:text-purple-300 transition-colors">
              + Group
            </button>
          <button id="btn-import-nodes" class="flex-1 px-2 py-1.5 border border-dashed border-green-700 rounded text-[10px] text-green-400 hover:border-green-500 hover:text-green-300 transition-colors">
            ↓ Import
          </button>
          <button id="btn-export-nodes" class="flex-1 px-2 py-1.5 border border-dashed border-blue-700 rounded text-[10px] text-blue-400 hover:border-blue-500 hover:text-blue-300 transition-colors">
            ↑ Export
          </button>
        </div>
      </div>

      <!-- Tree Settings -->
      <div class="p-3 border-t border-gray-700">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Tree Settings</h3>
        <div class="space-y-2">
          <div>
            <label class="block text-xs text-gray-500 mb-0.5">Name</label>
            <input id="tree-name" type="text" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200" placeholder="Sales Qualifying v3" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-0.5">Category</label>
            <select id="tree-category" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200">
              <option value="sales">Sales Qualifying</option>
              <option value="recruitment">Recruitment</option>
              <option value="inbound">Inbound / Reception</option>
              <option value="experimental">Experimental (A/B)</option>
              <option value="client_outreach">Client Outreach</option>
              <option value="custom">Custom</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-0.5">Status</label>
            <select id="tree-status" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200">
              <option value="draft">Draft</option>
              <option value="testing">Testing</option>
              <option value="active">Active</option>
              <option value="archived">Archived</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Compliance -->
      <div class="p-3 border-t border-gray-700">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Compliance</h3>
        <div id="compliance-checks" class="space-y-1 text-xs">
          <div class="flex items-center gap-2" id="check-disclosure"><span class="w-4">⏳</span> AI Disclosure</div>
          <div class="flex items-center gap-2" id="check-optout"><span class="w-4">⏳</span> Opt-out Available</div>
          <div class="flex items-center gap-2" id="check-no-deception"><span class="w-4">⏳</span> No Deception</div>
          <div class="flex items-center gap-2" id="check-terminal"><span class="w-4">⏳</span> Has Terminal Paths</div>
        </div>
      </div>
      </div><!-- /panel-nodes -->

      <!-- Trees Tab -->
      <div id="panel-trees" class="flex-1 overflow-y-auto hidden">
        <div class="p-3">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">All Trees</h3>
            <button id="btn-new-tree-tab" class="text-[10px] text-brand-400 hover:text-brand-300">+ New</button>
          </div>
          <div id="trees-list" class="space-y-1">
            <div class="text-xs text-gray-500 py-4 text-center">Loading...</div>
          </div>
        </div>
        <div class="p-3 border-t border-gray-700">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Filter</h3>
          <select id="trees-filter-status" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-xs text-gray-200 mb-1">
            <option value="">All statuses</option>
            <option value="active">Active</option>
            <option value="draft">Draft</option>
            <option value="testing">Testing</option>
            <option value="archived">Archived</option>
          </select>
          <select id="trees-filter-category" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-xs text-gray-200">
            <option value="">All categories</option>
            <option value="sales">Sales</option>
            <option value="recruitment">Recruitment</option>
            <option value="inbound">Inbound / Reception</option>
            <option value="experimental">Experimental (A/B)</option>
            <option value="client_outreach">Client Outreach</option>
            <option value="custom">Custom</option>
          </select>
        </div>
      </div>
    </aside>

    <!-- Center: Canvas + Bottom Panel -->
    <main class="flex-1 overflow-hidden relative flex flex-col" id="canvas-container">
      <div id="canvas" class="flex-1 overflow-auto relative" style="cursor: grab;">
        <svg id="canvas-svg" class="absolute" style="min-width: 4000px; min-height: 2000px;"></svg>
        <div id="nodes-layer" class="absolute" style="min-width: 4000px; min-height: 2000px;"></div>
      </div>
      <!-- Bottom Panel: Minimap + Stats -->
      <div id="bottom-panel" class="h-32 bg-gray-850 border-t border-gray-700 flex flex-shrink-0" style="background: #1a1d23;">
        <!-- Minimap -->
        <div class="w-56 border-r border-gray-700 p-1.5 flex flex-col">
          <div class="text-[9px] text-gray-500 font-semibold uppercase tracking-wider mb-1 px-1">Minimap</div>
          <div class="flex-1 relative overflow-hidden rounded bg-gray-900/50" id="minimap-container">
            <canvas id="minimap-canvas" class="w-full h-full" style="image-rendering: pixelated;"></canvas>
            <div id="minimap-viewport" class="absolute border border-brand-400/50 bg-brand-400/10 rounded-sm pointer-events-none" style="display:none;"></div>
          </div>
        </div>
        <!-- Stats -->
        <div class="flex-1 p-2 overflow-auto">
          <div class="flex gap-4 items-start h-full">
            <!-- Tree Stats -->
            <div class="flex flex-col gap-1.5">
              <div class="text-[9px] text-gray-500 font-semibold uppercase tracking-wider">Tree Stats</div>
              <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[11px]">
                <div class="text-gray-500">Nodes</div><div class="text-gray-200 font-mono" id="stat-nodes">0</div>
                <div class="text-gray-500">Edges</div><div class="text-gray-200 font-mono" id="stat-edges">0</div>
                <div class="text-gray-500">Groups</div><div class="text-gray-200 font-mono" id="stat-groups">0</div>
                <div class="text-gray-500">Max depth</div><div class="text-gray-200 font-mono" id="stat-depth">0</div>
              </div>
            </div>
            <!-- Path Stats -->
            <div class="flex flex-col gap-1.5">
              <div class="text-[9px] text-gray-500 font-semibold uppercase tracking-wider">Coverage</div>
              <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[11px]">
                <div class="text-gray-500">Terminals</div><div class="text-gray-200 font-mono" id="stat-terminals">0</div>
                <div class="text-gray-500">Dead ends</div><div class="text-red-400 font-mono" id="stat-deadends">0</div>
                <div class="text-gray-500">Orphans</div><div class="text-amber-400 font-mono" id="stat-orphans">0</div>
                <div class="text-gray-500">Transfers</div><div class="text-green-400 font-mono" id="stat-transfers">0</div>
              </div>
            </div>
            <!-- Zoom & Position -->
            <div class="flex flex-col gap-1.5">
              <div class="text-[9px] text-gray-500 font-semibold uppercase tracking-wider">View</div>
              <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[11px]">
                <div class="text-gray-500">Zoom</div><div class="text-gray-200 font-mono" id="stat-zoom">100%</div>
                <div class="text-gray-500">Selected</div><div class="text-brand-300 font-mono truncate max-w-[80px]" id="stat-selected">—</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Zoom controls -->
      <div class="absolute bottom-36 right-4 flex gap-1 bg-gray-800 rounded-lg p-1 shadow-lg border border-gray-700 z-10">
        <button id="btn-zoom-in" class="w-7 h-7 flex items-center justify-center text-gray-300 hover:text-white hover:bg-gray-700 rounded" title="Zoom in">+</button>
        <button id="btn-zoom-reset" class="w-7 h-7 flex items-center justify-center text-gray-300 hover:text-white hover:bg-gray-700 rounded text-xs" title="Fit to view">1:1</button>
        <button id="btn-zoom-out" class="w-7 h-7 flex items-center justify-center text-gray-300 hover:text-white hover:bg-gray-700 rounded" title="Zoom out">−</button>
        <div class="w-px h-5 bg-gray-600 self-center"></div>
        <button id="btn-center-tree" class="w-7 h-7 flex items-center justify-center text-gray-300 hover:text-white hover:bg-gray-700 rounded text-xs" title="Center tree on canvas">⊡</button>
        <button id="btn-center-selection" class="w-7 h-7 flex items-center justify-center text-gray-300 hover:text-white hover:bg-gray-700 rounded text-xs hidden" title="Center selection">⊞</button>
      </div>
    </main>

    <!-- Right Panel: Node Editor -->
    <aside class="w-80 bg-gray-800 border-l border-gray-700 overflow-y-auto flex-shrink-0 hidden" id="node-editor">
      <div class="p-4">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-gray-200" id="editor-title">Node Editor</h3>
          <button id="btn-close-editor" class="text-gray-400 hover:text-white">✕</button>
        </div>

        <!-- Node ID -->
        <div class="mb-3">
          <label class="block text-xs text-gray-500 mb-0.5">Node ID</label>
          <input id="edit-node-id" type="text" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200 font-mono" />
        </div>

        <!-- TTS Preview (what the agent will say) -->
        <div class="mb-3 bg-gray-900/60 border border-gray-600 rounded-lg p-3" id="tts-preview-section">
          <div class="flex items-center justify-between mb-1.5">
            <label class="text-xs font-semibold text-gray-300">Agent Says</label>
            <div class="flex gap-1">
              <button id="btn-tts-play" class="px-2 py-0.5 bg-purple-700 text-white text-[10px] rounded hover:bg-purple-600 disabled:opacity-40" title="Play TTS preview">▶ Play</button>
              <button id="btn-tts-render" class="px-2 py-0.5 bg-gray-700 text-gray-300 text-[10px] rounded hover:bg-gray-600" title="Pre-render & cache this phrase">Cache</button>
            </div>
          </div>
          <div id="tts-preview-text" class="text-sm text-gray-100 italic min-h-[2rem] leading-relaxed">—</div>
          <div id="tts-preview-variants" class="mt-1 hidden">
            <span class="text-[10px] text-gray-500">Variants:</span>
            <div id="tts-variant-list" class="text-[10px] text-gray-400 space-y-0.5 mt-0.5"></div>
          </div>
          <audio id="tts-audio-player" class="w-full mt-2 hidden" controls></audio>
          <div id="tts-status" class="text-[10px] text-gray-500 mt-1 hidden"></div>
        </div>

        <!-- Speak Text -->
        <div class="mb-3">
          <div class="flex items-center justify-between mb-0.5">
            <label class="block text-xs text-gray-500">Speak Text (variants, one per line)</label>
            <button id="btn-ai-generate-speak" class="px-2 py-0.5 bg-indigo-700 text-white text-[10px] rounded hover:bg-indigo-600 disabled:opacity-40" title="Generate speak text with AI based on node context">✨ AI Fill</button>
          </div>
          <textarea id="edit-speak" rows="3" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200" placeholder="Hi, is this {firstName}?"></textarea>
          <p class="text-xs text-gray-500 mt-0.5">Use &#123;slotName&#125; for dynamic values. Multiple lines = random variant selection.</p>
        </div>

        <!-- Action -->
        <div class="mb-3">
          <label class="block text-xs text-gray-500 mb-0.5">Action (terminal)</label>
          <select id="edit-action" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200">
            <option value="">None (continue)</option>
            <option value="transfer">Transfer to Agent</option>
            <option value="hangup">Hang Up</option>
            <option value="book">Book Meeting</option>
            <option value="llm_fallback">LLM Fallback (permanent)</option>
            <option value="llm_gather">LLM Gather (reason &amp; return)</option>
          </select>
          <p id="action-hint" class="text-[10px] text-gray-500 mt-0.5 hidden"></p>
        </div>

        <!-- LLM Gather Settings (shown when action=llm_gather) -->
        <div class="mb-3 border border-amber-700/50 rounded-lg p-3 hidden" id="gather-settings">
          <h4 class="text-xs font-semibold text-amber-300 mb-2">🧠 LLM Gather Settings</h4>
          <p class="text-[10px] text-gray-400 mb-2">The AI will listen, reason about the response, extract info, then return to a specific node. Good for complex answers, stories, or multi-part gathering.</p>
          <div class="space-y-2">
            <div>
              <label class="block text-[10px] text-gray-500 mb-0.5">Tone</label>
              <select id="edit-gather-tone" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-0.5 text-xs text-gray-200">
                <option value="professional">Professional (sales/recruiting)</option>
                <option value="empathetic">Empathetic (client outreach)</option>
                <option value="neutral">Neutral (data collection)</option>
              </select>
            </div>
            <div>
              <label class="block text-[10px] text-gray-500 mb-0.5">Max LLM Turns (before redirect)</label>
              <input id="edit-gather-max-turns" type="number" min="1" max="8" value="3" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-0.5 text-xs text-gray-200" />
            </div>
            <div>
              <label class="block text-[10px] text-gray-500 mb-0.5">Return To Node (after gathering)</label>
              <select id="edit-gather-return" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-0.5 text-xs text-gray-200">
                <option value="">— Next in tree —</option>
              </select>
            </div>
            <div>
              <label class="block text-[10px] text-gray-500 mb-0.5">Slots to Extract (one per line: slotName = description)</label>
              <textarea id="edit-gather-slots" rows="3" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-0.5 text-[10px] font-mono text-gray-200" placeholder="age = their age in years&#10;family_situation = single, married, kids&#10;concern = what they're worried about"></textarea>
            </div>
            <div>
              <label class="block text-[10px] text-gray-500 mb-0.5">LLM Context Prompt</label>
              <textarea id="edit-gather-prompt" rows="2" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-0.5 text-[10px] text-gray-200" placeholder="Listen carefully and acknowledge their story. Extract key details about their family and insurance needs."></textarea>
            </div>
          </div>
        </div>

        <!-- LLM Gather Escape Paths (shown when action=llm_gather and has history) -->
        <div class="mb-3 border border-cyan-700/50 rounded-lg p-3 hidden" id="gather-escape-paths">
          <div class="flex items-center justify-between mb-2">
            <h4 class="text-xs font-semibold text-cyan-300">🧭 Escape Paths</h4>
            <button id="btn-refresh-insights" class="text-[9px] text-gray-400 hover:text-gray-200">↻ Refresh</button>
          </div>
          <p class="text-[10px] text-gray-400 mb-2">How callers navigated this gather node in real calls.</p>
          <div id="escape-paths-content" class="space-y-2 text-[10px]">
            <div class="text-gray-500 italic">Loading insights...</div>
          </div>
          <!-- Unhandled patterns section -->
          <div id="unhandled-patterns" class="mt-3 border-t border-gray-600 pt-2 hidden">
            <h5 class="text-[10px] font-semibold text-amber-300 mb-1">💡 Unhandled Patterns</h5>
            <p class="text-[9px] text-gray-500 mb-1">Repeated phrases that could become tree edges:</p>
            <div id="unhandled-list" class="space-y-1"></div>
          </div>
        </div>

        <!-- Direct Next -->
        <div class="mb-3">
          <label class="block text-xs text-gray-500 mb-0.5">Direct Next (for greeting nodes)</label>
          <select id="edit-next" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200">
            <option value="">— No direct next —</option>
          </select>
        </div>

        <!-- Group Assignment -->
        <div class="mb-3">
          <label class="block text-xs text-gray-500 mb-0.5">Group</label>
          <select id="edit-group" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-sm text-gray-200">
            <option value="">— No group —</option>
          </select>
        </div>

        <!-- Conversational Settings -->
        <div class="mb-3 border border-gray-600 rounded-lg p-3">
          <h4 class="text-xs font-semibold text-gray-300 mb-2">🗣️ Conversational Behavior</h4>
          <div class="space-y-2">
            <div>
              <label class="block text-xs text-gray-500 mb-0.5">Mode</label>
              <select id="edit-converse-mode" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-xs text-gray-200">
                <option value="">Off (no conversational handling)</option>
                <option value="friendly">Friendly (multi-turn, warm)</option>
                <option value="brief">Brief (ack + redirect)</option>
                <option value="redirect">Redirect (ignore, re-ask)</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-0.5">Max Off-Script Turns</label>
              <input id="edit-converse-max" type="number" min="1" max="5" value="1" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-xs text-gray-200" />
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-0.5">Back-on-Track Phrases (one per line)</label>
              <textarea id="edit-converse-bot" rows="2" class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1 text-xs text-gray-200" placeholder="Anyway —&#10;So —"></textarea>
            </div>
          </div>
        </div>

        <!-- Parallel Actions (watchers running alongside this node) -->
        <div class="mb-3 border border-gray-600 rounded-lg p-3">
          <div class="flex items-center justify-between mb-2">
            <h4 class="text-xs font-semibold text-gray-300">⚡ Parallel Actions</h4>
            <button id="btn-add-watcher" class="text-xs text-purple-400 hover:text-purple-300">+ Add</button>
          </div>
          <p class="text-[10px] text-gray-500 mb-2">Background processes running while this node is active (sentiment, scoring, trigger-watch).</p>
          <div id="watchers-container" class="space-y-1.5"></div>
        </div>

        <!-- Edges Section -->
        <div class="mb-3">
          <div class="flex items-center justify-between mb-2">
            <label class="block text-xs font-semibold text-gray-300">Edges (responses)</label>
            <button id="btn-add-edge" class="text-xs text-brand-400 hover:text-brand-300">+ Add Edge</button>
          </div>
          <div id="edges-container" class="space-y-2"></div>
        </div>

        <!-- Edge Flow Visualization -->
