  document.getElementById('btn-add-group')?.addEventListener('click', () => {
    if (!currentTree) return;
    const name = prompt('Group name (e.g. "qualification", "objection_handling"):');
    if (!name) return;

    // Groups are stored in _groups metadata
    if (!currentTree._groups) currentTree._groups = {};
    currentTree._groups[name] = {
      label: name.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
      color: getNextGroupColor(),
      nodes: [],
      collapsed: false,
    };

    markDirty();
    renderCanvas();
