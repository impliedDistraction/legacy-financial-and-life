          <label class="text-[10px] text-gray-500">Match Mode</label>
          <div class="flex gap-1 mt-0.5">
            <button class="edge-mode-btn px-1.5 py-0.5 text-[9px] rounded ${matchMode === 'intent' ? 'bg-purple-700 text-white' : 'bg-gray-800 text-gray-400 hover:text-gray-200'}" data-mode="intent">Intent</button>
            <button class="edge-mode-btn px-1.5 py-0.5 text-[9px] rounded ${matchMode === 'regex' ? 'bg-purple-700 text-white' : 'bg-gray-800 text-gray-400 hover:text-gray-200'}" data-mode="regex">Regex</button>
            <button class="edge-mode-btn px-1.5 py-0.5 text-[9px] rounded ${matchMode === 'function' ? 'bg-purple-700 text-white' : 'bg-gray-800 text-gray-400 hover:text-gray-200'}" data-mode="function">Function</button>
          </div>
        </div>
        <div class="edge-match-panel" data-active-mode="${matchMode}">
          <!-- Intent mode -->
          <div class="edge-mode-content ${matchMode === 'intent' ? '' : 'hidden'}" data-for-mode="intent">
            <label class="text-[10px] text-gray-500">Intent</label>
            <select class="w-full bg-gray-800 border border-gray-600 rounded px-1.5 py-0.5 text-[10px] text-gray-300 edge-intent-select">
              <option value="">— Select intent —</option>
              ${intentOpts}
            </select>
            <label class="text-[10px] text-gray-500 mt-1 block">Extras (comma-separated)</label>
            <input type="text" value="${extrasList}" class="w-full bg-gray-800 border border-gray-600 rounded px-1.5 py-0.5 text-[10px] text-gray-300 edge-extras-input" placeholder="also, totally, bet" />
            <div class="text-[9px] text-gray-500 mt-0.5 font-mono edge-intent-preview truncate">${edge.match_regex ? '/' + (edge.match_regex.length > 50 ? edge.match_regex.slice(0, 50) + '…' : edge.match_regex) + '/' : ''}</div>
            <button class="edge-expand-btn mt-1 px-2 py-0.5 bg-amber-800 text-amber-200 text-[9px] rounded hover:bg-amber-700">🧠 Expand with LLM</button>
          </div>
          <!-- Regex mode -->
          <div class="edge-mode-content ${matchMode === 'regex' ? '' : 'hidden'}" data-for-mode="regex">
            <label class="text-[10px] text-gray-500">Match (regex)</label>
            <input type="text" value="${edge.match_regex || ''}" class="w-full bg-gray-800 border border-gray-600 rounded px-1.5 py-0.5 text-[10px] font-mono text-gray-300 edge-regex-input" placeholder="\\b(yes|yeah)\\b" />
          </div>
          <!-- Function mode -->
          <div class="edge-mode-content ${matchMode === 'function' ? '' : 'hidden'}" data-for-mode="function">
            <label class="text-[10px] text-gray-500">Built-in Function</label>
            <select class="w-full bg-gray-800 border border-gray-600 rounded px-1.5 py-0.5 text-[10px] text-gray-300 edge-fn-select">
              <option value="">—</option>
              <option value="isAffirmative" ${edge.match_fn === 'isAffirmative' ? 'selected' : ''}>isAffirmative</option>
              <option value="isNegative" ${edge.match_fn === 'isNegative' ? 'selected' : ''}>isNegative</option>
              <option value="isConversational" ${edge.match_fn === 'isConversational' ? 'selected' : ''}>isConversational</option>
              <option value="isSentimentPositive" ${edge.match_fn === 'isSentimentPositive' ? 'selected' : ''}>isSentimentPositive</option>
              <option value="isSentimentNegative" ${edge.match_fn === 'isSentimentNegative' ? 'selected' : ''}>isSentimentNegative</option>
            </select>
          </div>
        </div>
        ` : `
        <div class="text-[10px] text-gray-500 italic">Catches unmatched responses</div>
        `}
        <div>
          <label class="text-[10px] text-gray-500">Speak</label>
          <input type="text" value="${Array.isArray(edge.speak) ? edge.speak[0] || '' : ''}" class="w-full bg-gray-800 border border-gray-600 rounded px-1.5 py-0.5 text-[10px] text-gray-300 edge-speak-input" placeholder="Response text..." />
        </div>
        <div class="flex gap-2">
          <div class="flex-1">
            <label class="text-[10px] text-gray-500">→ Next</label>
            <select class="w-full bg-gray-800 border border-gray-600 rounded px-1 py-0.5 text-[10px] text-gray-300 edge-next-select">
              <option value="">—</option>
              ${getTreeNodes().map(n => `<option value="${n}" ${edge.next === n ? 'selected' : ''}>${n}</option>`).join('')}
            </select>
          </div>
          <div class="flex-1">
            <label class="text-[10px] text-gray-500">Action</label>
            <select class="w-full bg-gray-800 border border-gray-600 rounded px-1 py-0.5 text-[10px] text-gray-300 edge-action-select">
              <option value="" ${!edge.action ? 'selected' : ''}>—</option>
              <option value="hangup" ${edge.action === 'hangup' ? 'selected' : ''}>hangup</option>
              <option value="transfer" ${edge.action === 'transfer' ? 'selected' : ''}>transfer</option>
            </select>
          </div>
        </div>
        ${edge.extract ? `<div class="text-[10px] text-blue-300">📦 Extracts: ${edge.extract.slot} (${edge.extract.regex || edge.extract.value || ''})</div>` : ''}
      </div>`;
    }).join('');

    // Set selected intent values (must be done after innerHTML is set)
    edgeEntries.forEach(([name, edge]: [string, any]) => {
      if (edge.match_intent) {
        const div = container.querySelector(`[data-edge-name="${name}"]`);
        const select = div?.querySelector('.edge-intent-select') as HTMLSelectElement;
        if (select) select.value = edge.match_intent;
      }
    });

    // Attach edge field event listeners
    container.querySelectorAll('.edge-regex-input, .edge-speak-input, .edge-next-select, .edge-action-select, .edge-name-input, .edge-intent-select, .edge-extras-input, .edge-fn-select').forEach(el => {
      el.addEventListener('change', () => applyEdgeEdits());
    });
    container.querySelectorAll('.edge-regex-input, .edge-speak-input, .edge-name-input, .edge-extras-input').forEach(el => {
      el.addEventListener('input', debounce(() => applyEdgeEdits(), 500));
    });

    // Mode toggle buttons
    container.querySelectorAll('.edge-mode-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = (btn as HTMLElement).dataset.mode!;
        const panel = (btn as HTMLElement).closest('.bg-gray-700\\/50')!;
        // Update button styles
        panel.querySelectorAll('.edge-mode-btn').forEach(b => {
          (b as HTMLElement).className = `edge-mode-btn px-1.5 py-0.5 text-[9px] rounded ${(b as HTMLElement).dataset.mode === mode ? 'bg-purple-700 text-white' : 'bg-gray-800 text-gray-400 hover:text-gray-200'}`;
        });
        // Show/hide content panels
        panel.querySelectorAll('.edge-mode-content').forEach(p => {
          (p as HTMLElement).classList.toggle('hidden', (p as HTMLElement).dataset.forMode !== mode);
        });
        const matchPanel = panel.querySelector('.edge-match-panel') as HTMLElement;
        if (matchPanel) matchPanel.dataset.activeMode = mode;
        applyEdgeEdits();
      });
    });

    // Delete buttons
    container.querySelectorAll('.edge-delete-btn').forEach(el => {
      el.addEventListener('click', () => {
        const edgeDiv = (el as HTMLElement).closest('[data-edge-name]') as HTMLElement;
        const edgeName = edgeDiv?.dataset.edgeName;
        if (!edgeName || !selectedNode || !currentTree[selectedNode]?.edges) return;
        if (!confirm(`Delete edge "${edgeName}"?`)) return;
        delete currentTree[selectedNode].edges[edgeName];
        markDirty();
        renderEdgesEditor(currentTree[selectedNode].edges);
        renderCanvas();
      });
    });

    // "Expand with LLM" buttons
    container.querySelectorAll('.edge-expand-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const panel = (btn as HTMLElement).closest('.bg-gray-700\\/50')!;
        const intentSelect = panel.querySelector('.edge-intent-select') as HTMLSelectElement;
        const extrasInput = panel.querySelector('.edge-extras-input') as HTMLInputElement;
        const previewEl = panel.querySelector('.edge-intent-preview') as HTMLElement;
        
        const intentKey = intentSelect?.value;
        const extras = extrasInput?.value || '';
        const description = intentKey
          ? (intentLibrary[intentKey]?.description || intentKey) + (extras ? `. Also include: ${extras}` : '')
          : extras || 'general affirmative response';
        
        (btn as HTMLButtonElement).disabled = true;
        (btn as HTMLElement).textContent = '⏳ Expanding...';
        
        try {
          const res = await fetch('/api/voice-intent-expand', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ description, context: `Dialog tree edge for node "${selectedNode}"` }),
          });
          if (res.ok) {
            const data = await res.json();
            // Merge LLM phrases into extras
            if (data.phrases?.length > 0) {
              const existing = extras.split(',').map((s: string) => s.trim()).filter(Boolean);
              const merged = [...new Set([...existing, ...data.phrases])];
              extrasInput.value = merged.join(', ');
              if (previewEl) previewEl.textContent = '/' + (data.regex || '').slice(0, 60) + (data.regex?.length > 60 ? '…' : '') + '/';
              applyEdgeEdits();
            }
          }
        } catch {}
        
        (btn as HTMLButtonElement).disabled = false;
        (btn as HTMLElement).textContent = '🧠 Expand with LLM';
      });
    });
  }

  // ─── Edge Flow Visualization (mini-flowchart in right panel) ───
  function renderEdgeFlowViz(nodeId: string) {
    const container = document.getElementById('edge-flow-diagram')!;
    const vizSection = document.getElementById('edge-flow-viz')!;
    const node = currentTree[nodeId];
    
    if (!node || (!node.edges && !node.next && !node.action)) {
      vizSection.classList.add('hidden');
      return;
    }
    vizSection.classList.remove('hidden');

    let html = '';

    // Root: the node itself
    html += `<div class="flex items-center gap-2 mb-2">
      <div class="w-2 h-2 rounded-full bg-blue-400 flex-shrink-0"></div>
      <div class="text-[10px] font-mono text-blue-300 truncate">${nodeId}</div>
    </div>`;

    // If direct next (greeting node)
    if (node.next && !node.edges) {
      const targetLabel = node.next.replace(/_/g, ' ');
      html += `<div class="ml-3 border-l-2 border-gray-600 pl-3 py-1">
        <div class="flex items-center gap-1.5">
          <span class="text-[9px] text-gray-500">→</span>
          <span class="text-[10px] text-gray-300 cursor-pointer hover:text-white flow-nav" data-target="${node.next}">${targetLabel}</span>
        </div>
      </div>`;
    }

    // Edges as branching paths
    if (node.edges) {
      const entries = Object.entries(node.edges);
      const regularEdges = entries.filter(([n]) => n !== '_fallback');
      const fallbackEdge = entries.find(([n]) => n === '_fallback');

      html += `<div class="ml-3 border-l-2 border-gray-600 pl-2 space-y-1.5 py-1">`;
      
      for (const [edgeName, edge] of regularEdges as [string, any][]) {
        const matchLabel = edge.match_intent 
          ? `🎯 ${edge.match_intent}` 
          : edge.match_fn 
            ? `ƒ ${edge.match_fn}` 
            : edge.match_regex 
              ? `/${(edge.match_regex || '').slice(0, 25)}${(edge.match_regex || '').length > 25 ? '…' : ''}/` 
              : '(any)';
        const speakSnippet = Array.isArray(edge.speak) && edge.speak[0] ? `"${edge.speak[0].slice(0, 30)}${edge.speak[0].length > 30 ? '…' : ''}"` : '';
        const actionIcon = edge.action === 'transfer' ? '📲' : edge.action === 'hangup' ? '📴' : '';
        const targetColor = edge.action === 'transfer' ? 'text-green-300' : edge.action === 'hangup' ? 'text-red-300' : 'text-gray-200';
        const targetLabel = edge.next ? edge.next.replace(/_/g, ' ') : (edge.action || '—');

        html += `<div class="bg-gray-800/50 rounded px-2 py-1.5 border border-gray-700/50">
          <div class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 flex-shrink-0"></span>
            <span class="text-[9px] font-semibold text-green-400">${edgeName}</span>
            <span class="text-[8px] text-gray-500 font-mono truncate flex-1">${matchLabel}</span>
          </div>
          ${speakSnippet ? `<div class="text-[9px] text-gray-400 italic ml-4 truncate mt-0.5">${speakSnippet}</div>` : ''}
          <div class="flex items-center gap-1 ml-4 mt-0.5">
            <span class="text-[9px] text-gray-500">→</span>
            ${actionIcon ? `<span class="text-[9px]">${actionIcon}</span>` : ''}
            <span class="text-[9px] ${targetColor} ${edge.next ? 'cursor-pointer hover:text-white flow-nav' : ''}" ${edge.next ? `data-target="${edge.next}"` : ''}>${targetLabel}</span>
          </div>
        </div>`;
      }

      // Fallback (rendered differently)
      if (fallbackEdge) {
        const [, fb] = fallbackEdge as [string, any];
        const fbSpeak = Array.isArray(fb.speak) && fb.speak[0] ? `"${fb.speak[0].slice(0, 35)}…"` : '';
        const fbTarget = fb.next ? fb.next.replace(/_/g, ' ') : '(re-ask)';
        const isSelfLoop = fb.next === nodeId;
        html += `<div class="bg-red-900/20 rounded px-2 py-1 border border-red-800/30 mt-1">
          <div class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-red-500/70 flex-shrink-0"></span>
            <span class="text-[9px] font-semibold text-red-400">_fallback</span>
            <span class="text-[8px] text-gray-500">no match</span>
          </div>
          ${fbSpeak ? `<div class="text-[9px] text-gray-400 italic ml-4 truncate mt-0.5">${fbSpeak}</div>` : ''}
          <div class="flex items-center gap-1 ml-4 mt-0.5">
            <span class="text-[9px] text-gray-500">→</span>
            <span class="text-[9px] text-red-300 ${!isSelfLoop && fb.next ? 'cursor-pointer hover:text-white flow-nav' : ''}" ${!isSelfLoop && fb.next ? `data-target="${fb.next}"` : ''}>${isSelfLoop ? '↺ re-ask' : fbTarget}</span>
          </div>
        </div>`;
      }

      html += `</div>`;
    }

    // Terminal action (without edges)
    if (node.action && !node.edges) {
      const actionIcon = node.action === 'transfer' ? '📲' : node.action === 'hangup' ? '📴' : node.action === 'book' ? '📅' : '⚡';
      const actionColor = node.action === 'transfer' ? 'text-green-300' : node.action === 'hangup' ? 'text-red-300' : 'text-amber-300';
      html += `<div class="ml-3 border-l-2 border-gray-600 pl-3 py-1">
        <div class="flex items-center gap-1.5">
          <span class="text-sm">${actionIcon}</span>
          <span class="text-[10px] font-semibold ${actionColor}">${node.action}</span>
        </div>
      </div>`;
    }

    container.innerHTML = html;

    // Navigation: click targets to jump to that node
    container.querySelectorAll('.flow-nav').forEach(el => {
      el.addEventListener('click', () => {
        const target = (el as HTMLElement).dataset.target;
        if (target && currentTree[target]) selectNode(target);
      });
    });
  }

  function applyEdgeEdits() {
    if (!selectedNode || !currentTree[selectedNode]) return;
    const node = currentTree[selectedNode];
    if (!node.edges) node.edges = {};

    // Read all edge fields from DOM and write back to tree
    const container = document.getElementById('edges-container')!;
    const edgeDivs = container.querySelectorAll('[data-edge-name]');
    const newEdges: Record<string, any> = {};

    edgeDivs.forEach(div => {
      const originalName = (div as HTMLElement).dataset.edgeName!;
      const nameInput = div.querySelector('.edge-name-input') as HTMLInputElement;
      const regexInput = div.querySelector('.edge-regex-input') as HTMLInputElement;
      const speakInput = div.querySelector('.edge-speak-input') as HTMLInputElement;
      const nextSelect = div.querySelector('.edge-next-select') as HTMLSelectElement;
      const actionSelect = div.querySelector('.edge-action-select') as HTMLSelectElement;
      const intentSelect = div.querySelector('.edge-intent-select') as HTMLSelectElement;
      const extrasInput = div.querySelector('.edge-extras-input') as HTMLInputElement;
      const fnSelect = div.querySelector('.edge-fn-select') as HTMLSelectElement;
      const matchPanel = div.querySelector('.edge-match-panel') as HTMLElement;

      const edgeName = nameInput?.value?.trim() || originalName;
      const existingEdge = node.edges[originalName] || {};
      const activeMode = matchPanel?.dataset.activeMode || 'regex';

      // Build the edge based on active mode
      const newEdge: any = {
        ...existingEdge,
        speak: speakInput?.value ? [speakInput.value] : existingEdge.speak,
        next: nextSelect?.value || undefined,
        action: actionSelect?.value || undefined,
      };

      // Clear old match fields
      delete newEdge.match_regex;
      delete newEdge.match_fn;
      delete newEdge.match_intent;
      delete newEdge.match_extras;

      if (activeMode === 'intent' && intentSelect?.value) {
        const intentKey = intentSelect.value;
        const intent = intentLibrary[intentKey];
        const extras = (extrasInput?.value || '').split(',').map((s: string) => s.trim()).filter(Boolean);
        
        newEdge.match_intent = intentKey;
        if (extras.length > 0) newEdge.match_extras = extras;
        
        // Generate final regex from intent base + extras
        let baseRegex = intent?.regex || '';
        if (extras.length > 0) {
          const escapedExtras = extras.map((e: string) => e.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
          // Append extras to the regex pattern
          if (baseRegex.startsWith('\\b(') && baseRegex.endsWith(')\\b')) {
            baseRegex = baseRegex.slice(0, -3) + '|' + escapedExtras.join('|') + ')\\b';
          } else if (baseRegex.startsWith('(') && baseRegex.endsWith(')')) {
            baseRegex = baseRegex.slice(0, -1) + '|' + escapedExtras.join('|') + ')';
          } else {
            baseRegex = baseRegex + '|' + escapedExtras.join('|');
          }
        }
        newEdge.match_regex = baseRegex;
        // Also carry forward match_fn if the intent has one
        if (intent?.match_fn) newEdge.match_fn = intent.match_fn;
      } else if (activeMode === 'function' && fnSelect?.value) {
        newEdge.match_fn = fnSelect.value;
      } else if (activeMode === 'regex') {
        newEdge.match_regex = regexInput?.value || undefined;
      }

      // Clean undefined fields
      if (!newEdge.match_regex) delete newEdge.match_regex;
      if (!newEdge.match_fn) delete newEdge.match_fn;
      if (!newEdge.next) delete newEdge.next;
      if (!newEdge.action) delete newEdge.action;

      newEdges[edgeName] = newEdge;
    });

    node.edges = newEdges;
    markDirty();
    renderCanvas();
    if (selectedNode) renderEdgeFlowViz(selectedNode);
  }

  // ═══════════════════════════════════════════════════════════════
  // SAVE / APPLY CHANGES
  // ═══════════════════════════════════════════════════════════════
  function applyNodeEdits() {
    if (!selectedNode || !currentTree[selectedNode]) return;
    const node = currentTree[selectedNode];

    // Speak
    const speakVal = (document.getElementById('edit-speak') as HTMLTextAreaElement).value.trim();
    node.speak = speakVal ? speakVal.split('\n').filter(Boolean) : undefined;

    // Action
    const actionVal = (document.getElementById('edit-action') as HTMLSelectElement).value;
    if (actionVal) { node.action = actionVal; } else { delete node.action; }

    // Direct next
    const nextVal = (document.getElementById('edit-next') as HTMLSelectElement).value;
    if (nextVal) { node.next = nextVal; } else { delete node.next; }

    // Group assignment
    const groupVal = (document.getElementById('edit-group') as HTMLSelectElement).value;
    if (currentTree._groups) {
      // Remove from all groups first
      for (const g of Object.values(currentTree._groups) as any[]) {
        g.nodes = (g.nodes || []).filter((n: string) => n !== selectedNode);
      }
      // Add to selected group
      if (groupVal && currentTree._groups[groupVal]) {
        currentTree._groups[groupVal].nodes.push(selectedNode);
      }
    }

    // Converse
    const converseMode = (document.getElementById('edit-converse-mode') as HTMLSelectElement).value;
    if (converseMode) {
      node.converse = {
        mode: converseMode,
        max_turns: parseInt((document.getElementById('edit-converse-max') as HTMLInputElement).value) || 1,
        back_on_track: (document.getElementById('edit-converse-bot') as HTMLTextAreaElement).value.split('\n').filter(Boolean),
      };
    } else {
      delete node.converse;
    }

    markDirty();
    renderCanvas();
    runComplianceChecks();
    updateTtsPreview();
  }

  // Listen for changes in the editor
  ['edit-speak', 'edit-action', 'edit-next', 'edit-group', 'edit-converse-mode', 'edit-converse-max', 'edit-converse-bot'].forEach(id => {
    document.getElementById(id)?.addEventListener('change', applyNodeEdits);
    document.getElementById(id)?.addEventListener('input', debounce(applyNodeEdits, 500));
  });

  function markDirty() {
    isDirty = true;
    const btn = document.getElementById('btn-save') as HTMLButtonElement;
    btn.disabled = false;
    document.getElementById('save-status')!.textContent = '● Unsaved changes';
    document.getElementById('save-status')!.className = 'text-xs text-amber-400';
  }

  // Save button
  document.getElementById('btn-save')?.addEventListener('click', async () => {
    if (!currentTree) return;
    const btn = document.getElementById('btn-save') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Saving...';

    try {
      // Persist node positions into tree metadata before saving
      if (!currentTree._meta) currentTree._meta = {};
      const positions: Record<string, { x: number; y: number }> = {};
      for (const [nodeId, pos] of nodePositions) {
        positions[nodeId] = pos;
      }
      currentTree._meta.positions = positions;

      const payload = {
        tree_data: currentTree,
        name: (document.getElementById('tree-name') as HTMLInputElement).value || 'Untitled',
        category: (document.getElementById('tree-category') as HTMLSelectElement).value,
        status: (document.getElementById('tree-status') as HTMLSelectElement).value,
        slug: currentSlug || generateSlug((document.getElementById('tree-name') as HTMLInputElement).value),
        id: currentTreeId || undefined,
      };

      const res = await fetch('/api/voice-dialog-tree', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      currentTreeId = data.id || currentTreeId;
      currentSlug = data.slug || currentSlug;
      isDirty = false;
      document.getElementById('save-status')!.textContent = '✓ Saved';
      document.getElementById('save-status')!.className = 'text-xs text-green-400';
    } catch (err: any) {
      document.getElementById('save-status')!.textContent = '✕ Save failed: ' + err.message;
      document.getElementById('save-status')!.className = 'text-xs text-red-400';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Save';
    }
  });

  // New tree button — clears editor for a fresh tree
  document.getElementById('btn-new')?.addEventListener('click', () => {
    if (isDirty && !confirm('Discard unsaved changes?')) return;
    currentTree = {
      _meta: { description: 'New Dialog Tree', version: '1.0' },
      greeting: { speak: ['Hello!'], edges: { default: 'END' } },
    };
    currentTreeId = '';
    currentSlug = '';
    isDirty = false;
    selectedNode = null;
    document.getElementById('node-editor')!.classList.add('hidden');
    (document.getElementById('tree-name') as HTMLInputElement).value = 'Untitled';
    (document.getElementById('tree-category') as HTMLSelectElement).value = 'custom';
    (document.getElementById('tree-status') as HTMLSelectElement).value = 'draft';
    (document.getElementById('tree-selector') as HTMLSelectElement).value = '';
    document.getElementById('save-status')!.textContent = 'New tree';
    document.getElementById('save-status')!.className = 'text-xs text-blue-400';
    initEditor();
  });

  // Save As — always creates a new copy (clears currentTreeId)
  document.getElementById('btn-save-as')?.addEventListener('click', async () => {
    if (!currentTree) return;
    const nameInput = document.getElementById('tree-name') as HTMLInputElement;
    const newName = prompt('Save as new tree name:', nameInput.value + ' (copy)');
    if (!newName) return;
    nameInput.value = newName;
    // Clear ID so it creates a new record
    currentTreeId = '';
    currentSlug = '';
    // Trigger the normal save
    (document.getElementById('btn-save') as HTMLButtonElement).click();
  });

  // ═══════════════════════════════════════════════════════════════
  // ADD NODE (opens wizard)
  // ═══════════════════════════════════════════════════════════════
  document.getElementById('btn-add-node')?.addEventListener('click', () => {
    showNewNodeWizard();
  });

  // Delete node
  document.getElementById('btn-delete-node')?.addEventListener('click', () => {
    if (!selectedNode) return;
    if (!confirm(`Delete node "${selectedNode}"? This cannot be undone.`)) return;
    
    delete currentTree[selectedNode];
    nodePositions.delete(selectedNode);
    selectedNode = null;
    document.getElementById('node-editor')!.classList.add('hidden');
    
    markDirty();
    renderCanvas();
    renderNodeList();
  });

  // Close editor
  document.getElementById('btn-close-editor')?.addEventListener('click', () => {
    selectedNode = null;
    document.getElementById('node-editor')!.classList.add('hidden');
    renderCanvas();
    renderNodeList();
  });

  // ESC to deselect
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && selectedNode) {
      selectedNode = null;
      document.getElementById('node-editor')!.classList.add('hidden');
      renderCanvas();
      renderNodeList();
    }
  });

  // Click canvas background to deselect
  document.getElementById('canvas')?.addEventListener('click', (e: MouseEvent) => {
    // Only deselect if clicking the canvas itself, not a node
    const target = e.target as HTMLElement;
    if (target.id === 'canvas' || target.id === 'canvas-svg' || target.id === 'nodes-layer') {
      if (selectedNode) {
        selectedNode = null;
        document.getElementById('node-editor')!.classList.add('hidden');
        renderCanvas();
        renderNodeList();
      }
    }
  });

  // ═══════════════════════════════════════════════════════════════
  // TTS PREVIEW
  // ═══════════════════════════════════════════════════════════════
  function updateTtsPreview() {
    if (!selectedNode || !currentTree[selectedNode]) return;
    const node = currentTree[selectedNode];
    const speaks = Array.isArray(node.speak) ? node.speak.filter(Boolean) : [];
    
    const previewEl = document.getElementById('tts-preview-text')!;
    const variantsSection = document.getElementById('tts-preview-variants')!;
    const variantList = document.getElementById('tts-variant-list')!;
    const audioEl = document.getElementById('tts-audio-player') as HTMLAudioElement;
    
    audioEl.classList.add('hidden');
    audioEl.src = '';
    document.getElementById('tts-status')!.classList.add('hidden');

    if (speaks.length === 0) {
      previewEl.textContent = '— No speak text configured —';
      previewEl.className = 'text-sm text-gray-500 italic min-h-[2rem] leading-relaxed';
      variantsSection.classList.add('hidden');
    } else if (speaks.length === 1) {
      previewEl.textContent = `"${speaks[0]}"`;
      previewEl.className = 'text-sm text-gray-100 min-h-[2rem] leading-relaxed';
      variantsSection.classList.add('hidden');
    } else {
      // Multiple variants — show first as primary, list others
      previewEl.textContent = `"${speaks[0]}"`;
      previewEl.className = 'text-sm text-gray-100 min-h-[2rem] leading-relaxed';
      variantsSection.classList.remove('hidden');
      variantList.innerHTML = speaks.slice(1).map((s: string, i: number) => 
        `<div class="flex items-center gap-1">
          <span class="text-gray-600">${i + 2}.</span>
          <span class="truncate">"${s}"</span>
          <button class="tts-play-variant text-purple-400 hover:text-purple-300 ml-auto flex-shrink-0" data-text="${s.replace(/"/g, '&quot;')}">▶</button>
        </div>`
      ).join('');
    }
  }

  // Play TTS for current node's first speak variant
  document.getElementById('btn-tts-play')?.addEventListener('click', async () => {
    if (!selectedNode || !currentTree[selectedNode]) return;
    const node = currentTree[selectedNode];
    const speaks = Array.isArray(node.speak) ? node.speak.filter(Boolean) : [];
    if (speaks.length === 0) return;
    await playTtsForText(speaks[0]);
  });

  // Cache TTS for all variants of current node
  document.getElementById('btn-tts-render')?.addEventListener('click', async () => {
    if (!selectedNode || !currentTree[selectedNode]) return;
    const node = currentTree[selectedNode];
    const speaks = Array.isArray(node.speak) ? node.speak.filter(Boolean) : [];
    if (speaks.length === 0) return;
    
    const statusEl = document.getElementById('tts-status')!;
    statusEl.classList.remove('hidden');
    statusEl.textContent = `Caching ${speaks.length} variant(s)...`;
    
    try {
      const res = await fetch('/api/voice-tts-preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ texts: speaks, cache: true }),
      });
      if (res.ok) {
        const data = await res.json();
        statusEl.textContent = `✓ Cached ${data.cached || speaks.length} phrase(s)`;
        statusEl.className = 'text-[10px] text-green-400 mt-1';
      } else {
        statusEl.textContent = '✕ Cache failed';
        statusEl.className = 'text-[10px] text-red-400 mt-1';
      }
    } catch {
      statusEl.textContent = '✕ Bridge unreachable';
      statusEl.className = 'text-[10px] text-red-400 mt-1';
    }
    setTimeout(() => statusEl.classList.add('hidden'), 4000);
  });

  // Play variant from the list
  document.getElementById('tts-variant-list')?.addEventListener('click', (e: MouseEvent) => {
    const btn = (e.target as HTMLElement).closest('.tts-play-variant') as HTMLElement;
    if (btn) playTtsForText(btn.dataset.text || '');
  });

  async function playTtsForText(text: string) {
    if (!text) return;
    const audioEl = document.getElementById('tts-audio-player') as HTMLAudioElement;
    const statusEl = document.getElementById('tts-status')!;
    const playBtn = document.getElementById('btn-tts-play') as HTMLButtonElement;
    
    playBtn.disabled = true;
    playBtn.textContent = '⏳';
    statusEl.classList.remove('hidden');
    statusEl.textContent = 'Generating audio...';
    statusEl.className = 'text-[10px] text-gray-400 mt-1';

    try {
      const res = await fetch('/api/voice-tts-preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text }),
      });
      
      // Check if response is an error (JSON instead of audio)
      const contentType = res.headers.get('content-type') || '';
      if (!res.ok || contentType.includes('application/json')) {
        let errMsg = 'TTS generation failed';
        try {
          const errData = await res.json();
          errMsg = errData.error?.error || errData.error?.message || errData.error || errData.message || errMsg;
        } catch {}
        throw new Error(errMsg);
      }
      
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      audioEl.src = url;
      audioEl.classList.remove('hidden');
      audioEl.play();
      statusEl.classList.add('hidden');
    } catch (err: any) {
      statusEl.textContent = `✕ ${err.message || 'TTS failed'}`;
      statusEl.className = 'text-[10px] text-red-400 mt-1';
    } finally {
      playBtn.disabled = false;
      playBtn.textContent = '▶ Play';
    }
  }

  // ═══════════════════════════════════════════════════════════════
  // AI GENERATE SPEAK TEXT
  // ═══════════════════════════════════════════════════════════════
  document.getElementById('btn-ai-generate-speak')?.addEventListener('click', async () => {
    if (!selectedNode || !currentTree) return;
    const btn = document.getElementById('btn-ai-generate-speak') as HTMLButtonElement;
    const textarea = document.getElementById('edit-speak') as HTMLTextAreaElement;
    btn.disabled = true;
    btn.textContent = '⏳ Generating...';

    try {
      const node = currentTree[selectedNode];
      const edges = node?.edges ? Object.keys(node.edges) : [];
      const slots = currentTree._meta?.slots || [];
      const category = (document.getElementById('tree-category') as HTMLSelectElement)?.value || 'sales';
      const treeName = (document.getElementById('tree-name') as HTMLInputElement)?.value || '';
      const nodeAction = node?.action || '';

      // Gather context: previous node's transition speak, and what this node collects
      let prevContext = '';
      for (const [nid, ndata] of Object.entries(currentTree) as [string, any][]) {
        if (nid.startsWith('_')) continue;
        if (!ndata.edges) continue;
        for (const [, edge] of Object.entries(ndata.edges) as [string, any][]) {
          if (edge.next === selectedNode && edge.speak) {
            prevContext = Array.isArray(edge.speak) ? edge.speak[0] : edge.speak;
            break;
          }
        }
        if (prevContext) break;
      }

      const res = await fetch('/api/voice-ai-generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nodeId: selectedNode,
          edges,
          slots,
          category,
          treeName,
          nodeAction,
          prevContext,
          existingSpeak: textarea.value.trim() || undefined,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Generation failed' }));
        throw new Error(err.error || 'AI generation failed');
      }

      const data = await res.json();
      if (data.speak && data.speak.length > 0) {
        textarea.value = data.speak.join('\n');
        // Trigger the input change event to save to node
        textarea.dispatchEvent(new Event('input', { bubbles: true }));
        btn.textContent = '✓ Done';
        setTimeout(() => { btn.textContent = '✨ AI Fill'; }, 2000);
      } else {
        btn.textContent = '✕ No output';
        setTimeout(() => { btn.textContent = '✨ AI Fill'; }, 2000);
      }
    } catch (err: any) {
      btn.textContent = `✕ ${err.message?.slice(0, 20) || 'Failed'}`;
      setTimeout(() => { btn.textContent = '✨ AI Fill'; }, 3000);
    } finally {
      btn.disabled = false;
    }
  });

  // ═══════════════════════════════════════════════════════════════
  // COMPLIANCE CHECKS
  // ═══════════════════════════════════════════════════════════════
  function runComplianceChecks() {
    if (!currentTree) return;
    const allText = JSON.stringify(currentTree).toLowerCase();
    const nodes = getTreeNodes();

    // 1. AI Disclosure — must mention "AI" or "assistant" in greeting/consent
    const hasDisclosure = ['greeting_with_name', 'greeting_no_name', 'consent'].some(n => {
      const node = currentTree[n];
      if (!node) return false;
      const text = JSON.stringify(node.speak || []).toLowerCase() + JSON.stringify(node.edges || {}).toLowerCase();
      return text.includes('ai') || text.includes('assistant') || text.includes('artificial');
    });
    setCheck('check-disclosure', hasDisclosure);

    // 2. Opt-out available (global edge or explicit)
    const hasOptOut = currentTree._global_edges?.opt_out || allText.includes('opt_out') || allText.includes('do not call');
    setCheck('check-optout', !!hasOptOut);

    // 3. No deception — check for false human claims
    const noDeception = !allText.includes('i am a real person') && !allText.includes('i\'m a real person') && !allText.includes('not a robot');
    setCheck('check-no-deception', noDeception);

    // 4. Has terminal paths (can actually end the call)
    const hasTerminal = nodes.some(n => currentTree[n]?.action === 'hangup' || currentTree[n]?.action === 'transfer');
    setCheck('check-terminal', hasTerminal);
  }

  function setCheck(elId: string, passed: boolean) {
    const el = document.getElementById(elId);
    if (!el) return;
    const icon = el.querySelector('span')!;
    icon.textContent = passed ? '✅' : '❌';
    el.className = `flex items-center gap-2 ${passed ? 'text-green-300' : 'text-red-300'}`;
  }

  // ═══════════════════════════════════════════════════════════════
  // UTILITIES
  // ═══════════════════════════════════════════════════════════════
  function generateSlug(name: string): string {
    return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 60);
  }

  function debounce(fn: Function, ms: number) {
    let timer: any;
    return (...args: any[]) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn(...args), ms);
    };
  }

  // ═══════════════════════════════════════════════════════════════
  // ZOOM CONTROLS
  // ═══════════════════════════════════════════════════════════════
  function applyZoom() {
    const nodesLayer = document.getElementById('nodes-layer')!;
    const svg = document.getElementById('canvas-svg')!;
    nodesLayer.style.transform = `scale(${zoom})`;
    nodesLayer.style.transformOrigin = 'top left';
    svg.style.transform = `scale(${zoom})`;
    svg.style.transformOrigin = 'top left';
    // Toggle close-zoom indicator for CSS (shows edge labels)
    if (zoom >= 0.8) {
      svg.setAttribute('data-zoom-close', '');
    } else {
      svg.removeAttribute('data-zoom-close');
    }
    // Update zoom display in stats
    const zoomEl = document.getElementById('stat-zoom');
    if (zoomEl) zoomEl.textContent = Math.round(zoom * 100) + '%';
  }

  /** Fit tree to viewport with padding */
  function fitToView() {
    if (nodePositions.size === 0) return;
    const canvasEl = document.getElementById('canvas')!;
    const positions = [...nodePositions.entries()];
    let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
    for (const [nodeId, pos] of positions) {
      minX = Math.min(minX, pos.x);
      minY = Math.min(minY, pos.y);
      const node = currentTree[nodeId];
      const nh = node ? getNodeHeight(node, nodeId) : NODE_H;
      maxX = Math.max(maxX, pos.x + NODE_W);
      maxY = Math.max(maxY, pos.y + nh);
    }
    const treeW = maxX - minX + 100; // padding
    const treeH = maxY - minY + 100;
    const viewW = canvasEl.clientWidth;
    const viewH = canvasEl.clientHeight;
    // Fit zoom so tree fits in viewport (max 1.0, min 0.4)
    const fitZoom = Math.min(1.0, Math.max(0.4, Math.min(viewW / treeW, viewH / treeH) * 0.9));
    zoom = fitZoom;
    applyZoom();
    // Scroll to center the tree
    canvasEl.scrollTo({
      left: (minX - 50) * zoom,
      top: (minY - 50) * zoom,
      behavior: 'instant'
    });
  }

  document.getElementById('btn-zoom-in')?.addEventListener('click', () => {
    zoom = Math.min(2, zoom + 0.15);
    applyZoom();
  });

  document.getElementById('btn-zoom-out')?.addEventListener('click', () => {
    zoom = Math.max(0.3, zoom - 0.15);
    applyZoom();
  });

  document.getElementById('btn-zoom-reset')?.addEventListener('click', () => {
    fitToView();
  });

  /** Center the tree (preserving relative positions) in the canvas viewport */
  function centerTreeOnCanvas() {
    if (nodePositions.size === 0) return;
    const canvasEl = document.getElementById('canvas')!;
    
    // Find bounding box of all nodes
    let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
    for (const [nodeId, pos] of nodePositions) {
      const node = currentTree[nodeId];
      const nh = node ? getNodeHeight(node, nodeId) : NODE_H;
      minX = Math.min(minX, pos.x);
      minY = Math.min(minY, pos.y);
      maxX = Math.max(maxX, pos.x + NODE_W);
      maxY = Math.max(maxY, pos.y + nh);
    }
    
    const treeW = maxX - minX;
    const treeH = maxY - minY;
    
    // Target center: middle of the virtual canvas (or viewport-appropriate)
    const canvasW = Math.max(4000, treeW + 400);
    const canvasH = Math.max(2000, treeH + 400);
    const targetCenterX = canvasW / 2;
    const targetCenterY = canvasH / 2;
    
    // Current center of tree
    const treeCenterX = minX + treeW / 2;
    const treeCenterY = minY + treeH / 2;
    
    // Shift all nodes
    const dx = targetCenterX - treeCenterX;
    const dy = targetCenterY - treeCenterY;
    
    for (const [nodeId, pos] of nodePositions) {
      nodePositions.set(nodeId, { x: pos.x + dx, y: pos.y + dy });
    }
    
    renderCanvas();
    
    // Scroll to center of tree
    canvasEl.scrollTo({
      left: (targetCenterX * zoom) - canvasEl.clientWidth / 2,
      top: (targetCenterY * zoom) - canvasEl.clientHeight / 2,
      behavior: 'smooth'
    });
    
    markDirty();
  }

  /** Center just the selection (box or group) */
  function centerSelectionOnCanvas() {
    const nodes = boxSelectedNodes.size > 0 ? [...boxSelectedNodes] : (selectedNode ? [selectedNode] : []);
    if (nodes.length === 0) return;
    
    const canvasEl = document.getElementById('canvas')!;
    const positions = nodes.map(n => nodePositions.get(n)).filter(Boolean) as Array<{x:number, y:number}>;
    const avgX = positions.reduce((s, p) => s + p.x, 0) / positions.length;
    const avgY = positions.reduce((s, p) => s + p.y, 0) / positions.length;
    
    canvasEl.scrollTo({
      left: (avgX + NODE_W / 2) * zoom - canvasEl.clientWidth / 2,
      top: (avgY + NODE_H / 2) * zoom - canvasEl.clientHeight / 2,
      behavior: 'smooth'
    });
  }

  document.getElementById('btn-center-tree')?.addEventListener('click', centerTreeOnCanvas);
  document.getElementById('btn-center-selection')?.addEventListener('click', centerSelectionOnCanvas);

  // Mouse wheel: plain wheel = zoom, Shift+wheel = horizontal scroll
  document.getElementById('canvas')?.addEventListener('wheel', (e: WheelEvent) => {
    if (e.shiftKey) {
      // Shift+wheel → horizontal scroll (native)
      return;
    }
    e.preventDefault();
    const canvasEl = document.getElementById('canvas')!;
    const rect = canvasEl.getBoundingClientRect();
    // Mouse position relative to canvas content (before zoom)
    const mouseX = (e.clientX - rect.left + canvasEl.scrollLeft) / zoom;
    const mouseY = (e.clientY - rect.top + canvasEl.scrollTop) / zoom;
    
    zoom = Math.max(0.3, Math.min(2, zoom - e.deltaY * 0.002));
    applyZoom();
    
    // Adjust scroll to keep content under cursor stable
    canvasEl.scrollLeft = mouseX * zoom - (e.clientX - rect.left);
    canvasEl.scrollTop = mouseY * zoom - (e.clientY - rect.top);
  }, { passive: false });

  // Middle-mouse panning
  let isPanning = false;
  let panStartX = 0;
  let panStartY = 0;
  let panScrollStartX = 0;
  let panScrollStartY = 0;

  document.getElementById('canvas')?.addEventListener('mousedown', (e: MouseEvent) => {
    // Middle mouse button (button=1) starts panning
    if (e.button === 1) {
      e.preventDefault();
      e.stopPropagation();
      isPanning = true;
      panStartX = e.clientX;
      panStartY = e.clientY;
      const canvasEl = document.getElementById('canvas')!;
      panScrollStartX = canvasEl.scrollLeft;
      panScrollStartY = canvasEl.scrollTop;
      canvasEl.style.cursor = 'grabbing';
    }
  });

  // Prevent browser autoscroll on middle click
  document.getElementById('canvas')?.addEventListener('auxclick', (e: MouseEvent) => {
    if (e.button === 1) e.preventDefault();
  });

  document.addEventListener('mousemove', (e: MouseEvent) => {
    if (!isPanning) return;
    const canvasEl = document.getElementById('canvas')!;
    canvasEl.scrollLeft = panScrollStartX - (e.clientX - panStartX);
    canvasEl.scrollTop = panScrollStartY - (e.clientY - panStartY);
  });

  document.addEventListener('mouseup', (e: MouseEvent) => {
    if (isPanning) {
      isPanning = false;
      const canvasEl = document.getElementById('canvas')!;
      canvasEl.style.cursor = 'grab';
    }
  });

  // ═══════════════════════════════════════════════════════════════
  // BOTTOM PANEL: MINIMAP + STATS
  // ═══════════════════════════════════════════════════════════════
  function updateBottomPanel() {
    updateStats();
    renderMinimap();
  }

  function updateStats() {
    if (!currentTree) return;
    const nodes = Object.keys(currentTree).filter(k => !k.startsWith('_'));
    let edgeCount = 0;
    let terminals = 0;
    let deadEnds = 0;
    let transfers = 0;
    const reachable = new Set<string>();

    for (const nodeId of nodes) {
      const node = currentTree[nodeId];
      if (node.edges) {
        edgeCount += Object.keys(node.edges).length;
        for (const edge of Object.values(node.edges) as any[]) {
          if (edge.next) reachable.add(edge.next);
        }
      }
      if (node.next) { edgeCount++; reachable.add(node.next); }
      if (node.action === 'hangup') terminals++;
      if (node.action === 'transfer' || node.action === 'transfer_beth' || node.action === 'transfer_tim') transfers++;
      if (!node.next && !node.edges && !node.action) deadEnds++;
    }

    // Orphans: nodes not reachable by any edge (except root/greeting nodes)
    const rootNames = ['greeting', 'greeting_with_name', 'greeting_no_name', 'start', 'root'];
    const orphans = nodes.filter(n => !reachable.has(n) && !rootNames.includes(n));

    // Max depth from layout layers
    const depths = new Map<string, number>();
    function getDepth(nodeId: string, visited = new Set<string>()): number {
      if (visited.has(nodeId) || depths.has(nodeId)) return depths.get(nodeId) || 0;
      visited.add(nodeId);
      const node = currentTree[nodeId];
      if (!node) return 0;
      let maxChild = 0;
      if (node.edges) {
        for (const edge of Object.values(node.edges) as any[]) {
          if (edge.next && !visited.has(edge.next)) maxChild = Math.max(maxChild, getDepth(edge.next, visited) + 1);
        }
      }
      if (node.next && !visited.has(node.next)) maxChild = Math.max(maxChild, getDepth(node.next, visited) + 1);
      depths.set(nodeId, maxChild);
      return maxChild;
    }
    let maxDepth = 0;
    for (const n of nodes) maxDepth = Math.max(maxDepth, getDepth(n));

    const groups = currentTree._groups ? Object.keys(currentTree._groups).length : 0;

    const el = (id: string) => document.getElementById(id);
    if (el('stat-nodes')) el('stat-nodes')!.textContent = String(nodes.length);
    if (el('stat-edges')) el('stat-edges')!.textContent = String(edgeCount);
    if (el('stat-groups')) el('stat-groups')!.textContent = String(groups);
    if (el('stat-depth')) el('stat-depth')!.textContent = String(maxDepth);
    if (el('stat-terminals')) el('stat-terminals')!.textContent = String(terminals);
    if (el('stat-deadends')) el('stat-deadends')!.textContent = String(deadEnds);
    if (el('stat-orphans')) el('stat-orphans')!.textContent = String(orphans.length);
    if (el('stat-transfers')) el('stat-transfers')!.textContent = String(transfers);
    if (el('stat-zoom')) el('stat-zoom')!.textContent = Math.round(zoom * 100) + '%';
    if (el('stat-selected')) el('stat-selected')!.textContent = selectedNode ? selectedNode.replace(/_/g, ' ') : '—';
  }

  function renderMinimap() {
    const canvas = document.getElementById('minimap-canvas') as HTMLCanvasElement;
    const container = document.getElementById('minimap-container')!;
    const viewport = document.getElementById('minimap-viewport')!;
    if (!canvas || !container || nodePositions.size === 0) return;

    const cRect = container.getBoundingClientRect();
    canvas.width = cRect.width;
    canvas.height = cRect.height;
    const ctx = canvas.getContext('2d')!;
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Find bounds
    let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
    for (const [nodeId, pos] of nodePositions) {
      const node = currentTree[nodeId];
      const nh = node ? getNodeHeight(node, nodeId) : NODE_H;
      minX = Math.min(minX, pos.x);
      minY = Math.min(minY, pos.y);
      maxX = Math.max(maxX, pos.x + NODE_W);
      maxY = Math.max(maxY, pos.y + nh);
    }
    const pad = 40;
    minX -= pad; minY -= pad; maxX += pad; maxY += pad;
    const treeW = maxX - minX;
    const treeH = maxY - minY;
    const scale = Math.min(canvas.width / treeW, canvas.height / treeH);
    const offX = (canvas.width - treeW * scale) / 2;
    const offY = (canvas.height - treeH * scale) / 2;

    // Draw edges (thin lines)
    ctx.strokeStyle = '#4b5563';
    ctx.lineWidth = 0.5;
    if (currentTree) {
      for (const [nodeId, node] of Object.entries(currentTree) as any) {
        if (nodeId.startsWith('_')) continue;
        const fromPos = nodePositions.get(nodeId);
        if (!fromPos) continue;
        const targets: string[] = [];
        if (node.next) targets.push(node.next);
        if (node.edges) {
          for (const edge of Object.values(node.edges) as any[]) {
            if (edge.next) targets.push(edge.next);
          }
        }
        for (const t of targets) {
          const toPos = nodePositions.get(t);
          if (!toPos) continue;
          ctx.beginPath();
          ctx.moveTo(offX + (fromPos.x + NODE_W - minX) * scale, offY + (fromPos.y + NODE_H / 2 - minY) * scale);
          ctx.lineTo(offX + (toPos.x - minX) * scale, offY + (toPos.y + NODE_H / 2 - minY) * scale);
          ctx.stroke();
        }
      }
    }

    // Draw nodes (tiny rectangles)
    for (const [nodeId, pos] of nodePositions) {
      const node = currentTree[nodeId];
      const nh = node ? getNodeHeight(node, nodeId) : NODE_H;
      const rx = offX + (pos.x - minX) * scale;
      const ry = offY + (pos.y - minY) * scale;
      const rw = NODE_W * scale;
      const rh = nh * scale;

      if (nodeId === selectedNode) {
        ctx.fillStyle = '#3b82f6';
      } else if (node?.action === 'transfer' || node?.action === 'transfer_beth' || node?.action === 'transfer_tim') {
        ctx.fillStyle = '#22c55e';
      } else if (node?.action === 'hangup') {
        ctx.fillStyle = '#ef4444';
      } else if (node?.edges) {
        ctx.fillStyle = '#6366f1';
      } else {
        ctx.fillStyle = '#6b7280';
      }
      ctx.fillRect(rx, ry, Math.max(rw, 2), Math.max(rh, 1));
    }

    // Draw viewport indicator
    const canvasEl = document.getElementById('canvas')!;
    const vpX = offX + (canvasEl.scrollLeft / zoom - minX) * scale;
    const vpY = offY + (canvasEl.scrollTop / zoom - minY) * scale;
    const vpW = (canvasEl.clientWidth / zoom) * scale;
    const vpH = (canvasEl.clientHeight / zoom) * scale;
    viewport.style.display = 'block';
    viewport.style.left = vpX + 'px';
    viewport.style.top = vpY + 'px';
    viewport.style.width = vpW + 'px';
    viewport.style.height = vpH + 'px';

    // Click on minimap scrolls canvas
    canvas.onclick = (e) => {
      const cr = canvas.getBoundingClientRect();
      const mx = e.clientX - cr.left;
      const my = e.clientY - cr.top;
      const worldX = (mx - offX) / scale + minX;
      const worldY = (my - offY) / scale + minY;
      canvasEl.scrollTo({
        left: worldX * zoom - canvasEl.clientWidth / 2,
        top: worldY * zoom - canvasEl.clientHeight / 2,
        behavior: 'smooth'
      });
    };
  }

  // Update minimap on scroll
  document.getElementById('canvas')?.addEventListener('scroll', () => {
    requestAnimationFrame(renderMinimap);
  });

  // ═══════════════════════════════════════════════════════════════
  // BULK TTS RENDER
  // ═══════════════════════════════════════════════════════════════
  document.getElementById('btn-render-tts')?.addEventListener('click', async () => {
    if (!currentTree) return;
    const btn = document.getElementById('btn-render-tts') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Rendering...';

    const nodes = getTreeNodes();
    const allTexts: string[] = [];
    for (const id of nodes) {
      const node = currentTree[id];
      if (Array.isArray(node?.speak)) {
        allTexts.push(...node.speak.filter(Boolean));
      }
      // Also render edge speaks
      if (node?.edges) {
        for (const edge of Object.values(node.edges) as any[]) {
          if (Array.isArray(edge?.speak)) {
            allTexts.push(...edge.speak.filter(Boolean));
          }
        }
      }
    }

    if (allTexts.length === 0) {
      btn.textContent = '🔊 Render';
      btn.disabled = false;
      return;
    }

    try {
      const res = await fetch('/api/voice-tts-preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ texts: allTexts, cache: true }),
      });
      if (res.ok) {
        const data = await res.json();
        btn.textContent = `✓ ${data.cached || allTexts.length} cached`;
      } else {
        btn.textContent = '✕ Failed';
      }
    } catch {
      btn.textContent = '✕ Unreachable';
    }

    setTimeout(() => {
      btn.textContent = '🔊 Render';
      btn.disabled = false;
    }, 3000);
  });

