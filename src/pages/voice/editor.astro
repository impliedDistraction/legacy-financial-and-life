  function getNextGroupColor(): string {
    const colors = ['#7c3aed', '#0891b2', '#059669', '#d97706', '#dc2626', '#4f46e5'];
    const used = Object.values(currentTree._groups || {}).map((g: any) => g.color);
    return colors.find(c => !used.includes(c)) || colors[0];
  }

  // ═══════════════════════════════════════════════════════════════
  // IMPORT / EXPORT NODE PATHS
  // ═══════════════════════════════════════════════════════════════
  document.getElementById('btn-export-nodes')?.addEventListener('click', () => {
    if (!currentTree || !selectedNode) {
      alert('Select a node first, then export it and its downstream path.');
      return;
    }
    
    // Collect the selected node and all reachable nodes from it
    const exported: Record<string, any> = {};
    const queue = [selectedNode];
    const visited = new Set<string>();

    while (queue.length > 0) {
      const id = queue.shift()!;
      if (visited.has(id) || !currentTree[id]) continue;
      visited.add(id);
      exported[id] = JSON.parse(JSON.stringify(currentTree[id]));

      const node = currentTree[id];
      if (node.next && !visited.has(node.next)) queue.push(node.next);
      if (node.edges) {
        for (const edge of Object.values(node.edges) as any[]) {
          if (edge.next && !visited.has(edge.next)) queue.push(edge.next);
        }
      }
    }

    // Check if selected group nodes should be included
    if (currentTree._groups) {
      for (const [gName, group] of Object.entries(currentTree._groups) as any) {
        if ((group.nodes || []).includes(selectedNode)) {
          exported._exportedGroup = { name: gName, ...group };
        }
      }
    }

    exported._exportMeta = {
      source_tree: (document.getElementById('tree-name') as HTMLInputElement).value,
      exported_at: new Date().toISOString(),
      entry_node: selectedNode,
      node_count: Object.keys(exported).filter(k => !k.startsWith('_')).length,
    };

    // Download as JSON file
    const blob = new Blob([JSON.stringify(exported, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `nodes-${selectedNode}-${Date.now()}.json`;
    a.click();
    URL.revokeObjectURL(url);
  });

  document.getElementById('btn-import-nodes')?.addEventListener('click', () => {
    if (!currentTree) return;
    
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json';
    input.addEventListener('change', async () => {
      const file = input.files?.[0];
      if (!file) return;
      
      try {
        const text = await file.text();
        const data = JSON.parse(text);
        const meta = data._exportMeta;
        delete data._exportMeta;
        const exportedGroup = data._exportedGroup;
        delete data._exportedGroup;

        // Get importable nodes (non-underscore keys)
        const nodeKeys = Object.keys(data).filter(k => !k.startsWith('_'));
        if (nodeKeys.length === 0) {
          alert('No nodes found in file.');
          return;
        }

        // Check for conflicts
        const conflicts = nodeKeys.filter(k => currentTree[k]);
        let prefix = '';
        if (conflicts.length > 0) {
          prefix = prompt(`${conflicts.length} node(s) conflict with existing nodes (${conflicts.slice(0, 3).join(', ')}). Enter a prefix to rename them, or cancel:`, 'imported_') || '';
          if (!prefix) return;
        }

        // Import nodes
        for (const key of nodeKeys) {
          const newKey = prefix ? `${prefix}${key}` : key;
          const node = data[key];
          
          // Remap next/edge references if prefixed
          if (prefix) {
            if (node.next && nodeKeys.includes(node.next)) node.next = `${prefix}${node.next}`;
            if (node.edges) {
              for (const edge of Object.values(node.edges) as any[]) {
                if (edge.next && nodeKeys.includes(edge.next)) edge.next = `${prefix}${edge.next}`;
              }
            }
          }

          currentTree[newKey] = node;
        }

        // Import group if present
        if (exportedGroup && exportedGroup.name) {
          if (!currentTree._groups) currentTree._groups = {};
          const gName = prefix ? `${prefix}${exportedGroup.name}` : exportedGroup.name;
          currentTree._groups[gName] = {
            label: exportedGroup.label,
            color: exportedGroup.color || getNextGroupColor(),
            nodes: (exportedGroup.nodes || []).map((n: string) => prefix ? `${prefix}${n}` : n),
            collapsed: false,
          };
        }

        markDirty();
        computeLayout();
        renderCanvas();
        renderNodeList();
        
        const entryNode = prefix ? `${prefix}${meta?.entry_node || nodeKeys[0]}` : (meta?.entry_node || nodeKeys[0]);
        if (currentTree[entryNode]) selectNode(entryNode);
        
        alert(`Imported ${nodeKeys.length} node(s) from "${meta?.source_tree || 'unknown'}".`);
      } catch (err: any) {
        alert('Import failed: ' + err.message);
      }
    });
    input.click();
  });

  // ═══════════════════════════════════════════════════════════════
  // LEFT SIDEBAR TABS (Nodes / Trees)
  // ═══════════════════════════════════════════════════════════════
  let allTrees: any[] = [];

  document.querySelectorAll('[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      // Toggle active styling
      document.querySelectorAll('[data-tab]').forEach(b => {
        (b as HTMLElement).className = `flex-1 px-3 py-2 text-xs font-semibold border-b-2 ${
          (b as HTMLElement).dataset.tab === tab 
            ? 'text-brand-300 border-brand-400 bg-gray-800' 
            : 'text-gray-500 border-transparent hover:text-gray-300'
        }`;
      });
      // Show/hide panels
      document.getElementById('panel-nodes')!.classList.toggle('hidden', tab !== 'nodes');
      document.getElementById('panel-trees')!.classList.toggle('hidden', tab !== 'trees');

      if (tab === 'trees') refreshTreesList();
    });
  });

  async function refreshTreesList() {
    try {
      const res = await fetch('/api/voice-dialog-tree?list=true');
      if (!res.ok) return;
      const data = await res.json();
      allTrees = data.trees || [];
      renderTreesList();
    } catch {}
  }

  function renderTreesList() {
    const list = document.getElementById('trees-list')!;
    const statusFilter = (document.getElementById('trees-filter-status') as HTMLSelectElement).value;
    const catFilter = (document.getElementById('trees-filter-category') as HTMLSelectElement).value;
    
    let filtered = allTrees;
    if (statusFilter) filtered = filtered.filter(t => t.status === statusFilter);
    if (catFilter) filtered = filtered.filter(t => t.category === catFilter);

    if (filtered.length === 0) {
      list.innerHTML = '<div class="text-xs text-gray-500 py-4 text-center">No trees found</div>';
      return;
    }

    list.innerHTML = filtered.map(t => {
      const isActive = t.id === currentTreeId;
      const statusIcon = t.status === 'active' ? '🟢' : t.status === 'testing' ? '🟡' : t.status === 'archived' ? '⚫' : '⚪';
      return `<div class="px-2 py-2 rounded cursor-pointer text-xs transition-colors ${isActive ? 'bg-brand-600/30 border border-brand-500/50' : 'hover:bg-gray-700 border border-transparent'}" data-tree-id="${t.id}">
        <div class="flex items-center gap-2">
          <span class="text-[10px]">${statusIcon}</span>
          <span class="font-medium text-gray-200 truncate flex-1">${t.name}</span>
        </div>
        <div class="flex items-center gap-2 mt-0.5 ml-5">
          <span class="text-[10px] text-gray-500">${t.category || 'custom'}</span>
          <span class="text-[10px] text-gray-600">•</span>
          <span class="text-[10px] text-gray-500">${t.node_count || '?'} nodes</span>
        </div>
      </div>`;
    }).join('');

    // Click to load tree
    list.querySelectorAll('[data-tree-id]').forEach(el => {
      el.addEventListener('click', async () => {
        const id = (el as HTMLElement).dataset.treeId;
        if (!id) return;
        if (isDirty && !confirm('Discard unsaved changes?')) return;
        try {
          const res = await fetch(`/api/voice-dialog-tree?id=${id}`);
          if (res.ok) {
            const data = await res.json();
            currentTree = data.tree_data;
            currentTreeId = data.id;
            currentSlug = data.slug;
            (document.getElementById('tree-name') as HTMLInputElement).value = data.name;
            (document.getElementById('tree-category') as HTMLSelectElement).value = data.category || 'custom';
            (document.getElementById('tree-status') as HTMLSelectElement).value = data.status || 'draft';
            isDirty = false;
            selectedNode = null;
            document.getElementById('node-editor')!.classList.add('hidden');
            document.getElementById('save-status')!.textContent = 'Loaded';
            document.getElementById('save-status')!.className = 'text-xs text-gray-500';
            initEditor();
            renderTreesList(); // Refresh to show active highlight
            // Switch back to nodes tab
            (document.querySelector('[data-tab="nodes"]') as HTMLElement)?.click();
          }
        } catch {}
      });
    });
  }

  // Filter change handlers
  document.getElementById('trees-filter-status')?.addEventListener('change', renderTreesList);
  document.getElementById('trees-filter-category')?.addEventListener('change', renderTreesList);
  document.getElementById('btn-new-tree-tab')?.addEventListener('click', () => {
    document.getElementById('btn-new-tree')?.click();
    (document.querySelector('[data-tab="nodes"]') as HTMLElement)?.click();
  });

  // ═══════════════════════════════════════════════════════════════
  // LLM GATHER SETTINGS TOGGLE
  // ═══════════════════════════════════════════════════════════════
  const ACTION_HINTS: Record<string, string> = {
    transfer: 'Ends AI conversation and live-transfers to a human agent.',
    hangup: 'Politely ends the call.',
    book: 'Sends Calendly link and ends with booking CTA.',
    llm_fallback: 'Permanently hands off to LLM. No return to tree.',
    llm_gather: 'LLM listens and reasons, extracts slots, then returns to tree.',
  };

  document.getElementById('edit-action')?.addEventListener('change', () => {
    const val = (document.getElementById('edit-action') as HTMLSelectElement).value;
    const hint = document.getElementById('action-hint')!;
    const gatherPanel = document.getElementById('gather-settings')!;
    
    if (ACTION_HINTS[val]) {
      hint.textContent = ACTION_HINTS[val];
      hint.classList.remove('hidden');
    } else {
      hint.classList.add('hidden');
    }
    
    gatherPanel.classList.toggle('hidden', val !== 'llm_gather');
    document.getElementById('gather-escape-paths')!.classList.toggle('hidden', val !== 'llm_gather');

    // Populate return-to dropdown
    if (val === 'llm_gather') {
      const returnSel = document.getElementById('edit-gather-return') as HTMLSelectElement;
      returnSel.innerHTML = '<option value="">— Next in tree —</option>' +
        getTreeNodes().filter(n => n !== selectedNode).map(n => 
          `<option value="${n}">${n}</option>`
        ).join('');
      
      // Load existing gather config
      if (selectedNode && currentTree[selectedNode]?.gather) {
        const g = currentTree[selectedNode].gather;
        (document.getElementById('edit-gather-tone') as HTMLSelectElement).value = g.tone || 'professional';
        (document.getElementById('edit-gather-max-turns') as HTMLInputElement).value = String(g.max_turns || 3);
        returnSel.value = g.return_to || '';
        (document.getElementById('edit-gather-slots') as HTMLTextAreaElement).value = 
          (g.slots || []).map((s: any) => `${s.name} = ${s.description}`).join('\n');
        (document.getElementById('edit-gather-prompt') as HTMLTextAreaElement).value = g.prompt || '';
      }
    }
  });

  // Save gather settings into node
  ['edit-gather-tone', 'edit-gather-max-turns', 'edit-gather-return', 'edit-gather-slots', 'edit-gather-prompt'].forEach(id => {
    document.getElementById(id)?.addEventListener('change', () => {
      if (!selectedNode || !currentTree[selectedNode]) return;
      const node = currentTree[selectedNode];
      
      const slotsText = (document.getElementById('edit-gather-slots') as HTMLTextAreaElement).value;
      const slots = slotsText.split('\n').filter(Boolean).map(line => {
        const [name, ...desc] = line.split('=');
        return { name: (name || '').trim(), description: (desc.join('=') || '').trim() };
      }).filter(s => s.name);

      node.gather = {
        tone: (document.getElementById('edit-gather-tone') as HTMLSelectElement).value,
        max_turns: parseInt((document.getElementById('edit-gather-max-turns') as HTMLInputElement).value) || 3,
        return_to: (document.getElementById('edit-gather-return') as HTMLSelectElement).value || undefined,
        slots: slots.length > 0 ? slots : undefined,
        prompt: (document.getElementById('edit-gather-prompt') as HTMLTextAreaElement).value || undefined,
      };
      markDirty();
    });
  });

  // ═══════════════════════════════════════════════════════════════
  // ESCAPE PATHS (gather node analytics)
  // ═══════════════════════════════════════════════════════════════
  async function loadEscapePaths(nodeId: string) {
    const panel = document.getElementById('gather-escape-paths')!;
    const content = document.getElementById('escape-paths-content')!;
    const unhandledSection = document.getElementById('unhandled-patterns')!;
    const unhandledList = document.getElementById('unhandled-list')!;

    // Only show for llm_gather nodes
    const node = currentTree[nodeId];
    if (!node || node.action !== 'llm_gather') {
      panel.classList.add('hidden');
      return;
    }
    panel.classList.remove('hidden');
    content.innerHTML = '<div class="text-gray-500 italic">Loading insights...</div>';
    unhandledSection.classList.add('hidden');

    // Fetch gather session data + insights from Supabase (via API proxy)
    try {
      const res = await fetch(`/api/voice-gather-insights?node_id=${encodeURIComponent(nodeId)}&tree_id=${currentTreeId || ''}`);
      if (!res.ok) {
        content.innerHTML = '<div class="text-gray-500 italic">No call data yet. Insights appear after this node handles real calls.</div>';
        return;
      }
      const data = await res.json();

      // Render common paths
      if (data.paths && data.paths.length > 0) {
        content.innerHTML = data.paths.map((p: any) => {
          const icon = p.outcome === 'returned' ? '🟢' : p.outcome === 'max_turns' ? '🟡' : '🔴';
          const slotInfo = p.slots_filled ? `Slots: ${p.slots_filled}` : '';
          return `<div class="bg-gray-800 rounded p-1.5">
            <div class="flex items-center gap-1">
              <span>${icon}</span>
              <span class="font-medium text-gray-200">${p.label} (${p.count}x)</span>
            </div>
            ${slotInfo ? `<div class="text-gray-400 ml-5">${slotInfo}</div>` : ''}
            ${p.sample ? `<div class="text-gray-500 ml-5 italic truncate">"${p.sample}"</div>` : ''}
          </div>`;
        }).join('');
      } else {
        content.innerHTML = '<div class="text-gray-500 italic">No call data yet. Insights appear after this node handles real calls.</div>';
      }

      // Render unhandled patterns
      if (data.unhandled && data.unhandled.length > 0) {
        unhandledSection.classList.remove('hidden');
        unhandledList.innerHTML = data.unhandled.map((u: any) =>
          `<div class="flex items-center justify-between bg-gray-800 rounded px-2 py-1">
            <span class="text-gray-300 truncate flex-1">"${u.pattern}" (${u.count}x)</span>
            <button class="promote-to-edge-btn text-[9px] px-1.5 py-0.5 bg-green-800 text-green-200 rounded hover:bg-green-700 flex-shrink-0 ml-2" data-pattern="${(u.pattern || '').replace(/"/g, '&quot;')}" data-examples='${JSON.stringify(u.examples || [])}'>+ Edge</button>
          </div>`
        ).join('');

        // "Promote to edge" buttons
        unhandledList.querySelectorAll('.promote-to-edge-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const pattern = (btn as HTMLElement).dataset.pattern || '';
            let examples: string[] = [];
            try { examples = JSON.parse((btn as HTMLElement).dataset.examples || '[]'); } catch {}
            
            const edgeName = prompt('Edge name for this pattern:', pattern.toLowerCase().replace(/[^a-z0-9]+/g, '_').slice(0, 30));
            if (!edgeName || !selectedNode || !currentTree[selectedNode]) return;
            
            const node = currentTree[selectedNode];
            if (!node.edges) node.edges = {};
            
            // Generate regex from examples
            const escapedExamples = [pattern, ...examples]
              .map(e => e.toLowerCase().replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
            const regex = `(${[...new Set(escapedExamples)].join('|')})`;
            
            node.edges[edgeName] = {
              match_regex: regex,
              speak: [],
              next: '',
            };
            
            markDirty();
            renderEdgesEditor(node.edges);
            renderCanvas();
          });
        });
      }
    } catch {
      content.innerHTML = '<div class="text-gray-500 italic">Could not load insights (bridge offline).</div>';
    }
  }

  // Show escape paths when gather node selected
  document.getElementById('btn-refresh-insights')?.addEventListener('click', () => {
    if (selectedNode) loadEscapePaths(selectedNode);
  });

  // ═══════════════════════════════════════════════════════════════
  // RUBBER-BAND SELECTION (box select on canvas)
  // ═══════════════════════════════════════════════════════════════
  let boxSelecting = false;
  let boxStart = { x: 0, y: 0 };
  let boxEnd = { x: 0, y: 0 };
  let boxSelectedNodes: Set<string> = new Set();
  let selectionBox: HTMLElement | null = null;

  const canvas = document.getElementById('canvas')!;

  function canvasCoords(e: MouseEvent): { x: number; y: number } {
    const rect = canvas.getBoundingClientRect();
    return {
      x: (e.clientX - rect.left + canvas.scrollLeft) / zoom,
      y: (e.clientY - rect.top + canvas.scrollTop) / zoom,
    };
  }

  canvas.addEventListener('mousedown', (e: MouseEvent) => {
    // Only start box select on left click on empty canvas (not on nodes)
    const target = e.target as HTMLElement;
    if (target.id !== 'canvas' && target.id !== 'canvas-svg' && target.id !== 'nodes-layer') return;
    if (e.button !== 0) return;
    if (dragging) return;

    boxSelecting = true;
    boxStart = canvasCoords(e);
    boxEnd = { ...boxStart };
    boxSelectedNodes.clear();

    // Create selection rectangle
    selectionBox = document.createElement('div');
    selectionBox.className = 'absolute border-2 border-brand-400 bg-brand-400/10 rounded pointer-events-none z-40';
    selectionBox.style.cssText = `left:${boxStart.x}px; top:${boxStart.y}px; width:0; height:0;`;
    document.getElementById('nodes-layer')!.appendChild(selectionBox);
    e.preventDefault();
  });

  canvas.addEventListener('mousemove', (e: MouseEvent) => {
    if (!boxSelecting || !selectionBox) return;
    boxEnd = canvasCoords(e);
    
    const x = Math.min(boxStart.x, boxEnd.x);
    const y = Math.min(boxStart.y, boxEnd.y);
    const w = Math.abs(boxEnd.x - boxStart.x);
    const h = Math.abs(boxEnd.y - boxStart.y);
    selectionBox.style.cssText = `left:${x}px; top:${y}px; width:${w}px; height:${h}px;`;
    
    // Highlight nodes within box
    boxSelectedNodes.clear();
    const rect = { x, y, w, h };
    for (const [nodeId, pos] of nodePositions) {
      const nh = getNodeHeight(currentTree[nodeId], nodeId);
      if (pos.x + NODE_W > rect.x && pos.x < rect.x + rect.w &&
          pos.y + nh > rect.y && pos.y < rect.y + rect.h) {
        boxSelectedNodes.add(nodeId);
      }
    }
    
    // Visual feedback on nodes
    document.querySelectorAll('[data-node-id]').forEach(el => {
      const id = (el as HTMLElement).dataset.nodeId!;
      if (boxSelectedNodes.has(id)) {
        (el as HTMLElement).style.outline = '2px solid #818cf8';
      } else {
        (el as HTMLElement).style.outline = '';
      }
    });
  });

  canvas.addEventListener('mouseup', (e: MouseEvent) => {
    if (!boxSelecting) return;
    boxSelecting = false;
    
    if (selectionBox) {
      selectionBox.remove();
      selectionBox = null;
    }
    
    // Clear outline styles
    document.querySelectorAll('[data-node-id]').forEach(el => {
      (el as HTMLElement).style.outline = '';
    });

    // If we selected multiple nodes, show the group creation prompt
    if (boxSelectedNodes.size >= 2) {
      showBoxSelectionActions(boxSelectedNodes);
      // Show center-selection button
      document.getElementById('btn-center-selection')?.classList.remove('hidden');
    } else if (boxSelectedNodes.size === 1) {
      selectNode([...boxSelectedNodes][0]);
      document.getElementById('btn-center-selection')?.classList.add('hidden');
    } else {
      document.getElementById('btn-center-selection')?.classList.add('hidden');
    }
  });

  function showBoxSelectionActions(nodes: Set<string>) {
    // Show a floating action bar near the selection
    const positions = [...nodes].map(n => nodePositions.get(n)!).filter(Boolean);
    const avgX = positions.reduce((s, p) => s + p.x, 0) / positions.length;
    const minY = Math.min(...positions.map(p => p.y));

    // Remove existing action bar
    document.getElementById('box-select-actions')?.remove();
    
    const bar = document.createElement('div');
    bar.id = 'box-select-actions';
    bar.className = 'absolute z-50 flex gap-2 bg-gray-900 border border-gray-600 rounded-lg px-3 py-2 shadow-xl';
    bar.style.cssText = `left:${avgX}px; top:${minY - 50}px;`;
    bar.innerHTML = `
      <span class="text-xs text-gray-300">${nodes.size} selected</span>
      <button class="box-action px-2 py-0.5 bg-purple-700 text-white text-[10px] rounded hover:bg-purple-600" data-action="group">+ Group</button>
      <button class="box-action px-2 py-0.5 bg-blue-700 text-white text-[10px] rounded hover:bg-blue-600" data-action="export">↑ Export</button>
      <button class="box-action px-2 py-0.5 bg-gray-700 text-gray-300 text-[10px] rounded hover:bg-gray-600" data-action="dismiss">✕</button>
    `;
    
    bar.querySelectorAll('.box-action').forEach(btn => {
      btn.addEventListener('click', () => {
        const action = (btn as HTMLElement).dataset.action;
        if (action === 'group') {
          const name = prompt('Group name for these nodes:');
          if (name) {
            if (!currentTree._groups) currentTree._groups = {};
            currentTree._groups[name] = {
              label: name.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
              color: getNextGroupColor(),
              nodes: [...nodes],
              collapsed: false,
            };
            markDirty();
            renderCanvas();
            renderNodeList();
          }
        } else if (action === 'export') {
          // Export all selected nodes
          const exported: Record<string, any> = {};
          for (const id of nodes) {
            if (currentTree[id]) exported[id] = JSON.parse(JSON.stringify(currentTree[id]));
          }
          exported._exportMeta = {
            source_tree: (document.getElementById('tree-name') as HTMLInputElement).value,
            exported_at: new Date().toISOString(),
            entry_node: [...nodes][0],
            node_count: nodes.size,
          };
          const blob = new Blob([JSON.stringify(exported, null, 2)], { type: 'application/json' });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `nodes-selection-${Date.now()}.json`;
          a.click();
          URL.revokeObjectURL(url);
        }
        bar.remove();
      });
    });

    document.getElementById('nodes-layer')!.appendChild(bar);

    // Dismiss on click elsewhere
    const dismissOnClick = (e: MouseEvent) => {
      if (!bar.contains(e.target as Node)) {
        bar.remove();
        document.removeEventListener('click', dismissOnClick);
      }
    };
    setTimeout(() => document.addEventListener('click', dismissOnClick), 100);
  }

  // ═══════════════════════════════════════════════════════════════
  // + NEW NODE WIZARD (suggests missing nodes)
  // ═══════════════════════════════════════════════════════════════
  // Replace the plain prompt-based node creation with a wizard
  // that analyzes the tree and suggests what's missing.

  function analyzeTreeCompleteness(): { missing: Array<{ id: string; reason: string; category: string }> } {
    if (!currentTree) return { missing: [] };
    const nodes = getTreeNodes();
    const missing: Array<{ id: string; reason: string; category: string }> = [];

    // Check for greeting nodes
    if (!nodes.includes('greeting_with_name') && !nodes.includes('greeting')) {
      missing.push({ id: 'greeting_with_name', reason: 'Personalized greeting using {firstName}', category: 'greeting' });
    }
    if (!nodes.includes('greeting_no_name')) {
      missing.push({ id: 'greeting_no_name', reason: 'Fallback greeting when name unknown', category: 'greeting' });
    }

    // Check for opt-out / DNC
    if (!nodes.some(n => n.includes('opt_out') || n.includes('dnc') || n.includes('do_not_call'))) {
      missing.push({ id: 'opt_out', reason: 'Required: handle "remove me" / DNC requests', category: 'compliance' });
    }

    // Check for wrong person
    if (!nodes.some(n => n.includes('wrong_person'))) {
      missing.push({ id: 'wrong_person', reason: 'Handle "that\'s not me" responses', category: 'routing' });
    }

    // Check for terminal nodes
    if (!nodes.some(n => currentTree[n]?.action === 'transfer')) {
      missing.push({ id: 'transfer_to_agent', reason: 'Happy path: transfer interested callers', category: 'terminal' });
    }
    if (!nodes.some(n => currentTree[n]?.action === 'hangup' || n.includes('goodbye'))) {
      missing.push({ id: 'polite_goodbye', reason: 'Graceful call ending', category: 'terminal' });
    }

    // Check for identity confirmation
    if (!nodes.some(n => n.includes('identity') || n.includes('confirm_name'))) {
      missing.push({ id: 'identity_check', reason: 'Confirm you\'re speaking to the right person', category: 'opening' });
    }

    // Check for qualification question
    const category = (document.getElementById('tree-category') as HTMLSelectElement).value;
    if (category === 'sales' || category === 'recruitment') {
      if (!nodes.some(n => n.includes('interest') || n.includes('pitch'))) {
        missing.push({ id: 'interest_check', reason: 'Ask if they\'re open to hearing more', category: 'qualifying' });
      }
    }

    // Check for objection handling
    if (!nodes.some(n => n.includes('objection') || n.includes('not_interested'))) {
      missing.push({ id: 'not_interested', reason: 'Handle "not interested" gracefully', category: 'objection' });
    }

    // Check for time/scheduling
    if (!nodes.some(n => n.includes('schedule') || n.includes('callback') || n.includes('busy'))) {
      missing.push({ id: 'busy_callback', reason: 'Handle "I\'m busy, call back later"', category: 'routing' });
    }

    // Check for gather node (empathetic listening)
    if (category === 'client_outreach') {
      if (!nodes.some(n => currentTree[n]?.action === 'llm_gather')) {
        missing.push({ id: 'gather_needs', reason: 'Listen and understand client needs (LLM reasoning)', category: 'gathering' });
      }
    }

    return { missing };
  }

  // Override the add-node button behavior is handled above (ADD NODE section)

  function showNewNodeWizard() {
    const { missing } = analyzeTreeCompleteness();
    
    // Create wizard modal
    const modal = document.createElement('div');
    modal.id = 'new-node-wizard';
    modal.className = 'fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm';
    
    const suggestions = missing.length > 0 ? `
      <div class="mb-4">
        <h4 class="text-xs font-semibold text-amber-300 mb-2">💡 Suggested (missing from your tree)</h4>
        <div class="space-y-1 max-h-48 overflow-y-auto">
          ${missing.map(m => `
            <button class="wizard-suggest w-full text-left px-3 py-2 bg-gray-700/50 border border-gray-600 rounded hover:bg-gray-700 hover:border-gray-500 transition-colors" data-id="${m.id}">
              <div class="flex items-center justify-between">
                <span class="text-xs font-mono text-gray-200">${m.id}</span>
                <span class="text-[9px] px-1.5 py-0.5 rounded bg-gray-600 text-gray-300">${m.category}</span>
              </div>
              <p class="text-[10px] text-gray-400 mt-0.5">${m.reason}</p>
            </button>
          `).join('')}
        </div>
      </div>
    ` : '<p class="text-xs text-green-300 mb-4">✅ Your tree looks complete! All standard nodes present.</p>';

    modal.innerHTML = `
      <div class="bg-gray-800 border border-gray-600 rounded-xl shadow-2xl w-[420px] mx-4 max-h-[80vh] overflow-hidden flex flex-col">
        <div class="px-5 py-3 border-b border-gray-700 flex items-center justify-between">
          <h3 class="text-sm font-semibold text-white">+ Add Node</h3>
          <button id="wizard-close" class="text-gray-400 hover:text-white text-lg leading-none">&times;</button>
        </div>
        <div class="px-5 py-4 overflow-y-auto">
          ${suggestions}
          <div>
            <h4 class="text-xs font-semibold text-gray-300 mb-2">Custom Node</h4>
            <div class="flex gap-2">
              <input id="wizard-custom-id" type="text" class="flex-1 bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-sm text-gray-200 font-mono" placeholder="node_id_snake_case" />
              <button id="wizard-custom-btn" class="px-3 py-1.5 bg-brand-600 text-white text-xs rounded hover:bg-brand-700">Create</button>
            </div>
          </div>
        </div>
      </div>
    `;
    
    document.body.appendChild(modal);

    // Close handlers
    modal.addEventListener('click', (ev) => { if (ev.target === modal) modal.remove(); });
    modal.querySelector('#wizard-close')?.addEventListener('click', () => modal.remove());

    // Suggestion click
    modal.querySelectorAll('.wizard-suggest').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        createNodeFromWizard(id, missing.find(m => m.id === id)?.category || 'custom');
        modal.remove();
      });
    });

    // Custom node
    modal.querySelector('#wizard-custom-btn')?.addEventListener('click', () => {
      const id = (modal.querySelector('#wizard-custom-id') as HTMLInputElement).value.trim();
      if (!id) return;
      if (currentTree[id]) { alert('Node already exists!'); return; }
      createNodeFromWizard(id, 'custom');
      modal.remove();
    });

    // Enter in custom field
    modal.querySelector('#wizard-custom-id')?.addEventListener('keydown', (ev: any) => {
      if (ev.key === 'Enter') modal.querySelector('#wizard-custom-btn')?.dispatchEvent(new Event('click'));
    });
  }

  function createNodeFromWizard(id: string, category: string) {
    if (!currentTree) return;

    // Create with sensible defaults based on category
    const templates: Record<string, any> = {
      greeting: { speak: ["Hi, is this {firstName}?"], next: '' },
      compliance: { speak: ["No problem at all — I'll make sure you're removed from our list. Have a great day."], action: 'hangup' },
      terminal: { speak: ["Let me connect you with someone who can help."], action: id.includes('transfer') ? 'transfer' : 'hangup' },
      routing: { speak: ["Oh, I apologize for the confusion!"], action: 'hangup' },
      opening: { speak: ["Great, glad I reached you!"], edges: { confirmed: { match_regex: "\\b(yes|yeah|that's me|speaking)\\b", next: '' }, wrong: { match_regex: "\\b(no|wrong|not me)\\b", next: 'wrong_person' }, _fallback: { speak: ["Sorry, could you say that again?"], next: id } } },
      qualifying: { speak: ["I wanted to reach out because we've been helping people in your area with their coverage options. Do you have a quick minute?"], edges: { interested: { match_regex: "\\b(yes|sure|okay|go ahead)\\b", next: '' }, not_interested: { match_regex: "\\b(no|not interested|busy)\\b", next: 'not_interested' }, _fallback: { speak: ["No worries either way — just a quick question."], next: id } } },
      objection: { speak: ["I completely understand. Would it be better if I called back at a different time, or would you prefer I didn't call again?"], edges: { callback: { match_regex: "\\b(call back|later|another time)\\b", next: 'busy_callback' }, remove: { match_regex: "\\b(don't call|remove|no)\\b", next: 'opt_out' }, _fallback: { speak: ["No pressure at all."], next: 'polite_goodbye' } } },
      gathering: { speak: ["Tell me a bit about what's on your mind — I'm here to listen."], action: 'llm_gather', gather: { tone: 'empathetic', max_turns: 4, slots: [{ name: 'concern', description: 'what they are worried about' }] } },
      custom: { speak: [""], edges: { _fallback: { speak: ["Could you repeat that?"], next: id } } },
    };

    currentTree[id] = templates[category] || templates.custom;
    
    // Position in viewport center
    const canvasEl = document.getElementById('canvas')!;
    const viewCenterX = (canvasEl.scrollLeft + canvasEl.clientWidth / 2) / zoom;
    const viewCenterY = (canvasEl.scrollTop + canvasEl.clientHeight / 2) / zoom;
    nodePositions.set(id, { x: viewCenterX - NODE_W / 2, y: viewCenterY - NODE_H / 2 });
    
    // Deselect previous and select new
    selectedNode = null;
    document.getElementById('node-editor')!.classList.add('hidden');
    
    markDirty();
    renderCanvas();
    renderNodeList();
    selectNode(id);

    setTimeout(() => {
      const nodeEl = document.querySelector(`[data-node-id="${id}"]`) as HTMLElement;
      if (nodeEl) nodeEl.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });
    }, 50);
  }
})();
</script>

<style>
  .node-connect-target {
    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.6), 0 0 12px rgba(96, 165, 250, 0.3);
    border-color: #60a5fa !important;
  }
  .node-connect-target .node-handle-in {
    opacity: 1 !important;
    background: #22c55e;
    border-color: #86efac;
    transform: translateY(-50%) scale(1.4);
  }
  /* Edge handle labels — always visible but subtle */
  [data-edge-handle] span {
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }
  [data-node-id]:hover [data-edge-handle] span {
    opacity: 1;
  }
  /* Subtle glow on edge handles during connection drag */
  .connecting-active [data-edge-handle] > div {
    box-shadow: 0 0 4px currentColor;
  }
  /* Edge speak labels — hidden by default, visible on path hover */
  .edge-speak-label {
    font-family: ui-monospace, monospace;
    pointer-events: none;
    user-select: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  /* Show speak text when hovering nearby edge path */
  .edge-path {
    transition: opacity 0.15s ease, stroke-width 0.15s ease;
    pointer-events: stroke;
  }
  .edge-path:hover {
    opacity: 1 !important;
    stroke-width: 2.5;
  }
  .edge-path:hover + path + .edge-speak-label,
  .edge-path:hover + .edge-speak-label {
    opacity: 1 !important;
  }
  /* Also show all labels when canvas is zoomed in close */
  #canvas-svg[data-zoom-close] .edge-speak-label {
    opacity: 0.6;
  }
</style>

</Base>
