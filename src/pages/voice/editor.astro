<script>
(function() {
  // ═══════════════════════════════════════════════════════════════
  // STATE
  // ═══════════════════════════════════════════════════════════════
  let currentTree: any = null;      // The full tree JSON (same format as sales-dialog-tree-v2.json)
  let currentTreeId: string = '';   // Supabase UUID (empty for new)
  let currentSlug: string = '';
  let isDirty = false;
  let selectedNode: string | null = null;
  let nodePositions: Map<string, { x: number; y: number }> = new Map();
  let zoom = 1;
  let panOffset = { x: 0, y: 0 };

  /** Build a snapshot of the current tree data (same as what gets saved). */
  function buildTreeData(): any {
    if (!currentTree) return null;
    // Inject positions
    if (!currentTree._meta) currentTree._meta = {};
    const positions: Record<string, { x: number; y: number }> = {};
    for (const [nodeId, pos] of nodePositions) {
      positions[nodeId] = pos;
    }
    currentTree._meta.positions = positions;
    // Inject category from selector if available
    const catEl = document.getElementById('tree-category') as HTMLSelectElement | null;
    if (catEl) currentTree._meta.category = catEl.value;
    return currentTree;
  }

  let dragging: string | null = null;
  let dragStart = { x: 0, y: 0 };

  // Group drag state
  let groupDragging = false;
  let groupDragMembers: string[] = [];
  let groupDragOffsets: Map<string, { x: number; y: number }> = new Map();

  // Connection handle drag state
  let connecting = false;
  let connectSource: string | null = null;
  let connectTarget: string | null = null;
  let connectEdgeName: string | null = null; // Which specific edge is being dragged
  let connectLine: SVGLineElement | null = null;

  const NODE_W = 200;
  const NODE_H = 64;
  const EDGE_HANDLE_H = 16; // Height per edge handle on right side

  /** Build a map of nodeId → array of incoming edges [{from, edgeName}] */
  function computeIncomingEdges(): Map<string, Array<{from: string, edgeName: string}>> {
    const incoming = new Map<string, Array<{from: string, edgeName: string}>>();
    if (!currentTree) return incoming;
    for (const [nodeId, node] of Object.entries(currentTree) as any) {
      if (nodeId.startsWith('_')) continue;
      if (node.next && !node.edges) {
        if (!incoming.has(node.next)) incoming.set(node.next, []);
        incoming.get(node.next)!.push({ from: nodeId, edgeName: '_next' });
      }
      if (node.edges) {
        for (const [eName, edge] of Object.entries(node.edges) as any) {
          if (edge.next) {
            if (!incoming.has(edge.next)) incoming.set(edge.next, []);
            incoming.get(edge.next)!.push({ from: nodeId, edgeName: eName });
          }
        }
      }
    }
    return incoming;
  }

  // Cached incoming edges (rebuilt on renderCanvas)
  let incomingEdgesMap: Map<string, Array<{from: string, edgeName: string}>> = new Map();

  /** Compute rendered height of a node: base + max(outgoing, incoming) handles */
  function getNodeHeight(node: any, nodeId?: string): number {
    const outCount = node?.edges ? Object.keys(node.edges).length : 0;
    const inCount = nodeId ? (incomingEdgesMap.get(nodeId)?.length || 0) : 0;
    const handleCount = Math.max(outCount, inCount);
    if (handleCount <= 1) return NODE_H;
    return NODE_H + (handleCount - 1) * EDGE_HANDLE_H;
  }

  /** Get the Y offset for a specific edge handle on a node */
  function getEdgeHandleY(node: any, edgeIndex: number, nodeId?: string): number {
    const totalEdges = node?.edges ? Object.keys(node.edges).length : 0;
    if (totalEdges === 0) return NODE_H / 2;
    const nodeH = getNodeHeight(node, nodeId);
    const handleAreaTop = NODE_H - 8; // Start handles below the node header
    const handleAreaHeight = nodeH - handleAreaTop;
    const spacing = totalEdges > 1 ? handleAreaHeight / (totalEdges) : handleAreaHeight / 2;
    return handleAreaTop + spacing * (edgeIndex + 0.5);
  }

  /** Get the Y offset for a specific incoming edge handle on the left side */
  function getIncomingHandleY(nodeId: string, incomingIndex: number): number {
    const inEdges = incomingEdgesMap.get(nodeId) || [];
    const totalIn = inEdges.length;
    if (totalIn === 0) return NODE_H / 2;
    const node = currentTree[nodeId];
    const nodeH = getNodeHeight(node, nodeId);
    const handleAreaTop = NODE_H - 8;
    const handleAreaHeight = nodeH - handleAreaTop;
    const spacing = totalIn > 1 ? handleAreaHeight / totalIn : handleAreaHeight / 2;
    return handleAreaTop + spacing * (incomingIndex + 0.5);
  }

  // ═══════════════════════════════════════════════════════════════
  // TUTORIAL
  // ═══════════════════════════════════════════════════════════════
  const TUTORIAL_KEY = 'voice-editor-tutorial-seen';
  let tutorialStep = 0;
  const totalSteps = 8;

  function initTutorial() {
    const modal = document.getElementById('tutorial-modal')!;
    const dots = document.getElementById('tutorial-dots')!;
    
    // Render dots
    dots.innerHTML = Array.from({ length: totalSteps }, (_, i) =>
      `<span class="w-2 h-2 rounded-full transition-colors ${i === 0 ? 'bg-brand-400' : 'bg-gray-600'}" data-dot="${i}"></span>`
    ).join('');

    // Show on first visit
    if (!localStorage.getItem(TUTORIAL_KEY)) {
      showTutorial();
    }

    // Help button
    document.getElementById('btn-help')?.addEventListener('click', showTutorial);
    document.getElementById('tutorial-close')?.addEventListener('click', closeTutorial);
    document.getElementById('tutorial-done')?.addEventListener('click', closeTutorial);
    document.getElementById('tutorial-skip')?.addEventListener('click', closeTutorial);
    document.getElementById('tutorial-next')?.addEventListener('click', () => goToStep(tutorialStep + 1));
    document.getElementById('tutorial-prev')?.addEventListener('click', () => goToStep(tutorialStep - 1));

    // Click outside to close
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeTutorial();
    });
  }

  function showTutorial() {
    tutorialStep = 0;
    goToStep(0);
    document.getElementById('tutorial-modal')!.classList.remove('hidden');
  }

  function closeTutorial() {
    document.getElementById('tutorial-modal')!.classList.add('hidden');
    localStorage.setItem(TUTORIAL_KEY, 'true');
  }

  function goToStep(step: number) {
    tutorialStep = Math.max(0, Math.min(step, totalSteps - 1));
    
    // Show/hide steps
    document.querySelectorAll('.tutorial-step').forEach((el, i) => {
      (el as HTMLElement).classList.toggle('hidden', i !== tutorialStep);
    });

    // Update dots
    document.querySelectorAll('[data-dot]').forEach((el, i) => {
      el.className = `w-2 h-2 rounded-full transition-colors ${i === tutorialStep ? 'bg-brand-400' : 'bg-gray-600'}`;
    });

    // Update buttons
    const prev = document.getElementById('tutorial-prev') as HTMLButtonElement;
    const next = document.getElementById('tutorial-next') as HTMLButtonElement;
    const done = document.getElementById('tutorial-done') as HTMLButtonElement;
    
    prev.disabled = tutorialStep === 0;
    if (tutorialStep === totalSteps - 1) {
      next.classList.add('hidden');
      done.classList.remove('hidden');
    } else {
      next.classList.remove('hidden');
      done.classList.add('hidden');
    }
  }

  initTutorial();

  // ═══════════════════════════════════════════════════════════════
  // INIT
  // ═══════════════════════════════════════════════════════════════
  loadTreeList();
  
  // Default: load from bridge (current active tree)
  loadFromBridge();

  async function loadTreeList() {
    try {
      const res = await fetch('/api/voice-dialog-tree?list=true');
      if (res.ok) {
        const data = await res.json();
        const sel = document.getElementById('tree-selector') as HTMLSelectElement;
        sel.innerHTML = '<option value="_bridge">Active (from bridge)</option>';
        if (data.trees) {
          for (const t of data.trees) {
            sel.innerHTML += `<option value="${t.id}">${t.name} (${t.status})</option>`;
          }
        }
      }
    } catch {}
  }

  async function loadFromBridge() {
    try {
      // Try to get the raw tree JSON directly (preferred)
      const rawRes = await fetch('/api/voice-dialog-tree?raw=true');
      if (rawRes.ok) {
        const data = await rawRes.json();
        // Validate it's actually a tree (has _meta or at least one node with speak/edges)
        if (data._meta || Object.values(data).some((v: any) => v && (v.speak || v.edges || v.next))) {
          currentTree = data;
          currentTreeId = '';
          currentSlug = ''; // Don't pre-fill slug from bridge — let save generate from name
          // Clear name so initEditor populates from _meta
          (document.getElementById('tree-name') as HTMLInputElement).value = '';
          initEditor();
          return;
        }
      }

      // Bridge offline — show empty state with guidance
      console.warn('[editor] Voice bridge unreachable. Load a saved tree or create new.');
      showBridgeOfflineState();
    } catch (err) {
      console.error('Failed to load tree:', err);
      showBridgeOfflineState();
    }
  }

  function showBridgeOfflineState() {
    const nodesLayer = document.getElementById('nodes-layer')!;
    nodesLayer.innerHTML = `
      <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-center max-w-sm">
        <div class="text-4xl mb-3">📡</div>
        <h3 class="text-lg font-semibold text-gray-300 mb-2">Voice Bridge Offline</h3>
        <p class="text-sm text-gray-500 mb-4">Can't load the active tree from the bridge. The bridge (Sentinel) needs to be running.</p>
        <div class="space-y-2">
          <p class="text-xs text-gray-400">You can still:</p>
          <button class="w-full px-4 py-2 bg-brand-600 text-white text-sm rounded hover:bg-brand-700" onclick="document.getElementById('btn-new-tree')?.click()">
            Create a New Tree
          </button>
          <p class="text-xs text-gray-500">Or select a saved tree from the dropdown above.</p>
        </div>
      </div>
    `;
    // Clear the tree name to avoid confusion
    (document.getElementById('tree-name') as HTMLInputElement).value = '';
  }

  // ═══════════════════════════════════════════════════════════════
  // CANVAS RENDERING
  // ═══════════════════════════════════════════════════════════════
  function initEditor() {
    if (!currentTree) return;
    
    const treeName = document.getElementById('tree-name') as HTMLInputElement;
    // Only set name from tree metadata if not already populated (e.g. from Supabase load)
    if (!treeName.value || treeName.value === 'Untitled') {
      treeName.value = currentTree._meta?.description || currentSlug || 'Untitled';
    }

    // Build node positions from tree structure
    computeLayout();
    renderCanvas();
    renderNodeList();
    runComplianceChecks();
    // Auto-fit tree to viewport after initial render
    requestAnimationFrame(() => fitToView());
  }

  function getTreeNodes(): string[] {
    if (!currentTree) return [];
    return Object.keys(currentTree).filter(k => !k.startsWith('_'));
  }

  function computeLayout() {
    nodePositions.clear();
    const nodes = getTreeNodes();
    
    // Pre-compute incoming edges so getNodeHeight works correctly during layout
    incomingEdgesMap = computeIncomingEdges();

    // Restore saved positions from tree metadata if available
    const savedPositions = currentTree?._meta?.positions;
    if (savedPositions && typeof savedPositions === 'object') {
      let allFound = true;
      for (const n of nodes) {
        if (savedPositions[n]) {
          nodePositions.set(n, { x: savedPositions[n].x, y: savedPositions[n].y });
        } else {
          allFound = false;
        }
      }
      // If all nodes have saved positions, use them directly
      if (allFound && nodePositions.size === nodes.length) return;
      // Otherwise fall through to auto-layout for any missing nodes
    }
    nodePositions.clear();
    
    // Left-to-right topological layout
    const visited = new Set<string>();
    const layers: string[][] = []; // Each layer is a vertical column

    function followChain(nodeId: string, depth: number) {
      if (visited.has(nodeId) || !currentTree[nodeId]) return;
      visited.add(nodeId);
      while (layers.length <= depth) layers.push([]);
      layers[depth].push(nodeId);
      
      const node = currentTree[nodeId];
      if (node.next) followChain(node.next, depth + 1);
      if (node.edges) {
        // Follow the "happy path" (first non-fallback edge with next)
        for (const [name, edge] of Object.entries(node.edges) as any) {
          if (name === '_fallback') continue;
          if (edge.next && !visited.has(edge.next)) {
            followChain(edge.next, depth + 1);
            break;
          }
        }
        // Also traverse other edge targets at same or +1 depth
        for (const [name, edge] of Object.entries(node.edges) as any) {
          if (name === '_fallback') continue;
          if (edge.next && !visited.has(edge.next)) {
            followChain(edge.next, depth + 1);
          }
        }
      }
    }

    // Start from greetings
    if (currentTree.greeting_with_name) followChain('greeting_with_name', 0);
    if (currentTree.greeting_no_name) followChain('greeting_no_name', 0);
    // Pick up orphans
    for (const n of nodes) {
      if (!visited.has(n)) followChain(n, layers.length);
    }

    // Position: each layer is a column flowing left-to-right
    const COL_GAP = NODE_W + 120; // Horizontal gap between columns
    const ROW_GAP = 30; // Vertical gap between nodes in same column
    const startX = 60;
    const startY = 60;

    for (let col = 0; col < layers.length; col++) {
      const layer = layers[col];
      // Center the column vertically
      let totalHeight = 0;
      for (const nId of layer) {
        totalHeight += getNodeHeight(currentTree[nId], nId) + ROW_GAP;
      }
      totalHeight -= ROW_GAP;
      let y = startY + Math.max(0, (300 - totalHeight) / 2); // rough vertical centering

      for (const nId of layer) {
        nodePositions.set(nId, { x: startX + col * COL_GAP, y });
        y += getNodeHeight(currentTree[nId], nId) + ROW_GAP;
      }
    }
  }

  function renderCanvas() {
    const svg = document.getElementById('canvas-svg')!;
    const nodesLayer = document.getElementById('nodes-layer')!;
    
    // Clear
    svg.innerHTML = '';
    nodesLayer.innerHTML = '';

    if (!currentTree) return;

    // Rebuild incoming edges map
    incomingEdgesMap = computeIncomingEdges();

    // Draw group containers (behind everything)
    if (currentTree._groups) {
      for (const [gName, group] of Object.entries(currentTree._groups) as any) {
        const memberNodes = (group.nodes || []).filter((n: string) => nodePositions.has(n));
        if (memberNodes.length === 0) continue;
        
        // Calculate bounding box
        const positions = memberNodes.map((n: string) => nodePositions.get(n)!);
        const padding = 20;
        const minX = Math.min(...positions.map((p: any) => p.x)) - padding;
        const minY = Math.min(...positions.map((p: any) => p.y)) - padding - 20; // extra for label
        const maxX = Math.max(...positions.map((p: any) => p.x)) + NODE_W + padding;
        const maxY = Math.max(...memberNodes.map((n: string) => {
          const p = nodePositions.get(n)!;
          return p.y + getNodeHeight(currentTree[n], n);
        })) + padding;

        const groupDiv = document.createElement('div');
        groupDiv.className = 'absolute rounded-xl border-2 border-dashed pointer-events-none';
        groupDiv.style.cssText = `
          left: ${minX}px; top: ${minY}px;
          width: ${maxX - minX}px; height: ${maxY - minY}px;
          border-color: ${group.color || '#7c3aed'}40;
          background: ${group.color || '#7c3aed'}08;
        `;
        groupDiv.innerHTML = `<span class="absolute -top-0 left-3 px-1.5 py-0.5 text-[10px] font-semibold rounded pointer-events-auto cursor-pointer" 
          style="color: ${group.color || '#7c3aed'}; background: ${group.color || '#7c3aed'}20;"
          data-group-name="${gName}">${group.label || gName}</span>`;
        nodesLayer.appendChild(groupDiv);
      }
    }

    // Draw edges (SVG)
    const edgesSvg: string[] = [];
    edgesSvg.push(`<defs>
      <marker id="ed-arrow" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto">
        <path d="M0 0 L10 4 L0 8z" fill="#4b5563"/>
      </marker>
      <marker id="ed-arrow-green" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto">
        <path d="M0 0 L10 4 L0 8z" fill="#22c55e"/>
      </marker>
      <marker id="ed-arrow-red" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto">
        <path d="M0 0 L10 4 L0 8z" fill="#ef4444"/>
      </marker>
      <marker id="ed-arrow-amber" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto">
        <path d="M0 0 L10 4 L0 8z" fill="#f59e0b"/>
      </marker>
    </defs>`);

    for (const [nodeId, node] of Object.entries(currentTree) as any) {
      if (nodeId.startsWith('_')) continue;
      const fromPos = nodePositions.get(nodeId);
      if (!fromPos) continue;

      // Direct next (no edges) — bottom-center
      if (node.next && !node.edges) {
        const toPos = nodePositions.get(node.next);
        if (toPos) {
          edgesSvg.push(drawEdge(fromPos, toPos, '#4b5563', 'ed-arrow', false, node, -1, undefined, node.next, nodeId));
        }
      }

      // Named edges — from per-edge handles on right side
      if (node.edges) {
        const edgeEntries = Object.entries(node.edges);
        edgeEntries.forEach(([eName, edge]: [string, any], idx) => {
          const target = edge.next || (edge.action === 'hangup' ? '__hangup__' : null);
          if (!target) return;
          const toPos = nodePositions.get(target);
          if (!toPos) return;

          const speak = Array.isArray(edge.speak) ? edge.speak[0] : undefined;
          if (eName === '_fallback') {
            edgesSvg.push(drawEdge(fromPos, toPos, '#ef4444', 'ed-arrow-red', true, node, idx, speak, target, nodeId));
          } else if (edge.action === 'hangup') {
            edgesSvg.push(drawEdge(fromPos, toPos, '#ef4444', 'ed-arrow-red', false, node, idx, speak, target, nodeId));
          } else if (edge.action === 'transfer' || edge.action === 'transfer_beth' || edge.action === 'transfer_tim') {
            edgesSvg.push(drawEdge(fromPos, toPos, '#f59e0b', 'ed-arrow-amber', false, node, idx, speak, target, nodeId));
          } else {
            edgesSvg.push(drawEdge(fromPos, toPos, '#22c55e', 'ed-arrow-green', false, node, idx, speak, target, nodeId));
          }
        });
      }
    }

    svg.innerHTML = edgesSvg.join('');

    // Draw nodes (HTML divs for better interactivity)
    for (const [nodeId, pos] of nodePositions) {
      const node = currentTree[nodeId];
      if (!node) continue;

      const nodeH = getNodeHeight(node, nodeId);
      const div = document.createElement('div');
      div.className = `absolute rounded-lg border-2 shadow-md cursor-pointer transition-all select-none
        ${selectedNode === nodeId ? 'ring-2 ring-brand-400 border-brand-500' : 'border-gray-600 hover:border-gray-400'}
        ${node.action === 'transfer' || node.action === 'transfer_beth' || node.action === 'transfer_tim' ? 'bg-green-900/60 border-green-500' : 
          node.action === 'hangup' ? 'bg-red-900/40 border-red-500' :
          node.edges ? 'bg-blue-900/30 border-blue-600' : 'bg-gray-700'}`;
      div.style.cssText = `left:${pos.x}px; top:${pos.y}px; width:${NODE_W}px; min-height:${nodeH}px;`;
      div.dataset.nodeId = nodeId;

      // Node content
      const label = nodeId.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
      const hasSlots = node.edges && Object.values(node.edges).some((e: any) => e.extract?.slot);
      const hasConverse = node.converse?.mode;
      const speakPreview = Array.isArray(node.speak) ? (node.speak[0] || '').slice(0, 35) : '';
      
      // Build outgoing edge handles HTML (right side)
      let edgeHandlesHtml = '';
      if (node.edges) {
        const edgeEntries = Object.entries(node.edges);
        edgeEntries.forEach(([eName, edge]: [string, any], idx) => {
          const handleY = getEdgeHandleY(node, idx, nodeId);
          const isFallback = eName === '_fallback';
          const isAction = edge.action === 'hangup' || edge.action === 'transfer';
          const dotColor = isFallback ? 'bg-red-500' : isAction ? 'bg-amber-500' : 'bg-green-500';
          const textColor = isFallback ? 'text-red-400' : isAction ? 'text-amber-400' : 'text-green-400';
          const displayName = eName === '_fallback' ? '✗' : eName.slice(0, 12);
          edgeHandlesHtml += `
            <div class="absolute flex items-center gap-0.5" style="right: -6px; top: ${handleY - 6}px;" data-edge-handle="${eName}" data-edge-source="${nodeId}">
              <span class="text-[8px] ${textColor} font-mono truncate max-w-[60px] text-right pr-0.5 pointer-events-none select-none">${displayName}</span>
              <div class="w-3 h-3 rounded-full ${dotColor} border border-gray-900 hover:scale-150 hover:border-white transition-all cursor-crosshair z-10 flex-shrink-0" data-handle="out" data-source="${nodeId}" data-edge-name="${eName}" title="${eName} → ${edge.next || edge.action || '?'}"></div>
            </div>`;
        });
      }

      // Build incoming edge handles HTML (left side)
      let incomingHandlesHtml = '';
      const inEdges = incomingEdgesMap.get(nodeId) || [];
      if (inEdges.length > 0) {
        inEdges.forEach((inc, idx) => {
          const handleY = getIncomingHandleY(nodeId, idx);
          const fromLabel = inc.from.replace(/_/g, ' ').slice(0, 10);
          const edgeLabel = inc.edgeName === '_next' ? '→' : inc.edgeName === '_fallback' ? '✗' : inc.edgeName.slice(0, 8);
          incomingHandlesHtml += `
            <div class="absolute flex items-center gap-0.5" style="left: -6px; top: ${handleY - 6}px;" data-incoming-handle="${idx}" data-incoming-from="${inc.from}">
              <div class="w-3 h-3 rounded-full bg-blue-500 border border-gray-900 hover:scale-150 hover:border-white transition-all cursor-pointer z-10 flex-shrink-0 node-handle node-handle-in" data-handle="in" data-target="${nodeId}"></div>
              <span class="text-[8px] text-blue-400 font-mono truncate max-w-[60px] pl-0.5 pointer-events-none select-none">${edgeLabel}</span>
            </div>`;
        });
      } else {
        // Single generic input handle for nodes with no incoming edges yet
        incomingHandlesHtml = `<div class="node-handle node-handle-in absolute top-1/2 -left-2 -translate-y-1/2 w-3 h-3 rounded-full bg-gray-700 border-2 border-gray-500 hover:bg-green-500 hover:border-green-300 hover:scale-125 transition-all cursor-crosshair z-10 opacity-0 hover:opacity-100" data-handle="in" data-target="${nodeId}"></div>`;
      }

      div.innerHTML = `
        <div class="px-3 py-2 flex flex-col justify-center" style="min-height: ${NODE_H - 4}px;">
          <div class="text-xs font-semibold text-gray-100 truncate">${label}</div>
          <div class="text-[10px] text-gray-400 truncate mt-0.5">${speakPreview || (node.action ? '⚡ ' + node.action : '...')}</div>
          <div class="flex gap-1 mt-1 flex-wrap">
            ${hasSlots ? '<span class="text-[9px] px-1 bg-blue-800 text-blue-200 rounded">📦 slot</span>' : ''}
            ${hasConverse ? `<span class="text-[9px] px-1 bg-purple-800 text-purple-200 rounded">🗣️ ${hasConverse}</span>` : ''}
            ${node.action === 'transfer' || node.action === 'transfer_beth' || node.action === 'transfer_tim' ? '<span class="text-[9px] px-1 bg-green-800 text-green-200 rounded">📲 transfer</span>' : ''}
            ${node.action === 'hangup' ? '<span class="text-[9px] px-1 bg-red-800 text-red-200 rounded">📴 hangup</span>' : ''}
            ${node.action === 'send_booking_sms' ? '<span class="text-[9px] px-1 bg-amber-800 text-amber-200 rounded">📱 sms</span>' : ''}
            ${node.action === 'send_message_email' ? '<span class="text-[9px] px-1 bg-cyan-800 text-cyan-200 rounded">📧 email</span>' : ''}
          </div>
        </div>
        ${edgeHandlesHtml}
        <!-- Add-edge button (right side, below last edge handle) -->
        <div class="absolute flex items-center" style="right: -6px; bottom: -8px;" data-add-edge-btn="${nodeId}">
          <div class="w-3.5 h-3.5 rounded-full bg-gray-600 border border-dashed border-gray-400 hover:bg-brand-500 hover:border-brand-300 hover:scale-150 transition-all cursor-pointer z-10 flex items-center justify-center" title="Add edge">
            <span class="text-[8px] text-gray-300 font-bold leading-none">+</span>
          </div>
        </div>
        ${incomingHandlesHtml}
        <!-- Connection handle (default output port — used if no edges) -->
        ${!node.edges ? `<div class="node-handle node-handle-out absolute -bottom-2 left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-gray-600 border-2 border-gray-400 hover:bg-brand-500 hover:border-brand-300 hover:scale-125 transition-all cursor-crosshair z-10" data-handle="out" data-source="${nodeId}" title="Drag to connect"></div>` : ''}
      `;

      // Drag to reposition
      div.addEventListener('mousedown', (e: MouseEvent) => {
        if (e.button !== 0) return;
        // Don't start node drag if clicking on a connection handle
        if ((e.target as HTMLElement).closest('[data-handle]')) return;
        
        // Convert mouse to canvas-space coordinates
        const canvasEl = document.getElementById('canvas')!;
        const rect = canvasEl.getBoundingClientRect();
        const mouseCanvasX = (e.clientX - rect.left + canvasEl.scrollLeft) / zoom;
        const mouseCanvasY = (e.clientY - rect.top + canvasEl.scrollTop) / zoom;
        
        const currentPos = nodePositions.get(nodeId)!;
        dragging = nodeId;
        didDrag = false;
        // Store offset in canvas-space: distance from mouse to node origin
        dragStart = { x: mouseCanvasX - currentPos.x, y: mouseCanvasY - currentPos.y };

        // If this node is part of a box selection, drag all selected nodes
        if (boxSelectedNodes.size > 1 && boxSelectedNodes.has(nodeId)) {
          groupDragging = true;
          groupDragMembers = [...boxSelectedNodes].filter(n => n !== nodeId && nodePositions.has(n));
          groupDragOffsets.clear();
          for (const memberId of groupDragMembers) {
            const mPos = nodePositions.get(memberId)!;
            groupDragOffsets.set(memberId, { x: mouseCanvasX - mPos.x, y: mouseCanvasY - mPos.y });
          }
        }
        // If this node is in a group and shift is NOT held, drag the group
        else if (!e.shiftKey && currentTree._groups) {
          for (const [, group] of Object.entries(currentTree._groups) as any) {
            if ((group.nodes || []).includes(nodeId)) {
              groupDragging = true;
              groupDragMembers = group.nodes.filter((n: string) => n !== nodeId && nodePositions.has(n));
              groupDragOffsets.clear();
              for (const memberId of groupDragMembers) {
                const mPos = nodePositions.get(memberId)!;
                groupDragOffsets.set(memberId, { x: mouseCanvasX - mPos.x, y: mouseCanvasY - mPos.y });
              }
              break;
            }
          }
        }

        e.preventDefault();
      });

      nodesLayer.appendChild(div);
    }

    // Update bottom panel (minimap + stats)
    requestAnimationFrame(updateBottomPanel);
  }

  // Global mouse handlers for dragging — registered ONCE outside renderCanvas
  let dragRafPending = false;
  let didDrag = false; // Track whether mouse actually moved (vs. just click)
  document.addEventListener('mousemove', (e: MouseEvent) => {
    if (!dragging) return;
    didDrag = true;
    
    // Convert mouse to canvas-space
    const canvasEl = document.getElementById('canvas')!;
    const rect = canvasEl.getBoundingClientRect();
    const mouseCanvasX = (e.clientX - rect.left + canvasEl.scrollLeft) / zoom;
    const mouseCanvasY = (e.clientY - rect.top + canvasEl.scrollTop) / zoom;
    
    const newX = Math.max(0, mouseCanvasX - dragStart.x);
    const newY = Math.max(0, mouseCanvasY - dragStart.y);
    nodePositions.set(dragging, { x: newX, y: newY });
    
    // Direct DOM update for responsiveness (no full re-render)
    const draggedEl = document.querySelector(`[data-node-id="${dragging}"]`) as HTMLElement;
    if (draggedEl) {
      draggedEl.style.left = `${newX}px`;
      draggedEl.style.top = `${newY}px`;
    }

    // Also move all group/selection members
    if (groupDragging && groupDragMembers.length > 0) {
      for (const memberId of groupDragMembers) {
        const offset = groupDragOffsets.get(memberId);
        if (!offset) continue;
        const mx = Math.max(0, mouseCanvasX - offset.x);
        const my = Math.max(0, mouseCanvasY - offset.y);
        nodePositions.set(memberId, { x: mx, y: my });
        const memberEl = document.querySelector(`[data-node-id="${memberId}"]`) as HTMLElement;
        if (memberEl) {
          memberEl.style.left = `${mx}px`;
          memberEl.style.top = `${my}px`;
        }
      }
    }
    
    // Debounce SVG edge redraw with rAF
    if (!dragRafPending) {
      dragRafPending = true;
      requestAnimationFrame(() => {
        dragRafPending = false;
        redrawEdges();
      });
    }
  });

  document.addEventListener('mouseup', (e: MouseEvent) => {
    // Handle connection completion
    if (connecting && connectSource) {
      const targetEl = (e.target as HTMLElement).closest('[data-node-id]') as HTMLElement;
      const targetHandle = (e.target as HTMLElement).closest('[data-handle="in"]') as HTMLElement;
      const targetNodeId = targetHandle?.dataset.target || targetEl?.dataset.nodeId;
      
      if (targetNodeId && targetNodeId !== connectSource && currentTree[connectSource]) {
        if (connectEdgeName) {
          // Dragged from a specific edge handle → directly update that edge's target
          if (currentTree[connectSource].edges && currentTree[connectSource].edges[connectEdgeName]) {
            currentTree[connectSource].edges[connectEdgeName].next = targetNodeId;
            markDirty();
            renderCanvas();
            if (selectedNode === connectSource) selectNode(connectSource);
          }
        } else {
          // Show connection type menu for generic handle
          showConnectionMenu(connectSource, targetNodeId, e.clientX, e.clientY);
        }
      }
      // Remove temp line
      connectLine?.remove();
      connectLine = null;
      connecting = false;
      connectSource = null;
      connectTarget = null;
      connectEdgeName = null;
      // Remove all hover highlights
      document.querySelectorAll('.node-connect-target').forEach(el => el.classList.remove('node-connect-target'));
      return;
    }

    if (dragging) {
      const wasDrag = didDrag;
      const clickedNodeId = dragging;
      dragging = null;
      didDrag = false;
      groupDragging = false;
      groupDragMembers = [];
      groupDragOffsets.clear();
      if (wasDrag) {
        // Moved the node — re-render with new positions
        markDirty();
        renderCanvas();
      } else {
        // Was a click (no drag) — select the node
        selectNode(clickedNodeId);
      }
    }
  });

  // Connection handle: mousedown on output port starts connection drag
  document.addEventListener('mousedown', (e: MouseEvent) => {
    const handle = (e.target as HTMLElement).closest('[data-handle="out"]') as HTMLElement;
    if (!handle) return;
    e.preventDefault();
    e.stopPropagation();
    
    connectSource = handle.dataset.source || null;
    connectEdgeName = handle.dataset.edgeName || null;
    if (!connectSource) return;
    
    connecting = true;
    const sourcePos = nodePositions.get(connectSource);
    if (!sourcePos) return;
    
    // Determine origin point: per-edge handle on right side, or bottom-center
    let startX: number, startY: number;
    if (connectEdgeName && currentTree[connectSource]?.edges) {
      const edgeEntries = Object.keys(currentTree[connectSource].edges);
      const edgeIdx = edgeEntries.indexOf(connectEdgeName);
      if (edgeIdx >= 0) {
        startX = sourcePos.x + NODE_W + 4;
        startY = sourcePos.y + getEdgeHandleY(currentTree[connectSource], edgeIdx, connectSource);
      } else {
        startX = sourcePos.x + NODE_W / 2;
        startY = sourcePos.y + getNodeHeight(currentTree[connectSource], connectSource);
      }
    } else {
      startX = sourcePos.x + NODE_W / 2;
      startY = sourcePos.y + getNodeHeight(currentTree[connectSource], connectSource);
    }
    
    // Create a temporary SVG line from the source
    const svg = document.getElementById('canvas-svg')!;
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', String(startX));
    line.setAttribute('y1', String(startY));
    line.setAttribute('x2', String(startX));
    line.setAttribute('y2', String(startY));
    line.setAttribute('stroke', '#60a5fa');
    line.setAttribute('stroke-width', '2');
    line.setAttribute('stroke-dasharray', '6 3');
    line.id = 'temp-connect-line';
    svg.appendChild(line);
    connectLine = line;

    // Show all input handles
    document.querySelectorAll('.node-handle-in').forEach(el => {
      (el as HTMLElement).style.opacity = '1';
    });
  }, true); // Capture phase to prevent node drag

  // Connection handle: mousemove updates the temp line
  document.addEventListener('mousemove', (e: MouseEvent) => {
    if (!connecting || !connectLine) return;
    
    const canvas = document.getElementById('canvas')!;
    const rect = canvas.getBoundingClientRect();
    const x = e.clientX - rect.left + canvas.scrollLeft;
    const y = e.clientY - rect.top + canvas.scrollTop;
    
    connectLine.setAttribute('x2', String(x));
    connectLine.setAttribute('y2', String(y));

    // Highlight potential target nodes
    const targetEl = (e.target as HTMLElement).closest('[data-node-id]') as HTMLElement;
    document.querySelectorAll('.node-connect-target').forEach(el => el.classList.remove('node-connect-target'));
    if (targetEl && targetEl.dataset.nodeId !== connectSource) {
      targetEl.classList.add('node-connect-target');
    }
  });

  // Connection menu — shows options for how to connect two nodes
  function showConnectionMenu(source: string, target: string, x: number, y: number) {
    // Remove any existing menu
    document.getElementById('connect-menu')?.remove();
    
    const node = currentTree[source];
    const hasEdges = node.edges && Object.keys(node.edges).length > 0;
    
    const menu = document.createElement('div');
    menu.id = 'connect-menu';
    menu.className = 'fixed z-50 bg-gray-800 border border-gray-600 rounded-lg shadow-xl py-1 min-w-[180px] text-sm';
    menu.style.cssText = `left: ${x}px; top: ${y}px;`;
    
    const options = [
      { label: '→ Set as "next" (default flow)', action: 'next' },
      { label: '→ Set as fallback edge', action: 'fallback' },
      { label: '→ Add named edge...', action: 'named' },
    ];
    if (hasEdges) {
      options.push({ label: '✎ Replace existing edge...', action: 'replace' });
    }
    
    menu.innerHTML = `
      <div class="px-3 py-1.5 text-[10px] text-gray-400 border-b border-gray-700">
        Connect <span class="text-gray-200">${source}</span> → <span class="text-gray-200">${target}</span>
      </div>
      ${options.map(o => `
        <button class="w-full text-left px-3 py-1.5 text-gray-200 hover:bg-gray-700 transition-colors" data-connect-action="${o.action}">
          ${o.label}
        </button>
      `).join('')}
    `;

    menu.addEventListener('click', (ev) => {
      const btn = (ev.target as HTMLElement).closest('[data-connect-action]') as HTMLElement;
      if (!btn) return;
      const action = btn.dataset.connectAction;
      
      if (action === 'next') {
        currentTree[source].next = target;
        markDirty();
      } else if (action === 'fallback') {
        if (!currentTree[source].edges) currentTree[source].edges = {};
        currentTree[source].edges._fallback = { next: target };
        markDirty();
      } else if (action === 'named') {
        const name = prompt('Edge name (e.g., "yes", "interested", "age_given"):');
        if (name) {
          if (!currentTree[source].edges) currentTree[source].edges = {};
          currentTree[source].edges[name] = { next: target };
          markDirty();
        }
      } else if (action === 'replace') {
        const edges = Object.keys(currentTree[source].edges || {});
        const edgeName = prompt(`Which edge to redirect to "${target}"?\n\nExisting: ${edges.join(', ')}`);
        if (edgeName && currentTree[source].edges[edgeName]) {
          currentTree[source].edges[edgeName].next = target;
          markDirty();
        }
      }
      
      menu.remove();
      renderCanvas();
      if (selectedNode === source) selectNode(source);
    });

    // Close on outside click
    setTimeout(() => {
      document.addEventListener('click', function closeMenu(ev) {
        if (!menu.contains(ev.target as HTMLElement)) {
          menu.remove();
          document.removeEventListener('click', closeMenu);
        }
      });
    }, 50);

    document.body.appendChild(menu);
  }

  // Lightweight edge-only redraw (no DOM recreation)
  function redrawEdges() {
    const svg = document.getElementById('canvas-svg')!;
    const edgesSvg: string[] = [];
    edgesSvg.push(`<defs>
      <marker id="ed-arrow" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto">
        <path d="M0 0 L10 4 L0 8z" fill="#4b5563"/>
      </marker>
      <marker id="ed-arrow-green" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto">
        <path d="M0 0 L10 4 L0 8z" fill="#22c55e"/>
      </marker>
      <marker id="ed-arrow-red" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto">
        <path d="M0 0 L10 4 L0 8z" fill="#ef4444"/>
      </marker>
      <marker id="ed-arrow-amber" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto">
        <path d="M0 0 L10 4 L0 8z" fill="#f59e0b"/>
      </marker>
    </defs>`);

    if (!currentTree) { svg.innerHTML = ''; return; }

    // Ensure incoming edges map is current
    incomingEdgesMap = computeIncomingEdges();

    for (const [nodeId, node] of Object.entries(currentTree) as any) {
      if (nodeId.startsWith('_')) continue;
      const fromPos = nodePositions.get(nodeId);
      if (!fromPos) continue;

      // Direct "next" (no edges) — bottom-center to left-center
      if (node.next && !node.edges) {
        const toPos = nodePositions.get(node.next);
        if (toPos) edgesSvg.push(drawEdge(fromPos, toPos, '#4b5563', 'ed-arrow', false, node, -1, undefined, node.next, nodeId));
      }

      // Named edges — from right-side edge handle to target's left-center input
      if (node.edges) {
        const edgeEntries = Object.entries(node.edges);
        edgeEntries.forEach(([eName, edge]: [string, any], idx) => {
          const target = edge.next || (edge.action === 'hangup' ? null : null);
          if (!target) return;
          const toPos = nodePositions.get(target);
          if (!toPos) return;

          const speak = Array.isArray(edge.speak) ? edge.speak[0] : undefined;
          if (eName === '_fallback') {
            edgesSvg.push(drawEdge(fromPos, toPos, '#ef4444', 'ed-arrow-red', true, node, idx, speak, target, nodeId));
          } else if (edge.action === 'hangup') {
            edgesSvg.push(drawEdge(fromPos, toPos, '#ef4444', 'ed-arrow-red', false, node, idx, speak, target, nodeId));
          } else if (edge.action === 'transfer' || edge.action === 'transfer_beth' || edge.action === 'transfer_tim') {
            edgesSvg.push(drawEdge(fromPos, toPos, '#f59e0b', 'ed-arrow-amber', false, node, idx, speak, target, nodeId));
          } else {
            edgesSvg.push(drawEdge(fromPos, toPos, '#22c55e', 'ed-arrow-green', false, node, idx, speak, target, nodeId));
          }
        });
      }
    }

    svg.innerHTML = edgesSvg.join('');
  }

  function drawEdge(from: {x:number,y:number}, to: {x:number,y:number}, color: string, marker: string, dashed = false, sourceNode?: any, edgeIndex?: number, speakText?: string, targetNodeId?: string, sourceNodeId?: string) {
    // If this is a per-edge connection, originate from the right side at the edge handle's Y
    let x1: number, y1: number;
    if (sourceNode && edgeIndex !== undefined && edgeIndex >= 0 && sourceNode.edges) {
      x1 = from.x + NODE_W + 4; // Right edge of node + handle radius
      y1 = from.y + getEdgeHandleY(sourceNode, edgeIndex, sourceNodeId);
    } else {
      x1 = from.x + NODE_W / 2;
      y1 = from.y + getNodeHeight(sourceNode || {}, sourceNodeId);
    }
    // Target: left side of destination node, at specific incoming handle if available
    const tNode = targetNodeId ? currentTree[targetNodeId] : null;
    const targetH = tNode ? getNodeHeight(tNode, targetNodeId) : NODE_H;
    const x2 = to.x - 4; // Left edge of target node

    // Find the specific incoming handle index for this edge
    let y2: number;
    if (targetNodeId) {
      const inEdges = incomingEdgesMap.get(targetNodeId) || [];
      const edgeName = (sourceNode?.edges && edgeIndex !== undefined && edgeIndex >= 0) 
        ? Object.keys(sourceNode.edges)[edgeIndex] 
        : '_next';
      const inIdx = inEdges.findIndex(ie => ie.from === sourceNodeId && ie.edgeName === edgeName);
      if (inIdx >= 0 && inEdges.length > 0) {
        y2 = to.y + getIncomingHandleY(targetNodeId, inIdx);
      } else {
        y2 = to.y + targetH / 2;
      }
    } else {
      y2 = to.y + targetH / 2;
    }

    const dash = dashed ? 'stroke-dasharray="5 3"' : '';

    // Self-loop: draw a small loop to the right side of the node
    if (Math.abs(from.x - to.x) < 1 && Math.abs(from.y - to.y) < 1) {
      const loopX = from.x + NODE_W + 30;
      const loopY1 = y1 - 10;
      const loopY2 = y1 + 10;
      return `<path d="M${from.x + NODE_W + 4},${y1} C${loopX},${loopY1} ${loopX},${loopY2} ${from.x + NODE_W + 4},${y1 + 1}" fill="none" stroke="${color}" stroke-width="1" marker-end="url(#${marker})" ${dash} opacity="0.4" class="edge-path"/>`;
    }
    
    // Straight line for vertically aligned nodes (direct next, no edge handles)
    if (edgeIndex === undefined || edgeIndex < 0) {
      // For direct "next" edges, go bottom-center → left-center
      const nx1 = from.x + NODE_W / 2;
      const ny1 = from.y + getNodeHeight(sourceNode || {}, sourceNodeId);
      const midY = (ny1 + y2) / 2;
      return `<path d="M${nx1},${ny1} C${nx1},${midY} ${x2},${midY} ${x2},${y2}" fill="none" stroke="${color}" stroke-width="1.2" marker-end="url(#${marker})" ${dash} opacity="0.5" class="edge-path"/>`;
    }

    // Edge-handle connection: right-side handle → left-center of target
    const dx = Math.abs(x2 - x1);
    const cpOffset = Math.max(50, dx * 0.4);
    const pathId = `ep-${Math.round(x1)}-${Math.round(y1)}-${Math.round(x2)}-${Math.round(y2)}`;
    const edgeName = (sourceNode?.edges && edgeIndex !== undefined && edgeIndex >= 0) ? Object.keys(sourceNode.edges)[edgeIndex] : '_next';
    const pathD = `M${x1},${y1} C${x1 + cpOffset},${y1} ${x2 - cpOffset},${y2} ${x2},${y2}`;
    // Invisible wide hit-area path for click detection
    let svg = `<path d="${pathD}" fill="none" stroke="transparent" stroke-width="12" class="edge-hitarea" data-edge-source="${sourceNodeId || ''}" data-edge-name="${edgeName}" style="cursor:pointer;"/>`;
    // Visible path
    svg += `<path id="${pathId}" d="${pathD}" fill="none" stroke="${color}" stroke-width="1.2" marker-end="url(#${marker})" ${dash} opacity="0.55" class="edge-path" data-edge-source="${sourceNodeId || ''}" data-edge-name="${edgeName}" style="pointer-events:none;"/>`;

    // Add speak text label along the path
    if (speakText) {
      const truncated = speakText.length > 28 ? speakText.slice(0, 28) + '…' : speakText;
      // If path goes right-to-left or steeply downward, use a reversed path for text readability
      const textGoesBackward = x2 < x1 - 20;
      const textPathId = textGoesBackward ? `${pathId}-txt` : pathId;
      if (textGoesBackward) {
        // Hidden reversed path for text
        svg += `<path id="${textPathId}" d="M${x2},${y2} C${x2 - cpOffset},${y2} ${x1 + cpOffset},${y1} ${x1},${y1}" fill="none" stroke="none"/>`;
      }
      svg += `<text class="edge-speak-label" dy="-5" font-size="8" fill="${color}" opacity="0.6">
        <textPath href="#${textPathId}" startOffset="50%" text-anchor="middle">${truncated}</textPath>
      </text>`;
    }
    return svg;
  }

  // ═══════════════════════════════════════════════════════════════
  // NODE LIST (left panel)
  // ═══════════════════════════════════════════════════════════════
  // Track which nodes are expanded in the list
  const expandedListNodes = new Set<string>();

  function renderNodeList() {
    const list = document.getElementById('node-list')!;
    const nodes = getTreeNodes();
    
    // Build a map of node → group for icons
    const nodeGroupMap: Record<string, string> = {};
    if (currentTree._groups) {
      for (const [gName, g] of Object.entries(currentTree._groups) as any) {
        for (const n of (g.nodes || [])) { nodeGroupMap[n] = gName; }
      }
    }

    /** Render a single node item with expandable edges */
    function renderNodeItem(id: string): string {
      const node = currentTree[id];
      if (!node) return '';
      const icon = node.action === 'transfer' ? '📲' : node.action === 'hangup' ? '📴' : node.edges ? '❓' : '💬';
      const isSelected = selectedNode === id;
      const hasEdges = node.edges && Object.keys(node.edges).length > 0;
      const hasNext = !!node.next && !node.edges;
      const isExpanded = expandedListNodes.has(id);
      const expandable = hasEdges || hasNext;
      const chevron = expandable ? (isExpanded ? '▾' : '▸') : '';

      let itemHtml = `<div class="px-2 py-1 rounded cursor-pointer text-xs flex items-center gap-1.5 ${isSelected ? 'bg-brand-600/30 text-brand-200' : 'text-gray-300 hover:bg-gray-700'}" data-list-node="${id}">
        <span class="text-[9px] text-gray-500 w-3 text-center flex-shrink-0" data-list-toggle="${id}">${chevron}</span>
        <span>${icon}</span>
        <span class="truncate flex-1">${id.replace(/_/g, ' ')}</span>
        ${hasEdges ? `<span class="text-[9px] text-gray-500">${Object.keys(node.edges).length}</span>` : ''}
      </div>`;

      // Expanded edge sub-items
      if (isExpanded && expandable) {
        itemHtml += `<div class="ml-5 border-l border-gray-700/50 pl-1.5 space-y-0.5 mb-1">`;
        if (hasEdges) {
          for (const [eName, edge] of Object.entries(node.edges) as any) {
            const isFallback = eName === '_fallback';
            const target = edge.next || edge.action || '—';
            const edgeColor = isFallback ? 'text-red-400' : edge.action === 'hangup' ? 'text-red-400' : edge.action === 'transfer' ? 'text-amber-400' : 'text-green-400';
            const dot = isFallback ? '○' : '●';
            const speak = Array.isArray(edge.speak) ? edge.speak[0]?.slice(0, 20) : '';
            itemHtml += `<div class="px-1.5 py-0.5 rounded cursor-pointer text-[10px] flex items-center gap-1.5 hover:bg-gray-700/50 ${edgeColor}" data-list-edge="${id}:${eName}" title="${eName} → ${target}${speak ? '\n' + speak : ''}">
              <span class="flex-shrink-0">${dot}</span>
              <span class="truncate flex-1 font-mono">${eName === '_fallback' ? 'fallback' : eName}</span>
              <span class="text-[9px] text-gray-500 truncate max-w-[60px]">→ ${target.replace(/_/g, ' ').slice(0, 12)}</span>
            </div>`;
          }
        } else if (hasNext) {
          itemHtml += `<div class="px-1.5 py-0.5 rounded cursor-pointer text-[10px] flex items-center gap-1.5 hover:bg-gray-700/50 text-gray-400" data-list-edge="${id}:_next" title="next → ${node.next}">
            <span class="flex-shrink-0">→</span>
            <span class="truncate flex-1">next</span>
            <span class="text-[9px] text-gray-500 truncate max-w-[60px]">${node.next.replace(/_/g, ' ').slice(0, 12)}</span>
          </div>`;
        }
        itemHtml += `</div>`;
      }
      return itemHtml;
    }

    // Render groups first, then ungrouped nodes
    let html = '';

    // Grouped nodes (collapsible sections)
    if (currentTree._groups) {
      for (const [gName, group] of Object.entries(currentTree._groups) as any) {
        const members = (group.nodes || []).filter((n: string) => currentTree[n]);
        if (members.length === 0) continue;
        const color = group.color || '#7c3aed';
        html += `<div class="mt-2 mb-1">
          <div class="flex items-center gap-1.5 px-2 py-1 rounded cursor-pointer hover:bg-gray-700/50 group-header" data-group-select="${gName}">
            <span class="w-2.5 h-2.5 rounded-sm flex-shrink-0" style="background:${color}"></span>
            <span class="text-[10px] font-semibold uppercase tracking-wider flex-1 truncate" style="color:${color}">${group.label || gName}</span>
            <span class="text-[9px] text-gray-500">${members.length}</span>
          </div>
          <div class="ml-3 border-l border-gray-700 pl-1.5 space-y-0.5 mt-0.5">`;
        for (const id of members) {
          html += renderNodeItem(id);
        }
        html += `</div></div>`;
      }
    }

    // Ungrouped nodes
    const ungrouped = nodes.filter(n => !nodeGroupMap[n]);
    if (ungrouped.length > 0 && Object.keys(currentTree._groups || {}).length > 0) {
      html += `<div class="mt-2 mb-1"><div class="px-2 py-1 text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Ungrouped</div></div>`;
    }
    for (const id of ungrouped) {
      html += renderNodeItem(id);
    }

    list.innerHTML = html;

    // Node click handlers
    list.querySelectorAll('[data-list-node]').forEach(el => {
      el.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        // If clicking the toggle chevron, just expand/collapse
        if (target.dataset.listToggle) {
          e.stopPropagation();
          const nId = target.dataset.listToggle;
          if (expandedListNodes.has(nId)) {
            expandedListNodes.delete(nId);
          } else {
            expandedListNodes.add(nId);
          }
          renderNodeList();
          return;
        }
        const nodeId = el.getAttribute('data-list-node')!;
        // Auto-expand when selecting
        expandedListNodes.add(nodeId);
        selectNode(nodeId);
      });
    });

    // Edge click handlers
    list.querySelectorAll('[data-list-edge]').forEach(el => {
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        const [nodeId, edgeName] = (el as HTMLElement).dataset.listEdge!.split(':');
        selectNode(nodeId);
        highlightEdge(nodeId, edgeName);
      });
    });

    // Group header click: scroll to group center & highlight members
    list.querySelectorAll('[data-group-select]').forEach(el => {
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        const gName = (el as HTMLElement).dataset.groupSelect!;
        const group = currentTree._groups?.[gName];
        if (!group?.nodes?.length) return;
        
        // Calculate group center and scroll canvas to it
        const memberPositions = group.nodes.map((n: string) => nodePositions.get(n)).filter(Boolean);
        if (memberPositions.length === 0) return;
        const avgX = memberPositions.reduce((s: number, p: any) => s + p.x, 0) / memberPositions.length;
        const avgY = memberPositions.reduce((s: number, p: any) => s + p.y, 0) / memberPositions.length;
        
        const canvasEl = document.getElementById('canvas')!;
        canvasEl.scrollTo({
          left: (avgX * zoom) - canvasEl.clientWidth / 2 + NODE_W / 2,
          top: (avgY * zoom) - canvasEl.clientHeight / 2 + NODE_H / 2,
          behavior: 'smooth'
        });

        // Flash highlight on group members
        for (const nodeId of group.nodes) {
          const nodeEl = document.querySelector(`[data-node-id="${nodeId}"]`) as HTMLElement;
          if (nodeEl) {
            nodeEl.style.outline = `2px solid ${group.color || '#7c3aed'}`;
            setTimeout(() => { nodeEl.style.outline = ''; }, 1500);
          }
        }
      });
    });
  }

  // ═══════════════════════════════════════════════════════════════
  // NODE EDITOR (right panel)
  // ═══════════════════════════════════════════════════════════════
  function selectNode(nodeId: string) {
    selectedNode = nodeId;
    const node = currentTree[nodeId];
    if (!node) return;

    const editor = document.getElementById('node-editor')!;
    editor.classList.remove('hidden');

    (document.getElementById('editor-title') as HTMLElement).textContent = nodeId.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    (document.getElementById('edit-node-id') as HTMLInputElement).value = nodeId;
    (document.getElementById('edit-speak') as HTMLTextAreaElement).value = Array.isArray(node.speak) ? node.speak.join('\n') : (node.speak || '');
    (document.getElementById('edit-action') as HTMLSelectElement).value = node.action || '';
    
    // Direct next dropdown
    const nextSel = document.getElementById('edit-next') as HTMLSelectElement;
    const allNodes = getTreeNodes();
    nextSel.innerHTML = '<option value="">— No direct next —</option>' + 
      allNodes.filter(n => n !== nodeId).map(n => `<option value="${n}" ${node.next === n ? 'selected' : ''}>${n}</option>`).join('');

    // Group assignment
    const groupSel = document.getElementById('edit-group') as HTMLSelectElement;
    const groups = currentTree._groups || {};
    const currentGroup = Object.entries(groups).find(([_, g]: any) => (g.nodes || []).includes(nodeId));
    groupSel.innerHTML = '<option value="">— No group —</option>' +
      Object.entries(groups).map(([gName, g]: any) => 
        `<option value="${gName}" ${currentGroup?.[0] === gName ? 'selected' : ''}>${g.label || gName}</option>`
      ).join('');

    // Converse settings
    const converse = node.converse || {};
    (document.getElementById('edit-converse-mode') as HTMLSelectElement).value = converse.mode || '';
    (document.getElementById('edit-converse-max') as HTMLInputElement).value = String(converse.max_turns || 1);
    (document.getElementById('edit-converse-bot') as HTMLTextAreaElement).value = (converse.back_on_track || []).join('\n');

    // Parallel actions / watchers
    renderWatchers(node.watchers || []);

    // Edges
    renderEdgesEditor(node.edges || {});
    renderEdgeFlowViz(nodeId);
    updateTtsPreview();
    loadEscapePaths(nodeId);
    renderCanvas();
    renderNodeList();
  }

  // ═══════════════════════════════════════════════════════════════
  // EDGE HIGHLIGHTING (shared by left panel, canvas click, right panel)
  // ═══════════════════════════════════════════════════════════════
  let edgeHighlightTimeout: ReturnType<typeof setTimeout> | null = null;

  function highlightEdge(nodeId: string, edgeName: string) {
    const svg = document.getElementById('canvas-svg')!;
    const node = currentTree[nodeId];
    if (!node) return;
    
    // Clear any previous highlight timeout
    if (edgeHighlightTimeout) clearTimeout(edgeHighlightTimeout);
    
    // Dim all edges
    svg.querySelectorAll('.edge-path').forEach(p => {
      (p as SVGElement).style.opacity = '0.12';
      (p as SVGElement).style.strokeWidth = '';
    });
    
    // Show all speak labels briefly
    svg.querySelectorAll('.edge-speak-label').forEach(t => {
      (t as SVGElement).style.opacity = '0';
    });
    
    // Find and highlight the matching SVG path
    // The path is identified by source handle position. Find the edge index
    let edgeIndex = -1;
    if (node.edges) {
      const keys = Object.keys(node.edges);
      edgeIndex = keys.indexOf(edgeName);
    }
    
    const fromPos = nodePositions.get(nodeId);
    const target = edgeName === '_next' ? node.next : node.edges?.[edgeName]?.next;
    const toPos = target ? nodePositions.get(target) : null;
    
    if (fromPos && toPos && edgeIndex >= 0) {
      // Compute expected source x1,y1 to match path id
      const x1 = Math.round(fromPos.x + NODE_W + 4);
      const y1 = Math.round(fromPos.y + getEdgeHandleY(node, edgeIndex, nodeId));
      
      // Find path by ID prefix pattern
      const pathPrefix = `ep-${x1}-${y1}`;
      const matchingPath = svg.querySelector(`[id^="${pathPrefix}"]`) as SVGElement;
      if (matchingPath) {
        matchingPath.style.opacity = '1';
        matchingPath.style.strokeWidth = '2.5';
        // Show speak label for this path
        const pathId = matchingPath.id;
        const textEl = matchingPath.nextElementSibling as SVGElement;
        if (textEl?.classList.contains('edge-speak-label')) {
          textEl.style.opacity = '1';
        }
      }
    }
    
    // Highlight source handle on node
    const handleEl = document.querySelector(`[data-edge-handle="${edgeName}"][data-edge-source="${nodeId}"]`) as HTMLElement;
    if (handleEl) {
      handleEl.style.transform = 'scale(1.4)';
      handleEl.style.zIndex = '50';
    }
    
    // Flash the target node
    if (target) {
      const targetEl = document.querySelector(`[data-node-id="${target}"]`) as HTMLElement;
      if (targetEl) {
        targetEl.style.outline = '2px solid #22c55e';
        targetEl.style.outlineOffset = '2px';
      }
    }
    
    // Scroll right panel edge editor to this edge
    const edgeDiv = document.querySelector(`#edges-container [data-edge-name="${edgeName}"]`) as HTMLElement;
    if (edgeDiv) {
      edgeDiv.style.outline = '2px solid #818cf8';
      edgeDiv.style.outlineOffset = '1px';
      edgeDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    // Restore after 2.5 seconds
    edgeHighlightTimeout = setTimeout(() => {
      svg.querySelectorAll('.edge-path').forEach(p => {
        (p as SVGElement).style.opacity = '';
        (p as SVGElement).style.strokeWidth = '';
      });
      svg.querySelectorAll('.edge-speak-label').forEach(t => {
        (t as SVGElement).style.opacity = '';
      });
      if (handleEl) {
        handleEl.style.transform = '';
        handleEl.style.zIndex = '';
      }
      if (target) {
        const targetEl = document.querySelector(`[data-node-id="${target}"]`) as HTMLElement;
        if (targetEl) {
          targetEl.style.outline = '';
          targetEl.style.outlineOffset = '';
        }
      }
      if (edgeDiv) {
        edgeDiv.style.outline = '';
        edgeDiv.style.outlineOffset = '';
      }
    }, 2500);
  }

  // ═══════════════════════════════════════════════════════════════
  // INTENT LIBRARY (loaded once for Smart Match)
  // ═══════════════════════════════════════════════════════════════
  // Click on SVG edge paths (delegated handler)
  document.getElementById('canvas-svg')?.addEventListener('click', (e) => {
    const hitarea = (e.target as SVGElement).closest('.edge-hitarea') as SVGElement;
    if (!hitarea) return;
    const sourceId = hitarea.dataset.edgeSource;
    const edgeName = hitarea.dataset.edgeName;
    if (sourceId && edgeName) {
      // Select the source node first, then highlight the edge
      selectNode(sourceId);
      setTimeout(() => highlightEdge(sourceId, edgeName), 50);
    }
  });

  // Click on "Add Edge" button (delegated on nodes layer)
  document.getElementById('nodes-layer')?.addEventListener('click', (e) => {
    const addBtn = (e.target as HTMLElement).closest('[data-add-edge-btn]') as HTMLElement;
    if (!addBtn) return;
    e.stopPropagation();
    const nodeId = addBtn.dataset.addEdgeBtn!;
    openAddEdgeWizard(nodeId);
  });

  /** Add-edge wizard: guides through creating a new edge with regex help */
  function openAddEdgeWizard(nodeId: string) {
    // Remove any existing wizard
    document.getElementById('add-edge-wizard')?.remove();
    
    const node = currentTree[nodeId];
    if (!node) return;
    
    // Position wizard near the node
    const pos = nodePositions.get(nodeId);
    if (!pos) return;
    
    const allNodes = getTreeNodes().filter(n => n !== nodeId);
    const intentOpts = getIntentOptions();
    
    const wizard = document.createElement('div');
    wizard.id = 'add-edge-wizard';
    wizard.className = 'absolute z-50 bg-gray-900 border border-gray-600 rounded-xl shadow-2xl p-4 w-72';
    wizard.style.cssText = `left:${pos.x + NODE_W + 20}px; top:${pos.y}px;`;
    
    wizard.innerHTML = `
      <div class="flex items-center justify-between mb-3">
        <h4 class="text-sm font-semibold text-gray-200">Add Edge</h4>
        <button class="text-gray-400 hover:text-white text-lg" id="wizard-close">✕</button>
      </div>
      
      <!-- Step 1: Edge name -->
      <div class="space-y-2">
        <div>
          <label class="text-[10px] text-gray-500 uppercase tracking-wider">Edge Name</label>
          <input id="wizard-name" type="text" class="w-full bg-gray-800 border border-gray-600 rounded px-2 py-1 text-xs text-gray-200 font-mono mt-0.5" placeholder="e.g., yes, no, confused" />
          <div class="text-[9px] text-gray-500 mt-0.5">Short label for this response path</div>
        </div>
        
        <!-- Step 2: Match mode -->
        <div>
          <label class="text-[10px] text-gray-500 uppercase tracking-wider">How to Match</label>
          <div class="flex gap-1 mt-1">
            <button class="wizard-mode-btn px-2 py-1 text-[10px] rounded bg-purple-700 text-white" data-mode="intent">Intent</button>
            <button class="wizard-mode-btn px-2 py-1 text-[10px] rounded bg-gray-800 text-gray-400 hover:text-gray-200" data-mode="regex">Regex</button>
            <button class="wizard-mode-btn px-2 py-1 text-[10px] rounded bg-gray-800 text-gray-400 hover:text-gray-200" data-mode="function">Function</button>
          </div>
        </div>
        
        <!-- Intent panel -->
        <div id="wizard-panel-intent">
          <select id="wizard-intent" class="w-full bg-gray-800 border border-gray-600 rounded px-2 py-1 text-[10px] text-gray-300">
            <option value="">— Select intent —</option>
            ${intentOpts}
          </select>
          <div id="wizard-intent-preview" class="text-[9px] text-gray-500 font-mono mt-1 truncate"></div>
        </div>
        
        <!-- Regex panel (hidden) -->
        <div id="wizard-panel-regex" class="hidden">
          <input id="wizard-regex" type="text" class="w-full bg-gray-800 border border-gray-600 rounded px-2 py-1 text-[10px] font-mono text-gray-300" placeholder="\\b(yes|yeah|sure)\\b" />
          <button id="wizard-expand-regex" class="mt-1 px-2 py-0.5 bg-amber-800 text-amber-200 text-[9px] rounded hover:bg-amber-700">🧠 Expand with AI</button>
        </div>
        
        <!-- Function panel (hidden) -->
        <div id="wizard-panel-function" class="hidden">
          <select id="wizard-fn" class="w-full bg-gray-800 border border-gray-600 rounded px-2 py-1 text-[10px] text-gray-300">
            <option value="">—</option>
            <option value="isAffirmative">isAffirmative</option>
            <option value="isNegative">isNegative</option>
            <option value="isConversational">isConversational</option>
            <option value="isSentimentPositive">isSentimentPositive</option>
            <option value="isSentimentNegative">isSentimentNegative</option>
          </select>
        </div>
        
        <!-- Step 3: Target -->
        <div>
          <label class="text-[10px] text-gray-500 uppercase tracking-wider">Target Node</label>
          <select id="wizard-target" class="w-full bg-gray-800 border border-gray-600 rounded px-2 py-1 text-xs text-gray-300 mt-0.5">
            <option value="">— Select or create —</option>
            ${allNodes.map(n => `<option value="${n}">${n.replace(/_/g, ' ')}</option>`).join('')}
            <option value="__new__">+ Create new node...</option>
          </select>
        </div>
        
        <!-- Step 4: Speak (optional) -->
        <div>
          <label class="text-[10px] text-gray-500 uppercase tracking-wider">Speak (optional)</label>
          <input id="wizard-speak" type="text" class="w-full bg-gray-800 border border-gray-600 rounded px-2 py-1 text-[10px] text-gray-300 mt-0.5" placeholder="What the agent says on this edge..." />
        </div>
        
        <!-- Create button -->
        <button id="wizard-create" class="w-full mt-2 px-3 py-1.5 bg-brand-600 text-white text-xs font-medium rounded hover:bg-brand-700">Create Edge</button>
      </div>
    `;
    
    document.getElementById('nodes-layer')!.appendChild(wizard);
    
    // Mode switching
    wizard.querySelectorAll('.wizard-mode-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        wizard.querySelectorAll('.wizard-mode-btn').forEach(b => {
          b.className = 'wizard-mode-btn px-2 py-1 text-[10px] rounded bg-gray-800 text-gray-400 hover:text-gray-200';
        });
        (btn as HTMLElement).className = 'wizard-mode-btn px-2 py-1 text-[10px] rounded bg-purple-700 text-white';
        const mode = (btn as HTMLElement).dataset.mode!;
        document.getElementById('wizard-panel-intent')!.classList.toggle('hidden', mode !== 'intent');
        document.getElementById('wizard-panel-regex')!.classList.toggle('hidden', mode !== 'regex');
        document.getElementById('wizard-panel-function')!.classList.toggle('hidden', mode !== 'function');
      });
    });
    
    // Intent select → preview regex
    document.getElementById('wizard-intent')?.addEventListener('change', (e) => {
      const intent = (e.target as HTMLSelectElement).value;
      if (intent && intentLibrary[intent]) {
        const regex = intentLibrary[intent].regex || intentLibrary[intent].match_regex || '';
        document.getElementById('wizard-intent-preview')!.textContent = regex ? `/${regex}/` : '';
      }
    });
    
    // AI expand regex
    document.getElementById('wizard-expand-regex')?.addEventListener('click', async () => {
      const regexInput = document.getElementById('wizard-regex') as HTMLInputElement;
      const name = (document.getElementById('wizard-name') as HTMLInputElement).value;
      if (!name) { regexInput.placeholder = 'Enter edge name first'; return; }
      const btn = document.getElementById('wizard-expand-regex') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = '⏳ Expanding...';
      try {
        const res = await fetch('/api/voice-intent-expand', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ intent: name, existing_regex: regexInput.value })
        });
        if (res.ok) {
          const data = await res.json();
          if (data.regex) regexInput.value = data.regex;
        }
      } finally {
        btn.disabled = false; btn.textContent = '🧠 Expand with AI';
      }
    });
    
    // Close
    document.getElementById('wizard-close')?.addEventListener('click', () => wizard.remove());
    
    // Create
    document.getElementById('wizard-create')?.addEventListener('click', () => {
      const name = (document.getElementById('wizard-name') as HTMLInputElement).value.trim();
      if (!name) { (document.getElementById('wizard-name') as HTMLInputElement).focus(); return; }
      
      const activeMode = wizard.querySelector('.wizard-mode-btn.bg-purple-700')?.getAttribute('data-mode') || 'intent';
      const target = (document.getElementById('wizard-target') as HTMLSelectElement).value;
      const speak = (document.getElementById('wizard-speak') as HTMLInputElement).value.trim();
      
      // Build edge object
      const edge: any = {};
      if (activeMode === 'intent') {
        const intent = (document.getElementById('wizard-intent') as HTMLSelectElement).value;
        if (intent && intentLibrary[intent]) {
          edge.match_intent = intent;
          edge.match_regex = intentLibrary[intent].regex || intentLibrary[intent].match_regex || '';
        }
      } else if (activeMode === 'regex') {
        edge.match_regex = (document.getElementById('wizard-regex') as HTMLInputElement).value;
      } else if (activeMode === 'function') {
        edge.match_fn = (document.getElementById('wizard-fn') as HTMLSelectElement).value;
      }
      
      if (speak) edge.speak = [speak];
      
      // Handle target
      let targetId = target;
      if (target === '__new__') {
        const newName = prompt('New node ID (snake_case):');
        if (!newName) return;
        targetId = newName;
        currentTree[targetId] = { speak: [''], action: '' };
      }
      if (targetId) edge.next = targetId;
      
      // Add edge to node
      if (!currentTree[nodeId].edges) currentTree[nodeId].edges = {};
      currentTree[nodeId].edges[name] = edge;
      
      wizard.remove();
      markDirty();
      renderCanvas();
      renderNodeList();
      selectNode(nodeId);
    });
    
    // Focus name input
    (document.getElementById('wizard-name') as HTMLInputElement).focus();
  }

  let intentLibrary: Record<string, any> = {};
  let intentLibraryLoaded = false;

  async function loadIntentLibrary() {
    if (intentLibraryLoaded) return;
    try {
      const res = await fetch('/api/voice-intent-expand');
      if (res.ok) {
        const data = await res.json();
        intentLibrary = data.intents || {};
        intentLibraryLoaded = true;
      }
    } catch {}
  }
  loadIntentLibrary();

  function getIntentOptions(): string {
    return Object.entries(intentLibrary).map(([key, intent]: [string, any]) =>
      `<option value="${key}">${intent.label || key}</option>`
    ).join('');
  }

  // ═══════════════════════════════════════════════════════════════
  // PARALLEL ACTIONS / WATCHERS
  // ═══════════════════════════════════════════════════════════════
  const WATCHER_TYPES = [
    { value: 'sentiment', label: '😊 Sentiment Tracker', desc: 'Track caller tone/emotion in real-time' },
    { value: 'scoring', label: '📊 Call Scoring', desc: 'Score lead quality as info is gathered' },
    { value: 'trigger_watch', label: '🎯 Trigger Watch', desc: 'Listen for keywords/topics to act on' },
    { value: 'gather', label: '📋 Info Gatherer', desc: 'Passively collect data points (age, location, etc.)' },
    { value: 'compliance', label: '⚖️ Compliance Monitor', desc: 'Flag regulatory issues in real-time' },
    { value: 'custom', label: '⚙️ Custom Callback', desc: 'Run a custom function/webhook' },
  ];

  function renderWatchers(watchers: any[]) {
    const container = document.getElementById('watchers-container')!;
    if (!watchers.length) {
      container.innerHTML = '<div class="text-[10px] text-gray-600 italic">No parallel actions configured</div>';
      return;
    }
    container.innerHTML = watchers.map((w, i) => {
      const typeInfo = WATCHER_TYPES.find(t => t.value === w.type) || { label: w.type, desc: '' };
      return `
        <div class="flex items-center gap-2 p-1.5 bg-gray-700/50 rounded border border-gray-600 group">
          <span class="text-[10px] flex-1">
            <span class="text-purple-300 font-medium">${typeInfo.label}</span>
            ${w.config?.keywords ? `<span class="text-gray-500 ml-1">[${w.config.keywords.join(', ')}]</span>` : ''}
            ${w.config?.slot ? `<span class="text-blue-400 ml-1">→ ${w.config.slot}</span>` : ''}
          </span>
          <button class="watcher-remove text-[10px] text-red-400 opacity-0 group-hover:opacity-100 hover:text-red-300" data-idx="${i}">✕</button>
        </div>
      `;
    }).join('');

    // Remove watcher
    container.querySelectorAll('.watcher-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!selectedNode || !currentTree[selectedNode]) return;
        const idx = parseInt((btn as HTMLElement).dataset.idx || '0');
        const watchers = currentTree[selectedNode].watchers || [];
        watchers.splice(idx, 1);
        if (watchers.length === 0) delete currentTree[selectedNode].watchers;
        renderWatchers(currentTree[selectedNode].watchers || []);
        markDirty();
      });
    });
  }

  // Add watcher button
  document.getElementById('btn-add-watcher')?.addEventListener('click', () => {
    if (!selectedNode || !currentTree[selectedNode]) return;

    // Show type picker
    const type = prompt(
      `Add parallel action type:\n\n${WATCHER_TYPES.map((t, i) => `${i + 1}. ${t.label} — ${t.desc}`).join('\n')}\n\nEnter number (1-${WATCHER_TYPES.length}):`
    );
    if (!type) return;
    const idx = parseInt(type) - 1;
    if (idx < 0 || idx >= WATCHER_TYPES.length) return;

    const watcherType = WATCHER_TYPES[idx].value;
    const watcher: any = { type: watcherType, config: {} };

    // Type-specific config
    if (watcherType === 'trigger_watch') {
      const keywords = prompt('Keywords to watch for (comma-separated):');
      if (keywords) watcher.config.keywords = keywords.split(',').map(k => k.trim()).filter(Boolean);
      const action = prompt('Action when triggered (e.g., "flag", "branch_to:<node_id>", "notify"):') || 'flag';
      watcher.config.action = action;
    } else if (watcherType === 'gather') {
      const slot = prompt('Slot name to fill (e.g., "age", "zip_code", "income_range"):');
      if (slot) watcher.config.slot = slot;
    } else if (watcherType === 'custom') {
      const url = prompt('Webhook URL or function name:');
      if (url) watcher.config.callback = url;
    }

    if (!currentTree[selectedNode].watchers) currentTree[selectedNode].watchers = [];
    currentTree[selectedNode].watchers.push(watcher);
    renderWatchers(currentTree[selectedNode].watchers);
    markDirty();
  });

  function renderEdgesEditor(edges: Record<string, any>) {
