---
/**
 * /voice — AI Sales Call Dashboard
 *
 * Allows Beth to:
 * 1. Enter a phone number + prospect name and initiate an AI sales call
 * 2. Monitor active calls with live transcripts
 * 3. Transfer calls to herself ("jump in")
 * 4. Review completed call transcripts
 *
 * Protected by magic-link auth (same as /recruitment).
 */
import Base from '../../layouts/Base.astro';
import '../../styles/tailwind.css';
import { verifySessionCookie } from '../../lib/ai-demo-auth';

export const prerender = false;

const session = await verifySessionCookie(Astro.request.headers.get('cookie'));
if (!session) {
  return Astro.redirect('/ai-demo-login?redirect=/voice', 302);
}
---
<Base title="AI Sales Calls — Legacy Financial & Life" description="AI-powered sales calling dashboard">

<div class="bg-gray-50 min-h-screen">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-30">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <div>
          <h1 class="text-sm font-bold text-gray-900">AI Sales Calls</h1>
          <p class="text-xs text-gray-500">Legacy Financial & Life</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span id="bridge-status" class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-500">Checking...</span>
        <a href="/voice/editor" class="text-xs text-purple-600 hover:underline font-medium">🎨 Editor</a>
        <a href="/recruitment" class="text-xs text-brand-600 hover:underline">← Recruitment</a>
      </div>
    </div>
  </header>

  <div class="max-w-5xl mx-auto px-4 py-6 space-y-6">

    <!-- Dial Card -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-4">📞 Make a Call</h2>
      <form id="dial-form" class="flex flex-wrap gap-3 items-end">
        <div class="flex-1 min-w-[180px]">
          <label class="block text-xs font-medium text-gray-600 mb-1">Phone Number</label>
          <input type="tel" id="phone-input" placeholder="(555) 123-4567"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
            required />
        </div>
        <div class="flex-1 min-w-[150px]">
          <label class="block text-xs font-medium text-gray-600 mb-1">Prospect Name</label>
          <input type="text" id="name-input" placeholder="Jane Smith"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
        </div>
        <div class="flex-1 min-w-[200px]">
          <label class="block text-xs font-medium text-gray-600 mb-1">Context <span class="text-gray-400">(optional)</span></label>
          <input type="text" id="context-input" placeholder="e.g. Interested in final expense"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
        </div>
        <div class="min-w-[160px]">
          <label class="block text-xs font-medium text-gray-600 mb-1">Transfer To <span class="text-red-400">*</span></label>
          <input type="tel" id="transfer-input" placeholder="(555) 867-5309"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
            required />
        </div>
        <button type="submit" id="dial-btn"
          class="px-5 py-2 bg-brand-600 text-white text-sm font-medium rounded-lg hover:bg-brand-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap">
          🔊 Call Now
        </button>
      </form>
      <div class="mt-2 flex items-center gap-2">
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="test-mode" class="rounded border-gray-300 text-brand-600 focus:ring-brand-500" checked />
          <span class="text-xs text-gray-500">Test mode</span>
        </label>
        <span class="text-xs text-gray-400">(no real transfer — call ends gracefully)</span>
      </div>
      <p id="dial-error" class="mt-2 text-xs text-red-600 hidden"></p>
      <p id="dial-success" class="mt-2 text-xs text-green-600 hidden"></p>
    </div>

    <!-- Dialog Tree Flowchart -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
      <button id="tree-toggle" class="w-full p-4 flex items-center justify-between text-left hover:bg-gray-50 transition-colors rounded-xl">
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-gray-900">🌳 Call Script Flow</span>
          <span class="text-xs text-gray-400">How the AI agent qualifies prospects</span>
        </div>
        <svg id="tree-chevron" class="w-5 h-5 text-gray-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div id="tree-content" class="hidden border-t border-gray-100">
        <div id="tree-loading" class="p-6 text-center">
          <p class="text-xs text-gray-400">Loading call flow...</p>
        </div>
        <div id="tree-chart" class="p-4 overflow-x-auto"></div>
        <div id="tree-detail" class="hidden px-4 pb-4">
          <div class="bg-gray-50 rounded-lg p-3">
            <h4 id="detail-title" class="text-sm font-medium text-gray-900 mb-1"></h4>
            <p id="detail-speak" class="text-xs text-gray-600 italic mb-2"></p>
            <div id="detail-edges" class="space-y-1"></div>
            <div id="detail-slots" class="mt-2"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Active Calls -->
    <div id="active-calls-section" class="hidden">
      <h2 class="text-sm font-semibold text-gray-900 mb-3">🔴 Active Calls</h2>
      <div id="active-calls" class="space-y-3"></div>
    </div>

    <!-- Live Transcript Viewer (shown when a call is selected) -->
    <div id="transcript-section" class="hidden">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="p-4 border-b border-gray-100 flex items-center justify-between">
          <div>
            <h3 class="text-sm font-semibold text-gray-900">Live Transcript</h3>
            <p id="transcript-meta" class="text-xs text-gray-500"></p>
          </div>
          <div class="flex gap-2">
            <button id="transfer-btn"
              class="px-3 py-1.5 bg-orange-500 text-white text-xs font-medium rounded-lg hover:bg-orange-600 transition-colors disabled:opacity-50">
              📲 Transfer to Beth
            </button>
            <button id="close-transcript-btn"
              class="px-3 py-1.5 bg-gray-200 text-gray-700 text-xs font-medium rounded-lg hover:bg-gray-300 transition-colors">
              ✕ Close
            </button>
          </div>
        </div>
        <div id="transcript-body" class="p-4 max-h-[400px] overflow-y-auto space-y-2">
          <p class="text-xs text-gray-400 italic">Waiting for conversation...</p>
        </div>
        <div id="transcript-slots" class="px-4 pb-3 border-t border-gray-50">
          <p class="text-xs text-gray-500 mt-2" id="slots-display"></p>
        </div>
      </div>
    </div>

    <!-- Recent Calls -->
    <div>
      <h2 class="text-sm font-semibold text-gray-900 mb-3">📋 Recent Calls</h2>
      <div id="recent-calls" class="space-y-2">
        <p class="text-xs text-gray-400">Loading...</p>
      </div>
    </div>

  </div>
</div>

<script>
  // ─── State ───
  let pollingInterval = null;
  let transcriptInterval = null;
  let watchingSessionId = null;

  // ─── Dial Form ───
  const dialForm = document.getElementById('dial-form');
  const phoneInput = document.getElementById('phone-input') as HTMLInputElement;
  const nameInput = document.getElementById('name-input') as HTMLInputElement;
  const contextInput = document.getElementById('context-input') as HTMLInputElement;
  const transferInput = document.getElementById('transfer-input') as HTMLInputElement;
  const dialBtn = document.getElementById('dial-btn') as HTMLButtonElement;
  const dialError = document.getElementById('dial-error');
  const dialSuccess = document.getElementById('dial-success');

  dialForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    dialError!.classList.add('hidden');
    dialSuccess!.classList.add('hidden');

    const phone = phoneInput.value.trim();
    const prospectName = nameInput.value.trim();
    const prospectContext = contextInput.value.trim();
    const transferNumber = transferInput.value.trim();
    const testMode = (document.getElementById('test-mode') as HTMLInputElement)?.checked;

    if (!phone) { dialError!.textContent = 'Enter a phone number'; dialError!.classList.remove('hidden'); return; }
    if (!transferNumber) { dialError!.textContent = 'Enter a transfer number (Beth\'s phone)'; dialError!.classList.remove('hidden'); return; }

    dialBtn.disabled = true;
    dialBtn.textContent = '⏳ Dialing...';

    try {
      const res = await fetch('/api/voice-dial', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone, prospectName, prospectContext, testMode, transferNumber }),
      });
      const data = await res.json();

      if (!res.ok) {
        dialError!.textContent = data.error || 'Call failed';
        dialError!.classList.remove('hidden');
      } else {
        dialSuccess!.textContent = `✅ Call initiated to ${data.to || phone}`;
        dialSuccess!.classList.remove('hidden');
        phoneInput.value = '';
        nameInput.value = '';
        contextInput.value = '';
        // Remember transfer number for next call
        localStorage.setItem('voice_transfer_number', transferNumber);
        // Start polling for active sessions
        startPolling();
      }
    } catch (err: any) {
      dialError!.textContent = 'Network error: ' + err.message;
      dialError!.classList.remove('hidden');
    } finally {
      dialBtn.disabled = false;
      dialBtn.textContent = '🔊 Call Now';
    }
  });

  // ─── Active Calls Polling ───
  function startPolling() {
    if (pollingInterval) return;
    pollSessions();
    pollingInterval = setInterval(pollSessions, 2000);
  }

  async function pollSessions() {
    try {
      const res = await fetch('/api/voice-sessions');
      const data = await res.json();
      renderActiveCalls(data);
      updateBridgeStatus(true, data.active, data.max);
    } catch {
      updateBridgeStatus(false);
    }
  }

  function updateBridgeStatus(online: boolean, active = 0, max = 0) {
    const el = document.getElementById('bridge-status')!;
    if (online) {
      el.textContent = `Bridge: ${active}/${max} calls`;
      el.className = 'text-xs px-2 py-1 rounded-full bg-green-50 text-green-700';
    } else {
      el.textContent = 'Bridge offline';
      el.className = 'text-xs px-2 py-1 rounded-full bg-red-50 text-red-700';
    }
  }

  function renderActiveCalls(data: any) {
    const section = document.getElementById('active-calls-section')!;
    const container = document.getElementById('active-calls')!;

    if (!data.sessions || data.sessions.length === 0) {
      section.classList.add('hidden');
      // If we were watching a session that ended, stop transcript polling
      if (watchingSessionId) {
        stopTranscriptPolling();
        // Refresh recent calls to show the completed one
        loadRecentCalls();
      }
      return;
    }

    section.classList.remove('hidden');
    container.innerHTML = data.sessions.map((s: any) => {
      const dur = Math.round(s.duration / 1000);
      const name = s.prospectName || s.calledNumber || 'Unknown';
      const stateColor = s.state === 'SPEAKING' ? 'text-blue-600' : s.state === 'LISTENING' ? 'text-green-600' : 'text-gray-500';
      const isWatching = watchingSessionId === s.id;
      return `
        <div class="bg-white rounded-lg border ${isWatching ? 'border-brand-300 ring-2 ring-brand-100' : 'border-gray-200'} p-3 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
            <div>
              <p class="text-sm font-medium text-gray-900">${name}</p>
              <p class="text-xs text-gray-500">${s.calledNumber} · ${dur}s · ${s.turnCount || 0} turns · <span class="${stateColor} font-medium">${s.state}</span></p>
            </div>
          </div>
          <div class="flex gap-2">
            <button onclick="watchCall('${s.id}')" class="px-3 py-1 text-xs font-medium rounded ${isWatching ? 'bg-brand-100 text-brand-700' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'} transition-colors">
              ${isWatching ? '👁️ Watching' : '👁️ Watch'}
            </button>
          </div>
        </div>
      `;
    }).join('');
  }

  // ─── Transcript Viewer ───
  (window as any).watchCall = function(sessionId: string) {
    watchingSessionId = sessionId;
    document.getElementById('transcript-section')!.classList.remove('hidden');
    document.getElementById('transcript-body')!.innerHTML = '<p class="text-xs text-gray-400 italic">Loading transcript...</p>';
    startTranscriptPolling();
  };

  function startTranscriptPolling() {
    if (transcriptInterval) clearInterval(transcriptInterval);
    pollTranscript();
    transcriptInterval = setInterval(pollTranscript, 1500);
  }

  function stopTranscriptPolling() {
    if (transcriptInterval) { clearInterval(transcriptInterval); transcriptInterval = null; }
    watchingSessionId = null;
  }

  async function pollTranscript() {
    if (!watchingSessionId) return;
    try {
      const res = await fetch(`/api/voice-transcript?sessionId=${watchingSessionId}`);
      if (res.status === 404) {
        // Call ended
        document.getElementById('transcript-meta')!.textContent = 'Call ended';
        stopTranscriptPolling();
        loadRecentCalls();
        return;
      }
      const data = await res.json();
      renderTranscript(data);
    } catch {
      // Bridge unreachable
    }
  }

  function renderTranscript(data: any) {
    const body = document.getElementById('transcript-body')!;
    const meta = document.getElementById('transcript-meta')!;
    const slots = document.getElementById('slots-display')!;

    const dur = Math.round(data.duration / 1000);
    meta.textContent = `${data.prospectName || data.calledNumber} · ${dur}s · ${data.turnCount} turns · ${data.state}`;

    if (!data.transcript || data.transcript.length === 0) {
      body.innerHTML = '<p class="text-xs text-gray-400 italic">Waiting for conversation to start...</p>';
    } else {
      body.innerHTML = data.transcript.map((msg: any) => {
        const isAgent = msg.role === 'agent';
        return `
          <div class="flex ${isAgent ? 'justify-start' : 'justify-end'}">
            <div class="max-w-[80%] px-3 py-1.5 rounded-lg text-sm ${isAgent ? 'bg-blue-50 text-blue-900' : 'bg-green-50 text-green-900'}">
              <span class="text-xs font-medium ${isAgent ? 'text-blue-600' : 'text-green-600'}">${isAgent ? '🤖 Agent' : '👤 Caller'}</span>
              <p class="mt-0.5">${msg.text}</p>
            </div>
          </div>
        `;
      }).join('');
      // Auto-scroll to bottom
      body.scrollTop = body.scrollHeight;
    }

    // Show collected slots
    if (data.slots && Object.keys(data.slots).length > 0) {
      const slotStr = Object.entries(data.slots)
        .map(([k, v]) => `<span class="inline-block px-1.5 py-0.5 bg-gray-100 rounded text-xs mr-1">${k}: ${v}</span>`)
        .join('');
      slots.innerHTML = `Qualified: ${slotStr}`;
    } else {
      slots.innerHTML = '';
    }
  }

  // Transfer button
  document.getElementById('transfer-btn')?.addEventListener('click', async () => {
    if (!watchingSessionId) return;
    const btn = document.getElementById('transfer-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Transferring...';
    try {
      const res = await fetch('/api/voice-transfer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId: watchingSessionId }),
      });
      const data = await res.json();
      if (res.ok) {
        btn.textContent = '✅ Transfer sent';
      } else {
        btn.textContent = `❌ ${data.error}`;
      }
    } catch {
      btn.textContent = '❌ Failed';
    }
    setTimeout(() => { btn.disabled = false; btn.textContent = '📲 Transfer to Beth'; }, 3000);
  });

  // Close transcript
  document.getElementById('close-transcript-btn')?.addEventListener('click', () => {
    document.getElementById('transcript-section')!.classList.add('hidden');
    stopTranscriptPolling();
  });

  // ─── Recent Calls ───
  async function loadRecentCalls() {
    try {
      const res = await fetch('/api/voice-calls?limit=15');
      const data = await res.json();
      renderRecentCalls(data.calls || []);
    } catch {
      document.getElementById('recent-calls')!.innerHTML = '<p class="text-xs text-red-500">Could not load call history</p>';
    }
  }

  function renderRecentCalls(calls: any[]) {
    const container = document.getElementById('recent-calls')!;
    if (calls.length === 0) {
      container.innerHTML = '<p class="text-xs text-gray-400">No calls yet today</p>';
      return;
    }

    container.innerHTML = calls.map((c: any) => {
      const time = new Date(c.ts).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
      const turns = c.turns || 0;
      const dur = c.duration_s || 0;
      const name = c.transcript?.[0]?.text?.match(/is this (.+)\?/)?.[1] || c.called || 'Unknown';
      const outcome = c.reason === 'hangup' ? (turns >= 8 ? '✅ Qualified' : '⬜ Incomplete') : '⚠️ ' + c.reason;
      return `
        <details class="bg-white rounded-lg border border-gray-200 overflow-hidden">
          <summary class="px-4 py-2.5 cursor-pointer hover:bg-gray-50 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="text-xs text-gray-400">${time}</span>
              <span class="text-sm font-medium text-gray-900">${name}</span>
              <span class="text-xs text-gray-500">${dur}s · ${turns} turns</span>
            </div>
            <span class="text-xs">${outcome}</span>
          </summary>
          <div class="px-4 pb-3 pt-1 border-t border-gray-100 space-y-1 max-h-[300px] overflow-y-auto">
            ${(c.transcript || []).map((msg: any) => `
              <div class="flex ${msg.role === 'assistant' ? 'justify-start' : 'justify-end'}">
                <p class="text-xs px-2 py-1 rounded ${msg.role === 'assistant' ? 'bg-blue-50 text-blue-800' : 'bg-green-50 text-green-800'} max-w-[85%]">
                  ${msg.text || msg.content || ''}
                </p>
              </div>
            `).join('')}
          </div>
        </details>
      `;
    }).join('');
  }

  // ─── Init ───
  // Restore saved transfer number
  const savedTransfer = localStorage.getItem('voice_transfer_number');
  if (savedTransfer) transferInput.value = savedTransfer;

  startPolling();
  loadRecentCalls();

  // ─── Dialog Tree Flowchart ───
  const treeToggle = document.getElementById('tree-toggle');
  const treeContent = document.getElementById('tree-content');
  const treeChevron = document.getElementById('tree-chevron');
  let treeLoaded = false;
  let treeData: any = null;

  treeToggle?.addEventListener('click', () => {
    const isHidden = treeContent!.classList.contains('hidden');
    treeContent!.classList.toggle('hidden');
    treeChevron!.style.transform = isHidden ? 'rotate(180deg)' : '';
    if (isHidden && !treeLoaded) {
      loadDialogTree();
    }
  });

  async function loadDialogTree() {
    try {
      const res = await fetch('/api/voice-dialog-tree');
      if (!res.ok) throw new Error('Failed to load');
      treeData = await res.json();
      treeLoaded = true;
      renderFlowchart(treeData);
    } catch (err: any) {
      document.getElementById('tree-loading')!.innerHTML =
        `<p class="text-xs text-red-500">Could not load dialog tree: ${err.message}</p>`;
    }
  }

  function renderFlowchart(data: any) {
    const { nodes, edges } = data;
    document.getElementById('tree-loading')!.classList.add('hidden');
    const chart = document.getElementById('tree-chart')!;

    // Build an interactive SVG flowchart
    const nodeMap = new Map<string, any>(nodes.map((n: any) => [n.id, n]));

    // Determine layout order using topological sort from greeting nodes
    const order: string[] = [];
    const visited = new Set<string>();

    function visit(id: string) {
      if (visited.has(id)) return;
      visited.add(id);
      order.push(id);
      for (const e of edges) {
        if (e.from === id && !visited.has(e.to)) visit(e.to);
      }
    }
    // Start from greeting nodes
    if (nodeMap.has('greeting_with_name')) visit('greeting_with_name');
    if (nodeMap.has('greeting_no_name')) visit('greeting_no_name');
    // Visit any remaining unvisited nodes
    for (const n of nodes) {
      if (!visited.has(n.id)) visit(n.id);
    }

    // Node dimensions and layout
    const NODE_W = 180;
    const NODE_H = 54;
    const GAP_X = 40;
    const GAP_Y = 28;
    const COLS = 3;

    // Position nodes in a grid
    const positions = new Map<string, { x: number; y: number }>();
    // Group: greetings side-by-side on row 0, then questions flow down
    const mainFlow = ['greeting_with_name', 'greeting_no_name', 'identity_check', 'wellbeing', 'consent',
      'ask_age', 'ask_beneficiary', 'ask_decision_maker', 'ask_zip', 'ask_bank', 'ask_coverage', 'transfer'];
    const sideNodes = order.filter(id => !mainFlow.includes(id) && id !== '__hangup__');

    // Main flow: single column, centered
    let y = 0;
    const mainX = (NODE_W + GAP_X); // center column
    // Greeting row: two side by side
    if (nodeMap.has('greeting_with_name')) {
      positions.set('greeting_with_name', { x: mainX - (NODE_W + GAP_X) / 2, y });
    }
    if (nodeMap.has('greeting_no_name')) {
      positions.set('greeting_no_name', { x: mainX + (NODE_W + GAP_X) / 2, y });
    }
    y += NODE_H + GAP_Y;

    for (const id of mainFlow) {
      if (id === 'greeting_with_name' || id === 'greeting_no_name') continue;
      if (!nodeMap.has(id)) continue;
      positions.set(id, { x: mainX, y });
      y += NODE_H + GAP_Y;
    }

    // Hangup node
    positions.set('__hangup__', { x: mainX + NODE_W + GAP_X + 60, y: 3 * (NODE_H + GAP_Y) });

    // Side nodes
    let sideY = 0;
    const sideX = mainX * 2 + NODE_W + GAP_X;
    for (const id of sideNodes) {
      positions.set(id, { x: sideX, y: sideY });
      sideY += NODE_H + GAP_Y;
    }

    // Compute SVG size
    let maxX = 0, maxY = 0;
    for (const pos of positions.values()) {
      maxX = Math.max(maxX, pos.x + NODE_W);
      maxY = Math.max(maxY, pos.y + NODE_H);
    }
    const svgW = maxX + 40;
    const svgH = maxY + 40;

    // Build SVG
    let svg = `<svg viewBox="0 0 ${svgW} ${svgH}" width="${Math.min(svgW, 900)}" xmlns="http://www.w3.org/2000/svg" style="font-family: system-ui, sans-serif;">`;

    // Marker for arrowheads
    svg += `<defs>
      <marker id="arrow" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 4 L 0 8 z" fill="#94a3b8"/>
      </marker>
      <marker id="arrow-red" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 4 L 0 8 z" fill="#f87171"/>
      </marker>
      <marker id="arrow-green" viewBox="0 0 10 8" refX="10" refY="4" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 4 L 0 8 z" fill="#22c55e"/>
      </marker>
    </defs>`;

    // Draw edges first (behind nodes)
    for (const e of edges) {
      const from = positions.get(e.from);
      const to = positions.get(e.to);
      if (!from || !to) continue;

      const x1 = from.x + NODE_W / 2;
      const y1 = from.y + NODE_H;
      const x2 = to.x + NODE_W / 2;
      const y2 = to.y;

      const color = e.type === 'fallback' ? '#f87171' : e.type === 'action' ? '#f87171' : '#94a3b8';
      const marker = e.type === 'fallback' || e.type === 'action' ? 'url(#arrow-red)' : 'url(#arrow)';
      const dash = e.type === 'fallback' ? 'stroke-dasharray="4 3"' : '';

      // Curved path for non-straight connections
      if (Math.abs(x1 - x2) < 5) {
        svg += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2 - 2}" stroke="${color}" stroke-width="1.5" marker-end="${marker}" ${dash}/>`;
      } else {
        const midY = (y1 + y2) / 2;
        svg += `<path d="M${x1},${y1} C${x1},${midY} ${x2},${midY} ${x2},${y2 - 2}" fill="none" stroke="${color}" stroke-width="1.5" marker-end="${marker}" ${dash}/>`;
      }
    }

    // Draw nodes
    for (const [id, pos] of positions) {
      const node = nodeMap.get(id);
      if (!node) continue;

      const isTerminal = node.isTerminal;
      const hasSlots = node.slots && node.slots.length > 0;
      const fill = isTerminal ? (node.action === 'transfer' ? '#dcfce7' : '#fee2e2')
        : hasSlots ? '#eff6ff' : '#ffffff';
      const border = isTerminal ? (node.action === 'transfer' ? '#22c55e' : '#f87171')
        : hasSlots ? '#3b82f6' : '#d1d5db';
      const radius = isTerminal ? 20 : 8;

      svg += `<g class="tree-node" data-node-id="${id}" style="cursor:pointer">`;
      svg += `<rect x="${pos.x}" y="${pos.y}" width="${NODE_W}" height="${NODE_H}" rx="${radius}" ry="${radius}" fill="${fill}" stroke="${border}" stroke-width="1.5"/>`;

      // Label: node name
      const label = id.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()).replace('Ask ', '❓ ');
      const displayLabel = label.length > 22 ? label.slice(0, 20) + '…' : label;
      svg += `<text x="${pos.x + NODE_W / 2}" y="${pos.y + 20}" text-anchor="middle" font-size="11" font-weight="600" fill="#1f2937">${displayLabel}</text>`;

      // Subtitle: slots or action
      if (hasSlots) {
        svg += `<text x="${pos.x + NODE_W / 2}" y="${pos.y + 36}" text-anchor="middle" font-size="9" fill="#6b7280">📦 ${node.slots.join(', ')}</text>`;
      } else if (node.action) {
        const actionEmoji = node.action === 'transfer' ? '📲' : node.action === 'hangup' ? '📴' : '⚡';
        svg += `<text x="${pos.x + NODE_W / 2}" y="${pos.y + 36}" text-anchor="middle" font-size="9" fill="#6b7280">${actionEmoji} ${node.action}</text>`;
      } else {
        const shortSpeak = (node.speak || '').slice(0, 28) + ((node.speak || '').length > 28 ? '…' : '');
        svg += `<text x="${pos.x + NODE_W / 2}" y="${pos.y + 36}" text-anchor="middle" font-size="9" fill="#9ca3af">${escSvg(shortSpeak)}</text>`;
      }

      svg += `</g>`;
    }

    svg += `</svg>`;
    chart.innerHTML = svg;

    // Click handler for node details
    chart.querySelectorAll('.tree-node').forEach(g => {
      g.addEventListener('click', () => {
        const nodeId = g.getAttribute('data-node-id')!;
        showNodeDetail(nodeId);
      });
    });
  }

  function escSvg(text: string): string {
    return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function showNodeDetail(nodeId: string) {
    if (!treeData) return;
    const node = treeData.nodes.find((n: any) => n.id === nodeId);
    if (!node) return;

    const detail = document.getElementById('tree-detail')!;
    const title = document.getElementById('detail-title')!;
    const speak = document.getElementById('detail-speak')!;
    const edgesEl = document.getElementById('detail-edges')!;
    const slotsEl = document.getElementById('detail-slots')!;

    title.textContent = nodeId.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
    speak.textContent = node.speak ? `"${node.speak}"` : '(no speak text)';

    // Find outgoing edges
    const outEdges = treeData.edges.filter((e: any) => e.from === nodeId);
    if (outEdges.length > 0) {
      edgesEl.innerHTML = '<p class="text-xs font-medium text-gray-700 mb-1">Transitions:</p>' +
        outEdges.map((e: any) => {
          const color = e.type === 'fallback' ? 'text-red-600' : e.type === 'action' ? 'text-orange-600' : 'text-green-700';
          return `<span class="inline-block text-xs px-1.5 py-0.5 rounded bg-gray-100 mr-1 mb-1 ${color}">${e.label} → ${e.to.replace(/_/g, ' ')}</span>`;
        }).join('');
    } else {
      edgesEl.innerHTML = '<p class="text-xs text-gray-400">Terminal node (no outgoing edges)</p>';
    }

    if (node.slots && node.slots.length > 0) {
      slotsEl.innerHTML = '<p class="text-xs font-medium text-gray-700">Extracts:</p>' +
        node.slots.map((s: string) => `<span class="inline-block text-xs px-1.5 py-0.5 rounded bg-blue-50 text-blue-700 mr-1">${s}</span>`).join('');
    } else {
      slotsEl.innerHTML = '';
    }

    detail.classList.remove('hidden');
  }
</script>

</Base>
