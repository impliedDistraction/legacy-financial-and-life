---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/tailwind.css';

export const prerender = false;

// ─── Prospect Context (server-side) ──────────────────────────────
// When a prospect arrives via email CTA (?pid=UUID), look up their
// research data to personalize the page and chat experience.
// Test mode: ?test=jordan uses a synthetic persona without DB lookup.
const pid = Astro.url.searchParams.get('pid') || '';
const testPersona = Astro.url.searchParams.get('test') || '';
let prospectTier: 'new' | 'established' | 'unknown' = 'unknown';
let prospectName = '';
let prospectState = '';
let prospectCity = '';

// ─── Test Personas (no DB required) ─────────────────────────────
const TEST_PERSONAS: Record<string, { name: string; state: string; city: string; tier: 'new' | 'established' }> = {
  jordan: { name: 'Jordan', state: 'TN', city: 'Nashville', tier: 'new' },
  established: { name: 'Patricia', state: 'GA', city: 'Atlanta', tier: 'established' },
};

if (testPersona && TEST_PERSONAS[testPersona]) {
  const persona = TEST_PERSONAS[testPersona];
  prospectName = persona.name;
  prospectState = persona.state;
  prospectCity = persona.city;
  prospectTier = persona.tier;
} else if (pid && pid.length > 10) {
  const SB_URL = import.meta.env.SUPABASE_URL?.trim();
  const SB_KEY = import.meta.env.SUPABASE_SERVICE_ROLE_KEY?.trim();
  if (SB_URL && SB_KEY) {
    try {
      const res = await fetch(
        `${SB_URL}/rest/v1/recruitment_prospects?id=eq.${encodeURIComponent(pid)}&select=name,state,city,experience_level,web_presence,properties&limit=1`,
        { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
      );
      if (res.ok) {
        const [p] = await res.json();
        if (p) {
          prospectName = p.name?.split(' ')[0] || '';
          prospectState = p.state || '';
          prospectCity = p.city || '';
          const wp = p.web_presence || {};
          const biz = wp.business?.stage || '';
          const credTier = wp.credentials?.tier || '';
          const expLevel = p.experience_level || '';
          const props = p.properties || {};
          const statesCount = props.states_count || 0;
          const daysSinceLicense = props.licensed_date
            ? Math.floor((Date.now() - new Date(props.licensed_date).getTime()) / 86400000)
            : null;

          // Classification logic
          if (biz === 'agency_owner' || biz === 'team_lead' || credTier === 'highly_credentialed' || credTier === 'credentialed') {
            prospectTier = 'established';
          } else if (expLevel === 'new' || (daysSinceLicense !== null && daysSinceLicense < 730) || statesCount <= 2) {
            prospectTier = 'new';
          } else if (biz === 'captive' || biz === 'independent') {
            prospectTier = 'established';
          }
        }
      }
    } catch { /* non-critical — fall back to generic page */ }
  }
}
---
<Base
  title="Join Legacy Financial & Life"
  description="Explore a career opportunity with Legacy Financial & Life — mentorship, training, and proven systems for insurance professionals."
>
  <Header />

  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-gradient-to-br from-brand-50 to-white">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:py-24 text-center">
      {prospectTier === 'established' ? (
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900">
          {prospectName ? `${prospectName}, ` : ''}Ready to Spend More Time Doing What You Do Best?
        </h1>
        <p class="mt-6 text-lg text-slate-700 max-w-2xl mx-auto">
          You've built something real. Legacy Financial & Life partners with experienced agents who want
          back-office support, a growing referral network, and FMO-level resources — so you can focus on
          clients instead of paperwork.
        </p>
      ) : prospectTier === 'new' ? (
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900">
          {prospectName ? `${prospectName}, ` : ''}Your Next Step in Insurance Starts Here
        </h1>
        <p class="mt-6 text-lg text-slate-700 max-w-2xl mx-auto">
          Starting out is hard enough without doing it alone. Legacy Financial & Life provides
          mentorship from experienced agents, lead support, and proven systems to help you build
          a sustainable book of business from day one.
        </p>
      ) : (
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900">
          Your Next Step in Insurance Starts Here
        </h1>
        <p class="mt-6 text-lg text-slate-700 max-w-2xl mx-auto">
          Legacy Financial & Life is expanding. We offer mentorship from experienced agents,
          proven systems, weekly training, and the tools you need to build a sustainable book of business.
        </p>
      )}
    </div>
  </section>

  <!-- What We Offer -->
  <section class="mx-auto max-w-4xl px-4 py-12">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {prospectTier === 'established' ? (
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">🌐</div>
          <h3 class="font-bold text-slate-900 mb-2">FMO-Level Resources</h3>
          <p class="text-sm text-slate-600">Access to carrier appointments, compliance support, and tools reserved for high-volume producers.</p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">🤝</div>
          <h3 class="font-bold text-slate-900 mb-2">Referral Network</h3>
          <p class="text-sm text-slate-600">A growing network of contacts across varied services — cross-referrals that benefit your clients and your book.</p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">📋</div>
          <h3 class="font-bold text-slate-900 mb-2">Back-Office Support</h3>
          <p class="text-sm text-slate-600">Let us handle the admin so you can spend your day with clients, not carrier portals.</p>
        </div>
      ) : prospectTier === 'new' ? (
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">🎯</div>
          <h3 class="font-bold text-slate-900 mb-2">Lead Support</h3>
          <p class="text-sm text-slate-600">Shared leads and prospecting systems so you're not starting from zero every week.</p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">👨‍🏫</div>
          <h3 class="font-bold text-slate-900 mb-2">Direct Mentorship</h3>
          <p class="text-sm text-slate-600">1-on-1 guidance from agents with 300+ policies sold. Learn what actually works.</p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">📋</div>
          <h3 class="font-bold text-slate-900 mb-2">Proven Systems</h3>
          <p class="text-sm text-slate-600">Established processes for prospecting, presenting, and closing — no guesswork.</p>
        </div>
      ) : (
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">👨‍🏫</div>
          <h3 class="font-bold text-slate-900 mb-2">Direct Mentorship</h3>
          <p class="text-sm text-slate-600">1-on-1 guidance from agents with 300+ policies sold.</p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">📋</div>
          <h3 class="font-bold text-slate-900 mb-2">Proven Systems</h3>
          <p class="text-sm text-slate-600">Established processes for prospecting, presenting, and closing.</p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">🤝</div>
          <h3 class="font-bold text-slate-900 mb-2">Team Support</h3>
          <p class="text-sm text-slate-600">Weekly training, shared leads, and a collaborative culture.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Interest Form -->
  <section class="bg-slate-50 py-16" id="interest">
    <div class="mx-auto max-w-lg px-4">
      <h2 class="text-2xl font-bold text-center text-slate-900 mb-2">Interested? Let's Talk.</h2>
      <p class="text-center text-slate-600 mb-8">
        Fill out the form below and our hiring manager will reach out to schedule a brief 20–30 minute conversation.
      </p>

      <form id="joinForm" class="space-y-5 bg-white rounded-xl border border-slate-200 p-8 shadow-sm">
        <div>
          <label for="name" class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
          <input type="text" id="name" name="name" required autocomplete="name"
            class="w-full rounded-lg border border-slate-300 px-4 py-2 text-slate-900 focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email"
            class="w-full rounded-lg border border-slate-300 px-4 py-2 text-slate-900 focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
          <input type="tel" id="phone" name="phone" required autocomplete="tel"
            class="w-full rounded-lg border border-slate-300 px-4 py-2 text-slate-900 focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
        </div>

        <div>
          <label for="state" class="block text-sm font-medium text-slate-700 mb-1">Licensed State</label>
          <select id="state" name="state"
            class="w-full rounded-lg border border-slate-300 px-4 py-2 text-slate-900 focus:border-brand-500 focus:ring-2 focus:ring-brand-200">
            <option value="">Select your state</option>
            <option value="AL">Alabama</option>
            <option value="FL">Florida</option>
            <option value="GA">Georgia</option>
            <option value="LA">Louisiana</option>
            <option value="MI">Michigan</option>
            <option value="MS">Mississippi</option>
            <option value="OH">Ohio</option>
            <option value="OK">Oklahoma</option>
            <option value="SC">South Carolina</option>
            <option value="TN">Tennessee</option>
            <option value="TX">Texas</option>
            <option value="UT">Utah</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <!-- TCPA-compliant text consent -->
        <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="textConsent" name="textConsent" required
              class="mt-1 h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
            <span class="text-xs text-slate-600 leading-relaxed">
              By checking this box, I consent to receive text messages and phone calls from Legacy Financial & Life
              regarding career opportunities at the phone number provided. Message and data rates may apply.
              Message frequency varies. Reply STOP to opt out at any time. This consent is not a condition of employment.
            </span>
          </label>
        </div>

        <button type="submit" id="submitBtn"
          class="w-full rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Schedule My Conversation
        </button>

        <div id="formMessage" class="hidden text-center text-sm py-2 rounded-lg"></div>
      </form>
    </div>
  </section>

  <Footer />

  <!-- Chat Widget -->
  <div id="chat-widget" class="fixed bottom-6 right-6 z-50">
    <!-- Toggle Button -->
    <button id="chat-toggle" aria-label="Chat with us"
      class="w-14 h-14 bg-brand-600 hover:bg-brand-700 text-white rounded-full shadow-lg flex items-center justify-center transition-all hover:scale-105">
      <svg id="chat-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <svg id="chat-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Chat Panel -->
    <div id="chat-panel" class="hidden absolute bottom-16 right-0 w-80 sm:w-96 bg-white rounded-xl shadow-2xl border border-slate-200 flex flex-col overflow-hidden" style="height: 480px;">
      <!-- Header -->
      <div class="px-4 py-3 bg-brand-600 text-white flex items-center gap-3">
        <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center">
          <span class="text-white font-bold text-xs">LF</span>
        </div>
        <div class="flex-1">
          <p class="font-medium text-sm">Legacy Financial Team</p>
          <p class="text-xs text-white/80">Ask us anything about joining</p>
        </div>
      </div>

      <!-- Messages -->
      <div id="chat-messages" class="flex-1 overflow-y-auto p-3 space-y-3 bg-slate-50">
        <div class="flex gap-2">
          <div class="w-6 h-6 bg-brand-600 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
            <span class="text-white text-[10px] font-bold">LF</span>
          </div>
          <div class="bg-white rounded-xl rounded-tl-sm px-3 py-2 max-w-[85%] shadow-sm border border-slate-100">
            {prospectTier === 'established' ? (
              <p class="text-sm text-slate-700">Hey{prospectName ? ` ${prospectName}` : ''}! 👋 Sounds like you've been in the industry a while. I'm curious — what does your day actually look like right now? Are you spending your time where you want to be?</p>
            ) : prospectTier === 'new' ? (
              <p class="text-sm text-slate-700">Hey{prospectName ? ` ${prospectName}` : ''}! 👋 Thanks for checking us out. Getting started in insurance can be a lot — what's been the biggest challenge so far? Where does most of your time end up going?</p>
            ) : (
              <p class="text-sm text-slate-700">Hey! 👋 Thanks for checking us out. I'd love to learn a little about you — what does your day actually look like right now? Where does most of your time go?</p>
            )}
          </div>
        </div>
      </div>

      <!-- Input -->
      <div class="p-3 border-t border-slate-200 bg-white">
        <div class="flex gap-2">
          <input id="chat-input" type="text" placeholder="Type a message…"
            class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-400" />
          <button id="chat-send" aria-label="Send message"
            class="px-3 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-700 transition-colors disabled:opacity-50">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  const form = document.getElementById('joinForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const msgEl = document.getElementById('formMessage') as HTMLDivElement;

  // Extract prospect ID from URL if present (from email CTA tracking)
  const params = new URLSearchParams(window.location.search);
  const prospectId = params.get('pid') || '';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    msgEl.classList.add('hidden');

    const data = {
      name: (form.elements.namedItem('name') as HTMLInputElement).value.trim(),
      email: (form.elements.namedItem('email') as HTMLInputElement).value.trim(),
      phone: (form.elements.namedItem('phone') as HTMLInputElement).value.trim(),
      state: (form.elements.namedItem('state') as HTMLSelectElement).value,
      textConsent: (form.elements.namedItem('textConsent') as HTMLInputElement).checked,
      prospectId,
    };

    try {
      const res = await fetch('/api/join-interest', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        msgEl.textContent = 'Thank you! Our hiring manager will be in touch soon.';
        msgEl.className = 'text-center text-sm py-3 rounded-lg bg-green-50 text-green-700 border border-green-200';
        msgEl.classList.remove('hidden');
        form.reset();
      } else {
        const err = await res.json().catch(() => ({ error: 'Something went wrong' }));
        msgEl.textContent = err.error || 'Something went wrong. Please try again.';
        msgEl.className = 'text-center text-sm py-3 rounded-lg bg-red-50 text-red-700 border border-red-200';
        msgEl.classList.remove('hidden');
      }
    } catch {
      msgEl.textContent = 'Network error. Please check your connection and try again.';
      msgEl.className = 'text-center text-sm py-3 rounded-lg bg-red-50 text-red-700 border border-red-200';
      msgEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Schedule My Conversation';
    }
  });
</script>

<script>
  // ─── Chat Widget ─────────────────────────────────────────────────
  const chatToggle = document.getElementById('chat-toggle') as HTMLButtonElement;
  const chatPanel = document.getElementById('chat-panel') as HTMLDivElement;
  const chatMessages = document.getElementById('chat-messages') as HTMLDivElement;
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const chatSend = document.getElementById('chat-send') as HTMLButtonElement;
  const iconOpen = document.getElementById('chat-icon-open');
  const iconClose = document.getElementById('chat-icon-close');

  let chatOpen = false;
  let chatEngaged = false; // true after first message sent
  const sessionId = crypto.randomUUID();
  const conversationHistory: Array<{ role: string; content: string }> = [];
  const chatPid = new URLSearchParams(window.location.search).get('pid') || '';
  const chatTestPersona = new URLSearchParams(window.location.search).get('test') || '';

  // Vercel analytics helper (fires only if @vercel/analytics is loaded)
  function trackChatEvent(name: string, props?: Record<string, string | number>) {
    try {
      const va = (window as any).va;
      if (typeof va === 'function') va('event', { name, ...props });
    } catch { /* non-critical */ }
  }

  chatToggle?.addEventListener('click', () => {
    chatOpen = !chatOpen;
    chatPanel.classList.toggle('hidden', !chatOpen);
    iconOpen?.classList.toggle('hidden', chatOpen);
    iconClose?.classList.toggle('hidden', !chatOpen);
    if (chatOpen) {
      chatInput.focus();
      trackChatEvent('join_chat_opened');
    }
  });

  chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendChatMessage();
    }
  });

  chatSend?.addEventListener('click', sendChatMessage);

  function escapeHtml(text: string): string {
    const el = document.createElement('span');
    el.textContent = text;
    return el.innerHTML;
  }

  function addChatBubble(role: 'user' | 'assistant', content: string): HTMLElement {
    const wrapper = document.createElement('div');
    wrapper.className = role === 'user' ? 'flex gap-2 justify-end' : 'flex gap-2';

    // Process action blocks for assistant messages
    let displayText = content;
    let actionHtml = '';
    if (role === 'assistant') {
      const result = processActions(content);
      displayText = result.clean;
      actionHtml = result.html;
    }

    if (role === 'assistant') {
      wrapper.innerHTML = `
        <div class="w-6 h-6 bg-brand-600 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
          <span class="text-white text-[10px] font-bold">LF</span>
        </div>
        <div class="chat-bubble bg-white rounded-xl rounded-tl-sm px-3 py-2 max-w-[85%] shadow-sm border border-slate-100">
          <p class="text-sm text-slate-700 whitespace-pre-wrap">${escapeHtml(displayText)}</p>${actionHtml}
        </div>`;
    } else {
      wrapper.innerHTML = `
        <div class="bg-brand-600 text-white rounded-xl rounded-tr-sm px-3 py-2 max-w-[85%]">
          <p class="text-sm whitespace-pre-wrap">${escapeHtml(content)}</p>
        </div>`;
    }

    chatMessages.appendChild(wrapper);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return wrapper;
  }

  function processActions(text: string): { clean: string; html: string } {
    let html = '';
    const clean = text.replace(/\{\{(book_call|fill_form)\}\}/g, (_m, action) => {
      if (action === 'book_call') {
        html += `<div class="mt-2 pt-2 border-t border-slate-100">
          <a href="https://calendly.com/legacy-financial/consultation" target="_blank" rel="noopener"
             class="inline-block px-3 py-1.5 bg-brand-600 text-white text-xs font-medium rounded-lg hover:bg-brand-700 transition-colors">
            📅 Schedule a Call
          </a>
        </div>`;
      } else if (action === 'fill_form') {
        html += `<div class="mt-2 pt-2 border-t border-slate-100">
          <button onclick="document.getElementById('interest')?.scrollIntoView({behavior:'smooth'}); document.getElementById('chat-toggle')?.click();"
             class="inline-block px-3 py-1.5 bg-green-600 text-white text-xs font-medium rounded-lg hover:bg-green-700 transition-colors">
            📋 Fill Out Interest Form
          </button>
        </div>`;
      }
      return '';
    }).trimEnd();
    return { clean, html };
  }

  async function sendChatMessage() {
    const msg = chatInput.value.trim();
    if (!msg) return;

    // Track first engagement
    if (!chatEngaged) {
      chatEngaged = true;
      trackChatEvent('join_chat_engaged', { session_id: sessionId });
    }

    chatInput.value = '';
    chatInput.disabled = true;
    chatSend.disabled = true;

    addChatBubble('user', msg);
    conversationHistory.push({ role: 'user', content: msg });

    // Typing indicator
    const typingEl = document.createElement('div');
    typingEl.className = 'flex gap-2';
    typingEl.id = 'chat-typing';
    typingEl.innerHTML = `
      <div class="w-6 h-6 bg-brand-600 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
        <span class="text-white text-[10px] font-bold">LF</span>
      </div>
      <div class="bg-white rounded-xl rounded-tl-sm px-3 py-2 shadow-sm border border-slate-100">
        <span class="text-slate-400 text-sm">Typing…</span>
      </div>`;
    chatMessages.appendChild(typingEl);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    try {
      const res = await fetch('/api/join-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: conversationHistory, sessionId, prospectId: chatPid, testPersona: chatTestPersona }),
      });

      typingEl.remove();

      if (!res.ok || !res.body) {
        addChatBubble('assistant', "I'm having trouble connecting right now. Please fill out the form above and Beth will be in touch!");
        return;
      }

      // Stream response
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let fullText = '';
      let responseEl: HTMLElement | null = null;
      let buffer = '';

      const stripActions = (t: string) => t.replace(/\{\{(book_call|fill_form)\}\}/g, '').trimEnd();

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (line.startsWith(': ')) continue; // heartbeat
          if (!line.startsWith('data: ')) continue;
          const data = line.slice(6);
          if (data === '[DONE]') break;

          try {
            const json = JSON.parse(data);
            if (json.content) {
              fullText += json.content;

              if (!responseEl && stripActions(fullText).length >= 3) {
                responseEl = addChatBubble('assistant', stripActions(fullText));
              } else if (responseEl) {
                const p = responseEl.querySelector('.chat-bubble p');
                if (p) p.textContent = stripActions(fullText);
                chatMessages.scrollTop = chatMessages.scrollHeight;
              }
            }
          } catch { /* skip */ }
        }
      }

      // Final render with action blocks
      if (responseEl && fullText) {
        const bubble = responseEl.querySelector('.chat-bubble');
        if (bubble) {
          const { clean, html } = processActions(fullText);
          const p = bubble.querySelector('p');
          if (p) p.textContent = clean;
          if (html) {
            const container = document.createElement('div');
            container.innerHTML = html;
            while (container.firstChild) bubble.appendChild(container.firstChild);
          }
        }
      } else if (!responseEl && fullText) {
        addChatBubble('assistant', fullText);
      }

      conversationHistory.push({ role: 'assistant', content: fullText });
    } catch {
      typingEl.remove();
      addChatBubble('assistant', "Something went wrong. Please try the interest form above — Beth will reach out personally!");
    } finally {
      chatInput.disabled = false;
      chatSend.disabled = false;
      chatInput.focus();
    }
  }
</script>
