---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/tailwind.css';
import {
  resolveVariant,
  getVariantContent,
  fetchTopPainPoints,
  VARIANT_COOKIE,
  type JoinVariant,
  type PainPoint,
} from '../lib/join-variants';

export const prerender = false;

// ─── Prospect Context (server-side) ──────────────────────────────
// When a prospect arrives via email CTA (?pid=UUID), look up their
// research data to personalize the page and chat experience.
// Test mode: ?test=jordan uses a synthetic persona without DB lookup.
const pid = Astro.url.searchParams.get('pid') || '';
const testPersona = Astro.url.searchParams.get('test') || '';
let prospectTier: 'new' | 'established' | 'unknown' = 'unknown';
let prospectName = '';
let prospectState = '';
let prospectCity = '';

// ─── Test Personas (no DB required) ─────────────────────────────
const TEST_PERSONAS: Record<string, { name: string; state: string; city: string; tier: 'new' | 'established' }> = {
  jordan: { name: 'Jordan', state: 'TN', city: 'Nashville', tier: 'new' },
  established: { name: 'Patricia', state: 'GA', city: 'Atlanta', tier: 'established' },
};

if (testPersona && TEST_PERSONAS[testPersona]) {
  const persona = TEST_PERSONAS[testPersona];
  prospectName = persona.name;
  prospectState = persona.state;
  prospectCity = persona.city;
  prospectTier = persona.tier;
} else if (pid && pid.length > 10) {
  const SB_URL = import.meta.env.SUPABASE_URL?.trim();
  const SB_KEY = import.meta.env.SUPABASE_SERVICE_ROLE_KEY?.trim();
  if (SB_URL && SB_KEY) {
    try {
      const res = await fetch(
        `${SB_URL}/rest/v1/recruitment_prospects?id=eq.${encodeURIComponent(pid)}&select=name,state,city,experience_level,web_presence,properties&limit=1`,
        { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
      );
      if (res.ok) {
        const [p] = await res.json();
        if (p) {
          prospectName = p.name?.split(' ')[0] || '';
          prospectState = p.state || '';
          prospectCity = p.city || '';
          const wp = p.web_presence || {};
          const biz = wp.business?.stage || '';
          const credTier = wp.credentials?.tier || '';
          const expLevel = p.experience_level || '';
          const props = p.properties || {};
          const statesCount = props.states_count || 0;
          const daysSinceLicense = props.licensed_date
            ? (() => { const d = new Date(props.licensed_date); return isNaN(d.getTime()) ? null : Math.floor((Date.now() - d.getTime()) / 86400000); })()
            : null;

          // Classification logic
          if (biz === 'agency_owner' || biz === 'team_lead' || credTier === 'highly_credentialed' || credTier === 'credentialed') {
            prospectTier = 'established';
          } else if (expLevel === 'new' || (daysSinceLicense !== null && daysSinceLicense < 730) || statesCount <= 2) {
            prospectTier = 'new';
          } else if (biz === 'captive' || biz === 'independent') {
            prospectTier = 'established';
          }
        }
      }
    } catch { /* non-critical — fall back to generic page */ }
  }
}

// ─── A/B Variant Resolution ──────────────────────────────────────
const forceVariant = Astro.url.searchParams.get('variant');
const flagOverride = import.meta.env.FLAG_JOIN_VARIANT?.trim();
const effectiveForce = (flagOverride && flagOverride !== 'random') ? flagOverride : forceVariant;

const [variant, isNewAssignment] = resolveVariant(
  Astro.request.headers.get('cookie'),
  import.meta.env.FLAG_JOIN_VARIANT_WEIGHTS,
  effectiveForce,
);

// For variant C, fetch survey pain point aggregates
let surveyPainPoints: PainPoint[] | undefined;
if (variant === 'C') {
  const SB_URL = import.meta.env.SUPABASE_URL?.trim();
  const SB_KEY = import.meta.env.SUPABASE_SERVICE_ROLE_KEY?.trim();
  if (SB_URL && SB_KEY) {
    surveyPainPoints = await fetchTopPainPoints(SB_URL, SB_KEY);
  }
}

const content = getVariantContent(variant, prospectTier, surveyPainPoints);

// Set sticky cookie if new assignment
if (isNewAssignment) {
  Astro.cookies.set(VARIANT_COOKIE, variant, {
    path: '/join',
    maxAge: 60 * 60 * 24 * 90, // 90 days
    httpOnly: false, // readable by client-side tracking
    sameSite: 'lax',
  });
}
---
<Base
  title="Join Legacy Financial & Life"
  description="Explore a career opportunity with Legacy Financial & Life — mentorship, training, and proven systems for insurance professionals."
>
  <Header />

  <!-- Server-rendered prospect context for client-side tracking -->
  <div id="prospect-context" data-tier={prospectTier} data-pid={pid} data-name={prospectName} data-simplified={String(!!(pid || testPersona))} data-variant={variant} class="hidden"></div>

  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-gradient-to-br from-brand-50 to-white">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:py-24 text-center">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900">
        {prospectName && (prospectTier === 'established' || prospectTier === 'new') ? `${prospectName}, ` : ''}{content.hero.headline}
      </h1>
      <p class="mt-6 text-lg text-slate-700 max-w-2xl mx-auto">
        {content.hero.subhead}
      </p>
    </div>
  </section>

  <!-- What We Offer -->
  <section class="mx-auto max-w-4xl px-4 py-12">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {content.cards.map(card => (
        <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
          <div class="text-3xl mb-3">{card.emoji}</div>
          <h3 class="font-bold text-slate-900 mb-2">{card.title}</h3>
          <p class="text-sm text-slate-600">{card.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Alliance Resources -->
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h2 class="text-2xl font-bold text-center text-slate-900 mb-2">See The Alliance</h2>
    <p class="text-center text-slate-600 mb-8 max-w-2xl mx-auto">
      Legacy Financial agents get full access to The Alliance FMO — direct carrier contracts, training, and a nationwide agent community. Here's what that looks like:
    </p>
    <div class="grid gap-6 sm:grid-cols-2">
      <!-- Video embed -->
      <div class="rounded-xl overflow-hidden shadow-sm border border-slate-200 bg-black aspect-video">
        <iframe
          src="https://www.youtube-nocookie.com/embed/bgn3esWUjLM"
          title="Tour The Alliance — See Where Agents Grow, Connect & Win"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
          class="w-full h-full"
        ></iframe>
      </div>
      <!-- New Agent Guide link -->
      <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm flex flex-col justify-center">
        <div class="text-3xl mb-3">📖</div>
        <h3 class="font-bold text-slate-900 mb-2">New Agent Guide</h3>
        <p class="text-sm text-slate-600 mb-4">
          The full rundown on carrier access, comp structure, training resources, and what it means to be part of The Alliance — in one interactive guide.
        </p>
        <a href="https://online.fliphtml5.com/thgjn/NAG-Q2-2026-V4-NoBleed/" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-semibold text-sm">
          View the Guide
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Interest Form -->
  <section class="bg-slate-50 py-16" id="interest">
    <div class="mx-auto max-w-lg px-4">
      <h2 class="text-2xl font-bold text-center text-slate-900 mb-2">Your Call — No Pressure Either Way</h2>
      <p class="text-center text-slate-600 mb-8">
        {(pid || testPersona)
          ? "Want to chat live? Or just get the details sent to you? Both work."
          : "Fill out the form below and we'll reach out — or just request the info pack if you'd rather look at everything first."
        }
      </p>

      <!-- Prominent scheduling CTA (always visible for known prospects) -->
      {(pid || testPersona) && (
        <div id="scheduleCta" class="bg-brand-50 rounded-xl border border-brand-200 p-6 text-center mb-6">
          <p class="text-brand-900 font-semibold mb-1">Ready to talk? Skip the form.</p>
          <p class="text-sm text-brand-700 mb-4">Book a 30-minute call directly — no strings attached.</p>
          <a href="https://calendly.com/bethandtim-legacyf-l/30min" target="_blank" rel="noopener"
             class="inline-block w-full rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 font-semibold transition-colors text-center">
            &#128197; Book My 30-Minute Conversation
          </a>
        </div>
      )}

      <form id="joinForm" class="space-y-5 bg-white rounded-xl border border-slate-200 p-8 shadow-sm">
        {/* Full form for cold visitors (no pid) */}
        {!(pid || testPersona) && (
          <>
            <div>
              <label for="name" class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
              <input type="text" id="name" name="name" required autocomplete="name"
                class="w-full rounded-lg border border-slate-300 px-4 py-2 text-slate-900 focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
              <input type="email" id="email" name="email" required autocomplete="email"
                class="w-full rounded-lg border border-slate-300 px-4 py-2 text-slate-900 focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
              <input type="tel" id="phone" name="phone" required autocomplete="tel"
                class="w-full rounded-lg border border-slate-300 px-4 py-2 text-slate-900 focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
            </div>

            <div>
              <label for="state" class="block text-sm font-medium text-slate-700 mb-1">Licensed State</label>
              <select id="state" name="state"
                class="w-full rounded-lg border border-slate-300 px-4 py-2 text-slate-900 focus:border-brand-500 focus:ring-2 focus:ring-brand-200">
                <option value="">Select your state</option>
                <option value="AL">Alabama</option>
                <option value="FL">Florida</option>
                <option value="GA">Georgia</option>
                <option value="LA">Louisiana</option>
                <option value="MI">Michigan</option>
                <option value="MS">Mississippi</option>
                <option value="OH">Ohio</option>
                <option value="OK">Oklahoma</option>
                <option value="SC">South Carolina</option>
                <option value="TN">Tennessee</option>
                <option value="TX">Texas</option>
                <option value="UT">Utah</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </>
        )}

        {/* Simplified form for email arrivals (already have their info) */}
        {(pid || testPersona) && (
          <div class="text-center py-2">
            <p class="text-slate-700 font-medium">
              {prospectName ? `Hi ${prospectName}! ` : ''}Ready for a quick conversation?
            </p>
            <p class="text-sm text-slate-500 mt-1">
              We already have your contact details from your license profile. Just let us know it's okay to reach out.
            </p>
          </div>
        )}

        <!-- TCPA-compliant text consent -->
        <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="textConsent" name="textConsent"
              class="mt-1 h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
            <span class="text-xs text-slate-600 leading-relaxed">
              By checking this box, I consent to receive text messages and phone calls from Legacy Financial & Life
              regarding career opportunities at the phone number provided. Message and data rates may apply.
              Message frequency varies. Reply STOP to opt out at any time. This consent is not a condition of employment or engagement.
            </span>
          </label>
        </div>

        <!-- Referral network consent (optional) -->
        <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="referralConsent" name="referralConsent"
              class="mt-1 h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
            <span class="text-xs text-slate-600 leading-relaxed">
              <span class="font-medium text-slate-700">Optional:</span> I'm open to hearing about opportunities from
              Legacy Financial's trusted partner network. Your information will only be shared with vetted partners
              offering complementary professional services, and you can revoke this consent at any time.
            </span>
          </label>
        </div>

        <button type="submit" id="submitBtn"
          class="w-full rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          {(pid || testPersona) ? "Yes, I'm Interested — Reach Out" : "Schedule My Conversation"}
        </button>

        <div id="formMessage" class="hidden text-center text-sm py-2 rounded-lg"></div>
      </form>

      <!-- Booking CTA (hidden until successful submission) -->
      <div id="bookingCta" class="hidden bg-white rounded-xl border border-slate-200 p-8 shadow-sm text-center">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-2">You're all set!</h3>
        <p class="text-slate-600 mb-6">Let's get you on the calendar for a quick conversation with Tim &amp; Beth.</p>
        <a id="bookingLink" href="https://calendly.com/bethandtim-legacyf-l/30min" target="_blank" rel="noopener"
           class="inline-block w-full rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 font-semibold transition-colors text-center">
          &#128197; Book My 30-Minute Conversation
        </a>
        <p class="text-sm text-slate-500 mt-4">Not ready to book yet? No worries — our team will reach out to find a time that works.</p>
      </div>

      <p id="directBookHint" class="text-center text-sm text-slate-500 mt-4">
        {(pid || testPersona) ? 'Or fill out the quick form above and we\'ll reach out to you.' : 'Prefer to book directly?'}
        <a href="https://calendly.com/bethandtim-legacyf-l/30min" target="_blank" rel="noopener"
           class="text-brand-600 hover:text-brand-700 font-medium underline underline-offset-2">
          Schedule a 30-min call with Tim &amp; Beth
        </a>
      </p>
    </div>
  </section>

  <Footer />

  <!-- Chat Widget -->
  <div id="chat-widget" class="fixed bottom-6 right-6 z-50">
    <!-- Auto-dismiss nudge tooltip -->
    <div id="chat-nudge" class="absolute bottom-16 right-0 w-64 bg-white rounded-xl shadow-xl border border-slate-200 p-4 opacity-0 translate-y-2 transition-all duration-300 pointer-events-none">
      <button id="chat-nudge-dismiss" class="absolute top-2 right-2 text-slate-400 hover:text-slate-600 pointer-events-auto" aria-label="Dismiss">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
      <p class="text-sm font-medium text-slate-900 mb-1">Have questions? 👋</p>
      <p class="text-xs text-slate-600">Chat with us about the opportunity — we're here to help you decide if Legacy Financial is the right fit.</p>
      <div class="absolute bottom-0 right-6 translate-y-1/2 w-3 h-3 bg-white border-r border-b border-slate-200 rotate-45"></div>
    </div>

    <!-- Toggle Button with pulse ring -->
    <button id="chat-toggle" aria-label="Chat with us"
      class="relative w-14 h-14 bg-brand-600 hover:bg-brand-700 text-white rounded-full shadow-lg flex items-center justify-center transition-all hover:scale-105">
      <!-- Pulse ring (visible until chat is opened) -->
      <span id="chat-pulse" class="absolute inset-0 rounded-full bg-brand-400 animate-ping opacity-40"></span>
      <svg id="chat-icon-open" class="relative w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <svg id="chat-icon-close" class="relative w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Chat Panel -->
    <div id="chat-panel" class="hidden absolute bottom-16 right-0 w-80 sm:w-96 bg-white rounded-xl shadow-2xl border border-slate-200 flex flex-col overflow-hidden" style="height: 480px;">
      <!-- Header -->
      <div class="px-4 py-3 bg-brand-600 text-white flex items-center gap-3">
        <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center">
          <span class="text-white font-bold text-xs">LF</span>
        </div>
        <div class="flex-1">
          <p class="font-medium text-sm">Legacy Financial Team</p>
          <p class="text-xs text-white/80">Ask us anything about joining</p>
        </div>
      </div>

      <!-- Messages -->
      <div id="chat-messages" class="flex-1 overflow-y-auto p-3 space-y-3 bg-slate-50">
        <div class="flex gap-2">
          <div class="w-6 h-6 bg-brand-600 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
            <span class="text-white text-[10px] font-bold">LF</span>
          </div>
          <div class="bg-white rounded-xl rounded-tl-sm px-3 py-2 max-w-[85%] shadow-sm border border-slate-100">
            <p class="text-sm text-slate-700">{prospectName ? content.chatOpener.replace('Hey!', `Hey ${prospectName}!`) : content.chatOpener}</p>
          </div>
        </div>
      </div>

      <!-- Input -->
      <div class="p-3 border-t border-slate-200 bg-white">
        <div class="flex gap-2">
          <input id="chat-input" type="text" placeholder="Type a message…"
            class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-400" />
          <button id="chat-send" aria-label="Send message"
            class="px-3 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-700 transition-colors disabled:opacity-50">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  const form = document.getElementById('joinForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const msgEl = document.getElementById('formMessage') as HTMLDivElement;
  const bookingCta = document.getElementById('bookingCta') as HTMLDivElement;
  const bookingLink = document.getElementById('bookingLink') as HTMLAnchorElement;
  const directBookHint = document.getElementById('directBookHint') as HTMLParagraphElement;

  // Extract prospect context from server-rendered data + URL params
  const params = new URLSearchParams(window.location.search);
  const prospectId = params.get('pid') || '';
  const isTestMode = !!params.get('test');
  const ctxEl = document.getElementById('prospect-context');
  const isSimplified = ctxEl?.dataset.simplified === 'true';
  const prospectName = ctxEl?.dataset.name || '';

  const CALENDLY_BASE = 'https://calendly.com/bethandtim-legacyf-l/30min';

  function showBookingSuccess() {
    // Build Calendly URL with name prefill when available
    const nameForCal = prospectName || (form.elements.namedItem('name') as HTMLInputElement | null)?.value?.trim() || '';
    const emailForCal = (form.elements.namedItem('email') as HTMLInputElement | null)?.value?.trim() || '';
    const calParams = new URLSearchParams();
    if (nameForCal) calParams.set('name', nameForCal);
    if (emailForCal) calParams.set('email', emailForCal);
    const calUrl = calParams.toString() ? `${CALENDLY_BASE}?${calParams}` : CALENDLY_BASE;
    bookingLink.href = calUrl;

    form.classList.add('hidden');
    bookingCta.classList.remove('hidden');
    directBookHint?.classList.add('hidden');
    // Hide the pre-form scheduling CTA since they now have the post-form one
    const scheduleCta = document.getElementById('scheduleCta');
    if (scheduleCta) scheduleCta.classList.add('hidden');

    // Track conversion with variant info
    try {
      const va = (window as any).va;
      const variant = ctxEl?.dataset.variant || 'A';
      if (typeof va === 'function') va('event', { name: 'join_form_submitted', variant });
    } catch { /* non-critical */ }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    msgEl.classList.add('hidden');

    const nameEl = form.elements.namedItem('name') as HTMLInputElement | null;
    const emailEl = form.elements.namedItem('email') as HTMLInputElement | null;
    const phoneEl = form.elements.namedItem('phone') as HTMLInputElement | null;
    const stateEl = form.elements.namedItem('state') as HTMLSelectElement | null;

    const textConsent = (form.elements.namedItem('textConsent') as HTMLInputElement).checked;
    const referralConsent = (form.elements.namedItem('referralConsent') as HTMLInputElement).checked;

    const data = {
      name: nameEl?.value.trim() || '',
      email: emailEl?.value.trim() || '',
      phone: phoneEl?.value.trim() || '',
      state: stateEl?.value || '',
      textConsent,
      referralConsent,
      prospectId,
    };

    try {
      let success = false;

      if (isTestMode && !prospectId) {
        // Test persona mode — no real DB record to update, simulate success
        success = true;
      } else {
        const res = await fetch('/api/join-interest', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          success = true;
        } else {
          const err = await res.json().catch(() => ({ error: 'Something went wrong' }));
          msgEl.textContent = err.error || 'Something went wrong. Please try again.';
          msgEl.className = 'text-center text-sm py-3 rounded-lg bg-red-50 text-red-700 border border-red-200';
          msgEl.classList.remove('hidden');
        }
      }

      if (success) {
        showBookingSuccess();
      }
    } catch {
      msgEl.textContent = 'Network error. Please check your connection and try again.';
      msgEl.className = 'text-center text-sm py-3 rounded-lg bg-red-50 text-red-700 border border-red-200';
      msgEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = isSimplified ? "Yes, I'm Interested — Reach Out" : 'Schedule My Conversation';
    }
  });
</script>

<script>
  // ─── Visit Tracking Beacon ──────────────────────────────────────
  // Fires once on page load for prospects arriving from email CTA.
  // This confirms a real browser rendered the page (vs bot link prefetch).
  (function() {
    const ctx = document.getElementById('prospect-context');
    const pid = ctx?.dataset.pid || '';
    const tier = ctx?.dataset.tier || 'unknown';
    const variant = ctx?.dataset.variant || 'A';
    if (!pid || pid.length < 10) return;

    // Deduplicate: only fire once per session per prospect
    const visitKey = `join_visited_${pid}`;
    if (sessionStorage.getItem(visitKey)) return;
    sessionStorage.setItem(visitKey, '1');

    fetch('/api/join-visit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        prospectId: pid,
        tier,
        variant,
        referrer: document.referrer || null,
      }),
      keepalive: true,
    }).catch(() => {}); // non-critical
  })();
</script>

<script>
  // ─── Chat Widget ─────────────────────────────────────────────────
  const chatToggle = document.getElementById('chat-toggle') as HTMLButtonElement;
  const chatPanel = document.getElementById('chat-panel') as HTMLDivElement;
  const chatMessages = document.getElementById('chat-messages') as HTMLDivElement;
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const chatSend = document.getElementById('chat-send') as HTMLButtonElement;
  const iconOpen = document.getElementById('chat-icon-open');
  const iconClose = document.getElementById('chat-icon-close');
  const chatNudge = document.getElementById('chat-nudge') as HTMLDivElement;
  const chatNudgeDismiss = document.getElementById('chat-nudge-dismiss') as HTMLButtonElement;
  const chatPulse = document.getElementById('chat-pulse') as HTMLSpanElement;

  let chatOpen = false;
  let chatEngaged = false; // true after first message sent
  const sessionId = crypto.randomUUID();
  const conversationHistory: Array<{ role: string; content: string }> = [];
  const chatPid = new URLSearchParams(window.location.search).get('pid') || '';
  const chatTestPersona = new URLSearchParams(window.location.search).get('test') || '';

  // Show nudge tooltip after 3 seconds if chat hasn't been opened
  let nudgeTimeout: ReturnType<typeof setTimeout> | null = null;
  nudgeTimeout = setTimeout(() => {
    if (!chatOpen && chatNudge) {
      chatNudge.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
      chatNudge.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
    }
  }, 3000);

  // Dismiss nudge
  function dismissNudge() {
    if (chatNudge) {
      chatNudge.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
      chatNudge.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
    }
    if (chatPulse) chatPulse.classList.add('hidden');
    if (nudgeTimeout) clearTimeout(nudgeTimeout);
  }
  chatNudgeDismiss?.addEventListener('click', (e) => { e.stopPropagation(); dismissNudge(); });

  // Vercel analytics helper (fires only if @vercel/analytics is loaded)
  function trackChatEvent(name: string, props?: Record<string, string | number>) {
    try {
      const va = (window as any).va;
      const ctx = document.getElementById('prospect-context');
      const variant = ctx?.dataset.variant || 'A';
      if (typeof va === 'function') va('event', { name, variant, ...props });
    } catch { /* non-critical */ }
  }

  chatToggle?.addEventListener('click', () => {
    chatOpen = !chatOpen;
    chatPanel.classList.toggle('hidden', !chatOpen);
    iconOpen?.classList.toggle('hidden', chatOpen);
    iconClose?.classList.toggle('hidden', !chatOpen);
    if (chatOpen) {
      dismissNudge();
      chatInput.focus();
      trackChatEvent('join_chat_opened');
    }
  });

  chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendChatMessage();
    }
  });

  chatSend?.addEventListener('click', sendChatMessage);

  function escapeHtml(text: string): string {
    const el = document.createElement('span');
    el.textContent = text;
    return el.innerHTML;
  }

  function addChatBubble(role: 'user' | 'assistant', content: string): HTMLElement {
    const wrapper = document.createElement('div');
    wrapper.className = role === 'user' ? 'flex gap-2 justify-end' : 'flex gap-2';

    // Process action blocks for assistant messages
    let displayText = content;
    let actionHtml = '';
    if (role === 'assistant') {
      const result = processActions(content);
      displayText = result.clean;
      actionHtml = result.html;
    }

    if (role === 'assistant') {
      wrapper.innerHTML = `
        <div class="w-6 h-6 bg-brand-600 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
          <span class="text-white text-[10px] font-bold">LF</span>
        </div>
        <div class="chat-bubble bg-white rounded-xl rounded-tl-sm px-3 py-2 max-w-[85%] shadow-sm border border-slate-100">
          <p class="text-sm text-slate-700 whitespace-pre-wrap">${escapeHtml(displayText)}</p>${actionHtml}
        </div>`;
    } else {
      wrapper.innerHTML = `
        <div class="bg-brand-600 text-white rounded-xl rounded-tr-sm px-3 py-2 max-w-[85%]">
          <p class="text-sm whitespace-pre-wrap">${escapeHtml(content)}</p>
        </div>`;
    }

    chatMessages.appendChild(wrapper);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return wrapper;
  }

  function processActions(text: string): { clean: string; html: string } {
    let html = '';
    const clean = text.replace(/\{\{(book_call|schedule_call|fill_form|escalate_issue)\}\}/g, (_m, action) => {
      if (action === 'book_call') {
        html += `<div class="mt-2 pt-2 border-t border-slate-100">
          <a href="https://calendly.com/bethandtim-legacyf-l/30min" target="_blank" rel="noopener"
             class="inline-block px-3 py-1.5 bg-brand-600 text-white text-xs font-medium rounded-lg hover:bg-brand-700 transition-colors">
            📅 Schedule a Call
          </a>
        </div>`;
      } else if (action === 'schedule_call') {
        html += `<div class="mt-2 pt-2 border-t border-slate-100 schedule-widget" data-loaded="false">
          <p class="text-xs text-brand-700 font-semibold mb-2">📅 Pick a time for your 30-min conversation:</p>
          <div class="schedule-slots-container">
            <p class="text-xs text-slate-400 animate-pulse">Loading available times…</p>
          </div>
          <a href="https://calendly.com/bethandtim-legacyf-l/30min" target="_blank" rel="noopener"
             class="schedule-fallback hidden text-xs text-brand-600 hover:text-brand-700 underline underline-offset-2 mt-2 inline-block">
            Or book directly on Calendly →
          </a>
        </div>`;
      } else if (action === 'fill_form') {
        html += `<div class="mt-2 pt-2 border-t border-slate-100">
          <button onclick="try{document.getElementById('chat-toggle')?.click();setTimeout(function(){document.getElementById('interest')?.scrollIntoView({behavior:'smooth'})},150)}catch(e){}"
             class="inline-block px-3 py-1.5 bg-green-600 text-white text-xs font-medium rounded-lg hover:bg-green-700 transition-colors">
            📋 Fill Out Interest Form
          </button>
        </div>`;
      } else if (action === 'escalate_issue') {
        html += `<div class="mt-2 pt-2 border-t border-red-100" id="inline-escalate-form">
          <p class="text-xs text-red-700 font-semibold mb-1">🛠️ Report a Technical Issue</p>
          <div class="space-y-1.5">
            <textarea placeholder="What happened?" rows="2" maxlength="2000" class="w-full px-2 py-1 text-xs border border-red-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400 resize-none" data-escalate="summary"></textarea>
            <input type="email" placeholder="Your email (optional)" class="w-full px-2 py-1 text-xs border border-red-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400" data-escalate="email" />
            <button class="w-full py-1 bg-red-600 text-white text-xs font-medium rounded-lg hover:bg-red-700 transition-colors escalate-submit-btn">Submit Report</button>
          </div>
        </div>`;
      }
      return '';
    }).trimEnd();
    return { clean, html };
  }

  async function sendChatMessage() {
    const msg = chatInput.value.trim();
    if (!msg) return;

    // Track first engagement
    if (!chatEngaged) {
      chatEngaged = true;
      trackChatEvent('join_chat_engaged', { session_id: sessionId });
    }

    chatInput.value = '';
    chatInput.disabled = true;
    chatSend.disabled = true;

    addChatBubble('user', msg);
    conversationHistory.push({ role: 'user', content: msg });

    // Typing indicator
    const typingEl = document.createElement('div');
    typingEl.className = 'flex gap-2';
    typingEl.id = 'chat-typing';
    typingEl.innerHTML = `
      <div class="w-6 h-6 bg-brand-600 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
        <span class="text-white text-[10px] font-bold">LF</span>
      </div>
      <div class="bg-white rounded-xl rounded-tl-sm px-3 py-2 shadow-sm border border-slate-100">
        <span class="text-slate-400 text-sm">Typing…</span>
      </div>`;
    chatMessages.appendChild(typingEl);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    try {
      const res = await fetch('/api/join-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: conversationHistory, sessionId, prospectId: chatPid, testPersona: chatTestPersona }),
      });

      typingEl.remove();

      if (!res.ok || !res.body) {
        addChatBubble('assistant', "I'm having trouble connecting right now. Please fill out the form above and Beth will be in touch!");
        return;
      }

      // Stream response
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let fullText = '';
      let responseEl: HTMLElement | null = null;
      let buffer = '';

      const stripActions = (t: string) => t.replace(/\{\{(book_call|schedule_call|fill_form|escalate_issue)\}\}/g, '').trimEnd();

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (line.startsWith(': ')) continue; // heartbeat
          if (!line.startsWith('data: ')) continue;
          const data = line.slice(6);
          if (data === '[DONE]') break;

          try {
            const json = JSON.parse(data);
            if (json.content) {
              fullText += json.content;

              if (!responseEl && stripActions(fullText).length >= 3) {
                responseEl = addChatBubble('assistant', stripActions(fullText));
              } else if (responseEl) {
                const p = responseEl.querySelector('.chat-bubble p');
                if (p) p.textContent = stripActions(fullText);
                chatMessages.scrollTop = chatMessages.scrollHeight;
              }
            }
          } catch { /* skip */ }
        }
      }

      // Final render with action blocks
      if (responseEl && fullText) {
        const bubble = responseEl.querySelector('.chat-bubble');
        if (bubble) {
          const { clean, html } = processActions(fullText);
          const p = bubble.querySelector('p');
          if (p) p.textContent = clean;
          if (html) {
            const container = document.createElement('div');
            container.innerHTML = html;
            while (container.firstChild) bubble.appendChild(container.firstChild);
          }
          // Wire up escalate form if present
          const escalateForm = bubble.querySelector('#inline-escalate-form');
          if (escalateForm) {
            const submitBtn = escalateForm.querySelector('.escalate-submit-btn');
            submitBtn?.addEventListener('click', async () => {
              const summary = (escalateForm.querySelector('[data-escalate="summary"]') as HTMLTextAreaElement)?.value.trim();
              const email = (escalateForm.querySelector('[data-escalate="email"]') as HTMLInputElement)?.value.trim();
              if (!summary || summary.length < 10) {
                submitBtn.textContent = 'Please describe the issue (10+ chars)';
                setTimeout(() => { submitBtn.textContent = 'Submit Report'; }, 2000);
                return;
              }
              submitBtn.textContent = 'Submitting…';
              (submitBtn as HTMLButtonElement).disabled = true;
              try {
                await fetch('/api/escalate', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    summary,
                    category: 'technical',
                    source: 'join-chat',
                    pageUrl: window.location.pathname,
                    conversation: conversationHistory.slice(-10),
                    userContact: email ? { email } : undefined,
                  }),
                });
                escalateForm.innerHTML = `<p class="text-xs text-green-600 font-medium">✓ Report submitted — our team will investigate. Thank you!</p>`;
              } catch {
                escalateForm.innerHTML = `<p class="text-xs text-red-600 font-medium">Failed to submit. Please call (706) 333-5641 for help.</p>`;
              }
            });
          }

          // Wire up inline scheduling widget if present
          const scheduleWidget = bubble.querySelector('.schedule-widget');
          if (scheduleWidget && scheduleWidget.getAttribute('data-loaded') === 'false') {
            scheduleWidget.setAttribute('data-loaded', 'true');
            loadScheduleSlots(scheduleWidget as HTMLElement);
          }
        }
      } else if (!responseEl && fullText) {
        addChatBubble('assistant', fullText);
      }

      conversationHistory.push({ role: 'assistant', content: fullText });
    } catch {
      typingEl.remove();
      addChatBubble('assistant', "Something went wrong. Please try the interest form above — Beth will reach out personally!");
    } finally {
      chatInput.disabled = false;
      chatSend.disabled = false;
      chatInput.focus();
    }
  }

  // ─── Inline Scheduling Widget ────────────────────────────────────
  async function loadScheduleSlots(widget: HTMLElement) {
    const container = widget.querySelector('.schedule-slots-container') as HTMLElement;
    const fallbackLink = widget.querySelector('.schedule-fallback') as HTMLElement;

    try {
      const res = await fetch('/api/schedule-slots?max=6&days=7');
      if (!res.ok) throw new Error('API error');
      const data = await res.json();

      if (!data.available || !data.slots || data.slots.length === 0) {
        // Show fallback link to Calendly
        container.innerHTML = `<p class="text-xs text-slate-500">No times loaded — book directly below.</p>`;
        fallbackLink?.classList.remove('hidden');
        return;
      }

      // Render slot buttons grouped by day
      const tz = 'America/New_York';
      const slotsByDay = new Map<string, Array<{ start: string; label: string }>>();
      for (const slot of data.slots) {
        const dt = new Date(slot.start);
        const dayKey = dt.toLocaleDateString('en-US', { timeZone: tz, weekday: 'short', month: 'short', day: 'numeric' });
        const timeLabel = dt.toLocaleTimeString('en-US', { timeZone: tz, hour: 'numeric', minute: '2-digit', hour12: true });
        if (!slotsByDay.has(dayKey)) slotsByDay.set(dayKey, []);
        slotsByDay.get(dayKey)!.push({ start: slot.start, label: timeLabel });
      }

      let slotsHtml = '';
      for (const [day, times] of slotsByDay) {
        slotsHtml += `<div class="mb-1.5"><p class="text-[10px] text-slate-500 font-medium mb-0.5">${escapeHtml(day)}</p><div class="flex flex-wrap gap-1">`;
        for (const t of times) {
          slotsHtml += `<button class="slot-btn px-2 py-1 text-[11px] bg-brand-50 text-brand-700 border border-brand-200 rounded-md hover:bg-brand-100 hover:border-brand-400 transition-colors" data-start="${escapeHtml(t.start)}">${escapeHtml(t.label)}</button>`;
        }
        slotsHtml += `</div></div>`;
      }
      container.innerHTML = slotsHtml;
      fallbackLink?.classList.remove('hidden');

      // Wire up slot buttons
      container.querySelectorAll('.slot-btn').forEach(btn => {
        btn.addEventListener('click', () => handleSlotSelect(btn as HTMLButtonElement, widget));
      });
    } catch {
      container.innerHTML = `<p class="text-xs text-slate-500">Couldn't load times.</p>`;
      fallbackLink?.classList.remove('hidden');
    }
  }

  async function handleSlotSelect(btn: HTMLButtonElement, widget: HTMLElement) {
    const startTime = btn.getAttribute('data-start');
    if (!startTime) return;

    const container = widget.querySelector('.schedule-slots-container') as HTMLElement;

    // Confirm selection — show mini form for name/email
    const dt = new Date(startTime);
    const formatted = dt.toLocaleString('en-US', {
      timeZone: 'America/New_York',
      weekday: 'short', month: 'short', day: 'numeric',
      hour: 'numeric', minute: '2-digit', hour12: true,
    });

    container.innerHTML = `
      <div class="space-y-1.5">
        <p class="text-xs text-slate-700 font-medium">📅 ${escapeHtml(formatted)} ET</p>
        <input type="text" placeholder="Your name" maxlength="100" class="w-full px-2 py-1 text-xs border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-400" data-schedule="name" />
        <input type="email" placeholder="Your email" maxlength="200" class="w-full px-2 py-1 text-xs border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-400" data-schedule="email" />
        <div class="flex gap-2">
          <button class="flex-1 py-1 bg-brand-600 text-white text-xs font-medium rounded-lg hover:bg-brand-700 transition-colors schedule-confirm-btn">Confirm</button>
          <button class="px-2 py-1 text-xs text-slate-500 hover:text-slate-700 schedule-back-btn">← Back</button>
        </div>
      </div>`;

    // Back button reloads slots
    container.querySelector('.schedule-back-btn')?.addEventListener('click', () => {
      widget.setAttribute('data-loaded', 'false');
      loadScheduleSlots(widget);
    });

    // Confirm button books the slot
    container.querySelector('.schedule-confirm-btn')?.addEventListener('click', async () => {
      const nameInput = container.querySelector('[data-schedule="name"]') as HTMLInputElement;
      const emailInput = container.querySelector('[data-schedule="email"]') as HTMLInputElement;
      const name = nameInput?.value.trim();
      const email = emailInput?.value.trim();

      if (!name || name.length < 2) { nameInput?.focus(); return; }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { emailInput?.focus(); return; }

      const confirmBtn = container.querySelector('.schedule-confirm-btn') as HTMLButtonElement;
      confirmBtn.textContent = 'Booking…';
      confirmBtn.disabled = true;

      try {
        const res = await fetch('/api/schedule-slots', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ startTime, name, email, prospectId: chatPid }),
        });
        const result = await res.json();

        if (result.success) {
          container.innerHTML = `<p class="text-xs text-green-600 font-medium">✅ You're booked for ${escapeHtml(formatted)} ET! Check ${escapeHtml(email)} for confirmation.</p>`;
          trackChatEvent('join_schedule_booked', { session_id: sessionId });
        } else if (result.fallbackUrl) {
          container.innerHTML = `<p class="text-xs text-amber-600">${escapeHtml(result.error || 'Booking unavailable')}</p><a href="${result.fallbackUrl}" target="_blank" rel="noopener" class="text-xs text-brand-600 underline">Book on Calendly →</a>`;
        } else {
          container.innerHTML = `<p class="text-xs text-red-600">${escapeHtml(result.error || 'Booking failed')}</p>`;
          // Re-show slots after a moment
          setTimeout(() => { widget.setAttribute('data-loaded', 'false'); loadScheduleSlots(widget); }, 3000);
        }
      } catch {
        container.innerHTML = `<p class="text-xs text-red-600">Network error — try the link below.</p>`;
        widget.querySelector('.schedule-fallback')?.classList.remove('hidden');
      }
    });
  }
</script>
