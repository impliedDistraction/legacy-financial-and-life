---
import Base from '../layouts/Base.astro';
import { site } from '../content/site';
import '../styles/tailwind.css';

const licensedStates = 'Ohio, Georgia, Oklahoma, South Carolina, Mississippi, Michigan, Texas, Utah, Alabama, and Louisiana';
---

<Base title="Quote Request Received" description="Thank you! Your free quote request has been submitted. We'll be in touch shortly.">
  <!-- Minimal header matching free-quote page -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-200">
    <div class="mx-auto max-w-6xl flex items-center justify-between gap-4 px-4 py-3">
      <span class="text-sm font-medium text-brand-600">Quote Request Received</span>
      <span class="text-xs text-slate-500">We'll follow up shortly</span>
    </div>
  </header>

  <div class="min-h-[80vh] bg-gradient-to-br from-brand-50 to-white flex items-center justify-center px-4">
    <div class="max-w-2xl text-center py-20">
      <!-- Success Icon -->
      <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>

      <h1 class="text-4xl font-bold text-slate-900 mb-4">You're All Set!</h1>
      <p class="text-xl text-slate-700 mb-8">
        Your free quote request has been submitted. A licensed professional from our team will reach out shortly — no pressure, just answers.
      </p>

      <div class="bg-white rounded-xl border border-slate-200 p-6 mb-8 shadow-lg text-left">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">What happens next?</h2>
        <div class="space-y-3">
          <div class="flex items-start space-x-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-sm font-medium text-brand-700">1</span>
            <p class="text-slate-700">We review your information and identify the best options for your situation</p>
          </div>
          <div class="flex items-start space-x-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-sm font-medium text-brand-700">2</span>
            <p class="text-slate-700">Tim, Beth, Ivan, or Kendall will personally reach out to discuss your quote</p>
          </div>
          <div class="flex items-start space-x-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-sm font-medium text-brand-700">3</span>
            <p class="text-slate-700">We'll help you find the right coverage — on your timeline, no rush</p>
          </div>
        </div>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-8">
        <p class="text-amber-800 text-sm">
          <strong>What to do now:</strong> Keep an eye on your inbox. We'll follow up shortly with the next step.
        </p>
        <p class="mt-2 text-amber-800 text-sm">
          <strong>Licensed states:</strong> {licensedStates}
        </p>
      </div>

    </div>
  </div>

  <footer class="bg-slate-900 text-slate-400 py-8">
    <div class="mx-auto max-w-6xl px-4 text-center text-sm space-y-2">
      <p>&copy; {new Date().getFullYear()} Legacy Financial & Life. All rights reserved.</p>
      <p>Licensed in {licensedStates}. Policies and features vary by carrier and state.</p>
      <p><a href="/privacy" class="underline hover:text-white transition-colors">Privacy Policy</a></p>
    </div>
  </footer>
</Base>

<script>
  import { getQuoteInterest, markQuoteTrackingIdConsumed, trackQuoteAnalyticsEvent } from '../scripts/lead-analytics';

  const successTracked = sessionStorage.getItem('quote_success_tracked');

  if (successTracked !== 'true') {
    trackQuoteAnalyticsEvent({
      eventName: 'quote_form_success',
      route: '/quote-success',
      stage: 'handoff',
      status: 'success',
      ownerScope: 'handoff',
      interest: getQuoteInterest(),
    });

    // Fire Meta Pixel Lead conversion event for Facebook Ads attribution
    if (typeof window.fbq === 'function') {
      window.fbq('track', 'Lead');
    }

    sessionStorage.setItem('quote_success_tracked', 'true');
    markQuoteTrackingIdConsumed();
  }
</script>
