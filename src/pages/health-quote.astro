---
import Base from '../layouts/Base.astro';
import '../styles/tailwind.css';

const licensedStates = 'Ohio, Georgia, Oklahoma, South Carolina, Mississippi, Michigan, Texas, Utah, Alabama, and Louisiana';
---

<Base
  title="Health Plan Recommendations — Free, No Obligation"
  description="See real health plans available in your area with estimated costs. Automated assistance helps you compare — a licensed agent reviews before any enrollment."
>
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-200">
    <div class="mx-auto max-w-6xl flex items-center justify-between gap-4 px-4 py-3">
      <a href="/" class="text-sm font-medium text-brand-600">Legacy Financial & Life</a>
      <span class="text-xs text-slate-500">Plan Comparison Tool</span>
    </div>
  </header>

  <!-- Compliance Banner -->
  <div class="bg-blue-50 border-b border-blue-200 px-4 py-3 text-center text-sm text-blue-800">
    <strong>Automated Assistance:</strong> This tool uses publicly available plan data to help you compare options.
    A licensed insurance professional reviews all selections before any enrollment takes place.
  </div>

  <!-- Multi-step form -->
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-2xl px-4">

      <!-- Step indicators -->
      <div class="flex items-center justify-center gap-2 mb-10" id="step-indicators">
        <div class="step-dot active" data-step="1"><span>1</span> Your Info</div>
        <div class="step-connector"></div>
        <div class="step-dot" data-step="2"><span>2</span> Coverage</div>
        <div class="step-connector"></div>
        <div class="step-dot" data-step="3"><span>3</span> Results</div>
        <div class="step-connector"></div>
        <div class="step-dot" data-step="4"><span>4</span> Enroll</div>
      </div>

      <!-- ═══ STEP 1: Basic Info ═══ -->
      <div id="step-1" class="step-panel">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Let's find plans in your area</h2>
        <p class="text-slate-600 mb-8">We just need a few details to show you real plans with accurate prices.</p>

        <form id="quote-info-form" class="grid gap-5">
          <label class="grid gap-1">
            <span class="text-sm font-medium text-slate-700">Zip Code <span class="text-red-500">*</span></span>
            <input type="text" name="zip" required inputmode="numeric" maxlength="5" pattern="\d{5}"
              placeholder="Enter your 5-digit zip code"
              class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none" />
          </label>

          <label class="grid gap-1">
            <span class="text-sm font-medium text-slate-700">Date of Birth <span class="text-red-500">*</span></span>
            <input type="date" name="dob" required
              class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none" />
            <p class="text-xs text-slate-500">Used to determine age and plan eligibility</p>
          </label>

          <div class="grid sm:grid-cols-2 gap-4">
            <label class="grid gap-1">
              <span class="text-sm font-medium text-slate-700">Household Size</span>
              <select name="householdSize"
                class="rounded-lg border border-slate-300 px-4 py-3 bg-white transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none">
                <option value="1">Just me</option>
                <option value="2">2 people</option>
                <option value="3">3 people</option>
                <option value="4">4 people</option>
                <option value="5">5 people</option>
                <option value="6">6+ people</option>
              </select>
            </label>

            <label class="grid gap-1">
              <span class="text-sm font-medium text-slate-700">Tobacco Use</span>
              <select name="tobacco"
                class="rounded-lg border border-slate-300 px-4 py-3 bg-white transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none">
                <option value="no">No</option>
                <option value="yes">Yes</option>
              </select>
            </label>
          </div>

          <label class="grid gap-1">
            <span class="text-sm font-medium text-slate-700">Estimated Annual Household Income</span>
            <input type="text" name="income" inputmode="numeric" placeholder="e.g. 55000 (optional — for subsidy estimate)"
              class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none" />
            <p class="text-xs text-slate-500">Optional. Helps estimate what you'd actually pay after tax credits.</p>
          </label>

          <button type="submit"
            class="mt-2 rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-6 py-4 font-semibold text-lg transition-all shadow-md hover:shadow-lg">
            See My Plan Options →
          </button>
        </form>
      </div>

      <!-- ═══ STEP 2: Coverage Preferences (shown if marketplace) ═══ -->
      <div id="step-2" class="step-panel hidden">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">What matters most to you?</h2>
        <p class="text-slate-600 mb-8">These help us show the most relevant plans first. All are optional.</p>

        <form id="prefs-form" class="grid gap-5">
          <label class="grid gap-1">
            <span class="text-sm font-medium text-slate-700">Plan Metal Level Preference</span>
            <select name="metalPreference"
              class="rounded-lg border border-slate-300 px-4 py-3 bg-white transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none">
              <option value="">Show all levels</option>
              <option value="Bronze">Bronze — Lower premium, higher out-of-pocket</option>
              <option value="Silver">Silver — Balanced (subsidy-eligible)</option>
              <option value="Gold">Gold — Higher premium, lower out-of-pocket</option>
              <option value="Platinum">Platinum — Highest coverage</option>
            </select>
          </label>

          <label class="grid gap-1">
            <span class="text-sm font-medium text-slate-700">Plan Type Preference</span>
            <select name="planType"
              class="rounded-lg border border-slate-300 px-4 py-3 bg-white transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none">
              <option value="">No preference</option>
              <option value="PPO">PPO — More provider flexibility</option>
              <option value="HMO">HMO — Lower cost, network-based</option>
              <option value="EPO">EPO — Network-based, no referrals</option>
              <option value="POS">POS — Hybrid</option>
            </select>
          </label>

          <label class="grid gap-1">
            <span class="text-sm font-medium text-slate-700">Current Prescriptions</span>
            <textarea name="prescriptions" rows="3" placeholder="List any medications you take regularly (one per line)"
              class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"></textarea>
            <p class="text-xs text-slate-500">Optional. We'll note these for agent review of drug coverage.</p>
          </label>

          <div class="flex gap-3">
            <button type="button" id="back-to-step-1"
              class="rounded-lg border border-slate-300 px-6 py-3 font-medium text-slate-700 hover:bg-slate-50 transition-colors">
              ← Back
            </button>
            <button type="submit"
              class="flex-1 rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-6 py-4 font-semibold text-lg transition-all shadow-md hover:shadow-lg">
              Find Plans →
            </button>
          </div>
        </form>
      </div>

      <!-- ═══ STEP 2-T65: Medicare Pathway ═══ -->
      <div id="step-2-t65" class="step-panel hidden">
        <div class="text-center py-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-900 mb-3">You May Qualify for Medicare</h2>
          <p class="text-slate-600 max-w-md mx-auto mb-6">
            Based on your age, you're eligible (or soon will be) for Medicare coverage. Our licensed team specializes in helping people navigate Medicare Advantage, Part D, and Supplement options.
          </p>

          <div class="bg-slate-50 rounded-xl border border-slate-200 p-6 text-left mb-6">
            <h3 class="font-semibold text-slate-900 mb-3">What happens next:</h3>
            <ol class="space-y-3 text-sm text-slate-700">
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center font-semibold text-xs">1</span>
                <span>We'll collect your basic information and any medications you take</span>
              </li>
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center font-semibold text-xs">2</span>
                <span>A licensed agent reviews Medicare Advantage and Part D plans in your area</span>
              </li>
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center font-semibold text-xs">3</span>
                <span>We'll reach out with personalized recommendations — no obligation</span>
              </li>
            </ol>
          </div>

          <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 text-sm text-amber-800 mb-6">
            <strong>Important:</strong> Medicare enrollment has specific windows. If you're turning 65 soon, acting early ensures you don't miss your Initial Enrollment Period.
          </div>

          <form id="t65-form" class="grid gap-4 text-left">
            <label class="grid gap-1">
              <span class="text-sm font-medium text-slate-700">Full Name <span class="text-red-500">*</span></span>
              <input type="text" name="name" required placeholder="Your full name"
                class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none" />
            </label>

            <label class="grid gap-1">
              <span class="text-sm font-medium text-slate-700">Email <span class="text-red-500">*</span></span>
              <input type="email" name="email" required placeholder="you@example.com"
                class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none" />
            </label>

            <label class="grid gap-1">
              <span class="text-sm font-medium text-slate-700">Phone</span>
              <input type="tel" name="phone" placeholder="(555) 123-4567"
                class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none" />
            </label>

            <label class="grid gap-1">
              <span class="text-sm font-medium text-slate-700">Current Medications</span>
              <textarea name="prescriptions" rows="3" placeholder="List any prescriptions (one per line) — helps us find plans that cover your drugs"
                class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"></textarea>
            </label>

            <label class="grid gap-1">
              <span class="text-sm font-medium text-slate-700">Do you already have Medicare Parts A & B?</span>
              <select name="hasMedicare"
                class="rounded-lg border border-slate-300 px-4 py-3 bg-white transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none">
                <option value="">Select…</option>
                <option value="yes">Yes, I have Parts A & B</option>
                <option value="a-only">I only have Part A</option>
                <option value="no">No, I haven't enrolled yet</option>
                <option value="working">I'm still working and on employer coverage</option>
                <option value="unsure">I'm not sure</option>
              </select>
            </label>

            <button type="submit"
              class="mt-2 rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-6 py-4 font-semibold text-lg transition-all shadow-md hover:shadow-lg">
              Get My Medicare Review →
            </button>

            <p class="text-xs text-slate-500 text-center">
              By submitting, you consent to being contacted by a licensed agent about Medicare options. <a href="/privacy" class="underline">Privacy Policy</a>
            </p>
          </form>
        </div>
      </div>

      <!-- ═══ STEP 3: Results ═══ -->
      <div id="step-3" class="step-panel hidden">
        <div id="loading-state" class="text-center py-12">
          <div class="animate-spin h-10 w-10 border-4 border-brand-200 border-t-brand-600 rounded-full mx-auto"></div>
          <p class="mt-4 text-slate-600">Searching available plans in your area…</p>
        </div>

        <div id="results-container" class="hidden">
          <!-- Populated by JS -->
        </div>
      </div>

      <!-- ═══ STEP 4: Enrollment / Signature ═══ -->
      <div id="step-4" class="step-panel hidden">
        <div id="enrollment-container">
          <!-- Populated by JS after plan selection -->
        </div>
      </div>

    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-slate-900 text-slate-400 py-8">
    <div class="mx-auto max-w-md px-4 text-center text-xs leading-relaxed space-y-3">
      <p>Licensed in {licensedStates}.</p>
      <p>Plan data sourced from CMS Public Use Files. Premiums and availability subject to change.</p>
      <p><a href="/privacy" class="underline hover:text-white transition-colors">Privacy Policy</a></p>
    </div>
  </footer>
</Base>

<style>
  .step-panel { transition: opacity 0.3s ease; }
  .step-panel.hidden { display: none; }
  .step-dot {
    @apply flex items-center gap-1.5 text-xs font-medium text-slate-400;
  }
  .step-dot span {
    @apply flex items-center justify-center w-6 h-6 rounded-full bg-slate-200 text-slate-500 font-bold text-xs;
  }
  .step-dot.active { @apply text-brand-700; }
  .step-dot.active span { @apply bg-brand-600 text-white; }
  .step-dot.completed span { @apply bg-green-500 text-white; }
  .step-connector { @apply w-8 h-px bg-slate-200; }
</style>

<script>
  // ═══ Health Quote Multi-Step Flow ═══
  const steps = {
    current: 1,
    data: {} as Record<string, unknown>,
  };

  function showStep(n: number) {
    document.querySelectorAll('.step-panel').forEach(el => el.classList.add('hidden'));
    const target = document.getElementById(`step-${n}`);
    if (target) target.classList.remove('hidden');

    // Update indicators
    document.querySelectorAll('.step-dot').forEach(dot => {
      const stepNum = parseInt(dot.getAttribute('data-step') || '0');
      dot.classList.toggle('active', stepNum === n);
      dot.classList.toggle('completed', stepNum < n);
    });
    steps.current = n;
  }

  function calculateAge(dob: string): number {
    const birth = new Date(dob);
    const today = new Date();
    let age = today.getFullYear() - birth.getFullYear();
    const m = today.getMonth() - birth.getMonth();
    if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
    return age;
  }

  // Step 1: Basic info → determine pathway
  document.getElementById('quote-info-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);

    steps.data = {
      zip: formData.get('zip'),
      dob: formData.get('dob'),
      age: calculateAge(String(formData.get('dob'))),
      householdSize: parseInt(String(formData.get('householdSize'))) || 1,
      tobacco: formData.get('tobacco') === 'yes',
      annualIncome: parseInt(String(formData.get('income')).replace(/\D/g, '')) || undefined,
    };

    // T65 detection: age 64+ routes to Medicare pathway
    if ((steps.data.age as number) >= 64) {
      document.getElementById('step-2')?.classList.add('hidden');
      document.getElementById('step-2-t65')?.classList.remove('hidden');
      showStep(2);
      // Override step target
      const stepPanel = document.getElementById('step-2-t65');
      if (stepPanel) stepPanel.id = 'step-2';
    } else {
      showStep(2);
    }
  });

  // Step 1 back button
  document.getElementById('back-to-step-1')?.addEventListener('click', () => showStep(1));

  // Step 2: Coverage prefs → fetch plans
  document.getElementById('prefs-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);

    steps.data.metalPreference = formData.get('metalPreference') || undefined;
    steps.data.planType = formData.get('planType') || undefined;
    steps.data.prescriptions = String(formData.get('prescriptions') || '')
      .split('\n').map(s => s.trim()).filter(Boolean);

    showStep(3);
    await fetchAndDisplayPlans();
  });

  // T65 form submission
  document.getElementById('t65-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);

    steps.data.name = formData.get('name');
    steps.data.email = formData.get('email');
    steps.data.phone = formData.get('phone');
    steps.data.hasMedicare = formData.get('hasMedicare');
    steps.data.prescriptions = String(formData.get('prescriptions') || '')
      .split('\n').map(s => s.trim()).filter(Boolean);

    showStep(3);
    await submitT65Request();
  });

  async function fetchAndDisplayPlans() {
    const loading = document.getElementById('loading-state');
    const container = document.getElementById('results-container');
    if (!loading || !container) return;

    loading.classList.remove('hidden');
    container.classList.add('hidden');

    try {
      const resp = await fetch('/api/plan-recommend', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(steps.data),
      });

      const result = await resp.json();
      loading.classList.add('hidden');
      container.classList.remove('hidden');

      if (!result.success || result.plans?.length === 0) {
        container.innerHTML = `
          <div class="text-center py-8">
            <p class="text-lg text-slate-700 font-medium">No plans found for your area</p>
            <p class="text-slate-500 mt-2">${result.error || 'Please verify your zip code or contact us for help.'}</p>
            <a href="/book" class="mt-4 inline-block text-brand-600 font-medium hover:underline">Schedule a call with our team →</a>
          </div>`;
        return;
      }

      renderPlanResults(result);
    } catch (err) {
      loading.classList.add('hidden');
      container.classList.remove('hidden');
      container.innerHTML = `
        <div class="text-center py-8">
          <p class="text-lg text-red-600 font-medium">Something went wrong</p>
          <p class="text-slate-500 mt-2">Please try again or <a href="/book" class="text-brand-600 underline">schedule a call</a>.</p>
        </div>`;
    }
  }

  function renderPlanResults(result: any) {
    const container = document.getElementById('results-container');
    if (!container) return;

    const subsidyHtml = result.subsidy ? `
      <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-6">
        <p class="font-medium text-green-800">Estimated Tax Credit: $${result.subsidy.aptcMonthly.toFixed(2)}/month</p>
        <p class="text-sm text-green-700">Based on ${result.subsidy.fplPercent}% of federal poverty level. Actual amount determined at enrollment.</p>
      </div>` : '';

    const plansHtml = result.plans.map((plan: any, i: number) => `
      <div class="plan-card border border-slate-200 rounded-xl p-5 hover:border-brand-300 hover:shadow-md transition-all cursor-pointer" data-plan-index="${i}">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-bold px-2 py-0.5 rounded-full ${metalColor(plan.metalLevel)}">${plan.metalLevel}</span>
              <span class="text-xs text-slate-500">${plan.planType}</span>
              ${plan.isHSAEligible ? '<span class="text-xs text-emerald-600 font-medium">HSA Eligible</span>' : ''}
            </div>
            <h3 class="font-semibold text-slate-900">${plan.planName}</h3>
            <p class="text-sm text-slate-500">${plan.issuerName}</p>
          </div>
          <div class="text-right flex-shrink-0">
            ${plan.estimatedNetPremium !== null
              ? `<p class="text-xl font-bold text-brand-700">$${plan.estimatedNetPremium.toFixed(0)}<span class="text-sm font-normal">/mo</span></p>
                 <p class="text-xs text-slate-500 line-through">$${plan.monthlyPremium?.toFixed(0)}/mo full price</p>`
              : `<p class="text-xl font-bold text-slate-800">$${plan.monthlyPremium?.toFixed(0) || 'N/A'}<span class="text-sm font-normal">/mo</span></p>`
            }
          </div>
        </div>
        <div class="mt-3 flex gap-4 text-xs text-slate-600">
          <span>Deductible: ${plan.deductible || 'N/A'}</span>
          <span>Max OOP: ${plan.maxOutOfPocket || 'N/A'}</span>
        </div>
      </div>
    `).join('');

    container.innerHTML = `
      <div class="mb-6">
        <h2 class="text-2xl font-bold text-slate-900">${result.summary.totalPlans} plans available</h2>
        <p class="text-slate-600">in ${result.location.state}, zip ${result.location.zip}</p>
      </div>

      ${subsidyHtml}

      <div class="space-y-4 mb-6">
        ${plansHtml}
      </div>

      <div class="bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-xs text-slate-600 space-y-1">
        <p><strong>Disclaimer:</strong> ${result.compliance.automationDisclosure}</p>
        <p>${result.compliance.agentReview}</p>
        ${result.compliance.subsidyDisclaimer ? `<p>${result.compliance.subsidyDisclaimer}</p>` : ''}
      </div>
    `;

    // Store plans for selection
    (window as any).__planResults = result;

    // Plan selection handlers
    container.querySelectorAll('.plan-card').forEach(card => {
      card.addEventListener('click', () => {
        const idx = parseInt(card.getAttribute('data-plan-index') || '0');
        selectPlan(idx);
      });
    });
  }

  function metalColor(level: string): string {
    const colors: Record<string, string> = {
      'Bronze': 'bg-amber-100 text-amber-800',
      'Silver': 'bg-slate-200 text-slate-700',
      'Gold': 'bg-yellow-100 text-yellow-800',
      'Platinum': 'bg-purple-100 text-purple-800',
      'Catastrophic': 'bg-red-100 text-red-700',
      'Expanded Bronze': 'bg-amber-50 text-amber-700',
    };
    return colors[level] || 'bg-slate-100 text-slate-700';
  }

  function selectPlan(index: number) {
    const result = (window as any).__planResults;
    if (!result?.plans?.[index]) return;

    const plan = result.plans[index];
    (window as any).__selectedPlan = plan;

    showStep(4);
    renderEnrollmentStep(plan, result);
  }

  function renderEnrollmentStep(plan: any, result: any) {
    const container = document.getElementById('enrollment-container');
    if (!container) return;

    container.innerHTML = `
      <h2 class="text-2xl font-bold text-slate-900 mb-2">Confirm Your Selection</h2>
      <p class="text-slate-600 mb-6">Review your plan choice and provide consent. A licensed agent will verify before enrollment.</p>

      <div class="bg-brand-50 border border-brand-200 rounded-xl p-5 mb-6">
        <h3 class="font-semibold text-slate-900">${plan.planName}</h3>
        <p class="text-sm text-slate-600">${plan.issuerName} • ${plan.metalLevel} ${plan.planType}</p>
        <p class="mt-2 text-lg font-bold text-brand-700">
          ${plan.estimatedNetPremium !== null
            ? `$${plan.estimatedNetPremium.toFixed(2)}/mo estimated after subsidy`
            : `$${plan.monthlyPremium?.toFixed(2)}/mo`
          }
        </p>
      </div>

      <form id="enrollment-form" class="grid gap-5">
        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Full Legal Name <span class="text-red-500">*</span></span>
          <input type="text" name="signerName" required placeholder="As it appears on your ID"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none" />
        </label>

        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Email Address <span class="text-red-500">*</span></span>
          <input type="email" name="signerEmail" required placeholder="you@example.com"
            class="rounded-lg border border-slate-300 px-4 py-3 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none" />
        </label>

        <!-- Consent Block -->
        <div class="border border-slate-300 rounded-lg p-4 bg-slate-50">
          <h4 class="font-medium text-slate-900 mb-2">Consent & Authorization</h4>
          <div class="text-sm text-slate-700 space-y-2 max-h-40 overflow-y-auto pr-2" id="consent-text-display">
            <p>I understand that:</p>
            <ol class="list-decimal list-inside space-y-1">
              <li>This plan recommendation was generated by an automated system using publicly available data.</li>
              <li>A licensed insurance professional will review my selection before any enrollment is processed.</li>
              <li>I will not be enrolled in any plan without additional confirmation from a licensed agent.</li>
              <li>The premium and cost estimates shown are approximate and subject to final verification.</li>
              <li>I consent to being contacted by Legacy Financial & Life regarding this plan selection via email and phone.</li>
            </ol>
          </div>
        </div>

        <!-- Signature -->
        <label class="grid gap-1">
          <span class="text-sm font-medium text-slate-700">Type Your Signature <span class="text-red-500">*</span></span>
          <input type="text" name="signature" required placeholder="Type your full name as signature"
            style="font-family: 'Brush Script MT', cursive; font-size: 1.5rem;"
            class="rounded-lg border border-slate-300 px-4 py-4 transition-all hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none" />
          <p class="text-xs text-slate-500">By typing your name above, you acknowledge you have read and agree to the consent statement.</p>
        </label>

        <div class="flex gap-3">
          <button type="button" id="back-to-results"
            class="rounded-lg border border-slate-300 px-6 py-3 font-medium text-slate-700 hover:bg-slate-50 transition-colors">
            ← Back to Plans
          </button>
          <button type="submit" id="submit-enrollment"
            class="flex-1 rounded-lg bg-green-600 hover:bg-green-700 text-white px-6 py-4 font-semibold text-lg transition-all shadow-md hover:shadow-lg">
            Submit for Agent Review
          </button>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-lg px-4 py-3 text-xs text-blue-800">
          <strong>What happens next:</strong> Your selection is sent to a licensed agent for review. You'll receive an email confirmation once reviewed (typically same business day). No charges occur until the agent confirms enrollment with you.
        </div>
      </form>
    `;

    // Back button
    document.getElementById('back-to-results')?.addEventListener('click', () => showStep(3));

    // Enrollment form submission
    document.getElementById('enrollment-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const btn = document.getElementById('submit-enrollment') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Submitting…'; }

      const consentText = document.getElementById('consent-text-display')?.textContent || '';

      try {
        // First, create the quote session
        const sessionResp = await fetch('/api/plan-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ...steps.data,
            name: fd.get('signerName'),
            email: fd.get('signerEmail'),
            plan: plan,
          }),
        });
        const session = await sessionResp.json();

        if (!session.sessionId) throw new Error('Failed to create session');

        // Then submit signature
        const signResp = await fetch('/api/enrollment-sign', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            sessionId: session.sessionId,
            selectionId: session.selectionId,
            signerName: fd.get('signerName'),
            signerEmail: fd.get('signerEmail'),
            consentText,
            signatureData: fd.get('signature'),
            signatureType: 'typed',
          }),
        });
        const signResult = await signResp.json();

        if (signResult.success) {
          renderSuccessState();
        } else {
          throw new Error(signResult.error || 'Signature submission failed');
        }
      } catch (err: any) {
        if (btn) { btn.disabled = false; btn.textContent = 'Submit for Agent Review'; }
        alert(`Something went wrong: ${err.message}. Please try again or contact us.`);
      }
    });
  }

  function renderSuccessState() {
    const container = document.getElementById('enrollment-container');
    if (!container) return;
    container.innerHTML = `
      <div class="text-center py-12">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-slate-900 mb-3">Submitted for Review!</h2>
        <p class="text-slate-600 max-w-md mx-auto mb-6">
          Your plan selection and consent have been recorded. A licensed agent will review your choice and reach out to confirm — typically within the same business day.
        </p>
        <div class="bg-slate-50 border border-slate-200 rounded-lg px-6 py-4 text-sm text-slate-700 text-left max-w-sm mx-auto">
          <p class="font-medium mb-2">You'll receive:</p>
          <ul class="space-y-1">
            <li>✓ Email confirmation of your submission</li>
            <li>✓ Agent follow-up within 1 business day</li>
            <li>✓ No enrollment without your final confirmation</li>
          </ul>
        </div>
        <a href="/" class="mt-6 inline-block text-brand-600 font-medium hover:underline">← Return to homepage</a>
      </div>
    `;
  }

  async function submitT65Request() {
    const loading = document.getElementById('loading-state');
    const container = document.getElementById('results-container');
    if (!loading || !container) return;

    loading.innerHTML = `
      <div class="animate-spin h-10 w-10 border-4 border-brand-200 border-t-brand-600 rounded-full mx-auto"></div>
      <p class="mt-4 text-slate-600">Submitting your Medicare review request…</p>
    `;
    loading.classList.remove('hidden');
    container.classList.add('hidden');

    try {
      await fetch('/api/plan-session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          ...steps.data,
          pathway: 'medicare',
        }),
      });

      loading.classList.add('hidden');
      container.classList.remove('hidden');
      container.innerHTML = `
        <div class="text-center py-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-900 mb-3">We've Got Your Information!</h2>
          <p class="text-slate-600 max-w-md mx-auto">
            A licensed Medicare specialist will review plans in your area and reach out with personalized recommendations.
            Expect to hear from us within 1 business day.
          </p>
        </div>
      `;
    } catch {
      loading.classList.add('hidden');
      container.classList.remove('hidden');
      container.innerHTML = `
        <div class="text-center py-8">
          <p class="text-red-600 font-medium">Something went wrong. Please <a href="/book" class="underline">schedule a call</a> instead.</p>
        </div>
      `;
    }
  }
</script>
