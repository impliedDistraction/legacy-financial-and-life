---
import Base from '../layouts/Base.astro';
import { site } from '../content/site';
import '../styles/tailwind.css';

const licensedStates = 'Ohio, Georgia, Oklahoma, South Carolina, Mississippi, Michigan, Texas, Utah, Alabama, and Louisiana';
---

<Base title="Quote Submission Error — Legacy Financial & Life" description="There was an issue submitting your quote request. Please try again.">
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-200">
    <div class="mx-auto max-w-6xl flex items-center justify-between gap-4 px-4 py-3">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="flex-shrink-0" aria-label="Legacy Financial & Life home">
          <img src={site.branding.logo} alt={site.branding.logoAlt} class="h-10 w-10 object-contain" width="40" height="40" />
        </a>
        <img src="/images/fb-crest-logo.jpeg" alt="Lifetime Safeguard logo" class="h-10 w-10 flex-shrink-0 object-contain" width="40" height="40" />
      </div>
      <span class="text-sm font-medium text-brand-600">Quote Submission Issue</span>
    </div>
  </header>

  <div class="min-h-[80vh] bg-gradient-to-br from-red-50 to-white flex items-center justify-center px-4">
    <div class="max-w-2xl text-center py-20">
      <div class="w-24 h-24 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-12 h-12 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 15.5c-.77.833.192 2.5 1.732 2.5z"></path>
        </svg>
      </div>

      <h1 class="text-4xl font-bold text-slate-900 mb-4">We Couldn't Submit That Yet</h1>
      <p class="text-xl text-slate-700 mb-8">
        There was an issue sending your quote request. Please try again and we'll pick it up from there.
      </p>

      <div class="bg-white rounded-xl border border-slate-200 p-6 mb-8 shadow-lg text-left">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">What to do next</h2>
        <div class="space-y-3">
          <div class="flex items-start space-x-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-sm font-medium text-brand-700">1</span>
            <p class="text-slate-700">Go back to the quote form and submit it again.</p>
          </div>
          <div class="flex items-start space-x-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-sm font-medium text-brand-700">2</span>
            <p class="text-slate-700">Double-check your email address and phone number before sending.</p>
          </div>
          <div class="flex items-start space-x-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-sm font-medium text-brand-700">3</span>
            <p class="text-slate-700">Once it goes through, we'll follow up with the next step.</p>
          </div>
        </div>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-8">
        <p class="text-amber-800 text-sm">
          <strong>Licensed states:</strong> {licensedStates}
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/free-quote#quote-form"
          class="rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 font-semibold transition-colors"
        >
          Try Again
        </a>
        <a
          href="/"
          class="rounded-lg border border-brand-600 text-brand-600 hover:bg-brand-50 px-6 py-3 font-semibold transition-colors"
        >
          Return Home
        </a>
      </div>
    </div>
  </div>

  <footer class="bg-slate-900 text-slate-400 py-8">
    <div class="mx-auto max-w-6xl px-4 text-center text-sm space-y-2">
      <p>&copy; {new Date().getFullYear()} Legacy Financial & Life. All rights reserved.</p>
      <p>Licensed in {licensedStates}. Policies and features vary by carrier and state.</p>
      <p><a href="/privacy" class="underline hover:text-white transition-colors">Privacy Policy</a></p>
    </div>
  </footer>
</Base>