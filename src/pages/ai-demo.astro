  // ═══════════════════════════════════════════
  // SCOUT — Post analysis + draft generation
  // ═══════════════════════════════════════════
  interface QueueItem {
    id: string;
    postSnippet: string;
    groupName: string;
    draftText: string;
    editedText?: string;
    tone: string;
    score: number;
    risk: string;
    rationale: string;
    approach: string;
    status: 'pending' | 'approved' | 'rejected' | 'posted';
    createdAt: string;
    updatedAt: string;
  }

  const QUEUE_KEY = 'legacy_scout_queue';

  function loadQueue(): QueueItem[] {
    try {
      return JSON.parse(localStorage.getItem(QUEUE_KEY) || '[]');
    } catch { return []; }
  }

  function saveQueue(queue: QueueItem[]) {
    localStorage.setItem(QUEUE_KEY, JSON.stringify(queue));
    updateQueueBadge();
    renderQueue();
  }

  function updateQueueBadge() {
    const queue = loadQueue();
    const pending = queue.filter(q => q.status === 'pending').length;
    const badge = document.getElementById('queue-badge');
    if (badge) {
      if (pending > 0) {
        badge.textContent = String(pending);
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }
  }

  // Scout form
  const scoutPostInput = document.getElementById('scout-post-input') as HTMLTextAreaElement;
  const scoutGroupInput = document.getElementById('scout-group-input') as HTMLInputElement;
  const scoutAuthorInput = document.getElementById('scout-author-input') as HTMLInputElement;
  const scoutAnalyzeBtn = document.getElementById('scout-analyze-btn') as HTMLButtonElement;
  const scoutResults = document.getElementById('scout-results')!;

  scoutAnalyzeBtn.addEventListener('click', async () => {
    const postText = scoutPostInput.value.trim();
    if (postText.length < 10) return;

    scoutAnalyzeBtn.disabled = true;
    scoutAnalyzeBtn.textContent = '🔍 Analyzing…';
    scoutResults.innerHTML = `
      <div class="bg-white rounded-xl border border-gray-200 p-6 text-center">
        <div class="inline-flex gap-1 mb-2">
          <span class="typing-dot"></span>
          <span class="typing-dot"></span>
          <span class="typing-dot"></span>
        </div>
        <p class="text-sm text-gray-500">Analyzing engagement potential… This may take a moment.</p>
      </div>`;

    try {
      const res = await fetch('/api/ai-scout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          postText,
          groupName: scoutGroupInput.value.trim(),
          authorInfo: scoutAuthorInput.value.trim(),
        }),
      });

      const data = await res.json();

      if (data.error) {
        scoutResults.innerHTML = `
          <div class="bg-white rounded-xl border border-red-200 p-6">
            <p class="text-sm text-red-600">${escapeHtml(data.error)}</p>
            ${data.rawResponse ? `<pre class="text-xs text-gray-500 mt-2 whitespace-pre-wrap">${escapeHtml(data.rawResponse)}</pre>` : ''}
          </div>`;
        return;
      }

      const score: number = data.score || 0;
      const scoreColor = score >= 7 ? 'green' : score >= 4 ? 'amber' : 'red';
      const riskColor = data.risk === 'low' ? 'green' : data.risk === 'medium' ? 'amber' : 'red';
      const groupName = scoutGroupInput.value.trim();

      let html = `
        <!-- Score Card -->
        <div class="bg-white rounded-xl border border-gray-200 p-4">
          <div class="flex items-start gap-4">
            <div class="text-center">
              <div class="w-16 h-16 rounded-full border-4 border-${scoreColor}-400 flex items-center justify-center">
                <span class="text-2xl font-bold text-${scoreColor}-600">${score}</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">Score</p>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs px-2 py-0.5 rounded-full bg-${scoreColor}-100 text-${scoreColor}-700 font-medium">
                  ${score >= 7 ? 'Great opportunity' : score >= 4 ? 'Worth considering' : 'Low potential'}
                </span>
                <span class="text-xs px-2 py-0.5 rounded-full bg-${riskColor}-100 text-${riskColor}-700 font-medium">
                  ${data.risk} risk
                </span>
              </div>
              <p class="text-sm text-gray-800 mb-1">${escapeHtml(data.rationale || '')}</p>
              <p class="text-xs text-gray-500"><strong>Approach:</strong> ${escapeHtml(data.approach || '')}</p>
              ${data.meta ? `<p class="text-xs text-gray-400 mt-1">${data.meta.tokens} tokens · ${(data.meta.latencyMs / 1000).toFixed(1)}s</p>` : ''}
            </div>
          </div>
        </div>`;

      // Draft options
      if (data.drafts && data.drafts.length > 0) {
        html += `<h4 class="text-sm font-semibold text-gray-700 mt-2">Draft Replies</h4>`;
        data.drafts.forEach((draft: { text: string; tone: string; hasCta: boolean }, i: number) => {
          const draftId = `scout-draft-${Date.now()}-${i}`;
          html += `
            <div class="bg-white rounded-xl border border-gray-200 p-4" id="${draftId}">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs bg-brand-50 text-brand-700 px-2 py-0.5 rounded-full">Option ${i + 1}</span>
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">${escapeHtml(draft.tone)}</span>
                ${draft.hasCta ? '<span class="text-xs bg-purple-50 text-purple-600 px-2 py-0.5 rounded-full">has CTA</span>' : ''}
              </div>
              <p class="text-sm text-gray-800 whitespace-pre-wrap mb-3">${escapeHtml(draft.text)}</p>
              <div class="flex justify-end gap-2">
                <button class="scout-copy text-xs text-gray-500 hover:text-gray-700 px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50" data-text="${encodeURIComponent(draft.text)}">
                  📋 Copy
                </button>
                <button class="scout-reject text-xs text-red-500 hover:text-red-700 px-3 py-1.5 rounded-lg border border-red-200 hover:bg-red-50" data-text="${encodeURIComponent(draft.text)}" data-tone="${encodeURIComponent(draft.tone)}">
                  ✗ Skip
                </button>
                <button class="scout-approve text-xs text-white bg-green-600 hover:bg-green-700 px-3 py-1.5 rounded-lg font-medium" data-text="${encodeURIComponent(draft.text)}" data-tone="${encodeURIComponent(draft.tone)}" data-score="${score}" data-risk="${data.risk || ''}" data-rationale="${encodeURIComponent(data.rationale || '')}" data-approach="${encodeURIComponent(data.approach || '')}" data-group="${encodeURIComponent(groupName)}">
                  ✓ Send to Queue
                </button>
              </div>
            </div>`;
        });
      }

      scoutResults.innerHTML = html;

      // Wire up buttons
      scoutResults.querySelectorAll('.scout-copy').forEach(btn => {
        btn.addEventListener('click', () => {
          const text = decodeURIComponent((btn as HTMLElement).dataset.text || '');
          navigator.clipboard.writeText(text);
          btn.textContent = '✓ Copied!';
          setTimeout(() => { btn.textContent = '📋 Copy'; }, 2000);
        });
      });

      scoutResults.querySelectorAll('.scout-approve').forEach(btn => {
        btn.addEventListener('click', () => {
          const el = btn as HTMLElement;
          const item: QueueItem = {
            id: `q_${Date.now()}_${Math.random().toString(36).slice(2, 7)}`,
            postSnippet: postText.slice(0, 200),
            groupName: decodeURIComponent(el.dataset.group || ''),
            draftText: decodeURIComponent(el.dataset.text || ''),
            tone: decodeURIComponent(el.dataset.tone || ''),
            score: parseInt(el.dataset.score || '0'),
            risk: el.dataset.risk || 'unknown',
            rationale: decodeURIComponent(el.dataset.rationale || ''),
            approach: decodeURIComponent(el.dataset.approach || ''),
            status: 'pending',
            createdAt: new Date().toISOString(),
            updatedAt: new Date().toISOString(),
          };
          const queue = loadQueue();
          queue.unshift(item);
          saveQueue(queue);
          
          // Visual feedback
          const card = btn.closest('.bg-white');
          if (card) {
            card.classList.add('border-green-300', 'bg-green-50');
            const btns = card.querySelector('.flex.justify-end');
            if (btns) btns.innerHTML = '<span class="text-xs text-green-600 font-medium">✓ Added to Queue</span>';
          }
        });
      });

      scoutResults.querySelectorAll('.scout-reject').forEach(btn => {
        btn.addEventListener('click', () => {
          const el = btn as HTMLElement;
          // Track rejection
          fetch('/api/ai-approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              action: 'rejected',
              postSnippet: postText.slice(0, 200),
              draftText: decodeURIComponent(el.dataset.text || ''),
            }),
          }).catch(() => {});

          const card = btn.closest('.bg-white');
          if (card) {
            card.classList.add('opacity-40');
            const btns = card.querySelector('.flex.justify-end');
            if (btns) btns.innerHTML = '<span class="text-xs text-gray-400">Skipped</span>';
          }
        });
      });

    } catch {
      scoutResults.innerHTML = `
        <div class="bg-white rounded-xl border border-red-200 p-6 text-center">
          <p class="text-sm text-red-600">Failed to analyze post. The AI model may not be running.</p>
        </div>`;
    } finally {
      scoutAnalyzeBtn.disabled = false;
      scoutAnalyzeBtn.textContent = '🔍 Analyze Post';
    }
  });

  // ═══════════════════════════════════════════
  // QUEUE — Approval management
  // ═══════════════════════════════════════════
  const queueItems = document.getElementById('queue-items')!;
  const queueFilter = document.getElementById('queue-filter') as HTMLSelectElement;
  const queueClearBtn = document.getElementById('queue-clear-btn') as HTMLButtonElement;

  function renderQueue() {
    const queue = loadQueue();
    const filter = queueFilter.value;
    const filtered = filter === 'all' ? queue : queue.filter(q => q.status === filter);

    // Update stats
    const statPending = document.getElementById('stat-pending');
    const statApproved = document.getElementById('stat-approved');
    const statPosted = document.getElementById('stat-posted');
    const statRejected = document.getElementById('stat-rejected');
    if (statPending) statPending.textContent = String(queue.filter(q => q.status === 'pending').length);
    if (statApproved) statApproved.textContent = String(queue.filter(q => q.status === 'approved').length);
    if (statPosted) statPosted.textContent = String(queue.filter(q => q.status === 'posted').length);
    if (statRejected) statRejected.textContent = String(queue.filter(q => q.status === 'rejected').length);

    if (filtered.length === 0) {
      queueItems.innerHTML = `
        <div class="bg-white rounded-xl border border-gray-200 p-8 text-center text-gray-400">
          <p class="text-sm">${filter === 'all' ? 'No items in queue yet.' : `No ${filter} items.`}</p>
          <p class="text-xs mt-1">Use the Scout tab to analyze posts and send drafts here.</p>
        </div>`;
      return;
    }

    queueItems.innerHTML = filtered.map(item => {
      const statusColors: Record<string, string> = {
        pending: 'bg-amber-100 text-amber-700',
        approved: 'bg-green-100 text-green-700',
        rejected: 'bg-gray-100 text-gray-500',
        posted: 'bg-blue-100 text-blue-700',
      };
      const scoreColor = item.score >= 7 ? 'text-green-600' : item.score >= 4 ? 'text-amber-600' : 'text-red-600';
      const ago = getTimeAgo(item.createdAt);

      return `
        <div class="bg-white rounded-xl border border-gray-200 p-4" data-queue-id="${item.id}">
          <div class="flex items-start justify-between gap-3 mb-2">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="text-xs px-2 py-0.5 rounded-full ${statusColors[item.status]} font-medium">${item.status}</span>
              <span class="text-xs ${scoreColor} font-bold">Score: ${item.score}/10</span>
              ${item.groupName ? `<span class="text-xs text-gray-400">${escapeHtml(item.groupName)}</span>` : ''}
            </div>
            <span class="text-xs text-gray-400 whitespace-nowrap">${ago}</span>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-2 mb-2">
            <p class="text-xs text-gray-500 mb-0.5">Original post:</p>
            <p class="text-xs text-gray-700 italic">"${escapeHtml(item.postSnippet)}"</p>
          </div>

          <div class="border-l-2 border-brand-200 pl-3 mb-3">
            <p class="text-xs text-brand-600 font-medium mb-0.5">Draft reply (${escapeHtml(item.tone)}):</p>
            ${item.status === 'pending' 
              ? `<textarea class="queue-edit-area w-full text-sm text-gray-800 p-2 border border-gray-200 rounded-lg resize-none focus:outline-none focus:ring-2 focus:ring-brand-500" rows="3" data-id="${item.id}">${escapeHtml(item.editedText || item.draftText)}</textarea>`
              : `<p class="text-sm text-gray-800 whitespace-pre-wrap">${escapeHtml(item.editedText || item.draftText)}</p>`
            }
          </div>

          <div class="text-xs text-gray-400 mb-3">
            <strong>Rationale:</strong> ${escapeHtml(item.rationale)} · <strong>Approach:</strong> ${escapeHtml(item.approach)}
          </div>

          <div class="flex justify-end gap-2">
            ${item.status === 'pending' ? `
              <button class="queue-reject text-xs text-red-500 hover:text-red-700 px-3 py-1.5 rounded-lg border border-red-200 hover:bg-red-50" data-id="${item.id}">
                ✗ Reject
              </button>
              <button class="queue-approve text-xs text-white bg-green-600 hover:bg-green-700 px-3 py-1.5 rounded-lg font-medium" data-id="${item.id}">
                ✓ Approve
              </button>
            ` : ''}
            ${item.status === 'approved' ? `
              <button class="queue-copy text-xs text-gray-500 hover:text-gray-700 px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50" data-id="${item.id}">
                📋 Copy Reply
              </button>
              <button class="queue-posted text-xs text-white bg-blue-600 hover:bg-blue-700 px-3 py-1.5 rounded-lg font-medium" data-id="${item.id}">
                ✓ Mark as Posted
              </button>
            ` : ''}
            ${item.status === 'posted' || item.status === 'rejected' ? `
              <button class="queue-remove text-xs text-gray-400 hover:text-gray-600 px-3 py-1.5" data-id="${item.id}">
                Remove
              </button>
            ` : ''}
          </div>
        </div>`;
    }).join('');

    // Wire up queue action buttons
    queueItems.querySelectorAll('.queue-approve').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        updateQueueItem(id, 'approved');
      });
    });

    queueItems.querySelectorAll('.queue-reject').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        updateQueueItem(id, 'rejected');
      });
    });

    queueItems.querySelectorAll('.queue-posted').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        updateQueueItem(id, 'posted');
      });
    });

    queueItems.querySelectorAll('.queue-copy').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        const queue = loadQueue();
        const item = queue.find(q => q.id === id);
        if (item) {
          navigator.clipboard.writeText(item.editedText || item.draftText);
          btn.textContent = '✓ Copied!';
          setTimeout(() => { btn.textContent = '📋 Copy Reply'; }, 2000);
        }
      });
    });

    queueItems.querySelectorAll('.queue-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        const queue = loadQueue().filter(q => q.id !== id);
        saveQueue(queue);
      });
    });

    // Save edits on blur for pending items
    queueItems.querySelectorAll('.queue-edit-area').forEach(textarea => {
      textarea.addEventListener('blur', () => {
        const id = (textarea as HTMLElement).dataset.id!;
        const newText = (textarea as HTMLTextAreaElement).value;
        const queue = loadQueue();
        const item = queue.find(q => q.id === id);
        if (item && newText !== item.draftText) {
          item.editedText = newText;
          item.updatedAt = new Date().toISOString();
          saveQueue(queue);
        }
      });
    });
  }

  function updateQueueItem(id: string, newStatus: QueueItem['status']) {
    const queue = loadQueue();
    const item = queue.find(q => q.id === id);
    if (!item) return;

    // If pending, grab edited text from textarea
    if (item.status === 'pending') {
      const textarea = document.querySelector(`.queue-edit-area[data-id="${id}"]`) as HTMLTextAreaElement | null;
      if (textarea && textarea.value !== item.draftText) {
        item.editedText = textarea.value;
      }
    }

    item.status = newStatus;
    item.updatedAt = new Date().toISOString();
    saveQueue(queue);

    // Track to server
    fetch('/api/ai-approve', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: newStatus,
        postSnippet: item.postSnippet,
        draftText: item.draftText,
        editedText: item.editedText,
        score: item.score,
        groupName: item.groupName,
      }),
    }).catch(() => {});
  }

  function getTimeAgo(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'just now';
    if (mins < 60) return `${mins}m ago`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `${hours}h ago`;
    return `${Math.floor(hours / 24)}d ago`;
  }

  queueFilter.addEventListener('change', renderQueue);

  queueClearBtn.addEventListener('click', () => {
    if (confirm('Clear all queue items? This cannot be undone.')) {
      saveQueue([]);
    }
  });

  // Initial render
  updateQueueBadge();
  renderQueue();

  // ═══════════════════════════════════════════
  // FEEDBACK (shared logic for both panels)
  // ═══════════════════════════════════════════
  function setupFeedback(
    containerId: string,
    starsId: string,
    textId: string,
    submitId: string,
    section: string
  ) {
    const container = document.getElementById(containerId)!;
    const starsEl = document.getElementById(starsId)!;
    const textEl = document.getElementById(textId) as HTMLTextAreaElement;
    const submitEl = document.getElementById(submitId) as HTMLButtonElement;
    let selectedRating = 0;

    starsEl.querySelectorAll('.star-btn').forEach(star => {
      star.addEventListener('click', () => {
        selectedRating = parseInt((star as HTMLElement).dataset.rating || '0');
        starsEl.querySelectorAll('.star-btn').forEach((s, i) => {
          s.classList.toggle('selected', i < selectedRating);
        });
        submitEl.disabled = false;
      });
    });

    submitEl.addEventListener('click', async () => {
      if (!selectedRating) return;
      submitEl.disabled = true;
      submitEl.textContent = 'Sending…';

      try {
        await fetch('/api/ai-feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            rating: selectedRating,
            comment: textEl.value,
            section,
            page: '/ai-demo',
          }),
        });
        submitEl.textContent = '✓ Thank you!';
        submitEl.className = submitEl.className.replace('bg-gray-100 text-gray-600', 'bg-green-100 text-green-700');
      } catch {
        submitEl.textContent = 'Error — try again';
        submitEl.disabled = false;
      }
    });
  }

  setupFeedback('chat-feedback-panel', 'chat-stars', 'chat-feedback-text', 'chat-feedback-submit', 'messenger-chat');
  setupFeedback('comment-feedback-panel', 'comment-stars', 'comment-feedback-text', 'comment-feedback-submit', 'comment-drafts');
</script>

</Base>
