  // COMMENT DRAFTS
  // ═══════════════════════════════════════════
  const commentsInput = document.getElementById('comments-input') as HTMLTextAreaElement;
  const commentsCount = document.getElementById('comments-count')!;
  const generateBtn = document.getElementById('generate-drafts-btn') as HTMLButtonElement;
  const draftResults = document.getElementById('draft-results')!;

  commentsInput.addEventListener('input', () => {
    const lines = commentsInput.value.split('\n').filter(l => l.trim());
    commentsCount.textContent = `${lines.length} comment${lines.length !== 1 ? 's' : ''}`;
  });

  generateBtn.addEventListener('click', async () => {
    const lines = commentsInput.value.split('\n').filter(l => l.trim());
    if (lines.length === 0) return;

    generateBtn.disabled = true;
    generateBtn.textContent = 'Generating…';
    draftResults.innerHTML = `
      <div class="bg-white rounded-xl border border-gray-200 p-6 text-center">
        <div class="inline-flex gap-1 mb-2">
          <span class="typing-dot"></span>
          <span class="typing-dot"></span>
          <span class="typing-dot"></span>
        </div>
        <p class="text-sm text-gray-500">Generating ${lines.length} draft${lines.length !== 1 ? 's' : ''}… This may take a moment.</p>
      </div>`;

    try {
      const res = await fetch('/api/ai-comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ comments: lines.slice(0, 10) }),
      });

      const data = await res.json();
      draftResults.innerHTML = '';

      if (data.results) {
        data.results.forEach((r: { comment: string; draft: string; error?: boolean }, i: number) => {
          const card = document.createElement('div');
          card.className = 'bg-white rounded-xl border border-gray-200 p-4';
          card.innerHTML = `
            <div class="flex items-start gap-3 mb-3">
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full font-medium mt-0.5">${i + 1}</span>
              <div>
                <p class="text-xs text-gray-500 mb-1">Original Comment:</p>
                <p class="text-sm text-gray-800 italic">"${escapeHtml(r.comment)}"</p>
              </div>
            </div>
            <div class="ml-7 pl-3 border-l-2 ${r.error ? 'border-red-200' : 'border-brand-200'}">
              <p class="text-xs ${r.error ? 'text-red-500' : 'text-brand-600'} mb-1 font-medium">Draft Reply:</p>
              <p class="text-sm text-gray-800 whitespace-pre-wrap">${escapeHtml(r.draft)}</p>
            </div>
            <div class="flex justify-end mt-3 gap-2">
              <button class="copy-draft text-xs text-gray-500 hover:text-gray-700 px-2 py-1" data-draft="${encodeURIComponent(r.draft)}">
                📋 Copy
              </button>
            </div>`;
          draftResults.appendChild(card);
        });

        // Copy functionality
        draftResults.querySelectorAll('.copy-draft').forEach(btn => {
          btn.addEventListener('click', () => {
            const draft = decodeURIComponent((btn as HTMLElement).dataset.draft || '');
            navigator.clipboard.writeText(draft);
