---
/**
 * /t65-heatmap — T65 (Turning 65) population heatmap.
 *
 * Interactive visualization showing T65 density by state and top zip hotspots.
 * Helps agents quickly identify high-opportunity areas for campaigns/surveys.
 *
 * Protected by the same magic-link auth as /recruitment.
 */
import Base from '../layouts/Base.astro';
import '../styles/tailwind.css';
import { verifySessionCookie } from '../lib/ai-demo-auth';

export const prerender = false;

const session = await verifySessionCookie(Astro.request.headers.get('cookie'));
if (!session) {
  return Astro.redirect('/ai-demo-login?redirect=/t65-heatmap', 302);
}
---
<Base title="T65 Heatmap — Legacy Financial & Life" description="Turning-65 population density heatmap">

<div class="bg-gray-50 min-h-screen">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-30">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-amber-600 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
        </div>
        <div>
          <h1 class="text-sm font-bold text-gray-900">T65 Heatmap</h1>
          <p class="text-xs text-gray-500">Turning-65 Population Density</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <a href="/recruitment" class="text-xs text-brand-600 hover:text-brand-700 font-medium">← Recruitment</a>
      </div>
    </div>
  </header>

  <!-- Loading State -->
  <div id="loading" class="flex items-center justify-center py-20">
    <div class="text-center">
      <div class="animate-spin w-8 h-8 border-2 border-amber-600 border-t-transparent rounded-full mx-auto mb-3"></div>
      <p class="text-sm text-gray-500">Loading T65 data…</p>
    </div>
  </div>

  <!-- Main Content -->
  <div id="content" class="hidden max-w-7xl mx-auto px-4 py-6">
    <!-- Summary Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-white rounded-lg border border-gray-200 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide">States Tracked</p>
        <p id="stat-states" class="text-2xl font-bold text-gray-900 mt-1">—</p>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Total T65 Pop</p>
        <p id="stat-total" class="text-2xl font-bold text-gray-900 mt-1">—</p>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Highest Density</p>
        <p id="stat-density" class="text-2xl font-bold text-amber-600 mt-1">—</p>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Top Hotspot</p>
        <p id="stat-hotspot" class="text-2xl font-bold text-gray-900 mt-1">—</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Map Column -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-lg border border-gray-200 p-4">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-semibold text-gray-900">State T65 Density</h2>
            <div class="flex items-center gap-2 text-xs text-gray-500">
              <span class="inline-block w-3 h-3 rounded" style="background: #fef3c7"></span>Low
              <span class="inline-block w-3 h-3 rounded" style="background: #f59e0b"></span>Med
              <span class="inline-block w-3 h-3 rounded" style="background: #b45309"></span>High
            </div>
          </div>
          <!-- US Tile Grid Map -->
          <div id="map-container" class="relative">
            <div id="tile-map" class="grid gap-1" style="grid-template-columns: repeat(11, 1fr); grid-template-rows: repeat(8, 1fr);">
              <!-- Tiles are positioned by JS based on standard tile grid coordinates -->
            </div>
            <!-- Tooltip -->
            <div id="tooltip" class="hidden absolute bg-gray-900 text-white text-xs rounded-lg px-3 py-2 pointer-events-none shadow-lg z-10">
            </div>
          </div>
          <p class="text-xs text-gray-400 mt-3 text-center">Click a state to see top zip codes. Colored states have T65 data.</p>
        </div>
      </div>

      <!-- State Ranking -->
      <div>
        <div class="bg-white rounded-lg border border-gray-200 p-4">
          <h2 class="text-sm font-semibold text-gray-900 mb-3">State Rankings</h2>
          <div id="state-rankings" class="space-y-2">
            <!-- populated by JS -->
          </div>
        </div>
      </div>
    </div>

    <!-- County Expansion Panel (appears when state is selected) -->
    <div id="county-panel" class="hidden mt-6 bg-white rounded-lg border border-amber-200 p-4">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-gray-900">
          <span id="county-title">County Rankings</span>
        </h2>
        <div class="flex items-center gap-2">
          <select id="county-sort" class="text-xs border border-gray-200 rounded px-2 py-1">
            <option value="opportunityScore">Opportunity Score</option>
            <option value="density">T65 Density %</option>
            <option value="t65Pop">T65 Population</option>
          </select>
          <button id="county-close" class="text-xs text-gray-400 hover:text-gray-600">✕ Close</button>
        </div>
      </div>
      <div id="county-list" class="space-y-2">
        <!-- populated by JS -->
      </div>
      <div class="mt-3 text-center">
        <button id="county-show-more" class="text-xs text-amber-600 hover:text-amber-700 font-medium hidden">Show more counties →</button>
      </div>
    </div>

    <!-- Hotspot Table -->
    <div class="mt-6 bg-white rounded-lg border border-gray-200 p-4">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-gray-900">
          <span id="hotspot-title">Top Hotspot Zip Codes</span>
        </h2>
        <div class="flex items-center gap-2">
          <select id="state-filter" class="text-xs border border-gray-200 rounded px-2 py-1">
            <option value="all">All States</option>
          </select>
          <select id="sort-by" class="text-xs border border-gray-200 rounded px-2 py-1">
            <option value="opportunityScore">Opportunity Score</option>
            <option value="density">T65 Density %</option>
            <option value="t65Pop">T65 Population</option>
          </select>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b border-gray-100 text-left text-gray-500 uppercase tracking-wide">
              <th class="pb-2 pr-3">#</th>
              <th class="pb-2 pr-3">Zip</th>
              <th class="pb-2 pr-3">State</th>
              <th class="pb-2 pr-3 text-right">Total Pop</th>
              <th class="pb-2 pr-3 text-right">T65 Pop</th>
              <th class="pb-2 pr-3 text-right">Density</th>
              <th class="pb-2 text-right">Score</th>
            </tr>
          </thead>
          <tbody id="hotspot-table">
            <!-- populated by JS -->
          </tbody>
        </table>
      </div>
      <div id="table-footer" class="mt-3 flex items-center justify-between text-xs text-gray-500">
        <span id="showing-count"></span>
        <button id="show-more" class="text-amber-600 hover:text-amber-700 font-medium hidden">Show more →</button>
      </div>
    </div>

    <!-- Voter Roll Section (if data available) -->
    <div id="voter-section" class="hidden mt-6 bg-white rounded-lg border border-gray-200 p-4">
      <h2 class="text-sm font-semibold text-gray-900 mb-3">
        🗳️ Voter Roll T65 Data <span class="text-xs font-normal text-gray-500">(individual-level, higher accuracy)</span>
      </h2>
      <div id="voter-content"></div>
    </div>

    <!-- Data freshness -->
    <p id="freshness" class="text-xs text-gray-400 mt-4 text-center"></p>
  </div>
</div>

<style>
  .state-tile {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    cursor: default;
    transition: transform 0.1s, box-shadow 0.1s;
    border: 1px solid transparent;
  }
  .state-tile.has-data {
    cursor: pointer;
    border-color: rgba(0,0,0,0.1);
  }
  .state-tile.has-data:hover {
    transform: scale(1.08);
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    z-index: 5;
  }
  .state-tile.selected {
    box-shadow: 0 0 0 2px #1f2937;
    transform: scale(1.05);
  }
  .county-row {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 12px;
    transition: border-color 0.15s;
  }
  .county-row:hover {
    border-color: #f59e0b;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }
  .action-btn:hover {
    transform: scale(1.03);
  }
  .action-recruit { background: #dbeafe; color: #1d4ed8; }
  .action-recruit:hover { background: #bfdbfe; }
  .action-quote { background: #d1fae5; color: #065f46; }
  .action-quote:hover { background: #a7f3d0; }
  .action-group { background: #fef3c7; color: #92400e; }
  .action-group:hover { background: #fde68a; }
  .action-survey { background: #ede9fe; color: #5b21b6; }
  .action-survey:hover { background: #ddd6fe; }
</style>

<script>
  // @ts-nocheck
  let allData = null;
  let visibleCount = 25;
  let selectedState = 'all';
  let countyVisible = 10;

  async function init() {
    try {
      const res = await fetch('/api/t65-data');
      if (!res.ok) throw new Error('Failed to load');
      allData = await res.json();
      render();
    } catch (err) {
      document.getElementById('loading').innerHTML =
        `<p class="text-red-600 text-sm">Failed to load T65 data. Is Sentinel running?</p>`;
    }
  }

  function render() {
    const { census, voter, counties } = allData;
    document.getElementById('loading').classList.add('hidden');
    document.getElementById('content').classList.remove('hidden');

    const states = census.states || {};
    const hotspots = census.topHotspots || [];
    const stateList = Object.entries(states).sort((a, b) => b[1].avgDensity - a[1].avgDensity);

    // Summary cards
    const totalT65 = stateList.reduce((s, [, v]) => s + v.totalT65, 0);
    const topDensityState = stateList[0];
    const topHotspot = hotspots[0];

    document.getElementById('stat-states').textContent = stateList.length.toString();
    document.getElementById('stat-total').textContent = totalT65.toLocaleString();
    document.getElementById('stat-density').textContent =
      topDensityState ? `${topDensityState[1].avgDensity}% (${topDensityState[0]})` : '—';
    document.getElementById('stat-hotspot').textContent =
      topHotspot ? `${topHotspot.zip} (${topHotspot.state})` : '—';

    // Color the map
    const densities = stateList.map(([, v]) => v.avgDensity);
    const minD = Math.min(...densities);
    const maxD = Math.max(...densities);

    // Build tile grid map
    const tilePositions = {
      ME:[10,0], VT:[9,1], NH:[10,1], WA:[1,2], MT:[2,2], ND:[3,2], MN:[4,2],
      WI:[5,2], MI:[7,2], NY:[8,2], MA:[9,2], RI:[10,2], OR:[1,3], ID:[2,3],
      WY:[3,3], SD:[4,3], IA:[5,3], IL:[6,3], IN:[7,3], OH:[8,3], PA:[9,3],
      CT:[10,3], CA:[1,4], NV:[2,4], UT:[3,4], CO:[4,4], NE:[5,4], MO:[6,4],
      KY:[7,4], WV:[8,4], VA:[9,4], NJ:[10,4], AZ:[2,5], NM:[3,5], KS:[4,5],
      AR:[5,5], TN:[6,5], NC:[7,5], SC:[8,5], MD:[9,5], DE:[10,5], OK:[4,6],
      LA:[5,6], MS:[6,6], AL:[7,6], GA:[8,6], FL:[9,7], TX:[4,7], HI:[1,7],
      AK:[0,7]
    };
    const trackedStates = new Set(stateList.map(([c]) => c));
    const stateDataMap = Object.fromEntries(stateList);

    const tileContainer = document.getElementById('tile-map');
    const cells = {};
    for (let r = 0; r < 8; r++) {
      for (let c = 0; c < 11; c++) {
        const cell = document.createElement('div');
        cell.style.gridColumn = c + 1;
        cell.style.gridRow = r + 1;
        cells[`${c},${r}`] = cell;
        tileContainer.appendChild(cell);
      }
    }

    for (const [code, [col, row]] of Object.entries(tilePositions)) {
      const cell = cells[`${col},${row}`];
      if (!cell) continue;
      cell.classList.add('state-tile');
      cell.textContent = code;
      cell.setAttribute('data-state', code);

      if (trackedStates.has(code)) {
        const info = stateDataMap[code];
        const t = (info.avgDensity - minD) / (maxD - minD || 1);
        cell.style.background = densityColor(t);
        cell.style.color = t > 0.6 ? '#fff' : '#1f2937';
        cell.classList.add('has-data');
        cell.addEventListener('mouseenter', (e) => showTooltip(e, code, info));
        cell.addEventListener('mouseleave', hideTooltip);
        cell.addEventListener('click', () => selectState(code));
      } else {
        cell.style.background = '#f3f4f6';
        cell.style.color = '#9ca3af';
      }
    }

    // State rankings
    const rankHtml = stateList.map(([code, info], i) => {
      const t = (info.avgDensity - minD) / (maxD - minD || 1);
      return `
        <div class="flex items-center gap-2 cursor-pointer hover:bg-gray-50 rounded px-2 py-1.5 -mx-2 transition-colors"
             onclick="selectState('${code}')">
          <span class="text-xs font-mono text-gray-400 w-4">${i + 1}</span>
          <span class="text-xs font-semibold text-gray-900 w-6">${code}</span>
          <div class="flex-1">
            <div class="w-full bg-gray-100 rounded-full h-1.5">
              <div class="h-1.5 rounded-full" style="width:${t * 100}%; background:${densityColor(t)}"></div>
            </div>
          </div>
          <span class="text-xs text-gray-600 w-16 text-right">${info.avgDensity}%</span>
          <span class="text-xs text-gray-400 w-20 text-right">${info.totalT65.toLocaleString()}</span>
        </div>`;
    }).join('');
    document.getElementById('state-rankings').innerHTML = rankHtml;

    // Populate filter
    const filter = document.getElementById('state-filter');
    for (const [code] of stateList) {
      const opt = document.createElement('option');
      opt.value = code;
      opt.textContent = code;
      filter.appendChild(opt);
    }
    filter.addEventListener('change', (e) => { selectedState = e.target.value; visibleCount = 25; renderTable(); });
    document.getElementById('sort-by').addEventListener('change', () => { renderTable(); });
    document.getElementById('show-more').addEventListener('click', () => { visibleCount += 25; renderTable(); });
    document.getElementById('county-sort').addEventListener('change', () => { countyVisible = 10; renderCountyPanel(); });
    document.getElementById('county-close').addEventListener('click', () => {
      document.getElementById('county-panel').classList.add('hidden');
      selectedState = 'all';
      document.querySelectorAll('.state-tile').forEach(el => el.classList.remove('selected'));
    });
    document.getElementById('county-show-more').addEventListener('click', () => { countyVisible += 10; renderCountyPanel(); });

    renderTable();

    // Voter roll section
    if (voter && voter.states && Object.keys(voter.states).length > 0) {
      document.getElementById('voter-section').classList.remove('hidden');
      let vHtml = '<div class="space-y-3">';
      for (const [st, info] of Object.entries(voter.states)) {
        vHtml += `
          <div class="border border-gray-100 rounded-lg p-3">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold">${st}</span>
              <span class="text-xs text-gray-500">${info.totalT65.toLocaleString()} T65 | ${info.imminent.toLocaleString()} imminent (&lt;6 mo)</span>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-2">
              ${(info.topZips || []).slice(0, 5).map(z => `
                <div class="bg-amber-50 rounded p-2 text-center">
                  <p class="text-xs font-bold text-amber-700">${z.zip}</p>
                  <p class="text-[10px] text-gray-600">${z.city || ''}</p>
                  <p class="text-[10px] text-amber-600">${z.count} T65 / ${z.imminent} imm.</p>
                </div>
              `).join('')}
            </div>
          </div>`;
      }
      vHtml += '</div>';
      document.getElementById('voter-content').innerHTML = vHtml;
    }

    // Freshness
    if (census.lastUpdated) {
      const d = new Date(census.lastUpdated);
      document.getElementById('freshness').textContent =
        `Data last updated: ${d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;
    }
  }

  function renderTable() {
    const hotspots = allData.census.topHotspots || [];
    const sortKey = document.getElementById('sort-by').value;
    let filtered = selectedState === 'all' ? [...hotspots] : hotspots.filter(h => h.state === selectedState);
    filtered.sort((a, b) => b[sortKey] - a[sortKey]);

    const showing = filtered.slice(0, visibleCount);
    const tbody = document.getElementById('hotspot-table');
    tbody.innerHTML = showing.map((h, i) => `
      <tr class="border-b border-gray-50 hover:bg-amber-50/50 transition-colors">
        <td class="py-2 pr-3 text-gray-400">${i + 1}</td>
        <td class="py-2 pr-3 font-mono font-medium text-gray-900">${h.zip}</td>
        <td class="py-2 pr-3"><span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold bg-gray-100 text-gray-700">${h.state}</span></td>
        <td class="py-2 pr-3 text-right text-gray-600">${h.totalPop.toLocaleString()}</td>
        <td class="py-2 pr-3 text-right font-medium text-gray-900">${h.t65Pop.toLocaleString()}</td>
        <td class="py-2 pr-3 text-right">
          <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold ${h.density > 20 ? 'bg-amber-100 text-amber-800' : h.density > 15 ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-700'}">
            ${h.density.toFixed(1)}%
          </span>
        </td>
        <td class="py-2 text-right font-bold text-amber-700">${h.opportunityScore.toFixed(0)}</td>
      </tr>
    `).join('');

    document.getElementById('showing-count').textContent =
      `Showing ${showing.length} of ${filtered.length} hotspots`;
    const btn = document.getElementById('show-more');
    if (filtered.length > visibleCount) btn.classList.remove('hidden');
    else btn.classList.add('hidden');

    document.getElementById('hotspot-title').textContent =
      selectedState === 'all' ? 'Top Hotspot Zip Codes' : `${selectedState} Hotspot Zip Codes`;
  }

  function renderCountyPanel() {
    if (selectedState === 'all') {
      document.getElementById('county-panel').classList.add('hidden');
      return;
    }

    const countyData = allData.counties?.states?.[selectedState];
    if (!countyData || !countyData.counties?.length) {
      document.getElementById('county-panel').classList.add('hidden');
      return;
    }

    document.getElementById('county-panel').classList.remove('hidden');
    document.getElementById('county-title').textContent = `${selectedState} County Rankings`;

    const sortKey = document.getElementById('county-sort').value;
    const sorted = [...countyData.counties].sort((a, b) => b[sortKey] - a[sortKey]);
    const showing = sorted.slice(0, countyVisible);

    const listEl = document.getElementById('county-list');
    listEl.innerHTML = showing.map((c, i) => `
      <div class="county-row">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="text-xs font-mono text-gray-400 w-5">${i + 1}</span>
            <span class="text-sm font-semibold text-gray-900">${c.county}</span>
            <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-100 text-amber-800 font-bold">${c.density}%</span>
          </div>
          <div class="text-right">
            <span class="text-xs text-gray-600">${c.t65Pop.toLocaleString()} T65</span>
            <span class="text-xs text-gray-400 ml-2">/ ${c.totalPop.toLocaleString()} total</span>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex-1 mr-4">
            <div class="w-full bg-gray-100 rounded-full h-1.5">
              <div class="h-1.5 rounded-full bg-amber-400" style="width:${Math.min(100, (c.opportunityScore / sorted[0].opportunityScore) * 100)}%"></div>
            </div>
          </div>
          <div class="flex items-center gap-1.5 flex-wrap justify-end">
            ${buildActions(c, selectedState)}
          </div>
        </div>
      </div>
    `).join('');

    const moreBtn = document.getElementById('county-show-more');
    if (sorted.length > countyVisible) moreBtn.classList.remove('hidden');
    else moreBtn.classList.add('hidden');
  }

  function buildActions(county, state) {
    const actions = [];
    const countyEnc = encodeURIComponent(county.county);
    const stateEnc = encodeURIComponent(state);

    // Recruitment campaign — target agents in this county
    actions.push(`
      <a href="/recruitment?action=new_campaign&state=${stateEnc}&county=${countyEnc}"
         class="action-btn action-recruit" title="Launch recruitment campaign targeting ${county.county} County agents">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Recruit
      </a>
    `);

    // Group insurance — target businesses (ALE applicable, 50+ employees)
    actions.push(`
      <a href="/group?src=heatmap&state=${stateEnc}&county=${countyEnc}"
         class="action-btn action-group" title="Target ${county.county} County businesses for group coverage">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        Group
      </a>
    `);

    // Free quote — consumer lead gen with county targeting via UTM
    actions.push(`
      <a href="/free-quote?utm_source=heatmap&utm_campaign=t65_${state.toLowerCase()}&utm_content=${countyEnc}"
         class="action-btn action-quote" title="Drive Medicare-eligible consumers in ${county.county} to get a quote">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Quote
      </a>
    `);

    // Survey — launch a survey campaign for this county's agents
    actions.push(`
      <a href="/recruitment?tab=surveys&action=new_survey&state=${stateEnc}&county=${countyEnc}"
         class="action-btn action-survey" title="Launch survey for ${county.county} County agents">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
        Survey
      </a>
    `);

    return actions.join('');
  }

  function selectState(code) {
    selectedState = code;
    visibleCount = 25;
    countyVisible = 10;
    document.getElementById('state-filter').value = code;

    // Highlight on map
    document.querySelectorAll('.state-tile').forEach(el => el.classList.remove('selected'));
    const el = document.querySelector(`.state-tile[data-state="${code}"]`);
    if (el) el.classList.add('selected');

    renderTable();
    renderCountyPanel();

    // Scroll to county panel
    setTimeout(() => {
      document.getElementById('county-panel').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  }
  window.selectState = selectState;

  function densityColor(t) {
    if (t < 0.25) return '#fef3c7';
    if (t < 0.5) return '#fcd34d';
    if (t < 0.75) return '#f59e0b';
    return '#b45309';
  }

  function showTooltip(e, code, info) {
    const tip = document.getElementById('tooltip');
    tip.innerHTML = `
      <strong>${code}</strong><br>
      T65 Pop: ${info.totalT65.toLocaleString()}<br>
      Density: ${info.avgDensity}%<br>
      Zips: ${info.zipCount}
    `;
    tip.classList.remove('hidden');
    const rect = document.getElementById('map-container').getBoundingClientRect();
    tip.style.left = (e.clientX - rect.left + 10) + 'px';
    tip.style.top = (e.clientY - rect.top - 40) + 'px';
  }

  function hideTooltip() {
    document.getElementById('tooltip').classList.add('hidden');
  }

  init();
</script>

</Base>
