---
/**
 * /analytics — internal lead‑flow analytics dashboard.
 *
 * Server‑rendered page protected by magic‑link auth.  Queries Supabase
 * lead_flow_events for aggregate stats and a recent‑events timeline, and
 * surfaces the active Vercel flag values so other teams can see what
 * configuration is live.
 */
import { verifySessionCookie, COOKIE_NAME } from '../../lib/analytics-auth';
import { resolveFlagValues } from '../../lib/flags';

export const prerender = false;

// ── auth gate ───────────────────────────────────────────────────────

const session = await verifySessionCookie(Astro.request.headers.get('cookie'));

if (!session) {
  return Astro.redirect('/analytics/login', 302);
}

// ── helpers ─────────────────────────────────────────────────────────

const supabaseUrl = import.meta.env.SUPABASE_URL?.trim();
const serviceRoleKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY?.trim();
const tableName = import.meta.env.SUPABASE_LEAD_ANALYTICS_TABLE?.trim() || 'lead_flow_events';

async function supabaseQuery<T>(path: string): Promise<T | null> {
  if (!supabaseUrl || !serviceRoleKey) return null;
  try {
    const res = await fetch(`${supabaseUrl}/rest/v1/${path}`, {
      headers: {
        apikey: serviceRoleKey,
        Authorization: `Bearer ${serviceRoleKey}`,
        'Content-Type': 'application/json',
      },
    });
    if (!res.ok) return null;
    return res.json() as Promise<T>;
  } catch {
    return null;
  }
}

type EventRow = {
  id: string;
  tracking_id: string;
  route: string;
  event_name: string;
  source: string;
  stage: string;
  status: string;
  owner_scope: string;
  lead_email: string | null;
  interest: string | null;
  provider: string | null;
  occurred_at: string;
  properties: Record<string, unknown>;
};

type CampaignScoreRow = {
  tracking_id: string;
  occurred_at: string;
  properties: Record<string, unknown>;
};

type CountRow = { stage: string; status: string; count: number };

// ── data fetching ───────────────────────────────────────────────────

const now = new Date();
const dayAgo = new Date(now.getTime() - 24 * 60 * 60 * 1000).toISOString();
const weekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000).toISOString();

// Recent events (last 50)
const recentEvents = await supabaseQuery<EventRow[]>(
  `${tableName}?select=id,tracking_id,route,event_name,source,stage,status,owner_scope,lead_email,interest,provider,occurred_at,properties&order=occurred_at.desc&limit=50`,
) ?? [];

const scoreEvents7d = await supabaseQuery<CampaignScoreRow[]>(
  `${tableName}?select=tracking_id,occurred_at,properties&event_name=eq.quote_lead_scored&occurred_at=gte.${encodeURIComponent(weekAgo)}&order=occurred_at.desc&limit=250`,
) ?? [];

// Stage counts (last 24h)
const stageCounts24h = await supabaseQuery<CountRow[]>(
  `rpc/lead_stage_counts?since=${encodeURIComponent(dayAgo)}`,
) ?? [];

// Stage counts (last 7d)
const stageCounts7d = await supabaseQuery<CountRow[]>(
  `rpc/lead_stage_counts?since=${encodeURIComponent(weekAgo)}`,
) ?? [];

// Total unique tracking IDs in the last 7 days
const uniqueLeads7d = await supabaseQuery<{ count: number }[]>(
  `${tableName}?select=tracking_id&occurred_at=gte.${encodeURIComponent(weekAgo)}&limit=0`,
) ?? [];

// Aggregate stats from simpler queries when the RPC doesn't exist
const totalEvents24h = recentEvents.filter(
  (e) => new Date(e.occurred_at).getTime() >= new Date(dayAgo).getTime(),
).length;

// Compute quick stats from fetched recent events
const successCount = recentEvents.filter((e) => e.status === 'success').length;
const errorCount = recentEvents.filter((e) => e.status === 'error').length;
const warningCount = recentEvents.filter((e) => e.status === 'warning').length;

function stageLabel(stage: string): string {
  const labels: Record<string, string> = {
    landing: 'Landing',
    form: 'Form Interaction',
    submission: 'Submission',
    contact_sync: 'Contact Sync',
    email: 'Email',
    webhook: 'Webhook',
    handoff: 'Handoff',
    error: 'Error',
  };
  return labels[stage] ?? stage;
}

function statusColor(status: string): string {
  switch (status) {
    case 'success': return '#16a34a';
    case 'error': return '#dc2626';
    case 'warning': return '#d97706';
    default: return '#3b82f6';
  }
}

function maskEmail(email: string | null): string {
  if (!email) return '—';
  const [local, domain] = email.split('@');
  if (!domain) return '***';
  return `${local.slice(0, 2)}***@${domain}`;
}

function relativeTime(iso: string): string {
  const diff = now.getTime() - new Date(iso).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  return `${days}d ago`;
}

const flagValues = resolveFlagValues();

// Compute lead quality stats from scored events
const scoredEvents = recentEvents.filter(e => e.event_name === 'quote_lead_scored' && typeof e.properties?.score === 'number');
const avgScore = scoredEvents.length > 0
  ? Math.round(scoredEvents.reduce((sum, e) => sum + (e.properties.score as number), 0) / scoredEvents.length)
  : null;
const hotLeads = scoredEvents.filter(e => (e.properties.tier as string) === 'hot').length;
const warmLeads = scoredEvents.filter(e => (e.properties.tier as string) === 'warm').length;
const coldLeads = scoredEvents.filter(e => (e.properties.tier as string) === 'cold').length;

const campaignStatsMap = new Map<string, {
  campaignKey: string;
  attributionSource: string;
  utmSource: string;
  utmMedium: string;
  utmCampaign: string;
  count: number;
  totalScore: number;
  hot: number;
  warm: number;
  cold: number;
}>();

for (const event of scoreEvents7d) {
  const score = typeof event.properties?.score === 'number'
    ? event.properties.score
    : typeof event.properties?.score === 'string'
      ? Number(event.properties.score)
      : null;

  if (score === null || Number.isNaN(score)) {
    continue;
  }

  const campaignKey = String(event.properties?.campaign_key ?? 'direct');
  const existing = campaignStatsMap.get(campaignKey) ?? {
    campaignKey,
    attributionSource: String(event.properties?.attribution_source ?? 'direct'),
    utmSource: String(event.properties?.utm_source ?? '—'),
    utmMedium: String(event.properties?.utm_medium ?? '—'),
    utmCampaign: String(event.properties?.utm_campaign ?? '—'),
    count: 0,
    totalScore: 0,
    hot: 0,
    warm: 0,
    cold: 0,
  };

  existing.count += 1;
  existing.totalScore += score;

  const tier = String(event.properties?.tier ?? 'cold');
  if (tier === 'hot') existing.hot += 1;
  else if (tier === 'warm') existing.warm += 1;
  else existing.cold += 1;

  campaignStatsMap.set(campaignKey, existing);
}

const campaignStats = Array.from(campaignStatsMap.values())
  .map((item) => ({
    ...item,
    averageScore: Math.round(item.totalScore / item.count),
  }))
  .sort((left, right) => right.count - left.count)
  .slice(0, 8);

// Build a map of tracking_id -> score/tier for annotating the events table
const scoreByTrackingId = new Map<string, { score: number; tier: string }>();
for (const e of scoredEvents) {
  scoreByTrackingId.set(e.tracking_id, {
    score: e.properties.score as number,
    tier: e.properties.tier as string,
  });
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lead Analytics — Legacy Financial & Life</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0}
    body{font-family:system-ui,-apple-system,sans-serif;background:#f1f5f9;color:#0f172a;padding:0}
    .topbar{background:#1e293b;color:#e2e8f0;padding:.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem}
    .topbar h1{font-size:1rem;font-weight:700;color:#fff}
    .topbar .user{font-size:.75rem;color:#94a3b8}
    .topbar a{color:#93c5fd;font-size:.75rem;text-decoration:none}
    .topbar a:hover{text-decoration:underline}
    .container{max-width:1200px;margin:0 auto;padding:1.5rem}

    /* Summary Cards */
    .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:1.5rem}
    .card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:1.25rem;display:flex;flex-direction:column;gap:.25rem}
    .card .label{font-size:.6875rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:#64748b}
    .card .value{font-size:1.75rem;font-weight:700;color:#0f172a}
    .card .sub{font-size:.75rem;color:#94a3b8}

    /* Flags */
    .flags{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:1.25rem;margin-bottom:1.5rem}
    .flags h2{font-size:.875rem;font-weight:700;margin-bottom:.75rem;color:#334155}
    .flag-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:.75rem}
    .flag-item{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:.75rem 1rem}
    .flag-key{font-size:.75rem;font-weight:600;color:#475569;font-family:monospace}
    .flag-val{font-size:.9375rem;font-weight:700;color:#1e3a5f;margin-top:.125rem}

    /* Events table */
    .table-wrap{background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden}
    .table-wrap h2{font-size:.875rem;font-weight:700;padding:1rem 1.25rem .75rem;color:#334155;border-bottom:1px solid #f1f5f9}
    table{width:100%;border-collapse:collapse;font-size:.8125rem}
    thead{background:#f8fafc}
    th{text-align:left;padding:.5rem .75rem;font-weight:600;color:#64748b;font-size:.6875rem;text-transform:uppercase;letter-spacing:.04em;border-bottom:1px solid #e2e8f0}
    td{padding:.5rem .75rem;border-bottom:1px solid #f8fafc;vertical-align:top}
    tr:hover td{background:#f8fafc}
    .badge{display:inline-block;padding:.125rem .5rem;border-radius:9999px;font-size:.6875rem;font-weight:600;line-height:1.4}
    .badge-success{background:#dcfce7;color:#166534}
    .badge-error{background:#fee2e2;color:#991b1b}
    .badge-warning{background:#fef3c7;color:#92400e}
    .badge-info{background:#dbeafe;color:#1e40af}
    .badge-hot{background:#dcfce7;color:#166534}
    .badge-warm{background:#fef3c7;color:#92400e}
    .badge-cold{background:#fee2e2;color:#991b1b}
    .score-bar{height:6px;border-radius:3px;background:#e2e8f0;overflow:hidden;width:60px;display:inline-block;vertical-align:middle;margin-left:4px}
    .score-fill{height:100%;border-radius:3px}
    .mono{font-family:monospace;font-size:.75rem;color:#475569}
    .muted{color:#94a3b8}
    .section{background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;margin-bottom:1.5rem}
    .section h2{font-size:.875rem;font-weight:700;padding:1rem 1.25rem .75rem;color:#334155;border-bottom:1px solid #f1f5f9}

    .empty{text-align:center;padding:3rem 1rem;color:#94a3b8}

    /* Pipeline */
    .pipeline{display:flex;gap:.25rem;align-items:center;flex-wrap:wrap;margin-bottom:1.5rem}
    .pipeline-step{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:.5rem .75rem;text-align:center;flex:1;min-width:100px}
    .pipeline-step .step-label{font-size:.625rem;font-weight:600;text-transform:uppercase;color:#94a3b8}
    .pipeline-step .step-count{font-size:1.125rem;font-weight:700}
    .pipeline-arrow{color:#cbd5e1;font-size:1.25rem;flex-shrink:0}

    @media(max-width:640px){
      .pipeline{flex-direction:column}
      .pipeline-arrow{transform:rotate(90deg)}
    }
  </style>
</head>
<body>
  <div class="topbar">
    <h1>Lead Flow Analytics</h1>
    <div style="display:flex;align-items:center;gap:1rem">
      <span class="user">{session.email}</span>
      <a href="/">← Site</a>
    </div>
  </div>

  <div class="container">
    <!-- Summary cards -->
    <div class="cards">
      <div class="card">
        <span class="label">Recent Events</span>
        <span class="value">{recentEvents.length}</span>
        <span class="sub">Last 50 tracked</span>
      </div>
      <div class="card">
        <span class="label">Successes</span>
        <span class="value" style={`color:${statusColor('success')}`}>{successCount}</span>
        <span class="sub">Of recent batch</span>
      </div>
      <div class="card">
        <span class="label">Errors</span>
        <span class="value" style={`color:${statusColor('error')}`}>{errorCount}</span>
        <span class="sub">Of recent batch</span>
      </div>
      <div class="card">
        <span class="label">Warnings</span>
        <span class="value" style={`color:${statusColor('warning')}`}>{warningCount}</span>
        <span class="sub">Of recent batch</span>
      </div>
      {avgScore !== null && (
        <div class="card">
          <span class="label">Avg Lead Score</span>
          <span class="value" style={`color:${avgScore >= 80 ? '#16a34a' : avgScore >= 50 ? '#d97706' : '#dc2626'}`}>{avgScore}/100</span>
          <span class="sub">{hotLeads} hot · {warmLeads} warm · {coldLeads} cold</span>
        </div>
      )}
    </div>

    <!-- Pipeline funnel -->
    <div class="pipeline">
      {(['landing','form','submission','email','handoff'] as const).map((stage, i, arr) => {
        const count = recentEvents.filter((e) => e.stage === stage).length;
        return (
          <>
            <div class="pipeline-step">
              <div class="step-label">{stageLabel(stage)}</div>
              <div class="step-count">{count}</div>
            </div>
            {i < arr.length - 1 && <span class="pipeline-arrow">→</span>}
          </>
        );
      })}
    </div>

    <div class="section">
      <h2>Lead Score by Campaign (7d)</h2>
      {campaignStats.length === 0 ? (
        <div class="empty">
          <p>No scored leads with attribution found yet.</p>
        </div>
      ) : (
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr>
                <th>Campaign Key</th>
                <th>Source</th>
                <th>Medium</th>
                <th>Campaign</th>
                <th>Attr.</th>
                <th>Leads</th>
                <th>Avg Score</th>
                <th>Tier Mix</th>
              </tr>
            </thead>
            <tbody>
              {campaignStats.map((row) => (
                <tr>
                  <td class="mono">{row.campaignKey}</td>
                  <td>{row.utmSource}</td>
                  <td>{row.utmMedium}</td>
                  <td>{row.utmCampaign}</td>
                  <td>{row.attributionSource}</td>
                  <td>{row.count}</td>
                  <td>
                    <span class={`badge ${row.averageScore >= 80 ? 'badge-success' : row.averageScore >= 50 ? 'badge-warning' : 'badge-error'}`}>{row.averageScore}</span>
                  </td>
                  <td class="muted">{row.hot} hot · {row.warm} warm · {row.cold} cold</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <!-- Active flags -->
    <div class="flags">
      <h2>Active Feature Flags (Vercel Web Analytics annotated)</h2>
      <div class="flag-grid">
        {Object.entries(flagValues).map(([key, val]) => (
          <div class="flag-item">
            <div class="flag-key">{key}</div>
            <div class="flag-val">{String(val)}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Recent events table -->
    <div class="table-wrap">
      <h2>Recent Events (last 50)</h2>
      {recentEvents.length === 0 ? (
        <div class="empty">
          <p>No events found yet.</p>
          <p style="margin-top:.5rem">Supabase lead analytics may not be configured, or no leads have come through yet.</p>
        </div>
      ) : (
        <div style="overflow-x:auto">
        <table>
          <thead>
            <tr>
              <th>When</th>
              <th>Event</th>
              <th>Stage</th>
              <th>Status</th>
              <th>Owner</th>
              <th>Route</th>
              <th>Lead</th>
              <th>Interest</th>
              <th>Campaign</th>
              <th>Quality</th>
              <th>Tracking ID</th>
            </tr>
          </thead>
          <tbody>
            {recentEvents.map((evt) => (
              <tr>
                <td title={evt.occurred_at}>{relativeTime(evt.occurred_at)}</td>
                <td class="mono">{evt.event_name}</td>
                <td>{stageLabel(evt.stage)}</td>
                <td>
                  <span class={`badge badge-${evt.status}`}>{evt.status}</span>
                </td>
                <td>{evt.owner_scope}</td>
                <td class="mono">{evt.route}</td>
                <td class="muted">{maskEmail(evt.lead_email)}</td>
                <td>{evt.interest ?? <span class="muted">—</span>}</td>
                <td class="mono">{String(evt.properties?.campaign_key ?? evt.properties?.utm_campaign ?? '—')}</td>
                <td>
                  {(() => {
                    const scoreInfo = scoreByTrackingId.get(evt.tracking_id);
                    if (!scoreInfo) return <span class="muted">—</span>;
                    const tierClass = `badge badge-${scoreInfo.tier}`;
                    const barColor = scoreInfo.tier === 'hot' ? '#16a34a' : scoreInfo.tier === 'warm' ? '#d97706' : '#dc2626';
                    return (
                      <span>
                        <span class={tierClass}>{scoreInfo.score}</span>
                        <span class="score-bar"><span class="score-fill" style={`width:${scoreInfo.score}%;background:${barColor}`}></span></span>
                      </span>
                    );
                  })()}
                </td>
                <td class="mono" title={evt.tracking_id}>{evt.tracking_id.slice(0, 8)}…</td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
      )}
    </div>
  </div>
</body>
</html>
