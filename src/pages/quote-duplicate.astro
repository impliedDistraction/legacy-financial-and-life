---
import Base from '../layouts/Base.astro';
import { site } from '../content/site';
import '../styles/tailwind.css';

const licensedStates = 'Ohio, Georgia, Oklahoma, South Carolina, Mississippi, Michigan, Texas, Utah, Alabama, and Louisiana';
---

<Base title="Request Already on File" description="We already have your quote request. Our team will be in touch shortly.">
  <!-- Minimal header matching free-quote page -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-200">
    <div class="mx-auto max-w-6xl flex items-center justify-between gap-4 px-4 py-3">
      <span class="text-sm font-medium text-brand-600">Quote Request</span>
      <span class="text-xs text-slate-500">Already on file</span>
    </div>
  </header>

  <div class="min-h-[80vh] bg-gradient-to-br from-brand-50 to-white flex items-center justify-center px-4">
    <div class="max-w-2xl text-center py-20">
      <!-- Info Icon -->
      <div class="w-24 h-24 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-12 h-12 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>

      <h1 class="text-4xl font-bold text-slate-900 mb-4">We Already Have Your Info</h1>
      <p class="text-xl text-slate-700 mb-8">
        It looks like you've already submitted a quote request recently. Our team has your details and will be reaching out — no need to submit again.
      </p>

      <div class="bg-white rounded-xl border border-slate-200 p-6 mb-8 shadow-lg text-left">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">What you can do</h2>
        <div class="space-y-3">
          <div class="flex items-start space-x-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-sm font-medium text-brand-700">1</span>
            <p class="text-slate-700"><strong>Check your inbox</strong> — we sent a confirmation email when you first submitted</p>
          </div>
          <div class="flex items-start space-x-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-sm font-medium text-brand-700">2</span>
            <p class="text-slate-700"><strong>Reply to that email</strong> if you have questions or updated information</p>
          </div>
          <div class="flex items-start space-x-3">
            <span class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-sm font-medium text-brand-700">3</span>
            <p class="text-slate-700"><strong>Call us directly</strong> if you'd rather talk right away</p>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
        <a
          href={`tel:${site.phone.replace(/[^\d+]/g, '')}`}
          class="inline-flex items-center justify-center rounded-lg bg-brand-600 px-6 py-3 text-lg font-semibold text-white shadow-md transition-colors hover:bg-brand-500"
        >
          Call {site.phone}
        </a>
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-6 py-3 text-lg font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50"
        >
          Back to Home
        </a>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <p class="text-amber-800 text-sm">
          <strong>Need to update your information?</strong> Reply to the confirmation email we sent you, or give us a call. We're happy to help.
        </p>
      </div>
    </div>
  </div>

  <footer class="bg-slate-900 text-slate-400 py-8">
    <div class="mx-auto max-w-6xl px-4 text-center text-sm space-y-2">
      <p>&copy; {new Date().getFullYear()} Legacy Financial & Life. All rights reserved.</p>
      <p>Licensed in {licensedStates}. Policies and features vary by carrier and state.</p>
      <p><a href="/privacy" class="underline hover:text-white transition-colors">Privacy Policy</a></p>
    </div>
  </footer>
</Base>
