---
import '../styles/tailwind.css';
import Analytics from '@vercel/analytics/astro';
import SEO from '../components/SEO.astro';
import { safeJsonStringify } from 'flags';
import { resolveFlagValues } from '../lib/flags';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Legacy Financial & Life', description = 'Life insurance and retirement strategies built on clarity and respect.' } = Astro.props ?? {};

const flagValues = resolveFlagValues();
const flagValuesJson = safeJsonStringify(flagValues);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <SEO title={title} description={description} />
    <script type="application/json" data-flag-values set:html={flagValuesJson}></script>

    <!-- Meta Pixel Code -->
    <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1483583916632411');
    fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1483583916632411&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
  </head>
  <body>
    <main class="min-h-dvh">
      <slot />
    </main>
    <Analytics />
    <script src="/scripts/animations.js" defer></script>

    <!-- Calendly popup scheduling — intercepts /schedule links site-wide -->
    <script is:inline>
    (function() {
      var BOOKING_URL = 'https://calendly.com/bethandtim-legacyf-l/30min?hide_gdpr_banner=1&primary_color=1a62db';
      var loaded = false;

      function loadCalendly(cb) {
        if (loaded) return cb();
        var css = document.createElement('link');
        css.rel = 'stylesheet';
        css.href = 'https://assets.calendly.com/assets/external/widget.css';
        document.head.appendChild(css);

        var js = document.createElement('script');
        js.src = 'https://assets.calendly.com/assets/external/widget.js';
        js.onload = function() { loaded = true; cb(); };
        document.head.appendChild(js);
      }

      function openPopup() {
        if (window.Calendly) {
          window.Calendly.initPopupWidget({ url: BOOKING_URL });
        }
      }

      // Intercept clicks on /schedule links to open popup instead of navigating
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href="/schedule"]');
        if (!link) return;
        // Skip if on the /schedule page itself (let the inline widget handle it)
        if (window.location.pathname === '/schedule') return;

        e.preventDefault();
        loadCalendly(openPopup);
      });

      // Expose for chatbot or programmatic use
      window.__openSchedule = function() { loadCalendly(openPopup); };

      // Fetch next available slot and display it
      function showAvailability() {
        var badges = document.querySelectorAll('[data-next-available]');
        if (!badges.length) return;
        fetch('/api/availability')
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(d) {
            if (!d || !d.nextAvailable) return;
            var dt = new Date(d.nextAvailable);
            var opts = { weekday: 'short', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit', timeZone: 'America/New_York' };
            var text = 'Next available: ' + dt.toLocaleString('en-US', opts);
            badges.forEach(function(el) {
              el.textContent = text;
              el.classList.remove('hidden');
            });
          })
          .catch(function() { /* silently fail — availability is optional */ });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', showAvailability);
      } else {
        showAvailability();
      }
    })();
    </script>
  </body>
</html>