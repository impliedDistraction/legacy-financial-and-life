# Environment Variables for Legacy Financial & Life

# =============================================================================
# MAP PROVIDERS - API KEYS (Optional)
# =============================================================================

# Google Maps API Key (Optional - for enhanced features)
# Get your key at: https://console.cloud.google.com/apis/credentials
# Enable: Maps Embed API, Maps JavaScript API, Places API
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# MapBox Access Token (Optional - alternative map provider)
# Get your token at: https://account.mapbox.com/access-tokens/
# MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# =============================================================================
# FORM PROVIDERS
# =============================================================================

# Formspree Form ID (for contact forms)
# FORMSPREE_FORM_ID=your_formspree_form_id_here

# Resend email + contact sync
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx
# RESEND_LEGACY_FINANCIAL_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxx  (fallback)
# RESEND_REPLY_MONITOR_ADDRESS=quotes@reply.legacyfinancial.app
# RESEND_CONTACT_SEGMENT_ID=8aca73ce-937c-49e2-a1db-b7d18beef750
# RESEND_CONTACT_TOPIC_ID=ad459268-9afc-4719-9487-664f8d1fb8c8
# RESEND_ALERT_RECIPIENTS=tim@legacyf-l.com,beth@legacyf-l.com
# RESEND_ALERT_WEBHOOK_URL=https://hooks.example.com/services/legacy-financial
# RESEND_ALERT_FROM=Legacy Financial Alerts <hello@legacyfinancial.app>

# Recruitment sends — set to 'true' to enable live email delivery
# RECRUITMENT_SENDS_ENABLED=false

# =============================================================================
# RINGY CRM (Lead injection — legacy, scheduling now uses Calendly)
# =============================================================================
# Credentials from Ringy lead source setup email.
# API endpoint is hardcoded: https://app.ringy.com/api/public/leads/new-lead
# RINGY_AUTH_TOKEN=your_ringy_auth_token
# RINGY_SID=your_ringy_sid

# =============================================================================
# CALENDLY (Scheduling)
# =============================================================================
# Override the default Calendly booking URL (set in site.ts)
# CALENDLY_BOOKING_URL=https://calendly.com/legacy-financial/consultation

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================

# Google Analytics Measurement ID
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase lead flow analytics
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_LEAD_ANALYTICS_TABLE=lead_flow_events

# =============================================================================
# FEATURE FLAGS (Vercel Flags Explorer + Web Analytics annotation)
# =============================================================================

# FLAGS_SECRET: 32 random bytes, base64url-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Must also be set in Vercel Dashboard → Project Settings → Env Vars.
# FLAGS_SECRET=

# Quote flow A/B flags (values: control | streamlined)
# FLAG_QUOTE_FLOW_VARIANT=control
# FLAG_QUOTE_CONFIRMATION_VARIANT=default
# FLAG_RINGY_ENABLED=true

# =============================================================================
# ANALYTICS DASHBOARD AUTH (magic-link login for /analytics)
# =============================================================================

# ANALYTICS_SECRET: 32+ char HMAC key for signing tokens & session cookies.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ANALYTICS_SECRET=

# Comma-separated emails allowed to access the analytics dashboard
# ANALYTICS_ALLOWED_EMAILS=tim@legacyf-l.com,beth@legacyf-l.com

# =============================================================================
# NOTES
# =============================================================================
# 
# The site will work without these API keys:
# - Maps will fall back to basic Google Maps embed (no API key required)
# - Forms can use Formspree with their form action URL
# 
# With API keys, you get enhanced features:
# - Interactive map controls and better embedding
# - Custom map styling and advanced features
# - Better form handling and analytics integration

