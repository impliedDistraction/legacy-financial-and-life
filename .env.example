# Environment Variables for Legacy Financial & Life

# =============================================================================
# MAP PROVIDERS - API KEYS (Optional)
# =============================================================================

# Google Maps API Key (Optional - for enhanced features)
# Get your key at: https://console.cloud.google.com/apis/credentials
# Enable: Maps Embed API, Maps JavaScript API, Places API
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# MapBox Access Token (Optional - alternative map provider)
# Get your token at: https://account.mapbox.com/access-tokens/
# MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# =============================================================================
# FORM PROVIDERS
# =============================================================================

# Formspree Form ID (for contact forms)
# FORMSPREE_FORM_ID=your_formspree_form_id_here

# Resend email + contact sync
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx
# RESEND_REPLY_MONITOR_ADDRESS=quotes@reply.legacyfinancial.app
# RESEND_CONTACT_SEGMENT_ID=8aca73ce-937c-49e2-a1db-b7d18beef750
# RESEND_CONTACT_TOPIC_ID=ad459268-9afc-4719-9487-664f8d1fb8c8
# RESEND_ALERT_RECIPIENTS=tim@legacyf-l.com,beth@legacyf-l.com
# RESEND_ALERT_WEBHOOK_URL=https://hooks.example.com/services/legacy-financial
# RESEND_ALERT_FROM=Legacy Financial Alerts <hello@legacyfinancial.app>

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================

# Google Analytics Measurement ID
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# NOTES
# =============================================================================
# 
# The site will work without these API keys:
# - Maps will fall back to basic Google Maps embed (no API key required)
# - Forms can use Formspree with their form action URL
# 
# With API keys, you get enhanced features:
# - Interactive map controls and better embedding
# - Custom map styling and advanced features
# - Better form handling and analytics integration